---
// Learn about using Astro layouts:
// https://docs.astro.build/en/basics/layouts/

import { ViewTransitions } from 'astro:transitions';
import Footer from '../components/Footer.astro';
// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import { personSchema } from '../lib/personSchema';

interface BreadcrumbItem {
	name: string;
	url?: string;
}

interface Props {
	title?: string | undefined;
	description?: string | undefined;
	image?: string | undefined;
	noindex?: boolean | undefined;
	breadcrumbs?: BreadcrumbItem[];
	article?: {
		publishedTime: string;
		modifiedTime?: string;
		author?: string;
		tags?: string[];
	};
	profile?: {
		firstName: string;
		lastName: string;
		username?: string;
	};
}

const { title, description, image, noindex, breadcrumbs, article, profile } = Astro.props;

const navItems = [
	{ name: "Home", url: "https://swapbiswas.com/" },
	{ name: "Blog", url: "https://swapbiswas.com/blog/" },
	{ name: "Tools", url: "https://swapbiswas.com/tools/" },
	{ name: "Reading List", url: "https://swapbiswas.com/reading-list/" },
	{ name: "About", url: "https://swapbiswas.com/about/" },
	{ name: "Contact", url: "https://swapbiswas.com/contact/" },
];
const siteGraphSchema = {
	"@context": "https://schema.org",
	"@graph": [
		personSchema,
		...navItems.map((item) => ({
			"@type": "SiteNavigationElement",
			"name": item.name,
			"url": item.url,
		})),
	],
};

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://swapbiswas.com" },
		...breadcrumbs.map((crumb, i) => ({
			"@type": "ListItem",
			"position": i + 2,
			"name": crumb.name,
			...(crumb.url ? { "item": `https://swapbiswas.com${crumb.url}` } : {})
		}))
	]
} : null;
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} image={image} noindex={noindex} article={article} profile={profile} />
		{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
		<script type="application/ld+json" set:html={JSON.stringify(siteGraphSchema)} />
		<ViewTransitions />
		<slot name="head" />
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WGNTLP2R" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<div class="stack backgrounds">
			<Nav />
			<div id="main-content">
				{breadcrumbs && breadcrumbs.length > 0 && (
					<nav class="breadcrumb-nav" aria-label="Breadcrumb">
						<ol class="breadcrumb-list">
							<li class="breadcrumb-item">
								<a href="/" aria-label="Home">
									<svg class="breadcrumb-home" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
								</a>
								<svg class="breadcrumb-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
							</li>
							{breadcrumbs.map((crumb, i) => (
								<li class="breadcrumb-item">
									{crumb.url && i < breadcrumbs.length - 1 ? (
										<>
											<a href={crumb.url}>{crumb.name}</a>
											<svg class="breadcrumb-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
										</>
									) : (
										<span class="breadcrumb-current" aria-current="page">{crumb.name}</span>
									)}
								</li>
							))}
						</ol>
					</nav>
				)}
				<slot />
			</div>
			<Footer />
		</div>

		<!-- Newsletter Slide-in Popup -->
		<div class="nl-popup" id="nl-popup" role="dialog" aria-label="Subscribe to newsletter">
			<button class="nl-popup-close" aria-label="Close newsletter popup">&times;</button>
			<p class="nl-popup-title">Get Marketing & AI Insights</p>
			<p class="nl-popup-desc">Join the newsletter. No spam, just value.</p>
			<form class="nl-popup-form" id="nl-popup-form">
				<input type="email" name="email_address" placeholder="Your email" required autocomplete="email" aria-label="Email address" />
				<button type="submit">Subscribe</button>
			</form>
			<p class="nl-popup-status" id="nl-popup-status"></p>
		</div>

		<script>
			// Add "loaded" class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

		<!-- Service Worker Registration -->
		<script is:inline>
			if ('serviceWorker' in navigator) {
				navigator.serviceWorker.register('/sw.js');
			}
		</script>

		<!-- Core Web Vitals → dataLayer → GTM → GA4 -->
		<script>
			import { onCLS, onINP, onLCP, onFCP, onTTFB } from 'web-vitals';

			function sendToDataLayer({ name, value, rating, id, navigationType }: { name: string; value: number; rating: string; id: string; navigationType: string }) {
				window.dataLayer = window.dataLayer || [];
				window.dataLayer.push({
					event: 'web_vitals',
					cwv_metric: name,
					cwv_value: Math.round(name === 'CLS' ? value * 1000 : value),
					cwv_rating: rating,
					cwv_id: id,
					cwv_navigation_type: navigationType,
				});
			}

			onCLS(sendToDataLayer);
			onINP(sendToDataLayer);
			onLCP(sendToDataLayer);
			onFCP(sendToDataLayer);
			onTTFB(sendToDataLayer);
		</script>

		<!-- Analytics Event Tracking -->
		<script is:inline>
		(function() {
			if (window._analyticsInit) return;
			window._analyticsInit = true;

			var dl = window.dataLayer = window.dataLayer || [];
			function track(event, params) {
				dl.push(Object.assign({ event: event }, params || {}));
			}

			// Click tracking (runs once, delegates via document)
			document.addEventListener('click', function(e) {
				var link = e.target.closest('a');
				if (!link) return;
				var href = link.getAttribute('href') || '';

				// Mailto CTA clicks
				if (href.indexOf('mailto:') === 0) {
					track('cta_click', { cta_type: 'email', cta_text: link.textContent.trim() });
				}

				// Share button clicks
				if (link.classList.contains('share-btn')) {
					var platform = 'unknown';
					var label = link.getAttribute('aria-label') || '';
					if (label.indexOf('Twitter') > -1) platform = 'twitter';
					else if (label.indexOf('LinkedIn') > -1) platform = 'linkedin';
					else if (label.indexOf('Facebook') > -1) platform = 'facebook';
					track('share_click', { share_platform: platform, share_url: window.location.pathname });
				}

				// Footer social links
				if (link.closest('footer') && link.getAttribute('target') === '_blank') {
					track('social_click', { social_platform: link.textContent.trim().toLowerCase(), social_url: href });
				}

				// CTA navigation buttons
				if (link.closest('.cta')) {
					track('cta_click', { cta_type: 'navigation', cta_text: link.textContent.trim(), cta_url: href });
				}
			});

			// Theme toggle tracking - only track actual user clicks, not initial load
			var lastTheme = document.documentElement.classList.contains('theme-dark') ? 'dark' : 'light';
			var pageReady = false;
			window.addEventListener('load', function() { pageReady = true; });
			var themeObs = new MutationObserver(function() {
				var isDark = document.documentElement.classList.contains('theme-dark');
				var newTheme = isDark ? 'dark' : 'light';
				if (!pageReady || newTheme === lastTheme) return;
				lastTheme = newTheme;
				track('theme_toggle', { theme: newTheme });
			});
			themeObs.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

			// Re-init page-specific tracking on every navigation (View Transitions)
			function initPageTracking() {
				// Newsletter homepage form
				var nlForm = document.getElementById('newsletter-form');
				if (nlForm && !nlForm._tracked) {
					nlForm._tracked = true;
					nlForm.addEventListener('submit', function() {
						track('newsletter_signup', { signup_location: 'homepage' });
					});
				}

				// Newsletter popup form
				var nlPopup = document.getElementById('nl-popup-form');
				if (nlPopup && !nlPopup._tracked) {
					nlPopup._tracked = true;
					nlPopup.addEventListener('submit', function() {
						track('newsletter_signup', { signup_location: 'popup' });
					});
				}

				// Blog reading progress milestones
				var article = document.querySelector('.content-column') || document.querySelector('article');
				if (article && !article._tracked) {
					article._tracked = true;
					var milestones = { 25: false, 50: false, 75: false, 100: false };
					var scrollHandler = function() {
						var rect = article.getBoundingClientRect();
						var articleTop = rect.top + window.scrollY;
						var articleHeight = rect.height;
						var scrollPos = window.scrollY + window.innerHeight - articleTop;
						var pct = Math.min(Math.round((scrollPos / articleHeight) * 100), 100);
						for (var m in milestones) {
							if (!milestones[m] && pct >= parseInt(m)) {
								milestones[m] = true;
								track('blog_read_progress', { read_percent: parseInt(m), blog_title: document.title });
							}
						}
					};
					window.addEventListener('scroll', scrollHandler, { passive: true });
				}
			}

			// Run on initial load and on every View Transition navigation
			initPageTracking();
			document.addEventListener('astro:page-load', initPageTracking);
		})();
		</script>

		<script is:inline>
			(function() {
				var popup = document.getElementById('nl-popup');
				var closeBtn = popup && popup.querySelector('.nl-popup-close');
				var form = document.getElementById('nl-popup-form');
				var statusEl = document.getElementById('nl-popup-status');
				if (!popup) return;
				if (localStorage.getItem('nl-popup-dismissed')) return;

				var shown = false;
				function showPopup() {
					if (shown) return;
					shown = true;
					popup.classList.add('visible');
				}
				function dismiss() {
					popup.classList.remove('visible');
					localStorage.setItem('nl-popup-dismissed', '1');
				}

				var scrollHandler = function() {
					var pct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
					if (pct > 0.6) { showPopup(); window.removeEventListener('scroll', scrollHandler); }
				};
				window.addEventListener('scroll', scrollHandler, { passive: true });
				setTimeout(function() { showPopup(); window.removeEventListener('scroll', scrollHandler); }, 30000);

				if (closeBtn) closeBtn.addEventListener('click', dismiss);

				if (form) {
					form.addEventListener('submit', function(e) {
						e.preventDefault();
						var emailInput = form.querySelector('input[name="email_address"]');
						var email = emailInput ? emailInput.value : '';
						var btn = form.querySelector('button[type="submit"]');
						if (btn) { btn.textContent = 'Subscribing...'; btn.disabled = true; }
						var formData = new FormData();
						formData.append('email_address', email);
						fetch('https://app.kit.com/forms/9145889/subscriptions', {
							method: 'POST',
							body: formData,
							headers: { 'Accept': 'application/json' }
						}).then(function(res) {
							if (!res.ok) throw new Error('Subscription failed');
							if (statusEl) { statusEl.textContent = 'Subscribed!'; statusEl.style.color = 'var(--accent-regular)'; }
							form.reset();
							window.dataLayer = window.dataLayer || [];
							window.dataLayer.push({ event: 'newsletter_signup', signup_location: 'popup' });
							setTimeout(dismiss, 2000);
						}).catch(function() {
							if (statusEl) { statusEl.textContent = 'Something went wrong.'; statusEl.style.color = '#ca7879'; }
						}).finally(function() {
							if (btn) { btn.textContent = 'Subscribe'; btn.disabled = false; }
						});
					});
				}
			})();
		</script>

		<style>
			/* Newsletter Popup */
			.nl-popup {
				position: fixed;
				bottom: 1.5rem;
				right: 1.5rem;
				z-index: 9990;
				width: 320px;
				max-width: calc(100vw - 2rem);
				padding: 1.5rem;
				background: var(--gray-999);
				border: 1px solid var(--gray-800);
				border-radius: 1rem;
				box-shadow: var(--shadow-lg);
				transform: translateY(120%);
				opacity: 0;
				transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
				pointer-events: none;
			}

			.nl-popup.visible {
				transform: translateY(0);
				opacity: 1;
				pointer-events: auto;
			}

			.nl-popup-close {
				position: absolute;
				top: 0.5rem;
				right: 0.75rem;
				background: none;
				border: none;
				color: var(--gray-400);
				font-size: 1.5rem;
				cursor: pointer;
				line-height: 1;
				padding: 0.25rem;
			}

			.nl-popup-close:hover {
				color: var(--gray-0);
			}

			.nl-popup-title {
				font-family: var(--font-brand);
				font-weight: 600;
				font-size: var(--text-md);
				color: var(--gray-0);
				margin-bottom: 0.25rem;
			}

			.nl-popup-desc {
				font-size: var(--text-sm);
				color: var(--gray-400);
				margin-bottom: 0.75rem;
			}

			.nl-popup-form {
				display: flex;
				gap: 0.5rem;
			}

			.nl-popup-form input {
				flex: 1;
				padding: 0.5rem 0.75rem;
				border: 1px solid var(--gray-800);
				border-radius: 0.5rem;
				background: var(--gray-999_40);
				color: var(--gray-0);
				font-size: var(--text-sm);
				font-family: var(--font-body);
				outline: none;
				min-width: 0;
			}

			.nl-popup-form input:focus {
				border-color: var(--accent-dark);
			}

			.nl-popup-form input::placeholder {
				color: var(--gray-400);
			}

			.nl-popup-form button {
				padding: 0.5rem 1rem;
				border: none;
				border-radius: 0.5rem;
				background: var(--gradient-accent-orange);
				color: var(--accent-text-over);
				font-size: var(--text-sm);
				font-weight: 600;
				font-family: var(--font-brand);
				cursor: pointer;
				white-space: nowrap;
				transition: opacity 0.2s ease;
			}

			.nl-popup-form button:hover {
				opacity: 0.9;
			}

			.nl-popup-form button:disabled {
				opacity: 0.6;
				cursor: not-allowed;
			}

			.nl-popup-status {
				font-size: var(--text-sm);
				margin-top: 0.5rem;
				min-height: 1rem;
			}

			@media (max-width: 480px) {
				.nl-popup {
					bottom: 0;
					right: 0;
					left: 0;
					width: 100%;
					max-width: 100%;
					border-radius: 1rem 1rem 0 0;
					transform: translateY(100%);
				}
			}

			/* Breadcrumb Navigation */
			.breadcrumb-nav {
				max-width: 83rem;
				margin-inline: auto;
				padding: 1.25rem 1.5rem 0;
			}

			.breadcrumb-list {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0;
				list-style: none;
				padding: 0;
				margin: 0;
				font-size: var(--text-sm);
			}

			.breadcrumb-item {
				display: flex;
				align-items: center;
			}

			.breadcrumb-home {
				display: block;
			}

			.breadcrumb-item a {
				display: flex;
				align-items: center;
				color: var(--gray-400);
				text-decoration: none;
				transition: color 0.2s ease;
			}

			.breadcrumb-item a:hover {
				color: var(--accent-regular);
			}

			.breadcrumb-chevron {
				margin: 0 0.4rem;
				color: var(--gray-600);
				flex-shrink: 0;
			}

			.breadcrumb-current {
				color: var(--gray-200);
				font-weight: 500;
				max-width: 35ch;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			@media (max-width: 480px) {
				.breadcrumb-current {
					max-width: 20ch;
				}
			}

			.skip-link {
				position: absolute;
				top: -100%;
				left: 50%;
				transform: translateX(-50%);
				z-index: 10000;
				padding: 0.75rem 1.5rem;
				background: var(--accent-regular);
				color: var(--accent-text-over);
				font-family: var(--font-brand);
				font-weight: 600;
				border-radius: 0 0 0.5rem 0.5rem;
				text-decoration: none;
				transition: top 0.2s ease;
			}

			.skip-link:focus {
				top: 0;
			}

			:root {
				--_placeholder-bg: linear-gradient(transparent, transparent);
				--bg-image-main: url('/assets/backgrounds/bg-main-light-800w.jpg');
				--bg-image-main-curves: url('/assets/backgrounds/bg-main-light.svg');
				--bg-image-subtle-1: var(--_placeholder-bg);
				--bg-image-subtle-2: var(--_placeholder-bg);
				--bg-image-footer: var(--_placeholder-bg);
				--bg-svg-blend-mode: overlay;
				--bg-blend-mode: darken;
				--bg-image-aspect-ratio: 2.25;
				--bg-scale: 1.68;
				--bg-aspect-ratio: calc(var(--bg-image-aspect-ratio) / var(--bg-scale));
				--bg-gradient-size: calc(var(--bg-scale) * 100%);
			}

			:root.theme-dark {
				--bg-image-main: url('/assets/backgrounds/bg-main-dark-800w.jpg');
				--bg-image-main-curves: url('/assets/backgrounds/bg-main-dark.svg');
				--bg-svg-blend-mode: darken;
				--bg-blend-mode: lighten;
			}

			/* These backgrounds are displayed below the fold, so we lazy load them
			   once the `.loaded` class has been set.  */
			:root.loaded {
				--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-light-800w.jpg');
				--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-light-800w.jpg');
				--bg-image-footer: url('/assets/backgrounds/bg-footer-light-800w.jpg');
			}
			:root.loaded.theme-dark {
				--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-dark-800w.jpg');
				--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-dark-800w.jpg');
				--bg-image-footer: url('/assets/backgrounds/bg-footer-dark-800w.jpg');
			}

			@media (min-width: 50em) {
				:root {
					--bg-scale: 1;
					--bg-image-main: url('/assets/backgrounds/bg-main-light-1440w.jpg');
				}
				:root.theme-dark {
					--bg-image-main: url('/assets/backgrounds/bg-main-dark-1440w.jpg');
				}

				:root.loaded {
					--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-light-1440w.jpg');
					--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-light-1440w.jpg');
					--bg-image-footer: url('/assets/backgrounds/bg-footer-light-1440w.jpg');
				}
				:root.loaded.theme-dark {
					--bg-image-subtle-1: url('/assets/backgrounds/bg-subtle-1-dark-1440w.jpg');
					--bg-image-subtle-2: url('/assets/backgrounds/bg-subtle-2-dark-1440w.jpg');
					--bg-image-footer: url('/assets/backgrounds/bg-footer-dark-1440w.jpg');
				}
			}

			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				background:
					/*noise*/
					url('/assets/backgrounds/noise.png') top center/220px repeat,
					/*footer*/ var(--bg-image-footer) bottom center/var(--bg-gradient-size) no-repeat,
					/*header1*/ var(--bg-image-main-curves) top center/var(--bg-gradient-size) no-repeat,
					/*header2*/ var(--bg-image-main) top center/var(--bg-gradient-size) no-repeat,
					/*base*/ var(--gray-999);
				background-blend-mode: /*noise*/
					overlay,
					/*footer*/ var(--bg-blend-mode),
					/*header1*/ var(--bg-svg-blend-mode),
					/*header2*/ normal,
					/*base*/ normal;
			}
			@media (forced-colors: active) {
				/* Deactivate custom backgrounds for high contrast users. */
				.backgrounds {
					background: none;
					background-blend-mode: none;
					--bg-gradient-size: none;
				}
			}
		</style>
	</body>
</html>
