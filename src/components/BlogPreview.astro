---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

// Import stock images for Astro optimization
const stockImages = import.meta.glob<{ default: ImageMetadata }>('../assets/stock-*.webp', { eager: true });

interface Props {
	post: CollectionEntry<'blog'>;
}

const { data, id, body } = Astro.props.post;

// Resolve image: use optimized src/assets if available, fallback to public path
const stockKey = `../assets/${data.img.split('/').pop()}`;
const optimizedImg = stockImages[stockKey]?.default;

const wordCount = body ? body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));

const publishDate = data.publishDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'short',
	day: 'numeric',
});

function categorySlug(cat: string): string {
	return cat
		.toLowerCase()
		.replace(/&/g, 'and')
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');
}
---

<article class="card">
	{optimizedImg ? (
		<Image
			src={optimizedImg}
			alt={data.img_alt || ''}
			widths={[400, 800]}
			sizes="(max-width: 50em) 100vw, 400px"
			format="avif"
			loading="lazy"
			decoding="async"
			class="card-img"
		/>
	) : (
		<img src={data.img} alt={data.img_alt || ''} width="400" height="237" loading="lazy" decoding="async" />
	)}
	<div class="card-body">
		<h3 class="title">
			<a class="card-link" href={`/blog/${id}`}>{data.title}</a>
		</h3>
		<div class="card-meta">
			<span>{publishDate}</span>
			<span class="sep">&middot;</span>
			<span>{readingTime} min read</span>
		</div>
		<div class="card-tags">
			{data.category.slice(0, 2).map((cat) => (
				<a class="tag" href={`/blog/category/${categorySlug(cat)}/`}>{cat}</a>
			))}
		</div>
	</div>
</article>

<style>
	.card {
		position: relative;
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--theme-transition), border-color 0.2s ease;
	}

	.card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--gray-700);
	}

	img {
		width: 100%;
		height: 11rem;
		object-fit: cover;
	}

	.card-body {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0.75rem 1rem 1rem;
	}

	.title {
		font-family: var(--font-brand);
		font-size: var(--text-md);
		font-weight: 600;
		color: var(--gray-200);
		line-height: 1.4;
		margin: 0;
	}

	.card-link,
	.card-link:link,
	.card-link:visited,
	.card-link:hover {
		color: var(--gray-200) !important;
		text-decoration: none !important;
	}

	/* Stretched link: make the whole card clickable while keeping tag links clickable */
	.card-link::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.card-link:focus-visible {
		outline: none;
	}

	.card-link:focus-visible::before {
		outline: 2px solid var(--accent-regular);
		outline-offset: -2px;
		border-radius: 0.75rem;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	.card-tags {
		display: flex;
		gap: 0.35rem;
		flex-wrap: wrap;
		position: relative;
		z-index: 2;
	}

	.tag {
		font-size: 0.7rem;
		padding: 0.15rem 0.5rem;
		border-radius: 1rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		color: var(--gray-300);
		text-decoration: none;
		transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
	}

	.tag:hover {
		border-color: var(--accent-regular);
		color: var(--accent-light);
		background: var(--accent-overlay);
	}

	.tag:focus-visible {
		outline: 2px solid var(--accent-regular);
		outline-offset: 2px;
	}

	@media (min-width: 50em) {
		img {
			height: 14rem;
		}

		.card {
			border-radius: 1rem;
		}

		.title {
			font-size: var(--text-lg);
		}
	}
</style>
