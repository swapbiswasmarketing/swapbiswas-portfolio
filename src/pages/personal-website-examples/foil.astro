---
// REDESIGN PROTOTYPE - "Foil" - holographic collectible trading cards.
// Original concept (NOT a reskin of halftone): own layout, palette, fonts, mechanic.
//  - Every work entry is a TRADING CARD. On pointer-move a card does a 3D parallax tilt
//    (rotateX/rotateY toward the cursor + a subtle scale pop) and an iridescent HOLO FOIL
//    overlay shifts with the pointer - layered conic/linear rainbow gradients with
//    mix-blend-mode + a masked shine sweep, driven by CSS custom props (--mx/--my)
//    set on pointermove and rAF-throttled (only the hovered card updates).
//  - The HERO is Swapnil's signature "player card": his portrait, role, and the
//    657K+/18.2M+/10x as the card's stats. Intro copy sits beside it.
//  - LambdaTest work card is a higher rarity "featured" card carrying the only hard numbers.
//    Every other client card stays metric-free (never invent numbers).
// Palette: deep obsidian/ink backdrop, warm gold + cool platinum card frames, full-spectrum
//    holo only on the foil layers. Fonts: Cinzel (display nameplate) + Sora (UI) + JetBrains Mono (stats).
// Fully self-contained: own <html>, own fonts, own tokens. No BaseLayout, no global.css. noindex.
// GOTCHA-GUARDED: no text-shadow/filter on any background-clip:text element (scrim behind instead).
const heroStats = [
  { n: '657K+', l: 'Leads generated' },
  { n: '18.2M+', l: 'Organic traffic' },
  { n: '10x', l: 'Pipeline growth' },
];
const build = [
  { n: '20', plus: '+', l: 'AI agents & internal tools shipped' },
  { n: '15', plus: '+', l: 'Marketers mentored & levelled up' },
  { n: '76', plus: '',  l: 'Long-form articles published' },
];
const pillars = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.', sym: '◈' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.', sym: '▲' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.', sym: '◉' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.', sym: '✦' },
];
const work = [
  { i: '01', t: 'LambdaTest', y: '2021 - 2025', role: 'Product & digital marketing', r: '657K+ leads / 18.2M+ organic', d: 'Owned product and digital marketing end to end and built the full organic growth engine.', tier: 'Legendary', feat: true,
    stats: [{ n: '657K+', l: 'Leads' }, { n: '18.2M+', l: 'Organic' }] },
  { i: '02', t: 'TestMu AI', y: '2026', role: 'Rebrand lead', r: 'Full company rebrand', d: 'Led the complete rebrand from LambdaTest to TestMu AI.', tier: 'Epic' },
  { i: '03', t: 'Samsung', y: '2019', role: 'via Sociowash', r: 'Galaxy M-series launch', d: 'On the Galaxy M-series from inception; ran content distribution, collaborated with Technical Guruji.', tier: 'Epic' },
  { i: '04', t: 'Medilife Superspeciality', y: '0 to 1', role: 'Marketing & web', r: 'Website / GTM / social', d: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.', tier: 'Rare' },
  { i: '05', t: 'Lido Learning', y: '2021', role: 'Growth / CRM', r: 'CRM & lead operations', d: 'Ran CRM management and lead routing and assignment for the EdTech.', tier: 'Rare' },
  { i: '06', t: 'Appknox', y: 'Freelance', role: 'Content', r: 'Security content', d: 'Freelance content writer for the mobile app security company.', tier: 'Uncommon' },
];
const recognition = [
  { t: 'Value of Agility Award', m: 'LambdaTest, 2024', sym: '★' },
  { t: 'Wall of Fame', m: 'LambdaTest', sym: '♚' },
  { t: '#1 Product of the Day', m: 'Product Hunt', sym: '♦' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
const facts = [
  { k: 'Based', v: 'Mumbai, India' },
  { k: 'Tenure', v: '7+ years marketing / 4+ in B2B SaaS' },
  { k: 'Education', v: 'Postgrad in Digital Marketing & Growth Strategy, IIM Visakhapatnam' },
  { k: 'Practice', v: 'PMM & growth strategist who codes AI agents, ships websites and runs technical SEO' },
];
---
<!doctype html>
<html lang="en" data-theme="foil">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#06070d;            /* deep obsidian */
    --bg2:#0b0d18;
    --panel:#0f1220;
    --card:#12152a;
    --card2:#171b34;
    --ink:#f4f1ff;           /* near-white, AA on bg */
    --soft:#cfd0e8;          /* body text, AA on bg/card */
    --dim:#9ea0c4;           /* labels, >=4.5:1 on bg */
    --faint:#7173a0;
    --gold:#e9c876;
    --gold-d:#b89540;
    --plat:#cfd6ee;
    --line:rgba(180,186,235,.12);
    --hair:rgba(200,206,250,.26);
    --glow:rgba(140,120,255,.5);
    --disp:"Cinzel",Georgia,serif;
    --sans:"Sora",system-ui,sans-serif;
    --mono:"JetBrains Mono",ui-monospace,monospace;
    --pad:clamp(1.1rem,4.5vw,4rem);
    /* the holographic spectrum (re-used by foil layers) */
    --spectrum:#ff5e8a,#ffd166,#9bff8e,#5ee7ff,#9d7bff,#ff5e8a;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{overflow-x:clip}
  html{scroll-behavior:smooth}
  body{
    background:
      radial-gradient(1200px 700px at 78% -8%, rgba(120,90,255,.16), transparent 60%),
      radial-gradient(900px 600px at 8% 12%, rgba(60,180,255,.10), transparent 60%),
      radial-gradient(1000px 800px at 50% 110%, rgba(233,200,118,.08), transparent 60%),
      linear-gradient(180deg,var(--bg),var(--bg2));
    color:var(--soft);font-family:var(--sans);min-height:100vh;line-height:1.62;
    -webkit-font-smoothing:antialiased;letter-spacing:.005em;position:relative}
  /* faint starfield / dust grain */
  body::before{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.5;
    background-image:radial-gradient(rgba(200,206,250,.05) .5px,transparent .6px);background-size:3px 3px}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--gold);color:#1a1505}
  .wrap{width:min(1240px,100%);margin:0 auto;padding:0 var(--pad);position:relative;z-index:2}
  .mono{font-family:var(--mono);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dim)}

  /* ===== nav ===== */
  .nav{position:fixed;top:0;left:0;right:0;z-index:60;
    background:linear-gradient(180deg,rgba(6,7,13,.92),rgba(6,7,13,.55) 70%,transparent);
    backdrop-filter:blur(9px);-webkit-backdrop-filter:blur(9px)}
  .nav-in{width:min(1240px,100%);margin:0 auto;padding:.9rem var(--pad);display:flex;align-items:center;justify-content:space-between;gap:1rem;
    border-bottom:1px solid var(--line)}
  .logo{display:flex;align-items:center;gap:.6rem;font-family:var(--disp);font-weight:600;letter-spacing:.12em;font-size:.95rem;color:var(--ink)}
  .logo .gem{width:16px;height:16px;flex:none;border-radius:3px;transform:rotate(45deg);
    background:conic-gradient(from 0deg,var(--spectrum));box-shadow:0 0 12px rgba(140,120,255,.55)}
  .nav nav{display:flex;gap:1.6rem}
  .nav nav a{font-family:var(--mono);font-size:.72rem;letter-spacing:.13em;text-transform:uppercase;color:var(--dim);transition:color .3s}
  .nav nav a:hover{color:var(--ink)}
  @media(max-width:680px){.nav nav{display:none}}

  /* =========================================================
     THE CARD - shared shell for hero + work cards
     ========================================================= */
  .card{
    position:relative;border-radius:20px;isolation:isolate;
    background:
      linear-gradient(160deg,var(--card2),var(--card) 60%,#0d1022);
    border:1px solid var(--hair);
    box-shadow:0 1px 0 rgba(255,255,255,.04) inset, 0 26px 60px -28px rgba(0,0,0,.85);
    transform-style:preserve-3d;
    transition:transform .5s cubic-bezier(.2,.8,.2,1), box-shadow .5s;
    will-change:transform;
  }
  /* gold/platinum bevel frame */
  .card::before{content:"";position:absolute;inset:0;border-radius:20px;padding:1px;pointer-events:none;z-index:4;
    background:linear-gradient(140deg,rgba(207,214,238,.7),rgba(207,214,238,.06) 38%,rgba(233,200,118,.08) 62%,rgba(233,200,118,.6));
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);
    -webkit-mask-composite:xor;mask-composite:exclude}
  /* ---- HOLO FOIL: two stacked layers + shine sweep, all driven by --mx/--my ---- */
  .card .foil,.card .foil2,.card .shine{position:absolute;inset:0;border-radius:20px;pointer-events:none;z-index:3;
    opacity:0;transition:opacity .45s ease}
  /* layer 1 - broad iridescent wash following the cursor */
  .card .foil{
    background:
      radial-gradient(120% 120% at var(--mx,50%) var(--my,50%),
        rgba(255,94,138,.55),rgba(255,209,102,.42) 18%,rgba(155,255,142,.40) 34%,
        rgba(94,231,255,.46) 52%,rgba(157,123,255,.5) 72%,rgba(255,94,138,.42) 100%);
    mix-blend-mode:color-dodge;filter:saturate(1.3)}
  /* layer 2 - fine diagonal rainbow striping (the "foil texture"), shifted by pointer */
  .card .foil2{
    background:
      repeating-linear-gradient(115deg,
        rgba(255,94,138,.20) 0 6px,rgba(255,209,102,.20) 6px 12px,rgba(155,255,142,.20) 12px 18px,
        rgba(94,231,255,.20) 18px 24px,rgba(157,123,255,.20) 24px 30px);
    background-size:240% 240%;background-position:calc(var(--mx,50%) * 1) calc(var(--my,50%) * 1);
    mix-blend-mode:overlay;filter:saturate(1.4) contrast(1.1)}
  /* the swept shine highlight (gloss) */
  .card .shine{
    background:linear-gradient(115deg,transparent 30%,rgba(255,255,255,.5) 46%,rgba(255,255,255,.0) 60%);
    -webkit-mask:radial-gradient(60% 60% at var(--mx,50%) var(--my,50%),#000 0%,rgba(0,0,0,.35) 55%,transparent 75%);
    mask:radial-gradient(60% 60% at var(--mx,50%) var(--my,50%),#000 0%,rgba(0,0,0,.35) 55%,transparent 75%);
    mix-blend-mode:screen}
  .card.lit{box-shadow:0 1px 0 rgba(255,255,255,.06) inset, 0 40px 80px -30px rgba(0,0,0,.9), 0 0 50px -14px var(--glow)}
  .card.lit .foil{opacity:.85}
  .card.lit .foil2{opacity:.55}
  .card.lit .shine{opacity:.8}
  /* large-surface cards: ease the wash + diagonal banding so it reads as foil texture,
     not heavy colour bands, and keeps the body copy comfortably legible */
  .about-card.lit .foil,.wcard.feat.lit .foil,.brands.lit .foil{opacity:.6}
  .about-card.lit .foil2,.wcard.feat.lit .foil2,.brands.lit .foil2{opacity:.32}
  /* PLAYER card: the color-dodge wash blows out the portrait under the cursor.
     Soften ONLY the dodge layer over the photo window via a vertical mask that
     fades the foil to ~22% across the art band (top ~9% to ~70% of the card),
     while the nameplate/stat areas above and below keep the full shimmer. */
  .player .foil{
    -webkit-mask:linear-gradient(180deg,
      #000 0%,#000 8%,rgba(0,0,0,.22) 22%,rgba(0,0,0,.22) 62%,#000 74%,#000 100%);
    mask:linear-gradient(180deg,
      #000 0%,#000 8%,rgba(0,0,0,.22) 22%,rgba(0,0,0,.22) 62%,#000 74%,#000 100%)}
  /* content sits above foil so text stays readable */
  .card .cbody{position:relative;z-index:2}

  /* =========================================================
     HERO - player card + intro
     ========================================================= */
  header.hero{padding:8.5rem 0 3.5rem;position:relative;z-index:2}
  .hero-top{display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;
    border-bottom:1px solid var(--line);padding-bottom:1rem;margin-bottom:clamp(1.6rem,4vw,3rem)}
  .hero-grid{display:grid;grid-template-columns:1.05fr minmax(300px,420px);gap:clamp(1.6rem,4vw,3.6rem);align-items:center}

  .hero h1{font-family:var(--disp);font-weight:700;line-height:1.0;letter-spacing:.01em;
    font-size:clamp(2.8rem,8vw,6.4rem);color:var(--ink)}
  .hero h1 .l2{display:block}
  /* "ships." gets the holo spectrum fill - guarded: NO text-shadow / NO filter here */
  .hero h1 .ships{
    background:linear-gradient(100deg,#ff7ea6,#ffd166 28%,#9bff8e 48%,#5ee7ff 68%,#b89dff 92%);
    -webkit-background-clip:text;background-clip:text;color:transparent;-webkit-text-fill-color:transparent;text-shadow:none}
  .hero .sub{margin-top:clamp(1.3rem,2.6vw,1.9rem);max-width:48ch;color:var(--soft);
    font-size:clamp(1rem,1.2vw,1.12rem);line-height:1.68}
  .hero .sub b{color:var(--ink);font-weight:600}
  .hero .cta{margin-top:1.9rem;display:flex;gap:.8rem;flex-wrap:wrap}
  .btn{font-family:var(--mono);font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;padding:.85rem 1.4rem;border-radius:11px;
    border:1px solid var(--hair);display:inline-flex;gap:.55rem;align-items:center;color:var(--ink);
    transition:transform .35s,border-color .35s,background .35s,box-shadow .35s}
  .btn .ar{transition:transform .35s}
  .btn:hover .ar{transform:translate(3px,-3px)}
  .btn.primary{color:#1a1505;border:0;
    background:linear-gradient(100deg,#f3d989,var(--gold) 50%,#d9b75c);box-shadow:0 10px 30px -12px rgba(233,200,118,.5)}
  .btn.primary:hover{transform:translateY(-2px);box-shadow:0 16px 36px -12px rgba(233,200,118,.6)}
  .btn.ghost:hover{border-color:var(--hair);background:rgba(160,170,255,.07);transform:translateY(-2px)}

  /* ----- the PLAYER CARD (hero portrait card) ----- */
  .player{aspect-ratio:3/4.05;width:100%;max-width:420px;margin-inline:auto;overflow:hidden;
    padding:0;display:block}
  .player .pinner{position:relative;z-index:2;height:100%;display:flex;flex-direction:column}
  .player .ptopline{display:flex;justify-content:space-between;align-items:center;padding:.85rem 1rem .6rem;
    font-family:var(--mono);font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--dim)}
  .player .rarity{display:inline-flex;align-items:center;gap:.4rem;color:var(--gold)}
  .player .rarity::before{content:"";width:7px;height:7px;border-radius:50%;
    background:radial-gradient(circle at 30% 30%,#fff,var(--gold));box-shadow:0 0 8px rgba(233,200,118,.8)}
  .player .art{position:relative;flex:1;margin:0 .7rem;border-radius:14px;overflow:hidden;
    background:radial-gradient(120% 90% at 50% 0%,#23284a,#0c0e1c);
    border:1px solid rgba(200,206,250,.16)}
  .player .art img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:top center;
    filter:contrast(1.04) saturate(1.05)}
  .player .art::after{content:"";position:absolute;inset:0;
    background:linear-gradient(180deg,transparent 52%,rgba(8,9,18,.65) 86%,rgba(8,9,18,.95))}
  .player .nameplate{position:relative;padding:.75rem 1rem .5rem;text-align:center}
  .player .pname{font-family:var(--disp);font-weight:700;font-size:clamp(1.15rem,2.4vw,1.5rem);letter-spacing:.04em;color:var(--ink);line-height:1.05}
  .player .prole{font-family:var(--mono);font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-top:.3rem}
  /* stat strip across the card foot */
  .player .pstats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);
    margin:.55rem .7rem .8rem;border-radius:11px;overflow:hidden;border:1px solid var(--line)}
  .player .pstat{background:rgba(10,12,26,.72);padding:.6rem .3rem;text-align:center}
  .player .pstat .sv{font-family:var(--mono);font-weight:700;font-size:clamp(.92rem,2vw,1.12rem);color:var(--ink);line-height:1}
  .player .pstat .sk{font-family:var(--mono);font-size:.5rem;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);margin-top:.35rem}

  @media(max-width:820px){
    .hero-grid{grid-template-columns:1fr}
    .player{max-width:330px}
  }

  /* scroll cue */
  .scrollcue{margin-top:2.4rem;display:flex;align-items:center;gap:.7rem;color:var(--faint);
    font-family:var(--mono);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase}
  .scrollcue .bar{width:34px;height:1px;background:var(--hair);position:relative;overflow:hidden}
  .scrollcue .bar::after{content:"";position:absolute;inset:0;width:40%;background:var(--plat);animation:slide 2.2s linear infinite}
  @keyframes slide{0%{transform:translateX(-110%)}100%{transform:translateX(280%)}}

  /* ===== sections / heads ===== */
  section{padding:clamp(3.4rem,8vh,6rem) 0;position:relative;z-index:2}
  .shead{display:flex;justify-content:space-between;align-items:flex-end;gap:1.5rem;
    border-bottom:1px solid var(--line);padding-bottom:1.1rem;margin-bottom:2.4rem}
  .shead .idx{font-family:var(--mono);font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--faint);margin-bottom:.7rem}
  .shead h2{font-family:var(--disp);font-weight:700;font-size:clamp(1.7rem,4vw,3rem);line-height:1.02;letter-spacing:.02em;color:var(--ink)}
  .shead .meta{font-family:var(--mono);font-size:.66rem;letter-spacing:.08em;color:var(--dim);text-align:right;text-transform:uppercase;line-height:1.7}

  /* ===== build stats (deck stat block) ===== */
  .deck{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:16px;overflow:hidden}
  .dstat{background:linear-gradient(180deg,var(--card),#0d1022);padding:clamp(1.4rem,3vw,2.2rem) clamp(1.1rem,2.4vw,1.8rem);min-height:170px;
    display:flex;flex-direction:column;justify-content:space-between}
  .dstat .dn{font-family:var(--disp);font-weight:700;font-size:clamp(2.8rem,7vw,5rem);line-height:.85;letter-spacing:.01em;color:var(--ink)}
  .dstat .dn sup{font-size:.4em;color:var(--gold);vertical-align:super;font-family:var(--mono)}
  .dstat .dl{font-family:var(--mono);font-size:.72rem;letter-spacing:.04em;color:var(--dim);text-transform:uppercase;max-width:24ch;line-height:1.55}
  @media(max-width:760px){.deck{grid-template-columns:1fr}.dstat{min-height:auto;flex-direction:row;align-items:center;gap:1.4rem;justify-content:flex-start}.dstat .dl{max-width:none}}

  /* ===== disciplines = ability cards ===== */
  .abilities{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
  .ability{padding:1.5rem 1.3rem 1.6rem;min-height:210px;display:flex;flex-direction:column;gap:.7rem}
  .ability .asym{font-size:1.5rem;color:var(--gold);line-height:1}
  .ability .ai{font-family:var(--mono);font-size:.64rem;letter-spacing:.16em;color:var(--faint)}
  .ability .at{font-family:var(--disp);font-weight:600;font-size:1.18rem;line-height:1.15;letter-spacing:.01em;color:var(--ink)}
  .ability .ad{color:var(--soft);font-size:.92rem;line-height:1.55;margin-top:auto}
  @media(max-width:960px){.abilities{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:560px){.abilities{grid-template-columns:1fr}.ability{min-height:auto}}

  /* ===== work = card collection ===== */
  .collection{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
  .wcard{grid-column:span 1;padding:1.4rem 1.4rem 1.5rem;min-height:280px;display:flex;flex-direction:column;gap:.7rem}
  .wcard.feat{grid-column:span 3}
  .wcard .whead{display:flex;justify-content:space-between;align-items:center;gap:1rem;
    font-family:var(--mono);font-size:.62rem;letter-spacing:.13em;text-transform:uppercase;color:var(--faint)}
  .tier{display:inline-flex;align-items:center;gap:.4rem;padding:.3rem .6rem;border-radius:999px;
    font-family:var(--mono);font-size:.56rem;letter-spacing:.13em;text-transform:uppercase;border:1px solid var(--hair);color:var(--plat)}
  .tier.t-legendary{color:#1a1505;border-color:transparent;background:linear-gradient(100deg,#f3d989,var(--gold) 55%,#d9b75c)}
  .tier.t-epic{color:#e7d6ff;border-color:rgba(157,123,255,.5);background:rgba(157,123,255,.12)}
  .tier.t-rare{color:#bfe2ff;border-color:rgba(94,231,255,.45);background:rgba(94,231,255,.10)}
  .tier.t-uncommon{color:#c6f3c0;border-color:rgba(155,255,142,.4);background:rgba(155,255,142,.08)}
  .wcard .wt{font-family:var(--disp);font-weight:700;font-size:clamp(1.25rem,2.4vw,1.7rem);line-height:1.05;letter-spacing:.02em;color:var(--ink)}
  .wcard .wrole{font-family:var(--mono);font-size:.64rem;letter-spacing:.1em;text-transform:uppercase;color:var(--gold)}
  .wcard .wr{font-family:var(--mono);font-size:.82rem;color:var(--plat);letter-spacing:.01em}
  .wcard .wd{color:var(--soft);font-size:.92rem;line-height:1.55;margin-top:auto}
  .wcard .go{font-family:var(--mono);font-size:.64rem;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);
    display:inline-flex;gap:.4rem;align-items:center;margin-top:.6rem;transition:color .3s,gap .3s}
  .wcard:hover .go,.wcard.lit .go{color:var(--ink);gap:.7rem}
  /* featured layout */
  .wcard.feat{flex-direction:row;align-items:stretch;gap:2.2rem;min-height:240px}
  .wcard.feat .fleft{flex:1.15;display:flex;flex-direction:column;gap:.7rem}
