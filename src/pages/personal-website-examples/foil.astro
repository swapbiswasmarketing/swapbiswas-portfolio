<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const COARSE = window.matchMedia('(pointer: coarse)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.14, rootMargin: '0px 0px -7% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- holographic foil + 3D tilt ----------
     - One rAF scheduled at a time, globally; only the currently-hovered card updates.
     - On pointermove we store the latest pointer pos + target card, then flush in rAF.
     - Tilt + foil props (--mx/--my) are written together so they stay in sync.
     - Disabled entirely for reduced-motion (CSS provides a static sheen) and for
       coarse/touch pointers (tilt off; a tap still "lights" the card via :active-ish class). */
  if (!RM && !COARSE) {
    const MAXTILT = 9;       // degrees
    let raf = 0;
    let pending = null;      // { card, px, py } in card-local %  + pointer client coords

    function flush() {
      raf = 0;
      if (!pending) return;
      const { card, mx, my, rx, ry } = pending;
      card.style.setProperty('--mx', mx + '%');
      card.style.setProperty('--my', my + '%');
      card.style.transform =
        'perspective(900px) rotateX(' + rx.toFixed(2) + 'deg) rotateY(' + ry.toFixed(2) + 'deg) scale(1.025)';
    }

    function onMove(card, ev) {
      const rect = card.getBoundingClientRect();
      const x = ev.clientX - rect.left;
      const y = ev.clientY - rect.top;
      const mx = Math.max(0, Math.min(100, (x / rect.width) * 100));
      const my = Math.max(0, Math.min(100, (y / rect.height) * 100));
      // tilt: pointer right => rotateY+, pointer down => rotateX- (toward cursor)
      const ry = ((x / rect.width) - 0.5) * 2 * MAXTILT;
      const rx = -((y / rect.height) - 0.5) * 2 * MAXTILT;
      pending = { card, mx, my, rx, ry };
      if (!raf) raf = requestAnimationFrame(flush);
    }

    document.querySelectorAll('.card[data-tilt]').forEach(card => {
      card.addEventListener('pointerenter', () => card.classList.add('lit'));
      card.addEventListener('pointermove', (ev) => onMove(card, ev));
      card.addEventListener('pointerleave', () => {
        card.classList.remove('lit');
        // settle the card back; cancel any queued frame targeting it
        if (pending && pending.card === card) pending = null;
        card.style.transform = '';
        card.style.removeProperty('--mx');
        card.style.removeProperty('--my');
      });
    });
  } else if (COARSE && !RM) {
    // Touch: no tilt, but tapping a card flashes the foil briefly so it still feels alive.
    document.querySelectorAll('.card[data-tilt]').forEach(card => {
      card.addEventListener('pointerdown', () => {
        card.style.setProperty('--mx', '50%');
        card.style.setProperty('--my', '35%');
        card.classList.add('lit');
        setTimeout(() => card.classList.remove('lit'), 650);
      });
    });
  }
</script>
