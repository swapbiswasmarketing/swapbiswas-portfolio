<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- stat numerals: count-up + weight bloom ---------- */
  function animateNum(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){
      el.innerHTML = target + supHTML;
      el.style.fontVariationSettings = '"opsz" 144,"wght" 720,"wdth" 100,"GRAD" 0';
      return;
    }
    const dur = 1200, t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(target * eased);
      const wght = Math.round(300 + eased * 480);   // 300 -> 780 weight bloom
      const wdth = Math.round(100 + eased * 30);     // 100 -> 130 width bloom
      el.innerHTML = val + supHTML;
      el.style.fontVariationSettings = '"opsz" 144,"wght" ' + wght + ',"wdth" ' + wdth + ',"GRAD" 0';
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ animateNum(e.target.querySelector('.bignum')); numIO.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('.num').forEach(n => numIO.observe(n));

  /* ---------- THE MECHANIC: reactive kinetic hero ---------- */
  (function kinetic(){
    const word = document.getElementById('heroWord');
    if (!word) return;
    const letters = Array.from(word.querySelectorAll('.ltr')).filter(l => !l.classList.contains('sp'));
    if (!letters.length) return;

    // reduced motion: static optimal weights baked by CSS, no reactivity at all
    if (RM) return;

    // axis ranges + radius of influence
    const RADIUS = 280;          // px reach of the cursor field
    const W_BASE = 300, W_PEAK = 1000;
    const WD_BASE = 100, WD_PEAK = 151;
    const SL_PEAK = -9;          // max slant (negative = forward lean)
    const OPSZ = 144;

    let pointer = { x: -99999, y: -99999, inside: false };
    let scrollPush = 0;          // 0..1 global push from scroll velocity
    let lastScrollY = window.scrollY;
    let centres = [];            // cached letter centres (page coords)
    let rafPending = false;
    let active = false;

    function measure(){
      const sy = window.scrollY;
      centres = letters.map(l => {
        const r = l.getBoundingClientRect();
        return { x: r.left + r.width / 2, y: r.top + sy + r.height / 2, el: l, on: true };
      });
    }
    measure();

    // only update letters that are on screen
    function updateVisibility(){
      const top = window.scrollY, bot = top + window.innerHeight;
      for (const c of centres){
        c.on = c.y > top - 200 && c.y < bot + 200;
      }
    }

    function render(){
      rafPending = false;
      const sy = window.scrollY;
      const px = pointer.x, py = pointer.y + sy;   // pointer in page coords
      for (const c of centres){
        if (!c.on) continue;
        let f = 0;
        if (pointer.inside){
          const dx = c.x - px, dy = c.y - py;
          const d = Math.sqrt(dx*dx + dy*dy);
          if (d < RADIUS){ const t = 1 - d / RADIUS; f = t * t; }   // ease-in falloff
        }
        // scroll velocity adds a global floor of weight + slant
        const g = scrollPush;
        const fl = Math.max(f, g * 0.55);
        const wght = Math.round(W_BASE + fl * (W_PEAK - W_BASE));
        const wdth = Math.round(WD_BASE + f * (WD_PEAK - WD_BASE));
        const slnt = (f * SL_PEAK) + (g * SL_PEAK * 0.5);
        c.el.style.fontVariationSettings =
          '"opsz" ' + OPSZ + ',"wght" ' + wght + ',"wdth" ' + wdth + ',"GRAD" 0,"slnt" ' + slnt.toFixed(1);
      }
      // keep animating while there is residual scroll push so it settles to a legible rest state
      if (pointer.inside || scrollPush > 0.01){
        scrollPush *= 0.9;
        if (pointer.inside || scrollPush > 0.01) schedule();
      } else if (!settled){
        settle();
      }
    }

    let settled = false;
    function schedule(){ if (!rafPending){ rafPending = true; settled = false; requestAnimationFrame(render); } }

    // ease every letter back to the legible resting weight when idle
    function settle(){
      settled = true;
      for (const c of centres){
        c.el.style.fontVariationSettings = '"opsz" ' + OPSZ + ',"wght" 300,"wdth" 100,"GRAD" 0,"slnt" 0';
      }
    }

    word.addEventListener('pointermove', (ev) => {
      pointer.x = ev.clientX; pointer.y = ev.clientY; pointer.inside = true;
      schedule();
    });
    word.addEventListener('pointerleave', () => {
      pointer.inside = false;
      schedule();   // render loop will settle once scrollPush decays
    });

    // scroll velocity -> global push, rAF-throttled
    let scrollTick = false;
    window.addEventListener('scroll', () => {
      if (scrollTick) return;
      scrollTick = true;
      requestAnimationFrame(() => {
        const sy = window.scrollY;
        const v = Math.min(1, Math.abs(sy - lastScrollY) / 60);
        lastScrollY = sy;
        scrollPush = Math.max(scrollPush, v);
        updateVisibility();
        schedule();
        scrollTick = false;
      });
    }, { passive: true });

    // re-measure on resize / font load (letter boxes shift once the variable font swaps in)
    let rt;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => { measure(); schedule(); }, 160); });
    if (document.fonts && document.fonts.ready){
      document.fonts.ready.then(() => { measure(); schedule(); });
    }
    // gentle idle entrance: one settle pass so letters land at rest weight
    schedule();
  })();

  /* ---------- interactive specimen sliders ---------- */
  (function lab(){
    const wordEl = document.getElementById('labWord');
    const readout = document.getElementById('labReadout');
    const wght = document.getElementById('axWght');
    const wdth = document.getElementById('axWdth');
    const opsz = document.getElementById('axOpsz');
    if (!wordEl || !wght || !wdth || !opsz) return;
    const vW = document.getElementById('vWght'), vD = document.getElementById('vWdth'), vO = document.getElementById('vOpsz');
    let pending = false;
    function apply(){
      pending = false;
      const w = wght.value, d = wdth.value, o = opsz.value;
      wordEl.style.fontVariationSettings = '"opsz" ' + o + ',"wght" ' + w + ',"wdth" ' + d + ',"GRAD" 0';
      vW.textContent = w; vD.textContent = d; vO.textContent = o;
      readout.innerHTML = 'wght <b>' + w + '</b> &middot; wdth <b>' + d + '</b> &middot; opsz <b>' + o + '</b>';
    }
    function onInput(){ if (!pending){ pending = true; requestAnimationFrame(apply); } }
    [wght, wdth, opsz].forEach(s => s.addEventListener('input', onInput));
    apply();
  })();
</script>
</body>
