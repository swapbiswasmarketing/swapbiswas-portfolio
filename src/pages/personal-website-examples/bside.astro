          <div class="runtime"><span class="bar"></span> Drop the needle to play</div>
        </div>

        <div class="deck" id="deck" aria-hidden="true">
          <div class="platter">
            <div class="spinner" id="spinner">
              <div class="label">
                <span class="lcap">B - Side</span>
                <img src="/assets/portrait-cut.webp" alt="" loading="eager" decoding="async" />
                <span class="ring"></span>
                <span class="spindle"></span>
              </div>
            </div>
          </div>
          <div class="tonearm" id="tonearm">
            <span class="pivot"></span>
            <span class="arm"><span class="head"></span></span>
          </div>
          <div class="np-chip"><span class="dot"></span> <span id="chipText">Now playing - LambdaTest</span></div>
        </div>
      </div>
    </header>
  </div>

  <div class="wrap">
    <!-- ===== tracklist + now playing ===== -->
    <section id="tracks">
      <div class="shead">
        <div><div class="idx">&#47;&#47; Side A / B &middot; Tracklist</div><h2 class="reveal">Selected work, pressed to vinyl</h2></div>
        <div class="meta reveal">Tap a track to play<br/>2019 - 2026</div>
      </div>

      <div class="play-grid">
        <div class="sidewrap reveal">
          <div>
            <div class="side-label"><b>A</b> A-Side &middot; Launches &amp; wins <span class="ln"></span></div>
            <div class="tracklist" role="list">
              {aSide.map(tk => (
                <button class="track" type="button" role="listitem"
                  data-no={tk.no} data-title={tk.t} data-year={tk.y} data-role={tk.role}
