    <!-- ===== runtime / build stats ===== -->
    <section id="runtime">
      <div class="shead">
        <div><div class="idx">&#47;&#47; Total runtime</div><h2 class="reveal">What got built &amp; shipped</h2></div>
        <div class="meta reveal">The leads sit on track A1 -<br/>this is the body of work</div>
      </div>
      <div class="stats">
        {buildStats.map(s => (
          <div class="stat reveal">
            <div class="sv" data-target={s.n}>0{s.plus && <sup>{s.plus}</sup>}</div>
            <div class="sk">{s.l}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== gold records / recognition + brands ===== -->
    <section id="honours">
      <div class="shead">
        <div><div class="idx">&#47;&#47; Gold records</div><h2 class="reveal">Recognition &amp; labels</h2></div>
      </div>
      <div class="honours-grid">
        <div class="golds reveal">
          {recognition.map(a => (
            <div class="gold"><span class="disc" aria-hidden="true"></span><div><b>{a.t}</b><span>{a.m}</span></div></div>
          ))}
        </div>
        <div class="brands reveal">
          <div class="bl">Pressed with teams at</div>
          <div class="bgrid">{brands.map(b => <span>{b}</span>)}</div>
        </div>
      </div>
    </section>

    <!-- ===== credits / about ===== -->
    <section id="about">
      <div class="shead">
        <div><div class="idx">&#47;&#47; Credits</div><h2 class="reveal">About the maker</h2></div>
        <div class="meta reveal">Mumbai, India</div>
      </div>
      <div class="about-grid">
        <div class="about-photo reveal"><img src="/assets/portrait-cut.webp" alt="Swapnil Biswas" loading="lazy" decoding="async" /></div>
        <div>
          <p class="about-lead reveal">I treat my own career like a product - positioned, measured and shipped. Seven years in marketing, four deep in B2B SaaS.</p>
          <div class="facts">
            <div class="fact reveal"><div class="k">Based</div><div class="v">Mumbai, India</div></div>
            <div class="fact reveal"><div class="k">Tenure</div><div class="v">7+ years marketing &middot; 4+ in B2B SaaS</div></div>
            <div class="fact reveal"><div class="k">Education</div><div class="v">Postgrad in Digital Marketing &amp; Growth Strategy, IIM Visakhapatnam</div></div>
            <div class="fact reveal"><div class="k">Practice</div><div class="v">PMM &amp; growth strategist who codes AI agents, ships websites and runs technical SEO</div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== request a track / contact ===== -->
    <section id="contact" class="contact">
      <div class="cl reveal">Request a track &middot; Let's build something that compounds</div>
      <div class="big reveal"><a href="mailto:swapbiswas.marketing@gmail.com">Say hello <span class="ar">&#8599;</span></a></div>
      <div class="em reveal">swapbiswas.marketing@gmail.com &nbsp;&middot;&nbsp; <a href="https://www.linkedin.com/in/swapbiswas/">LinkedIn</a></div>
    </section>
  </div>

  <footer>
    <div class="foot-in">
      <span>B-Side &middot; Concept 33</span>
      <span>Swapnil Biswas &copy; 2026</span>
      <span><a href="/redesign/">View all concepts</a></span>
    </div>
  </footer>

<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- count-up build stats ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur = 1100; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.innerHTML = Math.round(target * eased) + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ countUp(e.target.querySelector('.sv')); numIO.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('.stat').forEach(n => numIO.observe(n));

  /* ---------- turntable / track player ---------- */
  (function player(){
    const deck    = document.getElementById('deck');
    const spinner = document.getElementById('spinner');
    const chipText= document.getElementById('chipText');
    const tracks  = Array.from(document.querySelectorAll('.track'));
    const npNo    = document.getElementById('npNo');
    const npTitle = document.getElementById('npTitle');
    const npRole  = document.getElementById('npRole');
    const npDesc  = document.getElementById('npDesc');
    const npStat  = document.getElementById('npStat');
    const npR     = document.getElementById('npR');
    const npBody  = document.getElementById('npBody');
    const npRuntime = document.getElementById('npRuntime');
    if (!tracks.length) return;

    function play(tk, fromClick){
      const d = tk.dataset;
      const single = d.single === '1';

      // tracklist active state
      tracks.forEach(t => t.classList.remove('active'));
      tk.classList.add('active');

      // now-playing panel (re-trigger fade by reflow)
      npBody.style.animation = 'none';
      // eslint-disable-next-line no-unused-expressions
      npBody.offsetHeight;
      npBody.style.animation = '';

      npNo.innerHTML = single ? (d.no + ' · The headline single') : (d.no + ' · Track');
      npTitle.textContent = d.title;
      npRole.innerHTML = d.role + ' · ' + d.year;
      npDesc.textContent = d.desc;
      npRuntime.textContent = 'Track ' + d.no;
      chipText.textContent = 'Now playing - ' + d.title;

      if (single){
        npStat.hidden = false;
        npStat.innerHTML =
          '<div class="s"><div class="v">657K+</div><div class="k">Leads generated</div></div>' +
          '<div class="s"><div class="v">18.2M+</div><div class="k">Organic traffic driven</div></div>';
        npR.hidden = true;
      } else {
        npStat.hidden = true;
        npR.hidden = false;
        npR.textContent = d.r;
      }

      // needle sits on the record (static in reduced-motion); spin only when motion allowed
      deck.classList.add('playing');
      if (!RM){
        // restart the spin-and-settle so each play re-spins, then rests with the portrait upright
        spinner.classList.remove('rot');
        // eslint-disable-next-line no-unused-expressions
        spinner.offsetHeight;
        spinner.classList.add('rot');
      }
    }

    tracks.forEach(tk => {
      tk.addEventListener('click', () => play(tk, true));
    });

    // default track on load = A1 (LambdaTest); content is already in the markup as a fallback,
    // so this just sets the active state + (optionally) starts the motion.
    const first = tracks[0];
    if (first){
      first.classList.add('active');
      if (RM){
        // reduced motion: needle is already resting on the record, no travel animation
        deck.classList.add('playing');
      } else {
        // small delay so the needle-drop reads as an intentional "play" on load
        setTimeout(() => { deck.classList.add('playing'); spinner.classList.add('rot'); }, 450);
      }
    }
  })();
</script>
</body>
</html>
