                    <span class="tsub">{tk.role}</span>
                  </span>
                  <span class="tmeta"><span class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>{tk.y}</span>
                </button>
              ))}
            </div>
          </div>

          <div>
            <div class="side-label"><b>B</b> B-Side &middot; Experiments &amp; craft <span class="ln"></span></div>
            <div class="tracklist" role="list">
              {bSide.map(tk => (
                <button class="track" type="button" role="listitem"
                  data-no={tk.no} data-title={tk.t} data-year={tk.y} data-role={tk.role}
                  data-r={tk.r} data-desc={tk.d} data-single={tk.single ? '1' : '0'}>
                  <span class="tno">{tk.no}</span>
                  <span class="tinfo">
                    <span class="ttl">{tk.t}</span>
                    <span class="tsub">{tk.role}</span>
                  </span>
                  <span class="tmeta"><span class="eq" aria-hidden="true"><i></i><i></i><i></i><i></i></span>{tk.y}</span>
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="now reveal" id="now" aria-live="polite">
          <div class="now-top">
            <span class="nl"><span class="dot"></span> Now playing</span>
            <span class="nr" id="npRuntime">Track A1</span>
          </div>
          <div class="now-body" id="npBody">
            <!-- filled by JS; static A1 fallback below for no-JS / reduced motion -->
            <div class="npno" id="npNo">A1 &middot; The headline single</div>
            <h3 id="npTitle">LambdaTest</h3>
            <div class="nrole" id="npRole">Product &amp; digital marketing &middot; 2021 - 2025</div>
            <p class="ndesc" id="npDesc">Owned product and digital marketing end to end and built the full organic growth engine.</p>
            <div class="nstat single" id="npStat">
              <div class="s"><div class="v">657K+</div><div class="k">Leads generated</div></div>
              <div class="s"><div class="v">18.2M+</div><div class="k">Organic traffic driven</div></div>
            </div>
            <div class="nr-line" id="npR" hidden>657K+ leads &middot; 18.2M+ organic</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== liner notes / disciplines ===== -->
    <section id="liner">
      <div class="shead">
        <div><div class="idx">&#47;&#47; Liner notes</div><h2 class="reveal">What I do</h2></div>
        <div class="meta reveal">Four disciplines<br/>one operator</div>
      </div>
      <div class="liner">
        {pillars.map(p => (
          <div class="ln-cell reveal">
            <div class="ln-i">{p.i}</div>
