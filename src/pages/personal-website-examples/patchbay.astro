              <span class="srole">{w.role}</span>
              <span class="sd">{w.d}</span>
            </span>
            <span class="sright">
              <span class="sout">{w.r}</span>
              <span class="smeter" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <!-- ===== recognition + brands ===== -->
    <section id="honours">
      <div class="shead">
        <div><div class="idx">// 03 / Decals</div><h2 class="reveal">Recognition &amp; brands</h2></div>
      </div>
      <div class="honours-grid">
        <div class="decals reveal">
          {recognition.map((a) => (
            <div class="decal"><span class="badge" aria-hidden="true"></span><div><b>{a.t}</b><span>{a.m}</span></div></div>
