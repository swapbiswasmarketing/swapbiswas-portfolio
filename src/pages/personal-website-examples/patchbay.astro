<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  setTimeout(() => document.getElementById('hero')?.classList.add('in'), 60);

  /* ---------- segmented count-up ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    if (isNaN(target)) return;
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur = 1100, t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.innerHTML = Math.round(target * eased) + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting){
        countUp(e.target.querySelector('.seg'));
        // light the mini VU under each gauge
        const bars = e.target.querySelectorAll('.gvu i');
        bars.forEach((b, i) => setTimeout(() => b.classList.add('on'), RM ? 0 : 70 * i));
        numIO.unobserve(e.target);
      }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.gauge').forEach(g => numIO.observe(g));

  /* ---------- knobs: drag to rotate (hero) ---------- */
  if (!RM){
    document.querySelectorAll('[data-knob]').forEach(knob => {
      let dragging = false, startY = 0, startRot = 0;
      const cur = () => parseFloat(getComputedStyle(knob).getPropertyValue('--rot')) || 0;
      const clamp = v => Math.max(-150, Math.min(150, v));
      knob.addEventListener('pointerdown', e => {
        dragging = true; startY = e.clientY; startRot = cur();
        knob.setPointerCapture(e.pointerId); e.preventDefault();
      });
      knob.addEventListener('pointermove', e => {
        if (!dragging) return;
        knob.style.setProperty('--rot', clamp(startRot + (startY - e.clientY) * 1.5) + 'deg');
      });
      const end = () => { dragging = false; };
      knob.addEventListener('pointerup', end);
      knob.addEventListener('pointercancel', end);
    });
    /* fader: drag horizontally */
    document.querySelectorAll('[data-fader]').forEach(cap => {
      const track = cap.parentElement;
      let dragging = false;
      const set = clientX => {
        const r = track.getBoundingClientRect();
        const p = Math.max(6, Math.min(94, ((clientX - r.left) / r.width) * 100));
        cap.style.setProperty('--p', p + '%');
      };
      cap.addEventListener('pointerdown', e => { dragging = true; cap.setPointerCapture(e.pointerId); e.preventDefault(); });
      cap.addEventListener('pointermove', e => { if (dragging) set(e.clientX); });
      const end = () => { dragging = false; };
      cap.addEventListener('pointerup', end);
      cap.addEventListener('pointercancel', end);
    });
  }

  /* ---------- THE PATCHBAY: cables, draw-connect, signal pulses ---------- */
  (function patchbay(){
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const svg = document.getElementById('cables');
    const patch = document.getElementById('patch');
    const grid = document.getElementById('patchGrid');
    if (!svg || !patch || !grid) return;

    // routing: each cable from a source jack to a destination jack.
    // input feeds all 4 modules; each module feeds the output. Modules carry amber; out lines teal.
    const routes = [
      { from: 'in-out',  to: 'pos-in', color: 'amber', node: 'pos' },
      { from: 'in-out',  to: 'seo-in', color: 'amber', node: 'seo' },
      { from: 'in-out',  to: 'ai-in',  color: 'amber', node: 'ai'  },
      { from: 'in-out',  to: 'grw-in', color: 'amber', node: 'grw' },
      { from: 'pos-out', to: 'out-in', color: 'teal',  node: 'pos' },
      { from: 'seo-out', to: 'out-in', color: 'teal',  node: 'seo' },
      { from: 'ai-out',  to: 'out-in', color: 'teal',  node: 'ai'  },
      { from: 'grw-out', to: 'out-in', color: 'teal',  node: 'grw' },
    ];

    let cables = []; // { route, group, shell, core, pulse, len, d }
    let built = false;

    function jackCenter(name){
      const j = patch.querySelector(`[data-jack="${name}"]`);
      if (!j) return null;
      const pr = patch.getBoundingClientRect();
      const r = j.getBoundingClientRect();
      return { x: r.left - pr.left + r.width / 2, y: r.top - pr.top + r.height / 2 };
    }

    // Cable routing: jacks all sit on the row centerline, behind opaque module panels.
    // To read as a real patchbay, every cable dips DOWN past the panel bottom into the
    // visible trough beneath the modules, then rises back to its destination jack.
    // `floor` = y of the trough belly (further down for longer hauls so the fan reads).
    function pathFor(a, b, floor){
      const dx = b.x - a.x;
      const span = Math.abs(dx);
      // belly sits in the trough; longer cables hang a touch deeper for a layered fan
      const belly = floor + Math.min(26, span * 0.03);
      // pull control handles outward + down so the cable leaves/enters the jacks vertically
      const c1x = a.x + dx * 0.18, c1y = belly;
      const c2x = b.x - dx * 0.18, c2y = belly;
      return `M ${a.x.toFixed(1)} ${a.y.toFixed(1)} C ${c1x.toFixed(1)} ${c1y.toFixed(1)}, ${c2x.toFixed(1)} ${c2y.toFixed(1)}, ${b.x.toFixed(1)} ${b.y.toFixed(1)}`;
    }

    function build(){
      const pr = patch.getBoundingClientRect();
      svg.setAttribute('viewBox', `0 0 ${pr.width} ${pr.height}`);
      svg.style.width = pr.width + 'px';
      svg.style.height = pr.height + 'px';
      svg.innerHTML = '';
      cables = [];
      // hide cables on narrow layout (matches CSS .cable-layer{display:none})
      if (window.matchMedia('(max-width:900px)').matches){ built = true; return; }

      // find the trough floor: just below the module panels, inside the patch padding
      const grid = document.getElementById('patchGrid');
      let panelBottom = pr.height * 0.78;
      if (grid){
        const gr = grid.getBoundingClientRect();
        panelBottom = gr.bottom - pr.top;
      }
      const floor = Math.min(pr.height - 16, panelBottom + 30); // belly baseline in the trough

      routes.forEach((route) => {
        const a = jackCenter(route.from), b = jackCenter(route.to);
        if (!a || !b) return;
        const d = pathFor(a, b, floor);
        const g = document.createElementNS(SVG_NS, 'g');
        g.setAttribute('class', 'cable ' + (route.color === 'teal' ? 'teal' : ''));
        g.dataset.node = route.node;

        const shell = document.createElementNS(SVG_NS, 'path');
        shell.setAttribute('class', 'cable-shell'); shell.setAttribute('d', d);

        const core = document.createElementNS(SVG_NS, 'path');
        core.setAttribute('class', 'cable-core'); core.setAttribute('d', d);

        g.appendChild(shell); g.appendChild(core); svg.appendChild(g);

        const len = core.getTotalLength();
        core.style.setProperty('--len', len);

        cables.push({ route, group: g, core, len, d, a, b });
      });

      // light the jacks that are wired
      patch.querySelectorAll('.jack').forEach(j => j.classList.add('lit'));

      // draw-connect, then start the signal
      if (RM){
        cables.forEach(c => { c.core.classList.add('connected'); }); // static, fully connected
        lightAllVU();
      } else {
        // stagger the draw-in
        cables.forEach((c, i) => {
          c.core.classList.add('draw');
          // force reflow so the dashoffset transition runs
          // eslint-disable-next-line no-unused-expressions
          c.core.getBoundingClientRect();
          setTimeout(() => c.core.classList.add('connected'), 120 + i * 70);
        });
        setTimeout(() => { startSignal(); lightAllVU(); }, 120 + cables.length * 70 + 300);
      }
      built = true;
    }

    /* ----- VU meters ----- */
    let vuRAF = 0;
    function lightAllVU(){
      // animate module VU meters on a loop (capped, throttled)
      const meters = Array.from(document.querySelectorAll('[data-vu]')).map(m => ({
        el: m, bars: Array.from(m.querySelectorAll('i')), level: 0.5, target: 0.6
      }));
      const stripMeters = document.querySelectorAll('.strip .smeter');
      stripMeters.forEach((m, k) => {
        const bars = m.querySelectorAll('i');
        const lvl = [4,3,2,3,2,2][k] || 3;
        bars.forEach((b, i) => { if (i < lvl) b.classList.add('on'); });
      });
      if (RM){
        meters.forEach(mt => mt.bars.forEach((b, i) => { if (i < 5) b.classList.add('on'); if (i >= 7) {} }));
        return;
      }
      let last = 0;
      function tick(now){
        if (now - last > 90){ // ~11fps update for the meters (cheap), render stays 60fps
          last = now;
          meters.forEach(mt => {
            mt.target = 0.35 + Math.random() * 0.6;
            mt.level += (mt.target - mt.level) * 0.5;
            const n = Math.round(mt.level * mt.bars.length);
            mt.bars.forEach((b, i) => {
              b.classList.toggle('on', i < n);
              b.classList.toggle('hot', i >= mt.bars.length - 1 && i < n);
            });
          });
        }
        vuRAF = requestAnimationFrame(tick);
      }
      cancelAnimationFrame(vuRAF);
      vuRAF = requestAnimationFrame(tick);
    }

    /* ----- travelling signal pulses ----- */
    let pulseRAF = 0;
    const pulseEls = [];
    function startSignal(){
      if (RM) return;
      // one pulse element per cable, capped at the 8 routes
      cables.forEach((c) => {
        const p = document.createElementNS(SVG_NS, 'path');
        p.setAttribute('class', 'pulse' + (c.route.color === 'teal' ? ' teal' : ''));
        p.setAttribute('d', c.d);
        // dash trick: a short lit segment travelling along the path
        const seg = 26;
        p.style.strokeDasharray = `${seg} ${c.len}`;
        c.group.appendChild(p);
        pulseEls.push({ el: p, len: c.len, seg, phase: Math.random(), color: c.route.color });
      });
      const speed = 230; // px / sec
      let t0 = performance.now();
      function frame(now){
        const dt = (now - t0) / 1000; t0 = now;
        for (const pu of pulseEls){
          pu.phase += (speed * dt) / (pu.len + pu.seg);
          if (pu.phase > 1) pu.phase -= 1;
          const off = -pu.phase * (pu.len + pu.seg);
          pu.el.style.strokeDashoffset = off;
          // fade pulse in/out at the ends so it reads as a discrete packet
          const fade = Math.sin(pu.phase * Math.PI);
          pu.el.style.opacity = (0.35 + fade * 0.65).toFixed(2);
        }
        pulseRAF = requestAnimationFrame(frame);
      }
      cancelAnimationFrame(pulseRAF);
      pulseRAF = requestAnimationFrame(frame);
    }

    /* ----- hover: highlight the routed path through a module ----- */
    function highlight(nodeId, on){
      cables.forEach(c => {
        if (c.route.node === nodeId) c.group.classList.toggle('lit', on);
      });
      const node = document.getElementById('node-' + nodeId);
      if (node) node.classList.toggle('lit', on);
    }
    grid.querySelectorAll('.node.mod').forEach(node => {
      const id = node.getAttribute('data-node');
      node.addEventListener('pointerenter', () => highlight(id, true));
      node.addEventListener('pointerleave', () => highlight(id, false));
      node.addEventListener('focus', () => highlight(id, true));
      node.addEventListener('blur', () => highlight(id, false));
    });

    // build after fonts/layout settle, and rebuild on resize (debounced)
    function init(){ requestAnimationFrame(build); }
    if (document.readyState === 'complete') init();
    else window.addEventListener('load', init);
    // fallback in case load already fired
    setTimeout(() => { if (!built) build(); }, 400);

    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      cancelAnimationFrame(pulseRAF);
      cancelAnimationFrame(vuRAF);
      pulseEls.length = 0;
      rt = setTimeout(() => { built = false; build(); }, 200);
    });
  })();
</script>
</body>
</html>
