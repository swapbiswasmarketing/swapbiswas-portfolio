            </figure>
          </div>
        </div>
      </div>
    </header>
  </div>

  <div class="wrap">
    <section id="numbers">
      <div class="shead">
        <div><div class="idx">&mdash; 00 / Output</div><h2>What got built &amp; shipped</h2></div>
        <div class="meta">The leads sit in the headline -<br/>this is the body of work</div>
      </div>
      <div class="nums scene">
        {stats.map((s) => (
          <div class="plate flap fold-down open" data-fold>
