              </div>
              <div class="scrollcue"><span class="bar2"></span> Scroll to unfold</div>
            </div>
            <figure class="photo-card" aria-label="Portrait of Swapnil Biswas">
              <img src="/assets/portrait-cut.webp" alt="Swapnil Biswas" fetchpriority="high" decoding="async" />
