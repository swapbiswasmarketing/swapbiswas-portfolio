<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const root = document.documentElement;

  if (!RM) {
    // Turn the fold engine ON: this folds shut every .flap that doesn't have .open.
    // We immediately strip .open from off-screen flaps so they start folded, then the
    // IntersectionObserver re-adds .open to unfold them as they scroll into view.
    root.classList.add('folds');

    const flaps = Array.from(document.querySelectorAll('.flap'));

    // Fold shut everything except the hero (hero unfolds on load).
    flaps.forEach((el) => {
      if (el.id === 'heroFlap') return;          // hero stays queued to open on load
      el.classList.remove('open');
    });

    // Hero: crease into shape shortly after load.
    const hero = document.getElementById('heroFlap');
    if (hero) {
      hero.classList.remove('open');
      requestAnimationFrame(() => requestAnimationFrame(() => {
        setTimeout(() => hero.classList.add('open'), 90);
      }));
    }

    // SAFETY NET: if anything is still folded after 2.6s (observer never fired,
    // tab backgrounded, etc.), force everything open so no content stays hidden.
    const failSafe = setTimeout(() => {
      flaps.forEach((el) => el.classList.add('open'));
    }, 2600);

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const el = e.target;
          // stagger siblings within the same grid for a fold-out cascade
          const parent = el.parentElement;
          const sibs = parent ? Array.from(parent.children).filter((c) => c.classList.contains('flap')) : [el];
          const i = Math.max(0, sibs.indexOf(el));
          setTimeout(() => el.classList.add('open'), i * 110);
          io.unobserve(el);
        }
      });
    }, { threshold: 0.18, rootMargin: '0px 0px -8% 0px' });

    flaps.forEach((el) => {
      if (el.id === 'heroFlap') return;
      io.observe(el);
    });

    // Clear the fail-safe once everything is open (avoids a late forced reflow).
    const checkAll = setInterval(() => {
      if (flaps.every((el) => el.classList.contains('open'))) {
        clearTimeout(failSafe);
        clearInterval(checkAll);
      }
    }, 500);
  }
</script>
</body>
