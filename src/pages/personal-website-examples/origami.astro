    <section id="what">
      <div class="shead">
        <div><div class="idx">&mdash; 01 / Disciplines</div><h2>What I do</h2></div>
        <div class="meta">Four disciplines<br/>one operator</div>
      </div>
      <div class="flaps scene">
        {pillars.map((p, idx) => (
          <div class={'disc flap open ' + (idx % 2 === 0 ? 'fold-left' : 'fold-right')} data-fold>
