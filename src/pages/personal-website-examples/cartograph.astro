  <!-- station data for the script (kept in DOM to avoid templating into JS) -->
  <script type="application/json" id="stationData" set:html={JSON.stringify(stations)}></script>

<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- the map ---------- */
  (function cartograph(){
    const stage  = document.getElementById('stage');
    const svg    = document.getElementById('map');
    const layer  = document.getElementById('mapLayer');
    const gGrid  = document.getElementById('gGrid');
    const gCont  = document.getElementById('gContour');
    const gNodes = document.getElementById('gNodes');
    const routeDraw = document.getElementById('routeDraw');
    const popup  = document.getElementById('popup');
    if (!stage || !svg || !layer) return;

    const VB = { w: 1320, h: 760 };           // svg user space
    const stations = JSON.parse(document.getElementById('stationData').textContent);

    /* ----- build grid + contour lines (decorative cartography) ----- */
    const NS = 'http://www.w3.org/2000/svg';
    function line(x1,y1,x2,y2,cls){ const l=document.createElementNS(NS,'line'); l.setAttribute('x1',x1);l.setAttribute('y1',y1);l.setAttribute('x2',x2);l.setAttribute('y2',y2);l.setAttribute('class',cls);return l; }
    // longitude (vertical) every 120, latitude (horizontal) every 95, extend beyond viewbox for pan room
    for (let x = -240; x <= VB.w + 240; x += 120){
      const major = (x % 360 === 0);
      gGrid.appendChild(line(x, -240, x, VB.h + 240, 'gridline' + (major ? ' major' : '')));
    }
    for (let y = -240; y <= VB.h + 240; y += 95){
      const major = (y % 285 === 0);
      gGrid.appendChild(line(-240, y, VB.w + 240, y, 'gridline' + (major ? ' major' : '')));
    }
    // a couple of soft contour rings to read as terrain
    function contour(cx,cy,r){ const c=document.createElementNS(NS,'circle'); c.setAttribute('cx',cx);c.setAttribute('cy',cy);c.setAttribute('r',r);c.setAttribute('class','contour');return c; }
    [60,130,210,300].forEach(r => gCont.appendChild(contour(250, 250, r)));
    [50,120,200].forEach(r => gCont.appendChild(contour(1060, 560, r)));

    /* ----- build station nodes ----- */
    // label placement: alternate above/below to avoid the route line
    const nodeEls = {};
    stations.forEach((s, i) => {
      const g = document.createElementNS(NS,'g');
      g.setAttribute('class', 'node' + (s.cur ? ' cur' : ''));
      g.setAttribute('data-id', s.id);
      g.setAttribute('tabindex', '0');
      g.setAttribute('role', 'button');
      g.setAttribute('aria-label', s.t + ', ' + s.role + ', ' + s.y);
      const above = (i % 2 === 0);
      const labelY = above ? s.y2 - 30 : s.y2 + 40;
      const codeY  = above ? s.y2 - 48 : s.y2 + 22;

      // measure-free label background: estimate width from text length
      const tw = Math.max(s.t.length * 9 + 22, 70);
      const lblX = s.x - tw/2;

      g.innerHTML =
        `<circle class="halo" cx="${s.x}" cy="${s.y2}" r="26"></circle>` +
        (s.cur ? `<circle class="pulse" cx="${s.x}" cy="${s.y2}" r="9"></circle>` : '') +
        `<circle class="ring" cx="${s.x}" cy="${s.y2}" r="9"></circle>` +
        `<circle class="dot" cx="${s.x}" cy="${s.y2}" r="3.5"></circle>` +
        `<text class="code" x="${s.x}" y="${codeY}" text-anchor="middle">${s.code} &middot; ${s.y.replace(' - ','-')}</text>` +
        `<rect class="lblbg" x="${lblX}" y="${labelY - 15}" width="${tw}" height="22" rx="6"></rect>` +
        `<text class="lbl" x="${s.x}" y="${labelY}" text-anchor="middle">${s.t}</text>`;
      gNodes.appendChild(g);
      nodeEls[s.id] = g;

      const open = () => selectStation(s.id);
      g.addEventListener('click', (e) => { e.stopPropagation(); open(); });
      g.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' '){ e.preventDefault(); open(); } });
    });
    // re-append route on top of grid but BELOW nodes already handled by DOM order (nodes are last child)

    /* ----- route draw animation ----- */
    (function drawRoute(){
      let len = 0;
      try { len = routeDraw.getTotalLength(); } catch(e){ len = 2600; }
      if (RM || !len){ routeDraw.style.strokeDasharray = 'none'; routeDraw.style.strokeDashoffset = '0'; return; }
      routeDraw.style.strokeDasharray = len;
      routeDraw.style.strokeDashoffset = len;
      const dur = 2200; let t0 = 0; let started = false;
      function step(now){
        if (!t0) t0 = now;
        const p = Math.min(1, (now - t0) / dur);
        const eased = 1 - Math.pow(1 - p, 2.2);
        routeDraw.style.strokeDashoffset = String(len * (1 - eased));
        if (p < 1) requestAnimationFrame(step);
        else routeDraw.style.strokeDashoffset = '0'; // guarantee fully drawn
      }
      // start once the stage is in view (or immediately if already visible)
      const startIO = new IntersectionObserver((ents) => {
        ents.forEach(en => { if (en.isIntersecting && !started){ started = true; requestAnimationFrame(step); startIO.disconnect(); } });
      }, { threshold: 0.25 });
      startIO.observe(stage);
      // hard fallback: if observer never fires, finish the draw after 4s
      setTimeout(() => { if (!started){ started = true; routeDraw.style.strokeDashoffset = '0'; } }, 4000);
    })();

    /* ===================== PAN / ZOOM ===================== */
    // view = how svg user-space maps into the layer transform.
    // We translate+scale #mapLayer. Coordinates from pointer are converted to svg space.
    const MIN = 0.3, MAX = 3.2;
    let view = { x: 0, y: 0, k: 1 };          // current
    let target = { x: 0, y: 0, k: 1 };        // eased target
    let raf = 0;

    function clampPan(v){
      // Keep the populated band reachable. Work entirely in USER space (v.x/v.y are user units).
      // Viewport size in user units:
      const vpW = svg.clientWidth / pxPerUser || VB.w;
      const vpH = svg.clientHeight / pxPerUser || VB.h;
      // Generous slack so the clamp never fights a valid fit (which may legitimately shift the
      // band well to the right - e.g. to clear the desktop legend, or because slice-cropping on a
      // narrow viewport pushes content sideways). It still stops a drag from sailing into the void.
      const mX = 900; // horizontal user-space slack around the content
      const m  = 360; // vertical user-space slack
      // screen_x = v.x + v.k*content_x. Keep content x in [-mX, VB.w+mX] reachable within [0, vpW].
      const maxX = mX * v.k;
      const minX = vpW - (VB.w + mX) * v.k;
      const maxY = m * v.k;
      const minY = vpH - (VB.h + m) * v.k;
      v.x = Math.min(maxX, Math.max(minX, v.x));
      v.y = Math.min(maxY, Math.max(minY, v.y));
      return v;
    }
    // Like clampPan but trusts fitView's deliberate horizontal placement (which may legitimately
    // sit the band right of the legend): only the vertical axis is bounded here.
    function clampPanFit(v){
      const vpH = svg.clientHeight / pxPerUser || VB.h;
      const m = 360;
      const maxY = m * v.k;
      const minY = vpH - (VB.h + m) * v.k;
      v.y = Math.min(maxY, Math.max(minY, v.y));
      return v;
    }
    // svg client size in user units (because preserveAspectRatio slice): we need pixel<->user scale
    let pxPerUser = 1;
    function recalcScale(){
      // slice => scale = max(clientW/vbW, clientH/vbH); user units to px
      pxPerUser = Math.max(svg.clientWidth / VB.w, svg.clientHeight / VB.h);
    }
    // pointer (clientX/Y) -> viewBox-user coords (before #mapLayer transform), accounting for slice centering
    function clientToVbUser(clientX, clientY){
      const rect = svg.getBoundingClientRect();
      const offX = (rect.width  - VB.w * pxPerUser) / 2;
      const offY = (rect.height - VB.h * pxPerUser) / 2;
      return {
        ux: (clientX - rect.left - offX) / pxPerUser,
        uy: (clientY - rect.top  - offY) / pxPerUser
      };
    }

    function apply(){
      layer.setAttribute('transform', `translate(${view.x} ${view.y}) scale(${view.k})`);
    }
    function animate(){
      const ease = 0.18;
      view.x += (target.x - view.x) * ease;
      view.y += (target.y - view.y) * ease;
      view.k += (target.k - view.k) * ease;
      apply();
      repositionPopup();
      if (Math.abs(target.x-view.x) > .3 || Math.abs(target.y-view.y) > .3 || Math.abs(target.k-view.k) > .002){
        raf = requestAnimationFrame(animate);
      } else { view = {...target}; apply(); repositionPopup(); raf = 0; }
    }
    function kick(){ if (!raf) raf = requestAnimationFrame(animate); }

    function zoomAt(clientX, clientY, factor){
      recalcScale();
      const { ux, uy } = clientToVbUser(clientX, clientY);   // viewBox-user point under cursor
      // content coord currently under the cursor: content = (ux - target.x) / target.k
      const cx = (ux - target.x) / target.k;
      const cy = (uy - target.y) / target.k;
      const nk = Math.min(MAX, Math.max(MIN, target.k * factor));
      // solve so the same content point stays under the cursor at the new scale
      target.k = nk;
      target.x = ux - cx * nk;
      target.y = uy - cy * nk;
      clampPan(target);
      kick(); hideHint();
    }

    /* ----- wheel zoom (throttled by rAF via eased target) ----- */
    stage.addEventListener('wheel', (e) => {
      e.preventDefault();
      const factor = e.deltaY < 0 ? 1.12 : 1/1.12;
      zoomAt(e.clientX, e.clientY, factor);
    }, { passive: false });

    /* ----- drag to pan (pointer) ----- */
    let dragging = false, moved = false, lastX = 0, lastY = 0, pid = null;
    stage.addEventListener('pointerdown', (e) => {
      // never start a pan from an interactive overlay (legend, controls, popup, compass, scale bar)
      if (e.target.closest('.controls') || e.target.closest('.legend') || e.target.closest('.popup') ||
          e.target.closest('.compass') || e.target.closest('.scalebar')) return;
      dragging = true; moved = false; lastX = e.clientX; lastY = e.clientY; pid = e.pointerId;
      stage.classList.add('grabbing');
      try { stage.setPointerCapture(pid); } catch(_){}
    });
    stage.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - lastX, dy = e.clientY - lastY;
      if (Math.abs(dx) + Math.abs(dy) > 3) { moved = true; hideHint(); }
      lastX = e.clientX; lastY = e.clientY;
      target.x += dx / pxPerUser;
      target.y += dy / pxPerUser;
      clampPan(target);
      // when actively dragging, snap view to target for 1:1 feel
      view.x += dx / pxPerUser; view.y += dy / pxPerUser; clampPan(view);
      apply(); repositionPopup();
    });
    function endDrag(e){
      if (!dragging) return;
      dragging = false; stage.classList.remove('grabbing');
      try { stage.releasePointerCapture(pid); } catch(_){}
    }
    stage.addEventListener('pointerup', endDrag);
    stage.addEventListener('pointercancel', endDrag);
    // clicking empty map closes popup (only if it wasn't a drag)
    svg.addEventListener('click', (e) => {
      if (moved) return;
      if (!e.target.closest('.node')) closePopup();
    });

    /* ----- pinch zoom (two pointers) ----- */
    const pts = new Map();
    let pinchDist = 0;
    stage.addEventListener('pointerdown', (e) => { pts.set(e.pointerId, e); });
    stage.addEventListener('pointermove', (e) => {
      if (!pts.has(e.pointerId)) return;
      pts.set(e.pointerId, e);
      if (pts.size === 2){
        dragging = false; stage.classList.remove('grabbing');
        const [a,b] = [...pts.values()];
        const d = Math.hypot(a.clientX-b.clientX, a.clientY-b.clientY);
        const cx = (a.clientX+b.clientX)/2, cy = (a.clientY+b.clientY)/2;
        if (pinchDist){ zoomAt(cx, cy, d / pinchDist); }
        pinchDist = d;
      }
    });
    function dropPt(e){ pts.delete(e.pointerId); if (pts.size < 2) pinchDist = 0; }
    stage.addEventListener('pointerup', dropPt);
    stage.addEventListener('pointercancel', dropPt);

    /* ----- control buttons ----- */
    function centerClient(){ const r = svg.getBoundingClientRect(); return { x: r.left + r.width/2, y: r.top + r.height/2 }; }
    document.getElementById('zin').addEventListener('click', () => { const c=centerClient(); zoomAt(c.x,c.y,1.3); });
    document.getElementById('zout').addEventListener('click', () => { const c=centerClient(); zoomAt(c.x,c.y,1/1.3); });
    document.getElementById('zreset').addEventListener('click', () => { fitView(); closePopup(); });

    /* ----- fit the route comfortably in view on load / reset ----- */
    // Frame the WHOLE populated band (all six stations + their labels) inside the part of the
    // stage that is actually visible - i.e. to the RIGHT of the desktop legend overlay, and
    // shrunk enough that the full chronological route reads on narrow / mobile viewports too.
    function fitView(){
      recalcScale();
      const rect = svg.getBoundingClientRect();
      const offX = (rect.width  - VB.w * pxPerUser) / 2;
      const offY = (rect.height - VB.h * pxPerUser) / 2;
      // populated band in user space (nodes + halos + labels): x 90..1130, y 200..640
      const bx0 = 90, by0 = 200, bx1 = 1130, by1 = 640;
      const bw = bx1 - bx0, bh = by1 - by0;
      const bcx = (bx0 + bx1) / 2, bcy = (by0 + by1) / 2;

      // Available PIXEL rectangle inside the stage. On desktop the legend overlay covers the
      // left third, so the route must live to the right of it; reserve that width dynamically.
      const gap = 24;
      const leg = document.querySelector('.overlay.legend');
      let availL = 18, availR = rect.width - 18, availT = 18, availB = rect.height - 18;
      if (leg && getComputedStyle(leg).display !== 'none'){
        const lb = leg.getBoundingClientRect();
        availL = (lb.right - rect.left) + gap;   // start the route clear of the legend
        availT = 18; availB = rect.height - 64;  // leave room for the bottom map chrome
      }
      const availPxW = Math.max(120, availR - availL);
      const availPxH = Math.max(120, availB - availT);
      const availCyPx = availT + availPxH / 2;

      // scale so the band's pixel footprint (bw*k*pxPerUser) fits the available pixel box
      let k = Math.min(availPxW / (bw * pxPerUser), availPxH / (bh * pxPerUser), MAX);
      k = Math.max(MIN, k);

      // Horizontal placement. When the legend overlay is present we LEFT-align the band to the
      // available area so the first station (Samsung) always sits clear of the legend - even at
      // narrow widths where the band, at MIN scale, is wider than the gap to the right of it.
      // Otherwise centre it. (px = offX + (target.x + k*coord) * pxPerUser  ->  solve for target.x)
      const bandPxW = bw * k * pxPerUser;
      const targetLeftPx = (leg && getComputedStyle(leg).display !== 'none' && bandPxW > availPxW)
        ? availL                          // band too wide: pin its left edge just past the legend
        : availL + (availPxW - bandPxW) / 2; // otherwise centre within the available area
      target.k = k;
      target.x = (targetLeftPx - offX) / pxPerUser - k * bx0;
      target.y = (availCyPx - offY) / pxPerUser - k * bcy;
      clampPanFit(target);
      kick();
    }

    /* ===================== POPUP ===================== */
    let activeId = null;
    const stopBtns = document.querySelectorAll('.stop');

    function fillPopup(s){
      popup.classList.toggle('cur', !!s.cur);
      document.getElementById('pCode').textContent = s.code + ' · ' + (s.cur ? 'Current role' : 'Station');
      document.getElementById('pYr').textContent = s.y;
      document.getElementById('pTitle').textContent = s.t;
      document.getElementById('pRole').textContent = s.role;
      document.getElementById('pOut').textContent = s.out;
      document.getElementById('pDesc').textContent = s.d;
    }
    function selectStation(id){
      const s = stations.find(x => x.id === id);
      if (!s) return;
      activeId = id;
      fillPopup(s);
      // mark active states
      Object.values(nodeEls).forEach(n => n.classList.remove('active'));
      nodeEls[id]?.classList.add('active');
      stopBtns.forEach(b => b.classList.toggle('active', b.getAttribute('data-stop') === id));
      // ensure the station is comfortably in frame: pan toward it if near edge
      ensureVisible(s);
      popup.classList.add('open');
      repositionPopup();
      hideHint();
    }
    function closePopup(){
      activeId = null;
      popup.classList.remove('open');
      Object.values(nodeEls).forEach(n => n.classList.remove('active'));
      stopBtns.forEach(b => b.classList.remove('active'));
    }
    document.getElementById('pclose').addEventListener('click', closePopup);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePopup(); });

    // position the popup near the station's CURRENT screen position
    function stationScreen(s){
      const rect = svg.getBoundingClientRect();
      recalcScale();
      const offX = (rect.width - VB.w * pxPerUser) / 2;
      const offY = (rect.height - VB.h * pxPerUser) / 2;
      // user coord after layer transform:
      const ux = view.x + view.k * s.x;
      const uy = view.y + view.k * s.y2;
      // to px within svg viewport:
      const px = offX + ux * pxPerUser;
      const py = offY + uy * pxPerUser;
      return { px, py, rect };
    }
    function repositionPopup(){
      if (!activeId) return;
      const s = stations.find(x => x.id === activeId);
      if (!s) return;
      const { px, py, rect } = stationScreen(s);
      const pw = popup.offsetWidth || 280, ph = popup.offsetHeight || 200;
      const gap = 22; // node radius + space
      // default: popup above the node, centered
      let left = px - pw/2;
      let top = py - ph - gap;
      let flip = false;
      if (top < 8){ top = py + gap + 14; flip = true; } // not enough room above -> below
      // clamp horizontally within stage
      left = Math.min(rect.width - pw - 10, Math.max(10, left));
      // tip x relative to popup
      const tipx = Math.min(pw - 24, Math.max(16, px - left - 6));
      popup.style.left = left + 'px';
      popup.style.top = top + 'px';
      popup.style.setProperty('--tipx', tipx + 'px');
      popup.classList.toggle('flip', flip);
    }

    // pan so a selected station isn't jammed against an edge / behind the legend
    function ensureVisible(s){
      const rect = svg.getBoundingClientRect();
      recalcScale();
      const offX = (rect.width - VB.w * pxPerUser) / 2;
      const offY = (rect.height - VB.h * pxPerUser) / 2;
      const px = offX + (target.x + target.k * s.x) * pxPerUser;
      const py = offY + (target.y + target.k * s.y2) * pxPerUser;
      const legendW = (window.innerWidth > 820) ? 410 : 20;
      const padL = legendW, padR = 40, padT = 120, padB = 80;
      let dpx = 0, dpy = 0;
      if (px < padL) dpx = padL - px;
      else if (px > rect.width - padR) dpx = (rect.width - padR) - px;
      if (py < padT) dpy = padT - py;
      else if (py > rect.height - padB) dpy = (rect.height - padB) - py;
      if (dpx || dpy){
        target.x += dpx / pxPerUser;
        target.y += dpy / pxPerUser;
        clampPan(target);
        kick();
      }
    }

    stopBtns.forEach(b => b.addEventListener('click', () => selectStation(b.getAttribute('data-stop'))));

    /* ----- hint dismiss ----- */
    let hintGone = false;
    function hideHint(){ if (hintGone) return; hintGone = true; document.getElementById('maphint')?.classList.add('gone'); }
    setTimeout(hideHint, 6000);

    /* ----- init + resize ----- */
    function init(){ recalcScale(); fitView(); view = {...target}; apply(); }
    init();
    let rt;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => { recalcScale(); fitView(); repositionPopup(); }, 160); });
  })();
</script>
</body>
</html>
