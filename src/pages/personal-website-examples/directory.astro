<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  document.body.classList.remove('no-js');

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  setTimeout(() => document.body.classList.add('lit'), 80);

  /* ---------- build-stat count-up ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    if (Number.isNaN(target)) return;
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur = 1100; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.innerHTML = Math.round(target * eased) + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ countUp(e.target); numIO.unobserve(e.target); } });
  }, { threshold: 0.6 });
  document.querySelectorAll('.bs .v[data-target]').forEach(n => numIO.observe(n));

  /* ============ ELEVATOR ============ */
  const floorsEls = Array.from(document.querySelectorAll('.floor'));
  // map floor-number -> section element
  const byNum = new Map();
  floorsEls.forEach(f => byNum.set(parseInt(f.getAttribute('data-floor'), 10), f));
  const allNums = Array.from(byNum.keys()).sort((a,b) => a - b); // ascending
  const minF = allNums[0], maxF = allNums[allNums.length - 1];

  const cnum = document.getElementById('cnum');
  const cdir = document.getElementById('cdir');
  const counter = document.getElementById('counter');
  const fbtns = Array.from(document.querySelectorAll('.fbtn'));
  const boardRows = Array.from(document.querySelectorAll('.board-row'));
  const body = document.body;

  let current = 0;     // ground floor
  let riding = false;

  function label(n){ return n === 0 ? 'G' : String(n); }

  function setActive(n){
    current = n;
    fbtns.forEach(b => b.setAttribute('aria-current', String(parseInt(b.dataset.floor,10) === n)));
    boardRows.forEach(b => b.setAttribute('aria-current', String(parseInt(b.dataset.floor,10) === n)));
  }

  function scrollToFloor(n, behavior){
    const el = byNum.get(n);
    if (!el) return;
    el.scrollIntoView({ behavior: behavior || 'smooth', block: 'start' });
  }

  // Ride the elevator: tick the counter through intermediate floors, play doors, then arrive.
  function ride(target){
    if (target === current && !riding) { return; }
    const dest = byNum.has(target) ? target : current;

    if (RM){
      // reduced motion - instant, no counter spin, no doors
      setActive(dest);
      cnum.textContent = label(dest);
      scrollToFloor(dest, 'auto');
      byNum.get(dest)?.focus({ preventScroll: true });
      return;
    }

    if (riding) return;
    riding = true;
    const dir = dest > current ? 1 : (dest < current ? -1 : 0);
    cdir.className = 'dir ' + (dir > 0 ? 'up' : dir < 0 ? 'down' : '');
    cdir.innerHTML = dir > 0 ? '&#9650;' : dir < 0 ? '&#9660;' : '&#9679;';
    counter.classList.add('moving');

    // close doors over the stage
    body.classList.add('riding');
    setActive(dest);

    const distance = Math.abs(dest - current);
    const steps = [];
    let n = current;
    while (n !== dest){ n += dir; steps.push(n); }
    if (steps.length === 0) steps.push(dest);

    // counter spin timing: total ~ doors closing window
    const closeMs = 440;
    const perStep = Math.max(70, Math.min(170, closeMs / Math.max(1, steps.length)));
    let si = 0;
    function tick(){
      cnum.textContent = label(steps[si]);
      si++;
      if (si < steps.length){ setTimeout(tick, perStep); }
    }
    cnum.textContent = label(current);
    setTimeout(tick, 60);

    // once doors are closed, jump scroll instantly (hidden behind doors), then open
    setTimeout(() => {
      scrollToFloor(dest, 'auto');
      cnum.textContent = label(dest);
      body.classList.remove('riding');
      body.classList.add('arriving');
      counter.classList.remove('moving');
      const arr = byNum.get(dest);
      if (arr) arr.focus({ preventScroll: true });
      setTimeout(() => {
        body.classList.remove('arriving');
        cdir.className = 'dir';
        cdir.innerHTML = '&#9679;';
        riding = false;
      }, 520);
    }, closeMs + 30);
  }

  // wire elevator buttons + directory rows
  function bind(el){
    el.addEventListener('click', (ev) => {
      const t = parseInt(el.dataset.floor, 10);
      if (!Number.isNaN(t)) { ev.preventDefault(); ride(t); }
    });
  }
  fbtns.forEach(bind);
  boardRows.forEach(bind);

  // CTA anchor links + topbar nameplate -> use elevator ride
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (ev) => {
      const id = a.getAttribute('href').slice(1);
      const el = document.getElementById(id);
      if (!el) return;
      const n = parseInt(el.getAttribute('data-floor'), 10);
      if (Number.isNaN(n)) return;
      ev.preventDefault();
      ride(n);
    });
  });

  /* ---------- arrow-key navigation ---------- */
  window.addEventListener('keydown', (ev) => {
    if (ev.target && /^(INPUT|TEXTAREA|SELECT)$/.test(ev.target.tagName)) return;
    if (ev.key === 'ArrowUp' || ev.key === 'PageUp'){
      const next = current + 1;
      if (byNum.has(next)) { ev.preventDefault(); ride(next); }
    } else if (ev.key === 'ArrowDown' || ev.key === 'PageDown'){
      const prev = current - 1;
      if (byNum.has(prev)) { ev.preventDefault(); ride(prev); }
    }
  });

  /* ---------- keep counter + active state in sync with manual scroll ---------- */
  // (so trackpad / spacebar scrolling still updates the floor readout)
  let scrollLock = false;
  const floorIO = new IntersectionObserver((entries) => {
    if (riding) return;
    entries.forEach(e => {
      if (e.isIntersecting && e.intersectionRatio > 0.55){
        const n = parseInt(e.target.getAttribute('data-floor'), 10);
        if (!Number.isNaN(n) && n !== current){
          setActive(n);
          if (!RM) cnum.textContent = label(n);
        }
      }
    });
  }, { threshold: [0.55] });
  floorsEls.forEach(f => floorIO.observe(f));

  // initial readout
  cnum.textContent = 'G';
</script>
</body>
</html>
