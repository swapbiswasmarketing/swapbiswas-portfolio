<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- LED readout count-up (metrics) ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur = 1100; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(target * eased);
      el.innerHTML = val + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ countUp(e.target.querySelector('.read')); numIO.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('.cell').forEach(n => numIO.observe(n));

  /* ---------- Circuit: etch traces + route the signal pulse ---------- */
  (function circuit(){
    const svg = document.getElementById('schem');
    const board = document.getElementById('board');
    if (!svg || !board) return;

    const traces = Array.from(svg.querySelectorAll('.trace'));
    const pulses = Array.from(svg.querySelectorAll('.pulse'));
    const ledByIc = {}; // node index -> led element
    svg.querySelectorAll('.node[data-ic]').forEach(n => { ledByIc[n.getAttribute('data-ic')] = n.querySelector('.led'); });
    const outLed = document.getElementById('out-led');

    // measure each path so the dash math is exact (independent of viewport scale: SVG user units)
    const lenOf = {};
    traces.forEach(t => {
      const len = t.getTotalLength();
      lenOf[t.getAttribute('data-route')] = len;
      t.style.setProperty('--len', len);
    });
    pulses.forEach(p => {
      const r = p.getAttribute('data-pulse');
      const len = lenOf[r] != null ? lenOf[r] : p.getTotalLength();
      p.style.setProperty('--len', len);
    });

    // FINAL STATE GUARANTEE: if motion is reduced, everything is already drawn + lit via CSS.
    // For the animated path, we still force a connected final state in case the 'in' trigger
    // somehow never lands: a fallback timer flips traces to fully etched.
    function settleFinal(){
      traces.forEach(t => { t.style.strokeDashoffset = '0'; t.classList.add('lit'); });
      Object.values(ledByIc).forEach(l => l && l.classList.add('on'));
      if (outLed) outLed.classList.add('on');
    }

    if (RM){ settleFinal(); return; }

    // hover an IC card -> light its matching trace path on the schematic
    const traceForIc = {
      0: ['r1','r5','r7'], 1: ['r2','r6','r8'], 2: ['r3','r5','r7'], 3: ['r4','r6','r8'],
    };
    document.querySelectorAll('.ic').forEach((card, idx) => {
      card.addEventListener('pointerenter', () => {
        svg.classList.add('focus');                 // dim the whole board
        (traceForIc[idx] || []).forEach(r => {
          const t = traces.find(x => x.getAttribute('data-route') === r);
          if (t) t.classList.add('hl');             // brighten just this card's path
        });
        const led = ledByIc[idx]; if (led) led.classList.add('on');
      });
      card.addEventListener('pointerleave', () => {
        svg.classList.remove('focus');
        (traceForIc[idx] || []).forEach(r => {
          const t = traces.find(x => x.getAttribute('data-route') === r);
          if (t) t.classList.remove('hl');
        });
      });
    });

    // pulse sequence: input -> bus -> ICs (light LED) -> output (light OUT)
    function firePulse(route, dur, delay, onArrive){
      const p = pulses.find(x => x.getAttribute('data-pulse') === route);
      const t = traces.find(x => x.getAttribute('data-route') === route);
      setTimeout(() => {
        if (t){ t.classList.add('lit'); t.dataset.kept = '1'; }
        if (p){
          p.style.setProperty('--dur', dur + 'ms');
          // restart animation cleanly
          p.classList.remove('run'); void p.offsetWidth; p.classList.add('run');
        }
        if (onArrive) setTimeout(onArrive, dur * 0.78);
      }, delay);
    }

    let routed = false;
    function routeSignal(){
      if (routed) return; routed = true;
      // 1) input stub
      firePulse('r0', 420, 250);
      // 2) four bus arms reach the ICs, each lighting its LED on arrival
      const arms = [
        { r: 'r1', ic: 0 }, { r: 'r2', ic: 1 }, { r: 'r3', ic: 2 }, { r: 'r4', ic: 3 },
      ];
      arms.forEach((a, i) => {
        firePulse(a.r, 900, 650 + i * 130, () => {
          const led = ledByIc[a.ic]; if (led) led.classList.add('on');
        });
      });
      // 3) ICs feed the output chip
      firePulse('r5', 760, 1500);
      firePulse('r6', 760, 1620, () => { if (outLed) outLed.classList.add('on'); });
      // keep the static r7/r8 collector traces lit too
      ['r7','r8'].forEach(r => { const t = traces.find(x => x.getAttribute('data-route') === r); if (t){ t.classList.add('lit'); t.dataset.kept='1'; } });
    }

    // kick off when the board enters / on load. Add 'in' to start CSS trace-draw, then route the pulse.
    function start(){
      board.classList.add('in');           // CSS draws traces (stroke-dashoffset -> 0)
      setTimeout(routeSignal, 350);         // let etch begin, then send the signal
    }
    // start shortly after load (board is above the fold)
    requestAnimationFrame(() => requestAnimationFrame(start));

    // hard safety net: guarantee a connected, visible final state even if anything above stalls
    setTimeout(() => { if (!board.classList.contains('in')) board.classList.add('in'); settleFinal(); }, 4200);

    // re-run the routing once if the user scrolls back to the top after leaving (subtle, capped)
    let lastFire = performance.now();
    const reIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && performance.now() - lastFire > 6000){
          lastFire = performance.now();
          routed = false;
          // reset pulses only (traces stay etched/lit)
          pulses.forEach(p => p.classList.remove('run'));
          routeSignal();
        }
      });
    }, { threshold: 0.4 });
    reIO.observe(svg);
  })();
</script>
</body>
</html>
