  .work .wnote{margin-top:1rem;max-width:46ch;font-size:.92rem;line-height:1.6;color:var(--read);font-family:var(--sans)}
  @media(max-width:720px){.work .wnote{max-width:100%;font-size:.88rem}}
  /* ---- per-project noir compositions (each a DISTINCT monochrome crop) ---- */
  /* LambdaTest (feature) - a rising area chart in light grey climbing out of black */
  .art.ramp{background:
      linear-gradient(to top right,rgba(247,247,247,.30) 0%,rgba(247,247,247,0) 48%),
      repeating-linear-gradient(90deg,rgba(247,247,247,.06) 0 1px,transparent 1px 70px),
      repeating-linear-gradient(0deg,rgba(247,247,247,.05) 0 1px,transparent 1px 70px),
      linear-gradient(135deg,#1a1a1a,#000)}
  /* TestMu AI - identity morph: two overlapping light discs, one dissolving */
  .art.morph{background:
      radial-gradient(closest-side at 38% 50%,rgba(247,247,247,.5),transparent 70%),
      radial-gradient(closest-side at 62% 50%,rgba(247,247,247,.22),transparent 70%),
      conic-gradient(from 140deg at 50% 50%,rgba(247,247,247,.1),rgba(0,0,0,0),rgba(247,247,247,.1)),
      linear-gradient(135deg,#171717,#000)}
  /* Samsung - broadcast: concentric signal arcs from a corner */
  .art.arc{background:
      radial-gradient(closest-side at 84% 84%,transparent 26%,rgba(247,247,247,.5) 28%,transparent 32%),
      radial-gradient(closest-side at 84% 84%,transparent 46%,rgba(247,247,247,.34) 48%,transparent 52%),
      radial-gradient(closest-side at 84% 84%,transparent 66%,rgba(247,247,247,.2) 68%,transparent 72%),
      linear-gradient(135deg,#161616,#000)}
  /* Medilife - medical pulse: a thin cross of light on a clinical black field */
  .art.pulse{background:
      linear-gradient(0deg,rgba(247,247,247,.4) 0 2px,transparent 2px) 50% 50% / 58% 58% no-repeat,
      linear-gradient(90deg,rgba(247,247,247,.4) 0 2px,transparent 2px) 50% 50% / 58% 58% no-repeat,
      radial-gradient(58% 70% at 50% 50%,rgba(247,247,247,.12),transparent 64%),
      linear-gradient(135deg,#141414,#000)}
  /* Lido Learning - funnel: stacked narrowing bands feeding a point */
  .art.funnel{background:
      linear-gradient(180deg,rgba(247,247,247,.34) 0 14%,transparent 14%),
      linear-gradient(180deg,transparent 26%,rgba(247,247,247,.26) 26% 38%,transparent 38%),
      linear-gradient(180deg,transparent 50%,rgba(247,247,247,.18) 50% 60%,transparent 60%),
      radial-gradient(36% 30% at 50% 92%,rgba(247,247,247,.4),transparent 70%),
      linear-gradient(135deg,#161616,#000)}
  /* Appknox - shield bloom on deep field */
  .art.shield{background:
      radial-gradient(56% 70% at 50% 42%,rgba(247,247,247,.34),transparent 62%),
      radial-gradient(70% 80% at 50% 8%,rgba(247,247,247,.16),transparent 60%),
      linear-gradient(135deg,#151515,#000)}
  /* contained iconographic hints (top-right) for shield + pulse */
