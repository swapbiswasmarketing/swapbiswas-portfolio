<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  // ---- spotlight background: cursor-following soft light over deep black + grain ----
  // On small screens, mobile WebGL is unreliable; hide canvas, show CSS fallback.
  // rest position biased toward the RIGHT, away from the left-aligned hero text
  // column (and over the faint hero portrait), so the headline keeps its contrast.
  const spotMouse = { x: 0.72, y: 0.46, tx: 0.72, ty: 0.46 };
  (function(){
    const cv = document.getElementById('spot') as HTMLCanvasElement | null;
    const css = document.getElementById('cssSpot');
    if(!cv){ if(css) (css as HTMLElement).style.display='block'; return; }
    if(isMobile){
      cv.style.display = 'none';
      if(css) (css as HTMLElement).style.display = 'block';
      return;
    }
    const gl = cv.getContext('webgl', { antialias:true, alpha:true });
    if(!gl){
      if(css) (css as HTMLElement).style.display = 'block';
      return;
    }
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    // Raw GLSL noir spotlight: a soft radial light follows the mouse and reveals a
    // faint procedural texture/grain; darkness + heavy vignette everywhere else.
    const fs = `precision highp float;
    uniform vec2 r;uniform float t;uniform vec2 m;
    float h(vec2 x){return fract(sin(dot(x,vec2(127.1,311.7)))*43758.5453);}
    float n(vec2 x){vec2 i=floor(x),f=fract(x);float a=h(i),b=h(i+vec2(1,0)),c=h(i+vec2(0,1)),d=h(i+vec2(1,1));vec2 u=f*f*(3.-2.*f);return mix(a,b,u.x)+(c-a)*u.y*(1.-u.x)+(d-b)*u.x*u.y;}
    float fbm(vec2 x){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*n(x);x*=2.03;a*=.5;}return v;}
    void main(){
      vec2 uv=gl_FragCoord.xy/r.xy;
      vec2 asp=vec2(r.x/r.y,1.0);
      // mouse in same aspect-corrected space (m is 0..1, y already flipped on CPU)
      vec2 pm=m*asp;
      vec2 pp=uv*asp;
      float d=length(pp-pm);
      // soft spotlight cone - tight hot core, long falloff
      float spot=smoothstep(.62,.0,d);
      spot=pow(spot,1.7);
      // faint drifting texture only visible inside the light
      float tex=fbm(uv*5.0+vec2(t*.02,t*.015));
      float fine=fbm(uv*22.0-vec2(t*.04));
      float reveal=spot*(.55+.5*tex)+spot*spot*fine*.18;
      // a barely-there ambient wash up top so the frame is never pure void
      float amb=smoothstep(.85,.0,length((uv-vec2(.5,.30))*vec2(1.0,1.35)))*.06;
      float lum=reveal*0.9+amb;
      // deep cinematic vignette pulling corners to black
      float vig=smoothstep(1.25,.25,length(uv-vec2(.5,.45)));
      lum*=vig;
      // monochrome, very slight warm-cool tilt to feel like film stock (still grey)
      vec3 col=vec3(lum);
      col*=vec3(1.0,0.99,0.97);
      // gentle filmic toe
      col=col/(col+vec3(.32))*1.32;
      gl_FragColor=vec4(col,1.0);
    }`;
    function sh(ty:number,s:string){const o=gl.createShader(ty)!;gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram()!;gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t'),um=gl.getUniformLocation(pr,'m');
    function size(){const dp=Math.min(window.devicePixelRatio||1,1.6);cv.width=innerWidth*dp;cv.height=innerHeight*dp;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);}
    size();addEventListener('resize',size);
    // track the cursor; uv has y up, clientY has y down -> flip
    addEventListener('mousemove',(e:MouseEvent)=>{
      spotMouse.tx=e.clientX/innerWidth;
      spotMouse.ty=1-(e.clientY/innerHeight);
    });
    if(reduce){
      gl.uniform1f(ut,2.0);gl.uniform2f(um,0.72,0.54);gl.drawArrays(gl.TRIANGLES,0,3);return;
    }
    let start=performance.now();
    (function loop(now:number){
      // ease the light toward the cursor for that heavy, cinematic lag
      spotMouse.x+=(spotMouse.tx-spotMouse.x)*.07;
      spotMouse.y+=(spotMouse.ty-spotMouse.y)*.07;
      gl.uniform1f(ut,(now-start)/1000);
      gl.uniform2f(um,spotMouse.x,spotMouse.y);
      gl.drawArrays(gl.TRIANGLES,0,3);
      requestAnimationFrame(loop);
    })(start);

    // The bright cursor-spotlight is the HERO's signature only. Fade the canvas to a
    // near-dark state once scrolled past the hero, so the roaming light never washes
    // out the body text in the lower sections (What I do, Selected work, etc.).
    const heroEl=document.querySelector('header.hero') as HTMLElement|null;
    function spotFade(){
      const hb=heroEl?heroEl.offsetHeight:innerHeight;
      const p=Math.min(1,Math.max(0,(window.scrollY-hb*0.30)/(hb*0.45)));
      cv.style.opacity=String(1-p*0.92);
    }
    spotFade();
    addEventListener('scroll',spotFade,{passive:true});
  })();

  // ---- smooth scroll + reveals ----
  if(!reduce){
    const lenis=new Lenis({lerp:.1,smoothWheel:true});
    function raf(time:number){lenis.raf(time);requestAnimationFrame(raf);}requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll',ScrollTrigger.update);

    // SIGNATURE: letter-by-letter reveal of the Bodoni hero lines.
    document.querySelectorAll<HTMLElement>('.hero h1 .line-anim').forEach(line=>{
      const html=line.innerHTML;
      // wrap each visible character of text nodes in a .ch span, preserving <em>.
      const frag=document.createElement('span');
      frag.innerHTML=html;
      const wrapText=(node:ChildNode)=>{
        if(node.nodeType===3){
          const txt=node.textContent||'';
          const out=document.createDocumentFragment();
          for(const c of txt){
            if(c===' '){out.appendChild(document.createTextNode(' '));continue;}
            const s=document.createElement('span');s.className='ch';s.textContent=c;out.appendChild(s);
          }
          node.replaceWith(out);
        } else if(node.nodeType===1){
          Array.from(node.childNodes).forEach(wrapText);
        }
      };
      Array.from(frag.childNodes).forEach(wrapText);
      line.innerHTML='';
      line.append(...Array.from(frag.childNodes));
    });

    gsap.set('.hero h1 .ch',{yPercent:120,opacity:0});
    gsap.set('.hero .credential,.hero .sub,.hero .cta,.hero .heroanchor',{opacity:0,y:20});
    const tl=gsap.timeline({delay:.15});
    tl.to('.hero h1 .ch',{yPercent:0,opacity:1,duration:.9,ease:'expo.out',stagger:.028},.15)
      .to('.hero .heroportrait',{opacity:.85,duration:1.6,ease:'power2.out'},.2);
    // credential / sub / cta / anchor fade in via a single robust staggered tween.
    // (Folding these into the timeline's relative positions was leaving the sub
    // paragraph and the CTAs stuck at opacity:0 - i.e. invisible.)
    gsap.to('.hero .credential,.hero .sub,.hero .cta,.hero .heroanchor',
      {opacity:1,y:0,duration:.8,stagger:.12,delay:.5,ease:'power2.out',
       onComplete(){ gsap.set('.hero .credential,.hero .sub,.hero .cta,.hero .heroanchor',{clearProps:'opacity'}); }});

    // film-scene reveals: batches fade up from black together.
    ScrollTrigger.batch('.reveal',{
      start:'top 88%',
      onEnter:batch=>gsap.to(batch,{opacity:1,y:0,duration:1.05,ease:'expo.out',stagger:.09,overwrite:true}),
    });
    ScrollTrigger.refresh();

    // scroll progress
    const prog=document.getElementById('progress');
    if(prog) gsap.to(prog,{scaleX:1,ease:'none',scrollTrigger:{trigger:document.body,start:'top top',end:'bottom bottom',scrub:.3}});

    // statement marquee - continuous drift, nudged by scroll velocity
    const mq=document.getElementById('marquee');
    if(mq) gsap.to(mq,{xPercent:-50,duration:26,ease:'none',repeat:-1});

    // custom trailing cursor + magnetic CTA
    const cur=document.getElementById('cur')!;
    let cx=-100,cy=-100,tx=cx,ty=cy;
    addEventListener('mousemove',(e:MouseEvent)=>{tx=e.clientX;ty=e.clientY;});
    (function cloop(){cx+=(tx-cx)*.18;cy+=(ty-cy)*.18;cur.style.transform=`translate(${cx}px,${cy}px) translate(-50%,-50%)`;requestAnimationFrame(cloop);})();
    document.querySelectorAll('a,button').forEach(el=>{
      el.addEventListener('mouseenter',()=>cur.classList.add('big'));
      el.addEventListener('mouseleave',()=>cur.classList.remove('big'));
    });
    document.querySelectorAll<HTMLElement>('.btn.primary').forEach(btn=>{
      btn.addEventListener('mousemove',(e:MouseEvent)=>{const r=btn.getBoundingClientRect();gsap.to(btn,{x:(e.clientX-r.left-r.width/2)*.35,y:(e.clientY-r.top-r.height/2)*.45,duration:.4,ease:'power3.out'});});
      btn.addEventListener('mouseleave',()=>gsap.to(btn,{x:0,y:0,duration:.6,ease:'elastic.out(1,.4)'}));
    });

    // SIGNATURE at card scale: the white spotlight tracks the cursor across each case file.
    document.querySelectorAll<HTMLElement>('.work .row').forEach(card=>{
      card.addEventListener('mousemove',(e:MouseEvent)=>{
        const r=card.getBoundingClientRect();
        card.style.setProperty('--mx',`${((e.clientX-r.left)/r.width)*100}%`);
        card.style.setProperty('--my',`${((e.clientY-r.top)/r.height)*100}%`);
      });
    });
  }
</script>
</body>
</html>
