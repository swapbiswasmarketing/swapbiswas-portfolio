  /* ---- the maker: TRANSPARENT CUTOUT lit by a spotlight cone ---- */
  /* a subtly lighter backdrop panel sits behind the figure so the near-black suit
     separates from the card; no edge-masking needed - the source is a clean cut-out. */
  .about .maker{position:relative;border:1px solid var(--line);overflow:hidden;isolation:isolate;
