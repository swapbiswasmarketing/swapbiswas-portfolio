  .about .plate{position:relative;border:1px solid var(--line);
    padding:clamp(1.8rem,3vw,2.8rem);overflow:hidden;display:flex;align-items:center;min-height:100%;
    background:radial-gradient(80% 120% at 88% -10%,rgba(247,247,247,.06),transparent 60%),#040404}
  .about p{position:relative;z-index:1;font-family:var(--serif);font-weight:400;
    font-size:clamp(1.5rem,3.2vw,2.4rem);line-height:1.34;letter-spacing:-.01em;max-width:26ch}
  .about p em{font-style:italic}
  @media(max-width:960px){.about .abody{grid-template-columns:200px 1fr;grid-template-areas:"rail maker" "text text"}
    .about .rail{grid-area:rail}.about .maker{grid-area:maker;aspect-ratio:5/4}.about .plate{grid-area:text}}
  @media(max-width:720px){.about .abody{grid-template-columns:1fr;grid-template-areas:"maker" "rail" "text";gap:1.6rem}
    .about .maker{aspect-ratio:5/4;max-height:62vh}
    .about .rail{flex-direction:row;flex-wrap:wrap;align-items:center;gap:1rem 1.4rem;border-left:0;padding-left:0;
      border-top:1px solid var(--line);padding-top:1.4rem}
    .about .rail .div{display:none}
    .about .rail .sig{flex-basis:100%}}
  .about{padding-top:clamp(4.2rem,9vh,7.2rem);padding-bottom:clamp(4.2rem,9vh,7.2rem)}
  /* ---- contact ---- */
  .contact{text-align:center;padding-bottom:7rem}
  .contact .big{font-family:var(--serif);font-weight:500;font-size:clamp(2.8rem,9vw,8rem);line-height:1;letter-spacing:-.02em}
  .contact .big a{position:relative}
  .contact .big a em{font-style:italic}
  .contact .big a::after{content:"";position:absolute;left:0;bottom:.04em;width:100%;height:2px;background:var(--ink);transform:scaleX(0);transform-origin:left;transition:transform .5s cubic-bezier(.2,.8,.2,1)}
  .contact .big a:hover::after{transform:scaleX(1)}
  .contact .em{margin-top:2.6rem;font-family:var(--mono);font-size:.78rem;letter-spacing:.06em;color:var(--read)}
  .contact .em a{color:var(--ink);border-bottom:1px solid var(--line);padding-bottom:2px}
  footer{border-top:1px solid var(--line);padding:2.5rem var(--m);display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;
    font-family:var(--mono);font-size:.7rem;letter-spacing:.06em;color:var(--read);position:relative;z-index:2}
  footer a{color:var(--read)}
  footer a:hover{color:var(--ink)}
  footer .fid{display:inline-flex;align-items:center;gap:.7rem}
  footer .fav{width:26px;height:26px;border-radius:50%;flex:none;object-fit:cover;object-position:50% 22%;
    filter:grayscale(1) contrast(1.12) brightness(.95);box-shadow:inset 0 0 0 1px rgba(247,247,247,.4);
    -webkit-mask-image:radial-gradient(circle at 50% 42%,#000 56%,transparent 84%);
    mask-image:radial-gradient(circle at 50% 42%,#000 56%,transparent 84%)}
  /* film-scene reveal: fade up from black */
  .reveal{opacity:0;transform:translateY(26px)}
  @media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none}}
  /* craft details */
  .progress{position:fixed;top:0;left:0;height:2px;width:100%;transform:scaleX(0);transform-origin:left;z-index:30;
    background:var(--ink);mix-blend-mode:difference}
  .cur{position:fixed;top:0;left:0;width:34px;height:34px;border:1px solid rgba(247,247,247,.7);border-radius:50%;
    pointer-events:none;z-index:40;transform:translate(-50%,-50%);mix-blend-mode:difference;
    transition:width .35s cubic-bezier(.2,.8,.2,1),height .35s cubic-bezier(.2,.8,.2,1),background .3s;will-change:transform}
  .cur.big{width:74px;height:74px;background:rgba(247,247,247,.1)}
  @media(hover:none),(pointer:coarse){.cur{display:none}}
</style>
</head>
