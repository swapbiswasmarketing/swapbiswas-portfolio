<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ===================================================================
     1. STROKE-DRAWN HEADLINE - real Archivo <text>, fully legible.
        Outline pass strokes itself via stroke-dasharray/dashoffset (fixed
        large dash - getTotalLength is unreliable on <text>), then the solid
        fill pass fades in so the finished headline is crisp and readable.
        A red pen-tip rides the baseline left-to-right while the outline draws.
     =================================================================== */
  (function headline(){
    const svg = document.getElementById('heroline');
    if (!svg) return;
    const pen = document.getElementById('hlpen');

    if (RM){ svg.classList.add('drawn'); if (pen) pen.style.display = 'none'; return; }

    // pen-tip sweep across both lines (decorative): use the rendered bbox of
    // the two stroke <text> lines to drive a baseline marker during the draw.
    function ridePen(){
      if (!pen) return;
      const strokes = svg.querySelectorAll('.hl-stroke');
      let segs = [];
      try {
        strokes.forEach(t => {
          const b = t.getBBox();
          segs.push({ x0: b.x, x1: b.x + b.width, y: b.y + b.height - b.height*0.14 });
        });
      } catch(e){ return; }
      if (!segs.length) return;
      pen.classList.add('show');
      const dur = 1600, t0 = performance.now();
      function frame(now){
        const p = Math.min(1, (now - t0) / dur);
        // map progress across the two lines sequentially
        const total = segs.length;
        const scaled = p * total;
        const idx = Math.max(0, Math.min(total - 1, Math.floor(scaled)));
        const local = scaled - idx;
        const s = segs[idx];
        if (s){
          pen.setAttribute('cx', s.x0 + (s.x1 - s.x0) * local);
          pen.setAttribute('cy', s.y);
        }
        if (p < 1) requestAnimationFrame(frame);
        else pen.classList.remove('show');
      }
      requestAnimationFrame(frame);
    }

    // trigger draw shortly after the font is ready so metrics/bbox are stable
    function go(){
      svg.classList.add('drawn');
      requestAnimationFrame(ridePen);
    }
    if (document.fonts && document.fonts.ready){
      document.fonts.ready.then(()=> setTimeout(go, 120));
      // safety: fire even if the fonts promise stalls
      setTimeout(()=>{ if (!svg.classList.contains('drawn')) go(); }, 1200);
    } else {
      setTimeout(go, 200);
    }
  })();

  /* ===================================================================
     2. HERO FIGURE - continuous single-line plot.
        A noise-to-signal motif: line starts as low jitter on the left,
        organises into a rising signal, then sweeps up into a clean
        upward route on the right. One stroke. Pen-tip rides the path.
     =================================================================== */
  (function herofig(){
    const path = document.getElementById('figpath');
    const tip  = document.getElementById('pentip');
    if (!path) return;

    // Build a continuous path: left = settling noise, right = clean rise.
    // viewBox 300x360, baseline ~330, top ~30.
    const pts = [];
    const x0 = 30, x1 = 280, base = 318, top = 46;
    const N = 120;
    for (let i=0;i<=N;i++){
      const t = i/N;
      const x = x0 + (x1-x0)*t;
      // baseline trend rising as a smooth ease-in curve (the "signal/route")
      const trend = base - (base-top) * Math.pow(t, 1.7);
      // noise that decays as t increases (signal emerges from noise)
      const decay = Math.pow(1-t, 1.6);
      const noise = Math.sin(i*1.9)*9*decay + Math.sin(i*0.7+1.3)*6*decay + (Math.random()-0.5)*5*decay;
      const y = trend + noise;
      pts.push([x, Math.max(top-6, Math.min(base+12, y))]);
    }
    // smooth the path with simple Catmull-Rom -> cubic
    function toPath(p){
      let d = `M ${p[0][0].toFixed(1)} ${p[0][1].toFixed(1)}`;
      for (let i=0;i<p.length-1;i++){
        const p0 = p[i-1]||p[i], p1=p[i], p2=p[i+1], p3=p[i+2]||p[i+1];
        const c1x = p1[0] + (p2[0]-p0[0])/6, c1y = p1[1] + (p2[1]-p0[1])/6;
        const c2x = p2[0] - (p3[0]-p1[0])/6, c2y = p2[1] - (p3[1]-p1[1])/6;
        d += ` C ${c1x.toFixed(1)} ${c1y.toFixed(1)} ${c2x.toFixed(1)} ${c2y.toFixed(1)} ${p2[0].toFixed(1)} ${p2[1].toFixed(1)}`;
      }
      // small upward "arrowhead route" flourish at the end
      const last = p[p.length-1];
      d += ` M ${last[0].toFixed(1)} ${last[1].toFixed(1)} l -9 5 m 9 -5 l -4 -9`;
      return d;
    }
    path.setAttribute('d', toPath(pts));

    let L = 0;
    try { L = path.getTotalLength(); } catch(e){ L = 1400; }
    path.style.setProperty('--flen', L);

    if (RM){ path.style.strokeDashoffset = '0'; return; }

    // animate dashoffset L -> 0 with rAF; ride the pen tip along the path.
    let started = false;
    function run(){
      if (started) return; started = true;
      const dur = 2600; const t0 = performance.now();
      tip.classList.add('show');
      function frame(now){
        const p = Math.min(1, (now - t0)/dur);
        const eased = p; // linear keeps a constant plotter speed (satisfying)
        const off = L * (1 - eased);
        path.style.strokeDashoffset = off;
        // position pen tip at the currently-drawn frontier
        try {
          const pt = path.getPointAtLength(L * eased);
          tip.setAttribute('cx', pt.x); tip.setAttribute('cy', pt.y);
        } catch(e){}
        if (p < 1) requestAnimationFrame(frame);
        else { tip.classList.remove('show'); }
      }
      requestAnimationFrame(frame);
    }

    // draw when hero figure scrolls into view (and on load since it's above the fold)
    const io = new IntersectionObserver((es)=>{
      es.forEach(e=>{ if (e.isIntersecting){ run(); io.disconnect(); } });
    }, { threshold: 0.3 });
    io.observe(document.querySelector('.plate'));
    // safety: ensure fully drawn even if observer never fires
    setTimeout(()=>{ if (!started){ path.style.strokeDashoffset='0'; } }, 4000);

    // hover re-plot
    const plate = document.querySelector('.plate');
    plate.addEventListener('pointerenter', ()=>{
      if (RM) return;
      started = false;
      path.style.transition = 'none';
      path.style.strokeDashoffset = L;
      requestAnimationFrame(()=>requestAnimationFrame(run));
    });
  })();

  /* ===================================================================
     3. GROWTH CHART - plotted curve that draws itself on scroll-in.
        Endpoint dot + 18.2M / 657K callouts revealed after the draw.
     =================================================================== */
  (function growth(){
    const chart = document.getElementById('growthchart');
    const curve = document.getElementById('ccurve');
    const fill  = document.getElementById('cfill');
    if (!chart || !curve) return;

    // curve points within plot box x[40..440], y[40..200], rising to top-right.
    const cpts = [];
    const cx0=40, cx1=420, cyBase=190, cyTop=40, M=60;
    for (let i=0;i<=M;i++){
      const t=i/M;
      const x = cx0 + (cx1-cx0)*t;
      // S-ish exponential growth with a couple of realistic kinks
      const growth = Math.pow(t, 2.1);
      const wobble = Math.sin(t*9)*3*(1-t) + Math.sin(t*4+1)*4*(1-t*0.5);
      const y = cyBase - (cyBase-cyTop)*growth + wobble;
      cpts.push([x, Math.max(cyTop-2, Math.min(cyBase+4, y))]);
    }
    function toPath(p){
      let d = `M ${p[0][0].toFixed(1)} ${p[0][1].toFixed(1)}`;
      for (let i=0;i<p.length-1;i++){
        const p0=p[i-1]||p[i],p1=p[i],p2=p[i+1],p3=p[i+2]||p[i+1];
        const c1x=p1[0]+(p2[0]-p0[0])/6,c1y=p1[1]+(p2[1]-p0[1])/6;
        const c2x=p2[0]-(p3[0]-p1[0])/6,c2y=p2[1]-(p3[1]-p1[1])/6;
        d+=` C ${c1x.toFixed(1)} ${c1y.toFixed(1)} ${c2x.toFixed(1)} ${c2y.toFixed(1)} ${p2[0].toFixed(1)} ${p2[1].toFixed(1)}`;
      }
      return d;
    }
    const dCurve = toPath(cpts);
    curve.setAttribute('d', dCurve);
    // area fill closes down to baseline
    const last = cpts[cpts.length-1];
    fill.setAttribute('d', dCurve + ` L ${last[0].toFixed(1)} 190 L 40 190 Z`);

    let L=0; try{ L = curve.getTotalLength(); }catch(e){ L=900; }
    curve.style.setProperty('--clen', L);

    if (RM){ chart.classList.add('drawn'); return; }
    const io = new IntersectionObserver((es)=>{
      es.forEach(e=>{ if (e.isIntersecting){ chart.classList.add('drawn'); io.disconnect(); } });
    }, { threshold: 0.4 });
    io.observe(chart);
    setTimeout(()=>chart.classList.add('drawn'), 4500); // safety draw
  })();

  /* ===================================================================
     4. SECTION RULERS - the bottom rule of each section head plots itself.
     =================================================================== */
  (function rulers(){
    const heads = document.querySelectorAll('.shead[data-rule]');
    heads.forEach(h=>{
      const line = h.querySelector('.ruler line');
      if (!line) return;
      // measure rendered width to set dash length precisely
      function setLen(){
        let L=0; try{ L = line.getTotalLength(); }catch(e){ L = h.getBoundingClientRect().width; }
        L = Math.max(L, h.getBoundingClientRect().width, 100);
        line.style.setProperty('--rlen', L);
      }
      setLen();
      window.addEventListener('resize', setLen, { passive:true });
      if (RM){ h.classList.add('drawn'); return; }
    });
    if (RM) return;
    const io = new IntersectionObserver((es)=>{
      es.forEach(e=>{ if (e.isIntersecting){ e.target.classList.add('drawn'); io.unobserve(e.target); } });
    }, { threshold: 0.5 });
    heads.forEach(h=>io.observe(h));
    // safety
    setTimeout(()=>heads.forEach(h=>h.classList.add('drawn')), 5000);
  })();

  /* ===================================================================
     5. GENERIC REVEALS + stat count-up
     =================================================================== */
  const rio = new IntersectionObserver((es)=>{
    es.forEach(e=>{ if (e.isIntersecting){ e.target.classList.add('show'); rio.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el=>rio.observe(el));

  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'),10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur=1100, t0=performance.now();
    function step(now){
      const p=Math.min(1,(now-t0)/dur);
      const eased = 1 - Math.pow(1-p,3);
      el.innerHTML = Math.round(target*eased) + supHTML;
      if (p<1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const nio = new IntersectionObserver((es)=>{
    es.forEach(e=>{ if (e.isIntersecting){ countUp(e.target); nio.unobserve(e.target); } });
  }, { threshold: 0.6 });
  document.querySelectorAll('.statrow .sn').forEach(n=>nio.observe(n));
</script>
</body>
</html>
