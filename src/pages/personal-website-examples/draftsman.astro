  .foot-in{width:min(1240px,100%);margin:0 auto;padding:0 var(--m);display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;font-family:var(--mono);font-size:.68rem;letter-spacing:.05em;color:var(--faint);text-transform:uppercase}
  .foot-in a{color:var(--dim)}.foot-in a:hover{color:var(--ink)}

  /* reveals */
  .reveal{opacity:0;transform:translateY(18px);transition:opacity .7s cubic-bezier(.2,.8,.2,1),transform .7s cubic-bezier(.2,.8,.2,1)}
  .reveal.show{opacity:1;transform:none}

  @media(prefers-reduced-motion:reduce){
