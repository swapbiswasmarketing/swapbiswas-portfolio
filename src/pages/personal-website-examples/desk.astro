  .stamp .seal::after{content:"\2605";position:absolute;inset:0;display:grid;place-items:center;font-size:.78rem}
  .stamp b{font-family:var(--serif);font-weight:600;font-size:1.18rem;line-height:1.1;color:var(--ink);display:block}
  .stamp span{font-family:var(--mono);font-size:.66rem;letter-spacing:.05em;color:var(--dim);text-transform:uppercase}
  .brands .bl{font-family:var(--mono);font-size:.66rem;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);margin-bottom:1rem}
  .brands .bgrid{display:flex;flex-wrap:wrap;gap:.55rem}
  .brands .bgrid span{font-family:var(--mono);font-size:.76rem;border:1px solid var(--line);border-radius:999px;padding:.45rem .85rem;color:var(--ink2);background:var(--paper)}
  @media(max-width:720px){.honours{grid-template-columns:1fr}}

  /* ===== about ===== */
  .about{display:grid;grid-template-columns:260px 1fr;gap:clamp(1.8rem,5vw,3.4rem);align-items:start}
  .about-photo{position:relative;aspect-ratio:5/6;border-radius:10px;overflow:hidden;background:var(--paper2);
    border:8px solid #fff;box-shadow:var(--shadow);transform:rotate(-1.5deg)}
  .about-photo img{width:100%;height:100%;object-fit:cover;object-position:top center;filter:sepia(.12) contrast(1.03)}
  .about-lead{font-family:var(--serif);font-weight:500;font-size:clamp(1.25rem,2.6vw,1.8rem);line-height:1.28;color:var(--ink);margin-bottom:1.8rem}
  .facts{display:grid;grid-template-columns:repeat(2,1fr);gap:1.4rem 1.8rem}
  .fact .k{font-family:var(--mono);font-size:.64rem;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);margin-bottom:.35rem}
  .fact .v{color:var(--ink2);font-size:.95rem;line-height:1.45}
  @media(max-width:680px){.about{grid-template-columns:1fr}.about-photo{max-width:240px}.facts{grid-template-columns:1fr}}

  /* ===== contact ===== */
  .contact{border-top:1px solid var(--line)}
  .contact .cl{font-family:var(--mono);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--dim);margin-bottom:1rem}
  .contact .big{font-family:var(--serif);font-weight:600;font-size:clamp(2.6rem,9vw,6rem);line-height:1.0;letter-spacing:-.02em;color:var(--ink)}
  .contact .big a{display:inline-flex;align-items:flex-start;gap:.12em;transition:color .3s}
  .contact .big a:hover{color:var(--accent)}
  .contact .big a .ar{font-size:.36em;margin-top:.25em}
  .contact .em{margin-top:1.4rem;font-family:var(--mono);font-size:.82rem;letter-spacing:.02em;color:var(--dim)}
  .contact .em a{color:var(--ink);border-bottom:1px solid var(--hair)}

  /* footer */
  footer{border-top:1px solid var(--line);padding:2rem 0 2.8rem;position:relative;z-index:2}
  .foot-in{width:min(1180px,100%);margin:0 auto;padding:0 var(--pad);display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;
    font-family:var(--mono);font-size:.7rem;letter-spacing:.05em;color:var(--faint);text-transform:uppercase}
  .foot-in a{color:var(--dim)}.foot-in a:hover{color:var(--accent)}

  /* reveals */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .7s cubic-bezier(.2,.8,.2,1),transform .7s cubic-bezier(.2,.8,.2,1)}
  .reveal.show{opacity:1;transform:none}

  @media(prefers-reduced-motion:reduce){
    .reveal{opacity:1!important;transform:none!important;transition:none}
    .desk-hint .dot{animation:none}
    html{scroll-behavior:auto}
  }
</style>
