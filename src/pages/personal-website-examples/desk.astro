<script type="module">
  // Studio Desk physics. matter.js loaded via esm.sh ESM CDN (bare npm import would break in a module).
  // Mechanic: each .art element maps to a Matter rectangle body; on each frame we sync the body's
  // position+angle back to the element via transform. Bodies drop, settle, and are drag/throwable.
  // Guards: reduced-motion OR a failed import OR no container = keep the STATIC inline transforms (fallback).
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- scroll reveals (independent of physics) ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- physics hero ---------- */
  async function initDesk(){
    const mat = document.getElementById('deskmat');
    const hint = document.getElementById('deskHint');
    if (!mat) return;
    const arts = Array.from(mat.querySelectorAll('.art'));
    if (!arts.length) return;

    // MOBILE (<=760px): physics OFF. The CSS lays the hero out headline-first with a tidy static
    // artifact grid below, so nothing overlaps the headline. No dragging needed on small screens.
    const isMobile = () => window.matchMedia('(max-width: 760px)').matches;
    if (isMobile()){
      if (hint) hint.style.display = 'none';
      // if the user later rotates/resizes up to desktop, (re)initialise physics once
      const onUp = () => { if (!isMobile()){ window.removeEventListener('resize', onUp); initDesk(); } };
      window.addEventListener('resize', onUp);
      return;
    }

    // Reduced-motion: leave the tidy static arrangement already set via inline transforms. No physics.
    if (RM){ if (hint) hint.textContent = 'A tidy desk'; return; }

    let Matter;
    try {
      Matter = (await import('https://esm.sh/matter-js@0.19.0')).default;
    } catch (err){
      // Graceful fallback: matter.js failed to load -> artifacts stay in their static layout, fully readable.
      if (hint) hint.textContent = 'A tidy desk';
      return;
    }

    const { Engine, Runner, Bodies, Body, Composite, Mouse, MouseConstraint, Events } = Matter;

    function rect(){ return mat.getBoundingClientRect(); }
    let R = rect();
    const WALL = 200; // thickness so nothing can squeeze through at speed

    const engine = Engine.create();
    engine.gravity.y = 0.9; // a drop-in; ramped to ~0 after settle so the top-down desk stays flat
    const world = engine.world;

    // bounding walls = the desk container edges (floor, ceiling, both sides), kept just inside the mat
    let walls = [];
    function buildWalls(){
      Composite.remove(world, walls);
      const w = R.width, h = R.height;
      walls = [
        Bodies.rectangle(w/2, h + WALL/2, w + WALL*2, WALL, { isStatic:true }),      // floor
        Bodies.rectangle(w/2, -WALL/2, w + WALL*2, WALL, { isStatic:true }),         // ceiling
        Bodies.rectangle(-WALL/2, h/2, WALL, h + WALL*2, { isStatic:true }),         // left
        Bodies.rectangle(w + WALL/2, h/2, WALL, h + WALL*2, { isStatic:true }),      // right
      ];
      Composite.add(world, walls);
    }
    buildWalls();

    // The artifacts were art-directed for a ~1130px-wide mat. Scale their composed x into the real width
    // so the COMPOSITION holds (and never overlaps the left headline) at any size.
    const DESIGN_W = 1130;
    const sx = Math.min(1, R.width / DESIGN_W);

    // On narrow screens the headline stacks in normal flow at the TOP of the mat; push artifacts below it
    // so the physics never lands a piece on top of the headline text.
    const stacked = R.width <= 760;
    const headEl = mat.querySelector('.desk-head');
    const headBottom = stacked && headEl ? headEl.getBoundingClientRect().bottom - R.top + 18 : 0;
    // when stacked, lay the artifacts out in a simple band below the headline using the available height
    const bandTop = headBottom;
    const bandH = Math.max(160, R.height - bandTop - 16);

    // Map each artifact to a body. It spawns just ABOVE its composed RESTING spot (data-x/data-y = top-left)
    // with a tiny stagger, so the settled state is the art-directed desk - not a pile at the floor.
    const n = arts.length;
    const items = arts.map((el, i) => {
      const w = parseFloat(el.dataset.w) || el.offsetWidth || 120;
      const h = parseFloat(el.dataset.h) || el.offsetHeight || 80;
      const ang = (parseFloat(el.dataset.rot) || 0) * Math.PI/180;
      // composed rest CENTRE, scaled + clamped inside the mat
      let restX = (parseFloat(el.dataset.x) || (40 + i*90)) * sx + w/2;
      let restY = (parseFloat(el.dataset.y) || 120) + h/2;
      if (stacked){
        // re-flow into a tidy 2-column band beneath the headline
        const col = i % 2, rowN = Math.ceil(n / 2), row = Math.floor(i / 2);
        restX = (col === 0 ? R.width * 0.30 : R.width * 0.70);
        restY = bandTop + (bandH / (rowN + 0.4)) * (row + 0.6);
      }
      restX = Math.max(w/2 + 6, Math.min(R.width - w/2 - 6, restX));
      restY = Math.max(h/2 + 6, Math.min(R.height - h/2 - 6, restY));
      const isThin = h <= 30;            // pen + paperclip: lighter
      // short drop onto the spot: only ~60-120px up, lightly staggered -> quick, tidy settle
      const startY = restY - (70 + (i % 4) * 16);
      const body = Bodies.rectangle(restX, startY, w, h, {
        chamfer: { radius: Math.min(7, h/2 - 1) },
        restitution: isThin ? 0.08 : 0.14,   // low bounce so they land where placed
        friction: 0.7,
        frictionAir: 0.045,                  // high drag -> settles fast, doesn't slide into a pile
        density: isThin ? 0.0012 : 0.0022,
        angle: ang,
      });
      el.style.transform = '';                 // physics owns the transform from here
      el.style.left = '0px'; el.style.top = '0px';
      el.style.width = w + 'px'; el.style.height = h + 'px';
      return { el, body, w, h, restX, restY };
    });
    Composite.add(world, items.map(it => it.body));

    // mouse drag + throw, scoped to the mat
    const mouse = Mouse.create(mat);
    // do NOT capture wheel: let the page scroll normally over the desk
    mouse.element.removeEventListener('wheel', mouse.mousewheel);
    mouse.element.removeEventListener('DOMMouseScroll', mouse.mousewheel);
    const mc = MouseConstraint.create(engine, {
      mouse,
      constraint: { stiffness: 0.18, damping: 0.25, render: { visible:false } },
    });
    Composite.add(world, mc);
    let dragging = false;
    Events.on(mc, 'startdrag', () => { dragging = true; mat.classList.add('dragging'); if (hint) hint.style.opacity = '0'; });
    Events.on(mc, 'enddrag', () => { dragging = false; mat.classList.remove('dragging'); });

    // clamp: if anything escapes the mat (e.g. a hard throw), pull it back inside so it can't cause scrollbars
    function clamp(){
      for (const it of items){
        const b = it.body; const half = Math.max(it.w, it.h)/2;
        let { x, y } = b.position;
        const minX = half, maxX = R.width - half, minY = -40, maxY = R.height - it.h/2 + 4;
        let corrected = false;
        if (x < minX){ x = minX; corrected = true; } else if (x > maxX){ x = maxX; corrected = true; }
        if (y > maxY){ y = maxY; corrected = true; }
        if (y < minY - 400){ y = minY; corrected = true; }   // flung way up
        if (corrected){ Body.setPosition(b, { x, y }); Body.setVelocity(b, { x: b.velocity.x*0.3, y: 0 }); }
        // hard cap velocity to keep things tame + on-screen
        const vmax = 26;
        const sp = Math.hypot(b.velocity.x, b.velocity.y);
        if (sp > vmax){ const k = vmax/sp; Body.setVelocity(b, { x: b.velocity.x*k, y: b.velocity.y*k }); }
      }
    }

    // sync bodies -> DOM each frame
    function sync(){
      for (const it of items){
        const { x, y } = it.body.position;
        it.el.style.transform = `translate(${x - it.w/2}px, ${y - it.h/2}px) rotate(${it.body.angle}rad)`;
      }
    }
    // The desk is a TOP-DOWN surface: gravity gives a satisfying drop-in, then fades to ~0 so pieces
    // lie flat where they settle (no bottom pile). They stay fully draggable + throwable with inertia.
    const t0 = performance.now();
    Events.on(engine, 'beforeUpdate', () => {
      const t = performance.now() - t0;
      // ramp gravity 0.9 -> 0 between 1.1s and 2.0s after load
      engine.gravity.y = t < 1100 ? 0.9 : Math.max(0, 0.9 * (1 - (t - 1100) / 900));
      // once flat, very gently draw any RESTING, untouched piece back toward its composed home
      if (t > 2000 && !dragging){
        for (const it of items){
          const b = it.body;
          if (b === mc.body) continue;                 // skip the grabbed body
          const sp = Math.hypot(b.velocity.x, b.velocity.y);
          if (sp > 1.2) continue;                       // leave moving/thrown pieces alone
          const dx = it.restX - b.position.x, dy = it.restY - b.position.y;
          if (Math.hypot(dx, dy) < 6) continue;
          Body.applyForce(b, b.position, { x: dx * 6e-6 * b.mass, y: dy * 6e-6 * b.mass });
        }
      }
    });
    Events.on(engine, 'afterUpdate', () => { clamp(); sync(); });

    const runner = Runner.create();
    Runner.run(runner, engine);

    // hide the hint after things settle
    setTimeout(() => { if (hint && hint.style.opacity !== '0') hint.style.transition = 'opacity .6s'; }, 100);
    setTimeout(() => { if (hint) hint.style.opacity = '0.0'; }, 6000);

    // keep walls + clamp bounds correct on resize (debounced)
    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => {
        R = rect();
        buildWalls();
        // nudge any out-of-bounds piece back in
        for (const it of items){
          const half = Math.max(it.w, it.h)/2;
          const x = Math.max(half, Math.min(R.width - half, it.body.position.x));
          const y = Math.min(R.height - it.h/2 + 4, it.body.position.y);
          Body.setPosition(it.body, { x, y });
        }
      }, 200);
    });

    // pause the runner when the desk is fully scrolled out of view (perf)
    const vis = new IntersectionObserver((es) => {
      es.forEach(e => { if (e.isIntersecting) Runner.run(runner, engine); else Runner.stop(runner); });
    }, { threshold: 0 });
    vis.observe(mat);
  }

  initDesk();
</script>
</body>
</html>
