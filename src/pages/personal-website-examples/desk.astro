  @media(max-width:760px){.works{grid-template-columns:1fr}.w.feat{grid-template-columns:1fr}.w.feat .fright{border-left:0;border-top:1px solid var(--line);padding-left:0;padding-top:1.3rem}}

  /* ===== recognition + brands ===== */
  .honours{display:grid;grid-template-columns:1.3fr 1fr;gap:clamp(1.6rem,4vw,3rem)}
  .stamps{display:flex;flex-direction:column}
