</main>

<footer>
  <span>&copy; 2026 Swapnil Biswas</span>
  <span>Concept 04 - Brut / <a href="/redesign/">View all concepts</a></span>
</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- custom cursor ----
  (function(){
    const cur = document.getElementById('cursor');
    if(!cur || window.matchMedia('(pointer:coarse)').matches) return;
    let x = innerWidth/2, y = innerHeight/2, tx = x, ty = y;
    addEventListener('mousemove', e => { tx = e.clientX; ty = e.clientY; });
    document.querySelectorAll('a,button,.stat,.pillar,.brands span.b').forEach(el => {
      el.addEventListener('mouseenter', () => cur.classList.add('big'));
      el.addEventListener('mouseleave', () => cur.classList.remove('big'));
    });
    // signature: work cards get the labelled "OPEN" cursor instead of the plain big disc
    document.querySelectorAll('.work a').forEach(el => {
      el.addEventListener('mouseenter', () => cur.classList.add('view'));
      el.addEventListener('mouseleave', () => cur.classList.remove('view'));
    });
    (function follow(){
      x += (tx - x) * 0.22; y += (ty - y) * 0.22;
      cur.style.transform = `translate(${x}px,${y}px) translate(-50%,-50%)`;
      requestAnimationFrame(follow);
    })();
  })();

  // ---- WebGL cursor-reactive halftone / dither distortion ----
  (function(){
    const cv = document.getElementById('gl');
    if(!cv) return;
    const gl = cv.getContext('webgl', { antialias:true, alpha:false });
    if(!gl){ return; } // CSS conic-gradient fallback already on the canvas
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs = `precision highp float;
    uniform vec2 r; uniform float t; uniform vec2 mo;
    float hash(vec2 x){return fract(sin(dot(x,vec2(127.1,311.7)))*43758.5453);}
    void main(){
      vec2 uv = gl_FragCoord.xy / r.xy;
      vec2 asp = vec2(r.x/r.y, 1.0);
      vec2 p = uv * asp;
      // OFF-CENTER anchor: bottom-right, so it supports the asymmetric grid
      vec2 anchor = vec2(0.80, 0.18) * asp;
      // mouse drives the warp so it reads as interactive
      vec2 mp = mo * asp;
      vec2 d = p - anchor;
      float dist = length(d);
      // soft mask: presence falls off toward the top-left, keeping type area clean
      float mask = smoothstep(1.05, 0.18, dist);
      // mouse-tied displacement (warp swells toward the cursor)
      vec2 dm = p - mp;
      float distm = length(dm);
      float pull = 0.14 / (distm*distm + 0.05);
      pull = min(pull, 1.4);
      vec2 warp = p - normalize(dm + 1e-4) * pull * 0.08;
      warp += 0.010 * vec2(sin(warp.y*8.0 + t*0.5), cos(warp.x*8.0 + t*0.45));
      // halftone dot grid radiating from the anchor
      float cells = 30.0;
      vec2 g = warp * cells;
      vec2 cell = floor(g);
      vec2 f = fract(g) - 0.5;
      float ripple = sin(dist*20.0 - t*1.2) * 0.5 + 0.5;
      float field = hash(cell) * 0.55 + ripple * 0.45 + sin(warp.x*4.0 + t*0.3)*0.2;
      float radius = clamp(field, 0.05, 0.60) * mask;
      float halftone = smoothstep(radius, radius - 0.06, length(f));
      // MONOCHROME ink dots on flat paper
      vec3 paper = vec3(0.914, 0.902, 0.867);
      vec3 ink   = vec3(0.106, 0.106, 0.106);
      vec3 blue  = vec3(0.231, 0.298, 1.0);
      vec3 dotcol = ink;
      // electric-blue ONLY as a sparing highlight near the mouse
      float hl = smoothstep(0.18, 0.0, distm) * step(0.55, field);
      dotcol = mix(dotcol, blue, hl);
      vec3 col = mix(paper, dotcol, halftone);
      gl_FragColor = vec4(col, 1.0);
    }`;
    function sh(ty,s){const o=gl.createShader(ty);gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram();
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));
    gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));
    gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t'),um=gl.getUniformLocation(pr,'mo');
    let mx=0.5,my=0.5,tmx=0.5,tmy=0.5;
    function size(){
      const d=Math.min(window.devicePixelRatio||1,1.6);
      const w=cv.clientWidth||innerWidth, h=cv.clientHeight||innerHeight;
      cv.width=Math.max(1,w*d);cv.height=Math.max(1,h*d);
      gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);
    }
    size();addEventListener('resize',size);
    const rect = () => cv.getBoundingClientRect();
    addEventListener('mousemove', e => {
      const b = rect();
      tmx = (e.clientX - b.left) / b.width;
      tmy = 1.0 - (e.clientY - b.top) / b.height;
    });
    if(reduce){ gl.uniform1f(ut,2.0); gl.uniform2f(um,0.5,0.5); gl.drawArrays(gl.TRIANGLES,0,3); return; }
    const start=performance.now();
    (function loop(now){
      mx += (tmx-mx)*0.08; my += (tmy-my)*0.08;
      gl.uniform1f(ut,(now-start)/1000);
      gl.uniform2f(um,mx,my);
      gl.drawArrays(gl.TRIANGLES,0,3);
      requestAnimationFrame(loop);
    })(start);
  })();

  // ---- smooth scroll + reveals + marquee skew ----
  if(!reduce){
    const lenis=new Lenis({lerp:.1,smoothWheel:true});
    function raf(t){lenis.raf(t);requestAnimationFrame(raf);}requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll',ScrollTrigger.update);

    // hero lines
    gsap.set('.hero h1 .ln>span',{yPercent:120});
    gsap.set('.hero .tag,.hero .sub,.hero .cta',{opacity:0,y:24});
    const tl=gsap.timeline({delay:.12});
    tl.to('.hero h1 .ln>span',{yPercent:0,duration:1.0,ease:'expo.out',stagger:.1})
      .to('.hero .tag',{opacity:1,y:0,duration:.6},.15)
      .to('.hero .sub',{opacity:1,y:0,duration:.7},.45)
      .to('.hero .cta',{opacity:1,y:0,duration:.7},.6);

    // batched, staggered reveals: siblings that enter together animate as one choreographed
    // run (grid rows ripple in) instead of each firing independently. Safety net below guarantees
    // every .reveal ends at opacity:1 even if a trigger never fires.
    ScrollTrigger.batch('.reveal',{
      start:'top 88%',
      onEnter: batch => gsap.to(batch,{opacity:1,y:0,duration:.85,ease:'expo.out',stagger:.08,overwrite:true})
    });
    // guarantee: anything still hidden after a beat (e.g. already in view, odd layout) is shown.
    ScrollTrigger.addEventListener('refresh', () => {
      gsap.utils.toArray('.reveal').forEach(el=>{
        const r = el.getBoundingClientRect();
        if(r.top < innerHeight && getComputedStyle(el).opacity === '0'){
          gsap.set(el,{opacity:1,y:0});
        }
      });
    });

    // scroll-velocity skew on the marquee
    const track = document.querySelector('#marquee .track');
    if(track){
      let skew = 0;
      lenis.on('scroll', ({velocity}) => {
        const v = Math.max(-12, Math.min(12, (velocity||0) * 0.35));
        skew += (v - skew) * 0.5;
        gsap.set(track,{skewX:skew*0.3});
      });
      // ease back toward 0 each frame
      gsap.ticker.add(() => { skew += (0 - skew) * 0.06; gsap.set(track,{skewX:skew*0.3}); });
    }
  }
</script>
</body>
</html>
