---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const title = "Free Product One-Pager Template | Build a Polished Product One-Pager in 5 Minutes";
const description = "Free product one-pager template. Capture the product, problem, solution, differentiators, use cases, proof, and CTA on a polished one-page PNG. No signup.";

const faqs = [
	{
		question: "What is a product one-pager?",
		answer: "A product one-pager is a single-page document that summarizes a product: what it is, who it's for, the problem it solves, the differentiators, key use cases, social proof, and the next step. It's the artifact PMMs use to align sales, partners, investors, and execs in 60 seconds of reading.",
	},
	{
		question: "How do I use this product one-pager template?",
		answer: "Fill in the product basics (name, tagline), the problem and audience, the solution and 3 key features, 3 reasons you win, 3 use cases or buyer personas, a customer proof block, and a call to action. The preview updates as you type. Click Download PNG when you're done.",
	},
	{
		question: "Is this product one-pager template free?",
		answer: "Yes, completely free. No signup, no email gate, no watermark on the download. The template runs entirely in your browser - your inputs never leave your device.",
	},
	{
		question: "What format does the one-pager download in?",
		answer: "The generator exports a high-resolution PNG (1000px wide, rendered at 2x device pixel ratio for retina displays) plus an optional US Letter PDF. Both work for Notion, Slides, Asana, sales decks, or as a printed leave-behind.",
	},
	{
		question: "What's the difference between a product one-pager and a sales battlecard?",
		answer: "A product one-pager is positioning-led - it explains what the product is and why it matters. A battlecard is comparison-led - it equips reps to win against specific competitors. Build the one-pager first; the battlecard borrows your positioning from it.",
	},
	{
		question: "Who is a product one-pager for?",
		answer: "Three audiences: (1) Internal sales and CS teams who need a single source of truth for product positioning. (2) Partners, analysts, and press who want a quick orientation. (3) Investors and prospective buyers who decide in 60 seconds whether to take a deeper meeting.",
	},
	{
		question: "How often should I update the product one-pager?",
		answer: "Every quarter at minimum, and after every major launch or repositioning. If your homepage hero has changed, your one-pager probably needs to change too. Date the version in the footer so reps know they're using the current copy.",
	},
];

const softwareSchema = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	"name": "Product One-Pager Template",
	"description": description,
	"url": "https://swapbiswas.com/tools/product-one-pager-template/",
	"applicationCategory": "BusinessApplication",
	"operatingSystem": "Any",
	"browserRequirements": "Requires JavaScript",
	"offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
	"creator": { "@type": "Person", "name": "Swapnil Biswas", "url": "https://swapbiswas.com/" }
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map((faq) => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": { "@type": "Answer", "text": faq.answer }
	}))
};
---

<BaseLayout
	title={title}
	description={description}
	breadcrumbs={[{ name: "Tools", url: "/tools/" }, { name: "Product One-Pager Template" }]}
>
	<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} slot="head" />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />

	<div class="stack gap-20">
		<main class="wrapper tool-page">
			<Hero
				title="Free Product One-Pager Template"
				tagline="Build a polished product one-pager in 5 minutes. Positioning, problem, solution, differentiators, proof, CTA. No signup. Download as PNG."
				align="start"
			/>

			<div class="tool-grid">
				<!-- FORM -->
				<section class="form-panel" aria-label="One-pager inputs">
					<form id="onepager-form" autocomplete="off">
						<fieldset>
							<legend>1. Product basics</legend>
							<div class="field-row">
								<div class="field">
									<label for="op-product">Product name</label>
									<input type="text" id="op-product" maxlength="50" placeholder="e.g., Acme Insights" />
								</div>
								<div class="field">
									<label for="op-category">Category</label>
									<input type="text" id="op-category" maxlength="40" placeholder="e.g., Revenue attribution platform" />
								</div>
							</div>
							<div class="field">
								<label for="op-tagline">One-line tagline</label>
								<input type="text" id="op-tagline" maxlength="140" placeholder="e.g., Attribute pipeline to channel in under 45 days" />
							</div>
						</fieldset>

						<fieldset>
							<legend>2. Problem & audience</legend>
							<div class="field">
								<label for="op-audience">Who it's for</label>
								<input type="text" id="op-audience" maxlength="100" placeholder="e.g., B2B SaaS demand gen leaders" />
							</div>
							<div class="field">
								<label for="op-problem">The problem you solve</label>
								<input type="text" id="op-problem" maxlength="180" placeholder="e.g., Demand teams can't tie pipeline to specific channels, so they over-spend on the wrong ones" />
							</div>
						</fieldset>

						<fieldset data-section-card="op-solution-card">
							<legend>3. Solution & key features<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="op-solution-card" checked /><span class="section-toggle-track"></span></label></legend>
							<div class="field">
								<label for="op-solution">Solution in one sentence</label>
								<input type="text" id="op-solution" maxlength="180" placeholder="e.g., A no-code attribution engine that maps every deal back to the first-touch channel" />
							</div>
							<div class="field"><input type="text" id="op-feature-1" maxlength="80" placeholder="Key feature 1: e.g., First and last-touch attribution" /></div>
							<div class="field"><input type="text" id="op-feature-2" maxlength="80" placeholder="Key feature 2: e.g., Multi-touch journey replay" /></div>
							<div class="field"><input type="text" id="op-feature-3" maxlength="80" placeholder="Key feature 3: e.g., 60+ native integrations" /></div>
						</fieldset>

						<fieldset data-section-card="op-diff-card">
							<legend>4. Why customers choose us (3)<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="op-diff-card" checked /><span class="section-toggle-track"></span></label></legend>
							<div class="field"><input type="text" id="op-diff-1" maxlength="120" placeholder="Differentiator 1: e.g., 45-day implementation vs 6 months with the legacy vendor" /></div>
							<div class="field"><input type="text" id="op-diff-2" maxlength="120" placeholder="Differentiator 2: e.g., No engineering required to set up new channels" /></div>
							<div class="field"><input type="text" id="op-diff-3" maxlength="120" placeholder="Differentiator 3: e.g., Built by ex-Salesforce data engineers" /></div>
						</fieldset>

						<fieldset data-section-card="op-usecase-card">
							<legend>5. Use cases (3)<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="op-usecase-card" checked /><span class="section-toggle-track"></span></label></legend>
							<div class="field"><input type="text" id="op-usecase-1" maxlength="110" placeholder="Use case 1: e.g., Quarterly board reporting on channel ROI" /></div>
							<div class="field"><input type="text" id="op-usecase-2" maxlength="110" placeholder="Use case 2: e.g., Budget reallocation across paid + organic" /></div>
							<div class="field"><input type="text" id="op-usecase-3" maxlength="110" placeholder="Use case 3: e.g., Sales-marketing alignment on lead quality" /></div>
						</fieldset>

						<fieldset data-section-card="op-proof-card">
							<legend>6. Proof<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="op-proof-card" checked /><span class="section-toggle-track"></span></label></legend>
							<div class="field-row">
								<div class="field">
									<label for="op-proof-stat">Hero stat</label>
									<input type="text" id="op-proof-stat" maxlength="30" placeholder="e.g., 3.4x" />
								</div>
								<div class="field">
									<label for="op-proof-stat-label">Stat label</label>
									<input type="text" id="op-proof-stat-label" maxlength="60" placeholder="e.g., faster pipeline reporting" />
								</div>
							</div>
							<div class="field">
								<label for="op-proof-logos">Customer logos / names (text)</label>
								<input type="text" id="op-proof-logos" maxlength="120" placeholder="e.g., NorthWind Labs, BrightOps, FieldKit, Latitude" />
							</div>
							<div class="field">
								<label for="op-proof-quote">Customer quote (one line)</label>
								<input type="text" id="op-proof-quote" maxlength="160" placeholder="e.g., We cut attribution work from 3 days to 30 minutes." />
							</div>
							<div class="field">
								<label for="op-proof-author">Quote attribution</label>
								<input type="text" id="op-proof-author" maxlength="80" placeholder="e.g., Alex M., VP Marketing at NorthWind Labs" />
							</div>
						</fieldset>

						<fieldset data-section-card="op-cta-card">
							<legend>7. Next step<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="op-cta-card" checked /><span class="section-toggle-track"></span></label></legend>
