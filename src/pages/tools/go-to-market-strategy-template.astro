			<!-- Newsletter -->
			<section class="tool-cta-strip">
				<div class="cta-text">
					<strong>Want more PMM tools and templates?</strong>
					<p>Join the newsletter. Positioning, launch playbooks, persona updates - no spam, just value.</p>
				</div>
