							<div class="field"><input type="text" id="gtm-channel-3" maxlength="80" placeholder="Primary channel 3: e.g., ABM via paid LinkedIn + display retargeting" /></div>
							<div class="field">
								<label for="gtm-expansion">Expansion motion</label>
								<input type="text" id="gtm-expansion" maxlength="100" placeholder="e.g., CS-led upsell at 75% feature adoption + multi-team rollouts" />
							</div>
						</fieldset>

						<fieldset data-section-card="gtm-goals-card">
							<legend>6. Goals (3 - measurable)<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="gtm-goals-card" checked /><span class="section-toggle-track"></span></label></legend>
							<div class="field"><input type="text" id="gtm-goal-1" maxlength="100" placeholder="Goal 1: e.g., $4M net-new ARR by end of FY26" /></div>
							<div class="field"><input type="text" id="gtm-goal-2" maxlength="100" placeholder="Goal 2: e.g., 60 enterprise logos in target segment" /></div>
							<div class="field"><input type="text" id="gtm-goal-3" maxlength="100" placeholder="Goal 3: e.g., NDR of 120%+ across cohorts" /></div>
						</fieldset>

						<fieldset data-section-card="gtm-metrics-card">
							<legend>7. Success metrics (3 - leading indicators)<label class="section-toggle"><input type="checkbox" class="section-toggle-input" data-toggle-card="gtm-metrics-card" checked /><span class="section-toggle-track"></span></label></legend>
							<div class="field"><input type="text" id="gtm-metric-1" maxlength="100" placeholder="Metric 1: e.g., Pipeline coverage 3x by start of each quarter" /></div>
							<div class="field"><input type="text" id="gtm-metric-2" maxlength="100" placeholder="Metric 2: e.g., Average sales cycle under 45 days" /></div>
							<div class="field"><input type="text" id="gtm-metric-3" maxlength="100" placeholder="Metric 3: e.g., Trial-to-paid conversion above 18%" /></div>
