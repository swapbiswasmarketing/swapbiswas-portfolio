	.tool-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	@media (min-width: 64em) {
		.tool-grid {
			grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
			align-items: start;
		}
		.preview-panel {
			position: sticky;
			top: 1.5rem;
			align-self: start;
		}
	}

	.preview-panel {
		min-width: 0;
	}

	.preview-sticky {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	/* Form panel */
	.form-panel {
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		padding: 1.5rem;
	}

	#launch-form fieldset {
		border: none;
		padding: 0;
		margin: 0 0 1.75rem;
	}

	#launch-form legend {
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-md);
		color: var(--gray-0);
		margin-bottom: 0.75rem;
		padding: 0;
	}

	.field { margin-bottom: 0.75rem; }
	.field-row {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}
	@media (min-width: 30em) {
		.field-row { grid-template-columns: 1fr 1fr; }
	}
	.field label {
		display: block;
		margin-bottom: 0.35rem;
		color: var(--gray-300);
		font-size: var(--text-xs);
		font-weight: 500;
	}
	#launch-form input[type="text"] {
		width: 100%;
		padding: 0.6rem 0.85rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		background: var(--gray-999_40);
		color: var(--gray-0);
		font-family: var(--font-body);
		font-size: var(--text-sm);
		transition: border-color 0.15s ease;
	}
	#launch-form input[type="text"]:focus {
		outline: none;
		border-color: var(--accent-regular);
	}

	.form-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 1rem;
	}

	.btn-secondary {
		padding: 0.5rem 1rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: transparent;
		color: var(--gray-200);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.btn-secondary:hover {
		background: var(--accent-subtle-overlay);
		color: var(--gray-0);
	}

	.btn-danger:hover {
		background: rgba(239, 68, 68, 0.12);
		color: #f87171;
		border-color: rgba(239, 68, 68, 0.3);
	}

	.sample-picker {
		position: relative;
		display: inline-block;
	}
	.sample-picker > summary { list-style: none; }
	.sample-picker > summary::-webkit-details-marker { display: none; }
	.sample-caret {
		display: inline-block;
		margin-left: 0.25rem;
		transition: transform 0.2s ease;
	}
	.sample-picker[open] .sample-caret { transform: rotate(180deg); }
	.sample-options {
		position: absolute;
		top: calc(100% + 0.25rem);
		left: 0;
		margin: 0;
		padding: 0.25rem;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		list-style: none;
		z-index: 20;
		min-width: 200px;
		box-shadow: var(--shadow-md);
	}
	.sample-options li { display: block; }
	.sample-option {
		display: block;
		width: 100%;
		text-align: left;
		padding: 0.5rem 0.75rem;
		background: transparent;
		border: none;
		color: var(--gray-200);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		cursor: pointer;
		border-radius: 0.35rem;
	}
	.sample-option:hover {
		background: var(--accent-subtle-overlay);
		color: var(--gray-0);
	}

	#launch-form legend {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		width: 100%;
	}

	.section-toggle {
		display: inline-flex;
		align-items: center;
		cursor: pointer;
		flex-shrink: 0;
	}

	.section-toggle-input {
		appearance: none;
		-webkit-appearance: none;
		width: 34px;
		height: 20px;
		background: var(--gray-800);
		border-radius: 999rem;
		position: relative;
		cursor: pointer;
		margin: 0;
		transition: background 0.2s ease;
	}

	.section-toggle-input::before {
		content: '';
		position: absolute;
		width: 14px;
		height: 14px;
		background: var(--gray-999);
		border-radius: 50%;
		top: 3px;
		left: 3px;
		transition: transform 0.2s ease;
		box-shadow: 0 1px 2px rgba(0,0,0,0.2);
	}

	.section-toggle-input:checked {
		background: var(--accent-regular);
	}

	.section-toggle-input:checked::before {
		transform: translateX(14px);
	}

	.section-toggle-track { display: none; }

	.fieldset-muted {
		opacity: 0.45;
		transition: opacity 0.2s ease;
	}
	.fieldset-muted .field input { pointer-events: none; }

	.section-excluded { display: none !important; }

	.bind-empty,
	.group-hidden {
		display: none !important;
	}

	.theme-picker {
		display: inline-flex;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		padding: 2px;
		background: var(--gray-999_40);
	}
	.theme-btn {
		padding: 0.35rem 0.75rem;
		border: none;
		background: transparent;
		color: var(--gray-300);
		font-family: var(--font-brand);
		font-size: var(--text-xs);
		font-weight: 500;
		cursor: pointer;
		border-radius: 999rem;
		transition: background 0.15s ease, color 0.15s ease;
	}
	.theme-btn:hover { color: var(--gray-0); }
	.theme-btn.active {
		background: var(--accent-regular);
		color: var(--accent-text-over);
	}

	/* Light theme */
	.launch-card[data-theme="light"] {
		background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
		color: #0f172a;
	}
	.launch-card[data-theme="light"] .lp-header,
	.launch-card[data-theme="light"] .lp-footer,
	.launch-card[data-theme="light"] .lp-card-head { border-color: #e2e8f0; }
	.launch-card[data-theme="light"] .lp-card {
		background: #f8fafc;
		border-color: #e2e8f0;
	}
	.launch-card[data-theme="light"] .lp-name { color: #0f172a; }
	.launch-card[data-theme="light"] .lp-tagline,
	.launch-card[data-theme="light"] .lp-meta,
	.launch-card[data-theme="light"] .lp-meta-row,
	.launch-card[data-theme="light"] .lp-card ul,
	.launch-card[data-theme="light"] .lp-team-row span:last-child,
	.launch-card[data-theme="light"] .lp-channel-row,
	.launch-card[data-theme="light"] .lp-milestone,
	.launch-card[data-theme="light"] .lp-risk-q,
	.launch-card[data-theme="light"] .lp-risk-a { color: #475569; }
	.launch-card[data-theme="light"] .lp-meta-label,
	.launch-card[data-theme="light"] .lp-team-role,
	.launch-card[data-theme="light"] .lp-footer { color: #94a3b8; }
	.launch-card[data-theme="light"] .lp-footer-url { color: #64748b; }
	.launch-card[data-theme="light"] .lp-channel-row,
	.launch-card[data-theme="light"] .lp-milestone { border-bottom-color: #e2e8f0; }

	/* Brand theme */
	.launch-card[data-theme="brand"] {
		background: linear-gradient(135deg, #1c0056 0%, #7611a6 100%);
		color: #ffffff;
	}
	.launch-card[data-theme="brand"] .lp-header,
	.launch-card[data-theme="brand"] .lp-footer,
	.launch-card[data-theme="brand"] .lp-card-head { border-color: rgba(255,255,255,0.15); }
	.launch-card[data-theme="brand"] .lp-card {
		background: rgba(255,255,255,0.08);
		border-color: rgba(255,255,255,0.18);
	}
	.launch-card[data-theme="brand"] .lp-name { color: #ffffff; }
	.launch-card[data-theme="brand"] .lp-tagline,
	.launch-card[data-theme="brand"] .lp-meta,
	.launch-card[data-theme="brand"] .lp-meta-row,
	.launch-card[data-theme="brand"] .lp-card ul,
	.launch-card[data-theme="brand"] .lp-team-row span:last-child,
	.launch-card[data-theme="brand"] .lp-channel-row,
	.launch-card[data-theme="brand"] .lp-milestone,
	.launch-card[data-theme="brand"] .lp-risk-q,
	.launch-card[data-theme="brand"] .lp-risk-a { color: rgba(255,255,255,0.92); }
	.launch-card[data-theme="brand"] .lp-meta-label,
	.launch-card[data-theme="brand"] .lp-team-role,
	.launch-card[data-theme="brand"] .lp-footer { color: rgba(255,255,255,0.7); }
	.launch-card[data-theme="brand"] .lp-footer-url { color: rgba(255,255,255,0.85); }
	.launch-card[data-theme="brand"] .lp-channel-row,
	.launch-card[data-theme="brand"] .lp-milestone { border-bottom-color: rgba(255,255,255,0.1); }
	.launch-card[data-theme="brand"] .lp-label { color: #f5a0a1; }
	.launch-card[data-theme="brand"] .lp-goals .lp-card-head { color: #5eead4; }
	.launch-card[data-theme="brand"] .lp-team .lp-card-head { color: #93c5fd; }
	.launch-card[data-theme="brand"] .lp-channels .lp-card-head { color: #d8b4fe; }
	.launch-card[data-theme="brand"] .lp-milestones .lp-card-head { color: #fdba74; }
	.launch-card[data-theme="brand"] .lp-risks .lp-card-head { color: #fda4af; }

	.preview-actions {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	.btn-icon {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.5rem 0.85rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: transparent;
		color: var(--gray-200);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 500;
		cursor: pointer;
		transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
	}
	.btn-icon:hover:not([disabled]) {
		background: var(--accent-subtle-overlay);
		color: var(--gray-0);
		border-color: var(--accent-regular);
	}
	.btn-icon[disabled] {
		opacity: 0.7;
		cursor: not-allowed;
	}

	.autosave-status {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin: 0;
		min-height: 1.1rem;
		font-size: var(--text-xs);
		color: var(--gray-400);
	}

	.fill-counter {
		font-variant-numeric: tabular-nums;
	}

	/* Preview panel */
	.preview-controls {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.preview-heading {
		font-size: var(--text-md);
		color: var(--gray-200);
		margin: 0;
	}

	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.6rem 1.25rem;
		border: none;
		border-radius: 999rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 600;
		cursor: pointer;
		transition: box-shadow 0.15s ease, transform 0.15s ease;
	}
	.btn-primary:hover:not([disabled]) {
		box-shadow: var(--shadow-md);
		transform: translateY(-1px);
	}
	.btn-primary[disabled] {
		opacity: 0.7;
		cursor: not-allowed;
	}

	.preview-frame {
		position: relative;
		width: 100%;
		overflow: hidden;
		border-radius: 16px;
	}

	/* Launch plan card */
	.launch-card {
		width: 1000px;
		background: linear-gradient(135deg, #0d1117 0%, #161b22 100%);
		color: #f0f6fc;
		border-radius: 16px;
		padding: 32px;
		font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
		display: flex;
		flex-direction: column;
		gap: 20px;
		transform-origin: top left;
		transform: scale(var(--lp-scale, 1));
	}

	.lp-header {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 24px;
		align-items: flex-start;
		padding-bottom: 20px;
		border-bottom: 1px solid #30363d;
	}

	.lp-label {
		display: inline-block;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #c084fc;
		margin-bottom: 8px;
	}

	.lp-name {
		font-size: 30px;
		font-weight: 700;
		line-height: 1.15;
		margin: 0 0 8px 0;
		color: #f0f6fc;
	}

	.lp-tagline {
		font-size: 15px;
		color: #c8cfd8;
		line-height: 1.5;
		max-width: 60ch;
	}

	.lp-meta {
		text-align: right;
		font-size: 13px;
		color: #c8cfd8;
		min-width: 280px;
	}

	.card-logo:not([hidden]) {
		display: block;
		max-height: 44px;
		max-width: 160px;
		margin: 0 0 12px auto;
		object-fit: contain;
	}

	.lp-meta-row {
		margin-bottom: 4px;
	}

	.lp-meta-label {
		color: #8b949e;
		font-weight: 600;
		margin-right: 4px;
	}

	.lp-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 16px;
	}

	.lp-card {
		background: #151b23;
		border: 1px solid #30363d;
		border-radius: 12px;
		padding: 18px;
	}

	.lp-card-head {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 14px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 12px;
		padding-bottom: 10px;
		border-bottom: 1px solid #30363d;
	}

	.lp-goals .lp-card-head { color: #5eead4; }
	.lp-team .lp-card-head { color: #60a5fa; }
	.lp-channels .lp-card-head { color: #c084fc; }
	.lp-milestones .lp-card-head { color: #fb923c; }
	.lp-risks .lp-card-head { color: #f5a0a1; }

	.lp-goals,
	.lp-team {
		grid-column: span 3;
	}

	.lp-channels {
		grid-column: span 6;
	}

	.lp-milestones,
	.lp-risks {
		grid-column: span 3;
	}

	.lp-card ul {
		margin: 0;
		padding-left: 20px;
		font-size: 14px;
		line-height: 1.55;
		color: #c8cfd8;
	}

	.lp-card li { margin-bottom: 6px; }
	.lp-card li:last-child { margin-bottom: 0; }

	/* Owners grid */
	.lp-team-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 8px 16px;
		font-size: 14px;
	}

	.lp-team-row {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.lp-team-role {
		font-size: 11px;
		color: #8b949e;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 600;
	}

	.lp-team-row span:last-child { color: #c8cfd8; }

	/* Channels */
	.lp-channel-row {
		display: grid;
		grid-template-columns: 90px 1fr;
		gap: 12px;
		align-items: baseline;
		padding: 6px 0;
		font-size: 14px;
		color: #c8cfd8;
		border-bottom: 1px solid #21262d;
	}
	.lp-channel-row:last-child { border-bottom: none; }
	.lp-channel-tier {
		font-size: 11px;
		color: #c084fc;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-weight: 600;
	}

	/* Milestones */
	.lp-milestone {
		display: grid;
		grid-template-columns: 60px 1fr;
		gap: 12px;
		align-items: baseline;
		padding: 6px 0;
		font-size: 13px;
		color: #c8cfd8;
		border-bottom: 1px solid #21262d;
	}
	.lp-milestone:last-child { border-bottom: none; }
	.lp-phase {
		font-size: 11px;
		color: #fb923c;
		font-weight: 700;
		letter-spacing: 0.04em;
	}
	.lp-milestone-day0 .lp-phase {
		color: #5eead4;
	}

	/* Risks */
	.lp-risk-item { margin-bottom: 12px; }
	.lp-risk-item:last-child { margin-bottom: 0; }
	.lp-risk-q {
		font-style: italic;
		color: #c8cfd8;
		font-size: 14px;
		margin-bottom: 4px;
	}
	.lp-risk-a {
		font-size: 13.5px;
		color: #d0d7de;
		line-height: 1.5;
	}
	.lp-risk-a strong { color: #f5a0a1; }

	.lp-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 16px;
		border-top: 1px solid #30363d;
		font-size: 11px;
		color: #6e7681;
	}

	.lp-footer-url {
		font-family: ui-monospace, SFMono-Regular, monospace;
		color: #8b949e;
	}

	.lp-placeholder {
		opacity: 0.45;
	}

	/* Newsletter strip */
	.tool-cta-strip {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		padding: 1.75rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		align-items: center;
	}
	@media (min-width: 50em) {
		.tool-cta-strip { grid-template-columns: 1fr auto; }
	}
	.cta-text strong {
		display: block;
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-md);
		color: var(--gray-0);
	}
	.cta-text p {
		margin: 0.25rem 0 0;
		color: var(--gray-300);
		font-size: var(--text-sm);
	}
	.cta-form { display: flex; gap: 0.5rem; }
	.cta-form input {
		flex: 1;
		min-width: 0;
		padding: 0.6rem 0.85rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		background: var(--gray-999_40);
		color: var(--gray-0);
		font-size: var(--text-sm);
	}
	.cta-form button {
		padding: 0.6rem 1.25rem;
		border: none;
		border-radius: 0.5rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-sm);
		cursor: pointer;
		white-space: nowrap;
	}
	.cta-status {
		grid-column: 1 / -1;
		margin: 0;
		font-size: var(--text-sm);
		min-height: 1rem;
	}

	/* SEO content */
	.seo-content { max-width: 60rem; }
	.seo-content h2 {
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin: 2.5rem 0 1rem;
	}
	.seo-content h2:first-child { margin-top: 0; }
	.seo-content p,
	.seo-content li {
		color: var(--gray-200);
		font-size: var(--text-md);
		line-height: 1.65;
	}
	.seo-content .how-to { padding-left: 1.25rem; }
	.seo-content .how-to li { margin-bottom: 0.75rem; }
	.seo-content a {
		color: var(--accent-regular);
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}
	.seo-link {
		display: inline-block;
		font-weight: 600;
	}
	.related-links { list-style: none; padding: 0; }
	.related-links li { margin-bottom: 0.5rem; }

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.faq-item {
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		padding: 1rem 1.25rem;
		background: var(--gray-999_40);
	}
	.faq-item summary {
		cursor: pointer;
		font-family: var(--font-brand);
		font-weight: 600;
		color: var(--gray-0);
		font-size: var(--text-md);
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}
	.faq-item summary::after {
		content: '+';
		color: var(--accent-regular);
		font-size: 1.5rem;
		font-weight: 400;
		line-height: 1;
		transition: transform 0.2s ease;
	}
	.faq-item[open] summary::after { content: '−'; }
