<script>
	function initLaunch() {
		const formMaybe = document.getElementById('launch-form') as HTMLFormElement | null;
		const card = document.getElementById('launch-card');
		if (!formMaybe || !card || (formMaybe as any)._initialized) return;
		(formMaybe as any)._initialized = true;
		const form: HTMLFormElement = formMaybe;

		const bindings = card.querySelectorAll<HTMLElement>('[data-bind]');

		function update() {
			const hasAnyContent = Array.from(form.querySelectorAll<HTMLInputElement>('input[type="text"]'))
				.some((input) => input.value.trim().length > 0);

			bindings.forEach((el) => {
				const id = el.getAttribute('data-bind');
				if (!id) return;
				const input = document.getElementById(id) as HTMLInputElement | null;
				const val = input?.value?.trim() || '';
				if (val) {
					el.textContent = val;
					el.classList.remove('lp-placeholder');
					el.classList.remove('bind-empty');
				} else if (hasAnyContent) {
					el.textContent = '';
					el.classList.remove('lp-placeholder');
					el.classList.add('bind-empty');
				} else {
					el.textContent = el.getAttribute('data-placeholder') || '';
					el.classList.add('lp-placeholder');
					el.classList.remove('bind-empty');
				}
			});
			card!.querySelectorAll<HTMLElement>('[data-hide-group]').forEach((group) => {
				const childBinds = group.querySelectorAll<HTMLElement>('[data-bind]');
				const allEmpty = childBinds.length > 0 && Array.from(childBinds).every((c) => c.classList.contains('bind-empty'));
				group.classList.toggle('group-hidden', allEmpty);
			});
		}

		bindings.forEach((el) => {
			if (!el.getAttribute('data-placeholder')) {
				el.setAttribute('data-placeholder', el.textContent || '');
			}
			el.classList.add('lp-placeholder');
		});

		// ===== Section toggles =====
		function applyToggle(toggle: HTMLInputElement) {
			const cardClass = toggle.dataset.toggleCard;
			if (!cardClass) return;
			const cardEl = card!.querySelector('.' + cardClass);
			const fieldset = toggle.closest('fieldset');
			const excluded = !toggle.checked;
			if (cardEl) cardEl.classList.toggle('section-excluded', excluded);
			if (fieldset) fieldset.classList.toggle('fieldset-muted', excluded);
		}

		form.querySelectorAll<HTMLInputElement>('.section-toggle-input').forEach((toggle) => {
			toggle.addEventListener('change', () => {
				applyToggle(toggle);
				saveState();
				scaleCard();
			});
		});

		// ===== localStorage persistence =====
		const STATE_KEY = 'tool-state-launch-plan';
		const statusEl = document.getElementById('autosave-text');
		const counterEl = document.getElementById('fill-counter');
		let saveTimer: any;

		function updateCounter() {
			if (!counterEl) return;
			const inputs = form.querySelectorAll<HTMLInputElement>('input[type="text"]');
			const filled = Array.from(inputs).filter((i) => i.value.trim().length > 0).length;
			counterEl.textContent = `${filled}/${inputs.length} fields filled${filled === inputs.length ? ' ✓' : ''}`;
		}

		function saveState() {
			try {
				const fields: Record<string, string> = {};
				form.querySelectorAll<HTMLInputElement>('input[type="text"]').forEach((input) => {
					if (input.value) fields[input.id] = input.value;
				});
				const excluded: Record<string, boolean> = {};
				form.querySelectorAll<HTMLInputElement>('.section-toggle-input').forEach((toggle) => {
					if (!toggle.checked && toggle.dataset.toggleCard) excluded[toggle.dataset.toggleCard] = true;
				});
				const theme = (card as HTMLElement).dataset.theme || 'dark';
				const logo = cardLogo?.getAttribute('hidden') === null ? cardLogo.src : null;
				localStorage.setItem(STATE_KEY, JSON.stringify({ fields, excluded, theme, logo, savedAt: Date.now() }));
				if (statusEl) {
					statusEl.textContent = 'Saved';
					setTimeout(() => { if (statusEl && statusEl.textContent === 'Saved') statusEl.textContent = ''; }, 1500);
				}
			} catch (e) {}
		}

		function loadState() {
			try {
				const raw = localStorage.getItem(STATE_KEY);
				if (!raw) return false;
				const saved = JSON.parse(raw);
				Object.entries(saved.fields || {}).forEach(([id, val]) => {
					const input = document.getElementById(id) as HTMLInputElement | null;
					if (input && typeof val === 'string') input.value = val;
				});
				Object.entries(saved.excluded || {}).forEach(([cardClass, isExcluded]) => {
					const toggle = form.querySelector<HTMLInputElement>(`.section-toggle-input[data-toggle-card="${cardClass}"]`);
					if (toggle && isExcluded) { toggle.checked = false; applyToggle(toggle); }
				});
				if (saved.theme && typeof saved.theme === 'string') applyTheme(saved.theme);
				if (saved.logo && typeof saved.logo === 'string') applyLogo(saved.logo);
				return true;
			} catch (e) { return false; }
		}

		function applyTheme(theme: string) {
			(card as HTMLElement).dataset.theme = theme;
			document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
				btn.classList.toggle('active', btn.dataset.theme === theme);
			});
		}
		document.querySelectorAll<HTMLButtonElement>('.theme-btn').forEach((btn) => {
			btn.addEventListener('click', () => {
				applyTheme(btn.dataset.theme || 'dark');
				saveState();
				scaleCard();
			});
		});

		// ===== Logo upload =====
		const cardLogo = document.getElementById('card-logo') as HTMLImageElement | null;
		const uploadBtn = document.getElementById('upload-logo');
		const removeBtn = document.getElementById('remove-logo');
		const fileInput = document.getElementById('logo-file-input') as HTMLInputElement | null;

		const TRANSPARENT_PX = 'data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=';
		function applyLogo(dataUrl: string | null) {
			if (cardLogo) {
				if (dataUrl) {
					cardLogo.src = dataUrl;
					cardLogo.removeAttribute('hidden');
				} else {
					cardLogo.src = TRANSPARENT_PX;
					cardLogo.setAttribute('hidden', '');
				}
			}
			if (dataUrl) {
				uploadBtn?.setAttribute('hidden', '');
				removeBtn?.removeAttribute('hidden');
			} else {
				uploadBtn?.removeAttribute('hidden');
				removeBtn?.setAttribute('hidden', '');
			}
			scaleCard();
		}

		uploadBtn?.addEventListener('click', () => fileInput?.click());
		fileInput?.addEventListener('change', () => {
			const file = fileInput.files?.[0];
			if (!file) return;
			if (file.size > 1024 * 1024) {
				if (!confirm('That logo is over 1MB. localStorage may struggle. Continue?')) {
					fileInput.value = '';
					return;
				}
			}
			const reader = new FileReader();
			reader.onload = (e) => {
				applyLogo(e.target?.result as string);
				saveState();
			};
			reader.readAsDataURL(file);
		});
		removeBtn?.addEventListener('click', () => {
			if (fileInput) fileInput.value = '';
			applyLogo(null);
			saveState();
		});

		function debouncedSave() {
			clearTimeout(saveTimer);
			if (statusEl) statusEl.textContent = 'Saving...';
			saveTimer = setTimeout(saveState, 400);
		}

		form.addEventListener('input', () => { update(); updateCounter(); debouncedSave(); });

		document.getElementById('clear-saved')?.addEventListener('click', () => {
			if (!confirm('Clear all saved data for this tool? This cannot be undone.')) return;
			try { localStorage.removeItem(STATE_KEY); } catch (e) {}
			form.reset();
			form.querySelectorAll<HTMLInputElement>('.section-toggle-input').forEach((t) => { t.checked = true; applyToggle(t); });
			update();
			updateCounter();
			if (statusEl) statusEl.textContent = 'Cleared';
		});

