				'risk-2': 'Public launch fizzles on Product Hunt due to weekend timing',
				'risk-2-mit': 'Schedule for Tue 12:01 AM PT, line up 50+ supporters in advance, primary KPI is signups not PH ranking',
			},
		};

		function loadSample(key: string) {
			const sample = samples[key];
			if (!sample) return;
			Object.entries(sample).forEach(([id, val]) => {
				const input = document.getElementById(id) as HTMLInputElement | null;
				if (input) input.value = val;
			});
			update();
			updateCounter();
			saveState();
		}

		form.querySelectorAll<HTMLButtonElement>('.sample-option').forEach((btn) => {
			btn.addEventListener('click', () => {
				loadSample(btn.dataset.sample || '');
				const picker = btn.closest('details');
				if (picker) picker.removeAttribute('open');
			});
		});

		document.getElementById('reset-form')?.addEventListener('click', () => {
			form.reset();
			form.querySelectorAll<HTMLInputElement>('.section-toggle-input').forEach((t) => { t.checked = true; applyToggle(t); });
			update();
			updateCounter();
			saveState();
		});

		// Scale card to fit frame width AND viewport height
		const frame = document.getElementById('preview-frame');
		const cardEl = card as HTMLElement;
		function scaleCard() {
			if (!frame) return;
			const frameWidth = frame.clientWidth;
			const widthScale = Math.min(1, frameWidth / 1000);
			const prev = cardEl.style.getPropertyValue('--lp-scale');
			cardEl.style.setProperty('--lp-scale', '1');
			const naturalHeight = cardEl.scrollHeight;
			cardEl.style.setProperty('--lp-scale', prev || String(widthScale));

			const isDesktop = window.matchMedia('(min-width: 64em)').matches;
			let heightScale = 1;
			if (isDesktop) {
				const reservedTop = 24;
				const reservedBottom = 24;
				const controlsHeight = 64;
				const available = window.innerHeight - reservedTop - reservedBottom - controlsHeight;
				heightScale = available / naturalHeight;
			}

			const scale = Math.min(widthScale, heightScale, 1);
			cardEl.style.setProperty('--lp-scale', String(scale));
			frame.style.height = (naturalHeight * scale) + 'px';
		}
		scaleCard();
		const ro = new ResizeObserver(scaleCard);
		if (frame) ro.observe(frame);
		const mo = new MutationObserver(scaleCard);
		mo.observe(card, { childList: true, subtree: true, characterData: true });
		window.addEventListener('resize', scaleCard);
		if ((document as any).fonts?.ready) {
			(document as any).fonts.ready.then(scaleCard);
		}

		// ===== Shared render helper =====
		const themeBgColors: Record<string, string> = { dark: '#0d1117', light: '#ffffff', brand: '#1c0056' };

		async function renderCard(format: 'png' | 'blob'): Promise<any> {
			const cEl = card as HTMLElement;
			const frameEl = document.getElementById('preview-frame');
			const prevTransform = cEl.style.transform;
			const prevFrameHeight = frameEl?.style.height || '';
			try {
				const mod: any = await import('https://esm.sh/html-to-image@1.11.13' as any);
				cEl.style.transform = 'none';
				if (frameEl) frameEl.style.height = cEl.scrollHeight + 'px';
				const theme = cEl.dataset.theme || 'dark';
				const opts = {
					pixelRatio: 2,
					backgroundColor: themeBgColors[theme] || '#0d1117',
					cacheBust: true,
					skipFonts: true,
					width: 1000,
					height: cEl.scrollHeight,
				};
				return format === 'blob' ? await mod.toBlob(cEl, opts) : await mod.toPng(cEl, opts);
			} finally {
				cEl.style.transform = prevTransform;
				if (frameEl) frameEl.style.height = prevFrameHeight;
			}
		}

		// ===== Copy to clipboard =====
		const copyBtn = document.getElementById('copy-png');
		copyBtn?.addEventListener('click', async () => {
			const original = copyBtn.textContent;
			copyBtn.setAttribute('disabled', 'true');
			copyBtn.textContent = 'Copying...';
			try {
				const blob = await renderCard('blob');
				if (!blob) throw new Error('Empty blob');
				if (!navigator.clipboard || !(window as any).ClipboardItem) {
					alert('Copy to clipboard is not supported in this browser. Use Download PNG instead.');
					return;
				}
				await navigator.clipboard.write([new (window as any).ClipboardItem({ 'image/png': blob })]);
				copyBtn.textContent = 'Copied!';
				(window as any).dataLayer = (window as any).dataLayer || [];
				(window as any).dataLayer.push({ event: 'tool_copy', tool_name: 'product_launch_plan_template', tool_output: 'png' });
				setTimeout(() => { copyBtn.textContent = original; copyBtn.removeAttribute('disabled'); }, 1800);
				return;
			} catch (err) {
				console.error('Copy failed', err);
				alert('Copy failed. Please use Download PNG instead.');
			}
			copyBtn.textContent = original;
			copyBtn.removeAttribute('disabled');
		});

		// ===== Download as PDF =====
		async function pngToPdf(dataUrl: string, filename: string) {
			const mod: any = await import('https://esm.sh/jspdf@2.5.1' as any);
			const JsPDF = mod.jsPDF || mod.default;
			const img = new Image();
			await new Promise<void>((res, rej) => { img.onload = () => res(); img.onerror = rej; img.src = dataUrl; });
			const pageW = 612, pageH = 792, margin = 36;
			const maxW = pageW - 2 * margin, maxH = pageH - 2 * margin;
			const scale = Math.min(maxW / img.width, maxH / img.height);
			const w = img.width * scale, h = img.height * scale;
			const x = (pageW - w) / 2, y = (pageH - h) / 2;
			const pdf = new JsPDF({ orientation: 'portrait', unit: 'pt', format: 'letter' });
			pdf.addImage(dataUrl, 'PNG', x, y, w, h, undefined, 'FAST');
			pdf.save(filename);
		}

		const pdfBtn = document.getElementById('download-pdf');
		pdfBtn?.addEventListener('click', async () => {
			const original = pdfBtn.textContent;
			pdfBtn.setAttribute('disabled', 'true');
			pdfBtn.textContent = 'Building...';
			try {
				const dataUrl = await renderCard('png');
				const productName = (document.getElementById('product-name') as HTMLInputElement)?.value?.trim() || '';
				const safeName = productName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
				await pngToPdf(dataUrl, safeName ? `launch-plan-${safeName}.pdf` : 'launch-plan.pdf');
				(window as any).dataLayer = (window as any).dataLayer || [];
				(window as any).dataLayer.push({ event: 'tool_download', tool_name: 'product_launch_plan_template', tool_output: 'pdf' });
			} catch (err) {
				console.error('PDF failed', err);
				alert('PDF download failed. Please try Download PNG instead.');
			} finally {
				pdfBtn.textContent = original;
				pdfBtn.removeAttribute('disabled');
			}
		});

		// Download PNG
		const downloadBtn = document.getElementById('download-png');
		downloadBtn?.addEventListener('click', async () => {
			const original = downloadBtn.textContent;
			downloadBtn.setAttribute('disabled', 'true');
			downloadBtn.textContent = 'Preparing...';
			try {
				const dataUrl = await renderCard('png');
				const productName = (document.getElementById('product-name') as HTMLInputElement)?.value?.trim() || '';
				const safeName = productName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
				const link = document.createElement('a');
				link.download = safeName ? `launch-plan-${safeName}.png` : 'launch-plan.png';
				link.href = dataUrl;
				link.click();
				(window as any).dataLayer = (window as any).dataLayer || [];
				(window as any).dataLayer.push({ event: 'tool_download', tool_name: 'product_launch_plan_template', tool_output: 'png' });
			} catch (err) {
				console.error('Download failed', err);
				alert('Download failed. Please try again or use a different browser.');
			} finally {
				downloadBtn.textContent = original;
				downloadBtn.removeAttribute('disabled');
			}
		});

		// Restore previous session if any
		loadState();
		update();
		updateCounter();
	}

	function initToolNewsletter() {
		const form = document.getElementById('tool-newsletter-form') as HTMLFormElement | null;
		const status = document.getElementById('tool-newsletter-status');
		if (!form || (form as any)._initialized) return;
		(form as any)._initialized = true;

		form.addEventListener('submit', (e) => {
			e.preventDefault();
			const emailInput = form.querySelector('input[name="email_address"]') as HTMLInputElement | null;
			const email = emailInput?.value || '';
			const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
			if (btn) { btn.textContent = 'Subscribing...'; btn.disabled = true; }
			const formData = new FormData();
			formData.append('email_address', email);
			fetch('https://app.kit.com/forms/9145889/subscriptions', {
				method: 'POST',
				body: formData,
				headers: { 'Accept': 'application/json' }
			}).then((res) => {
				if (!res.ok) throw new Error('fail');
				if (status) { status.textContent = 'Subscribed!'; status.style.color = 'var(--accent-regular)'; }
				form.reset();
				(window as any).dataLayer = (window as any).dataLayer || [];
				(window as any).dataLayer.push({ event: 'newsletter_signup', signup_location: 'tool_launch_plan' });
			}).catch(() => {
				if (status) { status.textContent = 'Something went wrong.'; status.style.color = '#ca7879'; }
			}).finally(() => {
				if (btn) { btn.textContent = 'Subscribe'; btn.disabled = false; }
			});
		});
	}

	initLaunch();
	initToolNewsletter();
	document.addEventListener('astro:page-load', () => {
		initLaunch();
		initToolNewsletter();
	});
</script>

