---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import ContactCTA from '../../components/ContactCTA.astro';
import Hero from '../../components/Hero.astro';
import Pill from '../../components/Pill.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

// Reading time calculation
const wordCount = entry.body ? entry.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));

// Format publish date
const publishDate = entry.data.publishDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const updatedDate = entry.data.updatedDate
	? entry.data.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
	: null;

// Related posts (same category, excluding current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
	.filter((p) => p.id !== entry.id && p.data.category.some((c) => entry.data.category.includes(c)))
	.sort((a, b) => {
		const aScore = a.data.category.filter((c) => entry.data.category.includes(c)).length;
		const bScore = b.data.category.filter((c) => entry.data.category.includes(c)).length;
		return bScore - aScore || b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
	})
	.slice(0, 3);

const blogPostSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": entry.data.title,
	"description": entry.data.description,
	"image": `https://swapbiswas.com/og/${entry.id}.png`,
	"datePublished": entry.data.publishDate.toISOString(),
	"dateModified": (entry.data.updatedDate || entry.data.publishDate).toISOString(),
	"author": {
		"@type": "Person",
		"@id": "https://swapbiswas.com/#person",
		"name": "Swapnil Biswas",
		"url": "https://swapbiswas.com"
	},
	"publisher": {
		"@type": "Person",
		"@id": "https://swapbiswas.com/#person",
		"name": "Swapnil Biswas"
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": `https://swapbiswas.com/blog/${entry.id}/`
	},
	"keywords": entry.data.category.join(", ")
};

const faqSchema = entry.data.faqs && entry.data.faqs.length > 0 ? {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": entry.data.faqs.map((faq) => ({
		"@type": "Question",
		"name": faq.q,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.a
		}
	}))
} : null;
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={`/og/${entry.id}.png`} breadcrumbs={[{ name: "Blog", url: "/blog/" }, { name: entry.data.title }]}>
	<div class="reading-progress" aria-hidden="true"><div class="reading-progress-bar"></div></div>
	<script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />
	{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<Hero title={entry.data.title} align="start">
						<div class="details">
							<div class="tags">
								{entry.data.category.map((cat) => (
									<Pill>{cat}</Pill>
								))}
							</div>
							<p class="meta-line">
								{publishDate} &middot; {readingTime} min read
								{updatedDate && <span class="updated-badge">Updated {updatedDate}</span>}
							</p>
							<p class="description">{entry.data.description}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="blog-layout">
					{tocHeadings.length > 2 && (
						<aside class="toc-sidebar">
							<nav class="toc">
								<button class="toc-toggle" aria-expanded="false">
									<span class="toc-title">Table of Contents</span>
									<span class="toc-toggle-icon">+</span>
								</button>
								<ol class="toc-list">
									{tocHeadings.map((h) => (
										<li class:list={[`toc-item`, `depth-${h.depth}`]}>
											<a href={`#${h.slug}`}>{h.text}</a>
										</li>
									))}
								</ol>
							</nav>
						</aside>
					)}
					<div class="stack gap-10 content-column">
						<img src={`/og/${entry.id}.png`} alt={entry.data.img_alt || ''} />
						<div class="content">
							<Content />
						</div>
						<ShareButtons title={entry.data.title} url={`https://swapbiswas.com/blog/${entry.id}/`} />

						<!-- FAQ Section -->
						{entry.data.faqs && entry.data.faqs.length > 0 && (
							<section class="faq-section" aria-labelledby="faq-heading">
								<h2 id="faq-heading" class="faq-heading">Frequently Asked Questions</h2>
								<div class="faq-list">
									{entry.data.faqs.map((faq, i) => (
										<details class="faq-item" open={i === 0}>
											<summary class="faq-question">
												<span>{faq.q}</span>
												<svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
											</summary>
											<p class="faq-answer">{faq.a}</p>
										</details>
									))}
								</div>
							</section>
						)}

						<!-- Author Bio -->
						<a href="/about/" class="author-bio">
							<img src="/assets/portrait-new.webp" alt="Swapnil Biswas" class="author-avatar" width="64" height="64" loading="lazy" />
							<div class="author-info">
								<p class="author-name">Written by <strong>Swapnil Biswas</strong></p>
								<p class="author-desc">Product Marketing & Growth Strategist. I write about AI, SEO, and marketing strategy from real experience - not theory.</p>
							</div>
						</a>

						<!-- Related Posts -->
						{relatedPosts.length > 0 && (
							<div class="related-posts">
								<h2>Related Articles</h2>
								<div class="related-grid">
									{relatedPosts.map((post) => (
										<a href={`/blog/${post.id}/`} class="related-card">
											<img src={`/og/${post.id}.png`} alt={post.data.title} loading="lazy" decoding="async" />
											<span class="related-title">{post.data.title}</span>
										</a>
									))}
								</div>
							</div>
						)}
					</div>
				</div>
			</main>
		</div>
		<ContactCTA />
	</div>

	<!-- Back to top button -->
	<button class="back-to-top" aria-label="Back to top" title="Back to top">&#8593;</button>
</BaseLayout>

<style>
	/* Reading Progress Bar */
	.reading-progress {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 3px;
		z-index: 9998;
		background: transparent;
	}

	.reading-progress-bar {
		height: 100%;
		width: 0%;
		background: var(--gradient-accent-orange);
		transition: width 0.1s linear;
	}

	/* Updated Badge */
	.updated-badge {
		display: inline-block;
		margin-left: 0.5rem;
		padding: 0.1rem 0.5rem;
		font-size: 0.75rem;
		border-radius: 999rem;
		background: var(--accent-overlay);
		color: var(--accent-dark);
		font-weight: 500;
	}

	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	/* Blog Layout */
	.blog-layout {
		position: relative;
		overflow-x: hidden;
	}

	/* Table of Contents - Sidebar */
	.toc-sidebar {
		margin-bottom: 1.5rem;
	}

	.toc {
		padding: 1rem 1.25rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		background: var(--gradient-subtle);
	}

	.toc-toggle {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		color: inherit;
	}

	.toc-title {
		font-size: var(--text-md);
		font-family: var(--font-brand);
		font-weight: 600;
		color: var(--gray-0);
	}

	.toc-toggle-icon {
		font-size: var(--text-lg);
		color: var(--gray-300);
		transition: transform 0.2s ease;
		line-height: 1;
	}

	.toc-sidebar.toc-open .toc-toggle-icon {
		transform: rotate(45deg);
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-left: 2px solid var(--gray-800);
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease, margin-top 0.3s ease;
		margin-top: 0;
	}

	.toc-sidebar.toc-open .toc-list {
		max-height: 80vh;
		margin-top: 0.75rem;
		overflow-y: auto;
		padding-right: 0.35rem;
	}

	.toc-item a {
		display: block;
		padding: 0.35rem 0 0.35rem 1rem;
		margin-left: -2px;
		border-left: 2px solid transparent;
		color: var(--gray-400);
		font-size: var(--text-sm);
		text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.toc-item a:hover {
		color: var(--gray-0);
	}

	.toc-item.active > a {
		color: var(--accent-regular);
		border-left-color: var(--accent-regular);
	}

	.toc-item.depth-3 a {
		padding-left: 2rem;
		font-size: 0.8rem;
	}

	.content-column {
		max-width: min(65ch, 100%);
		margin-inline: auto;
		min-width: 0;
	}

	.content {
		max-width: 100%;
		margin-inline: auto;
		overflow-wrap: break-word;
		word-break: break-word;
	}

	.content :global(table) {
		display: table;
		border-collapse: collapse;
		min-width: 100%;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		font-size: var(--text-sm);
	}

	/* Wrap tables in a scrollable container via JS */
	.content :global(.table-wrap) {
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		border-radius: 0.75rem;
		margin-top: 1rem;
		margin-bottom: 1rem;
	}

	.content :global(thead) {
		background: var(--gray-999_40);
	}

	.content :global(th) {
		padding: 0.75rem 1rem;
		text-align: left;
		font-weight: 600;
		color: var(--gray-0);
		border-bottom: 2px solid var(--gray-800);
		white-space: nowrap;
	}

	.content :global(td) {
		padding: 0.75rem 1rem;
		color: var(--gray-200);
		border-bottom: 1px solid var(--gray-800);
		min-width: 6rem;
	}

	.content :global(td:first-child),
	.content :global(th:first-child) {
		min-width: 8rem;
	}

	.content :global(tbody tr:hover) {
		background: var(--gray-999_40);
	}

	.content :global(tbody tr:last-child td) {
		border-bottom: none;
	}

	.content :global(pre) {
		position: relative;
		overflow-x: auto;
		padding: 1.25rem 1.5rem;
		border-radius: 0.75rem;
		border: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		font-size: var(--text-sm);
		line-height: 1.7;
	}

	.content :global(.copy-btn) {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		padding: 0.3rem 0.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.375rem;
		background: var(--gray-999);
		color: var(--gray-300);
		font-size: 0.75rem;
		font-family: var(--font-body);
		cursor: pointer;
		opacity: 0;
		transition: opacity 0.2s ease, background 0.2s ease;
	}

	.content :global(pre:hover .copy-btn) {
		opacity: 1;
	}

	.content :global(.copy-btn:hover) {
		background: var(--gray-800);
		color: var(--gray-0);
	}

	.content :global(code) {
		font-size: 0.9em;
	}

	.content :global(:not(pre) > code) {
		padding: 0.15em 0.4em;
		border-radius: 0.3rem;
		background: var(--gray-999_40);
		border: 1px solid var(--gray-800);
		font-size: 0.85em;
		color: var(--gray-100);
	}

	.content :global(h2),
	.content :global(h3) {
		scroll-margin-top: 5rem;
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4),
	.content :global(h5) {
		margin: 1.5rem 0;
	}

	.content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		cursor: zoom-in;
		transition: opacity 0.2s ease;
	}

	.content :global(img:hover) {
		opacity: 0.85;
	}

	/* Image lightbox overlay */
	:global(.lightbox) {
		position: fixed;
		inset: 0;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.85);
		backdrop-filter: blur(8px);
		cursor: zoom-out;
		opacity: 0;
		transition: opacity 0.25s ease;
		pointer-events: none;
	}

	:global(.lightbox.active) {
		opacity: 1;
		pointer-events: auto;
	}

	:global(.lightbox img) {
		max-width: 90vw;
		max-height: 90vh;
		object-fit: contain;
		border-radius: 0.75rem;
		box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
		transform: scale(0.95);
		transition: transform 0.25s ease;
	}

	:global(.lightbox.active img) {
		transform: scale(1);
	}

	.content :global(blockquote) {
		font-size: var(--text-md);
		font-family: var(--font-body);
		font-weight: 400;
		font-style: italic;
		line-height: 1.6;
		padding: 1rem 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		background: var(--gray-999_40);
		border-radius: 0 0.5rem 0.5rem 0;
		color: var(--gray-200);
	}

	.content :global(blockquote p) {
		margin: 0;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.details {
			flex-direction: row;
			gap: 2.5rem;
		}

		.content :global(blockquote) {
			font-size: var(--text-lg);
		}
	}

	@media (min-width: 72em) {
		.toc-sidebar {
			position: fixed;
			top: 5rem;
			width: 16rem;
			margin-bottom: 0;
			opacity: 0;
			pointer-events: none;
			transition: opacity 0.3s ease;
		}

		.toc-toggle-icon {
			display: none;
		}

		.toc-toggle {
			cursor: default;
		}

		.toc {
			border: none;
			border-radius: 0;
			background: none;
			padding: 0;
		}

		.toc-list {
			max-height: none;
			overflow: visible;
			margin-top: 0.75rem;
			max-height: calc(100vh - 10rem);
			overflow-y: auto;
			padding-right: 0.5rem;
		}

		/* Thin scrollbar for TOC */
		.toc::-webkit-scrollbar,
		.toc-list::-webkit-scrollbar {
			width: 3px;
		}

		.toc::-webkit-scrollbar-track,
		.toc-list::-webkit-scrollbar-track {
			background: transparent;
		}

		.toc::-webkit-scrollbar-thumb,
		.toc-list::-webkit-scrollbar-thumb {
			background: var(--gray-800);
			border-radius: 3px;
		}
	}

	/* Meta line (date + reading time) */
	.meta-line {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	/* FAQ Section */
	.faq-section {
		margin-top: 2rem;
		padding-top: 2rem;
		border-top: 1px solid var(--gray-800);
	}

	.faq-heading {
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		font-weight: 600;
		color: var(--gray-0);
		margin-bottom: 1.25rem;
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.faq-item {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		background: var(--gray-999_40);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.faq-item[open] {
		border-color: var(--gray-700);
		box-shadow: var(--shadow-sm);
	}

	.faq-question {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 1.25rem;
		cursor: pointer;
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-md);
		color: var(--gray-100);
		list-style: none;
		user-select: none;
		transition: color 0.2s ease;
	}

	.faq-question::-webkit-details-marker {
		display: none;
	}

	.faq-question::marker {
		content: '';
	}

	.faq-question:hover {
		color: var(--gray-0);
	}

	.faq-chevron {
		flex-shrink: 0;
		color: var(--gray-400);
		transition: transform 0.25s ease, color 0.2s ease;
	}

	.faq-item[open] .faq-chevron {
		transform: rotate(180deg);
		color: var(--accent-regular);
	}

	.faq-answer {
		padding: 0 1.25rem 1.25rem;
		margin: 0;
		font-size: var(--text-sm);
		line-height: 1.7;
		color: var(--gray-300);
	}

	/* Author Bio */
	.author-bio {
		display: flex;
		gap: 1rem;
		align-items: center;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1rem;
		background: var(--gradient-subtle);
		text-decoration: none;
		transition: box-shadow var(--theme-transition);
	}

	.author-bio:hover {
		box-shadow: var(--shadow-md);
	}

	.author-avatar {
		width: 64px;
		height: 64px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}

	.author-info {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.author-name {
		font-size: var(--text-md);
		color: var(--gray-200);
		margin: 0;
	}

	.author-desc {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0;
		line-height: 1.5;
	}

	/* Related Posts */
	.related-posts {
		margin-top: 1rem;
	}

	.related-posts h2 {
		font-size: var(--text-xl);
		margin-bottom: 1rem;
	}

	.related-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.related-card {
		display: block;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		text-decoration: none;
		transition: box-shadow var(--theme-transition);
	}

	.related-card:hover {
		box-shadow: var(--shadow-md);
	}

	.related-card img {
		width: 100%;
		height: 10rem;
		object-fit: cover;
		border-radius: 0;
		border: none;
		box-shadow: none;
		background: none;
	}

	.related-title {
		display: block;
		padding: 0.75rem 1rem;
		font-size: var(--text-sm);
		font-weight: 500;
		color: var(--gray-200);
		font-family: var(--font-brand);
	}

	@media (min-width: 50em) {
		.related-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Back to top button */
	:global(.back-to-top) {
		position: fixed;
		bottom: 2rem;
		right: 2rem;
		z-index: 100;
		width: 3rem;
		height: 3rem;
		border: 1px solid var(--gray-800);
		border-radius: 50%;
		background: var(--gray-999);
		color: var(--gray-200);
		font-size: 1.25rem;
		cursor: pointer;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.3s ease, box-shadow 0.2s ease, transform 0.2s ease;
		box-shadow: var(--shadow-sm);
	}

	:global(.back-to-top.visible) {
		opacity: 1;
		pointer-events: auto;
	}

	@media (max-width: 480px) {
		:global(.back-to-top) {
			left: 1.5rem;
			right: auto;
		}
	}

	:global(.back-to-top:hover) {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
		color: var(--gray-0);
	}
</style>

<script>
	const tocSidebar = document.querySelector('.toc-sidebar') as HTMLElement | null;
	const contentEl = document.querySelector('.content') as HTMLElement | null;
	const wrapper = document.querySelector('main.wrapper') as HTMLElement | null;
	const tocToggle = document.querySelector('.toc-toggle') as HTMLButtonElement | null;
	const tocList = document.querySelector('.toc-list') as HTMLElement | null;
	const tocItems = document.querySelectorAll('.toc-item');
	const isDesktop = () => window.matchMedia('(min-width: 72em)').matches;

	const headings = Array.from(tocItems).map((item) => {
		const link = item.querySelector('a');
		const id = link?.getAttribute('href')?.slice(1);
		return { item, el: id ? document.getElementById(id) : null };
	}).filter((h) => h.el);

	// Mobile TOC toggle
	if (tocToggle && tocSidebar) {
		tocToggle.addEventListener('click', () => {
			if (isDesktop()) return;
			const isOpen = tocSidebar.classList.toggle('toc-open');
			tocToggle.setAttribute('aria-expanded', String(isOpen));
		});

		// Close TOC when a link is clicked on mobile
		tocSidebar.querySelectorAll('.toc-item a').forEach((link) => {
			link.addEventListener('click', () => {
				if (!isDesktop()) {
					tocSidebar.classList.remove('toc-open');
					tocToggle.setAttribute('aria-expanded', 'false');
				}
			});
		});
	}

	// Position TOC at the left edge of the wrapper (desktop only)
	function positionToc() {
		if (!tocSidebar || !wrapper || !isDesktop()) return;
		const wrapperRect = wrapper.getBoundingClientRect();
		tocSidebar.style.left = `${wrapperRect.left}px`;
	}

	function onScroll() {
		if (!contentEl || !tocSidebar) return;

		// Desktop: show/hide based on content position
		if (isDesktop()) {
			const contentRect = contentEl.getBoundingClientRect();
			const stickyTop = 80;
			const tocHeight = tocSidebar.offsetHeight;
			const pastTop = contentRect.top < stickyTop;
			const beforeBottom = contentRect.bottom > stickyTop + tocHeight;
			const visible = pastTop && beforeBottom;
			tocSidebar.style.opacity = visible ? '1' : '0';
			tocSidebar.style.pointerEvents = visible ? 'auto' : 'none';
		} else {
			// Reset inline styles on mobile
			tocSidebar.style.opacity = '';
			tocSidebar.style.pointerEvents = '';
			tocSidebar.style.left = '';
		}

		// Active heading tracking
		let current = headings[0];
		for (const h of headings) {
			if (h.el!.getBoundingClientRect().top <= 120) {
				current = h;
			} else {
				break;
			}
		}
		tocItems.forEach((item) => item.classList.remove('active'));
		current?.item.classList.add('active');

		// Desktop: scroll active TOC item into view
		if (isDesktop()) {
			const activeLink = tocSidebar.querySelector('.toc-item.active > a') as HTMLElement | null;
			if (activeLink) {
				const list = tocSidebar.querySelector('.toc-list') as HTMLElement;
				if (list && list.scrollHeight > list.clientHeight) {
					activeLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
				}
			}
		}
	}

	positionToc();
	onScroll();
	window.addEventListener('scroll', onScroll, { passive: true });
	window.addEventListener('resize', () => { positionToc(); onScroll(); }, { passive: true });

	// Wrap tables in scrollable container
	document.querySelectorAll('.content table').forEach((table) => {
		const wrapper = document.createElement('div');
		wrapper.className = 'table-wrap';
		table.parentNode!.insertBefore(wrapper, table);
		wrapper.appendChild(table);
	});

	// Copy button for code blocks
	document.querySelectorAll('.content pre').forEach((pre) => {
		const btn = document.createElement('button');
		btn.className = 'copy-btn';
		btn.textContent = 'Copy';
		btn.addEventListener('click', async () => {
			const code = pre.querySelector('code');
			const text = code ? code.innerText : pre.innerText;
			await navigator.clipboard.writeText(text);
			btn.textContent = 'Copied!';
			setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
		});
		pre.appendChild(btn);
	});

	// Image lightbox
	const lightbox = document.createElement('div');
	lightbox.className = 'lightbox';
	const lightboxImg = document.createElement('img');
	lightbox.appendChild(lightboxImg);
	document.body.appendChild(lightbox);

	function closeLightbox() {
		lightbox.classList.remove('active');
	}

	lightbox.addEventListener('click', closeLightbox);
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeLightbox();
	});

	document.querySelectorAll('.content img').forEach((img) => {
		img.addEventListener('click', () => {
			lightboxImg.src = (img as HTMLImageElement).src;
			lightboxImg.alt = (img as HTMLImageElement).alt;
			lightbox.classList.add('active');
		});
	});

	// Reading progress bar
	const progressBar = document.querySelector('.reading-progress-bar') as HTMLElement | null;
	if (progressBar && contentEl) {
		window.addEventListener('scroll', () => {
			const contentRect = contentEl.getBoundingClientRect();
			const contentTop = contentRect.top + window.scrollY;
			const contentHeight = contentEl.offsetHeight;
			const scrolled = window.scrollY - contentTop;
			const progress = Math.min(100, Math.max(0, (scrolled / (contentHeight - window.innerHeight)) * 100));
			progressBar.style.width = `${progress}%`;
		}, { passive: true });
	}

	// Back to top button
	const backToTop = document.querySelector('.back-to-top') as HTMLButtonElement | null;
	if (backToTop) {
		window.addEventListener('scroll', () => {
			backToTop.classList.toggle('visible', window.scrollY > 400);
		}, { passive: true });
		backToTop.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});
	}
</script>
