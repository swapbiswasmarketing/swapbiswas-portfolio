---
import { getCollection } from 'astro:content';
import { Picture } from 'astro:assets';
// Component Imports
import CallToAction from '../components/CallToAction.astro';
// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Icon from '../components/Icon.astro';
import BlogPreview from '../components/BlogPreview.astro';
import ResumeSection from '../components/ResumeSection.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import portraitImg from '../assets/portrait-new.webp';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 3);

const brands = [
	{ name: 'LambdaTest', logo: '/assets/brands/lambdatest-trim.webp' },
	{ name: 'Samsung', logo: '/assets/brands/samsung-trim.webp' },
	{ name: 'Sociowash', logo: '/assets/brands/sociowash-trim.png' },
	{ name: 'Medilife', logo: '/assets/brands/medilife-trim.webp' },
	{ name: 'Appknox', logo: '/assets/brands/appknox.svg' },
	{ name: 'Lido Learning', logo: '/assets/brands/lido-trim.webp' },
];

// The Selected Work showcase is built and ready, but the work entries currently
// use placeholder images (e.g. "800x950"). Flip this to true once they have real
// project imagery and the section will appear automatically.
const showSelectedWork = false;
---

<BaseLayout
	description="Swapnil Biswas - Product Marketing & Growth Strategist specializing in AI, SEO, and content. 657K+ leads generated, 18M+ traffic driven. Explore my work and blog."
	image="/og/home.webp"
>
	<script slot="head" is:inline>
		// Enable the Signal intro loader before paint (only with JS + no reduced-motion),
		// so no-JS / reduced-motion visitors always see content immediately.
		(function () {
			try {
				var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				if (!reduce && !window.__signalLoaderShown) {
					document.documentElement.classList.add('signal-js');
				}
			} catch (e) {}
			// Safety: never let the loader trap content if the main script fails to run.
			setTimeout(function () {
				var l = document.getElementById('signal-loader');
				if (l) l.style.display = 'none';
				document.documentElement.classList.remove('signal-js');
			}, 4500);
		})();
	</script>
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@graph": [
			{
				"@type": "WebSite",
				"@id": "https://swapbiswas.com/#website",
				"url": "https://swapbiswas.com",
				"name": "Swapnil Biswas",
				"description": "Product Marketing & Growth Strategist specializing in AI, SEO, and content.",
				"publisher": { "@id": "https://swapbiswas.com/#person" },
				"potentialAction": {
					"@type": "SearchAction",
					"target": "https://swapbiswas.com/blog/?q={search_term_string}",
					"query-input": "required name=search_term_string"
				}
			},
			{ "@id": "https://swapbiswas.com/#person" },
			{
				"@type": "ItemList",
				"name": "Latest Blog Posts",
				"itemListElement": posts.map((post, i) => ({
					"@type": "ListItem",
					"position": i + 1,
					"url": `https://swapbiswas.com/blog/${post.id}/`
				}))
			}
		]
	})} />
	<div class="stack gap-20 lg:gap-30">
		<!-- Signal: ambient background, scroll progress, section HUD (decorative) -->
		<div class="signal-aura" aria-hidden="true"><span class="aura aura-1"></span><span class="aura aura-2"></span><span class="aura aura-3"></span></div>
		<canvas class="signal-constellation" aria-hidden="true"></canvas>
		<div class="signal-grain" aria-hidden="true"></div>
		<div class="signal-progress" aria-hidden="true"><span id="signal-progress-bar"></span></div>
		<div class="signal-hud" aria-hidden="true"><span id="signal-hud-idx">01</span><span class="signal-hud-sep"></span><span class="signal-hud-total">06</span></div>
		<!-- Signal: continuous strand + custom cursor + intro loader (decorative) -->
		<div class="signal-cursor" aria-hidden="true"><span class="sc-ring"></span><span class="sc-dot"></span></div>
		<span class="signal-cursor-label" aria-hidden="true"></span>
		<div class="signal-loader" id="signal-loader" aria-hidden="true">
			<div class="sl-inner">
				<div class="sl-count"><span id="signal-pct">0</span><i>%</i></div>
				<div class="sl-label">Calibrating signal</div>
				<div class="sl-bar"><span id="signal-bar"></span></div>
			</div>
		</div>
		<svg class="signal-strand" id="signal-strand" aria-hidden="true" preserveAspectRatio="none">
			<defs>
				<linearGradient id="signalGrad" x1="0" y1="0" x2="0" y2="1">
					<stop id="sg0" offset="0%" stop-color="#C561F6"></stop>
					<stop id="sg1" offset="45%" stop-color="#9B30D9"></stop>
					<stop id="sg2" offset="75%" stop-color="#7611A6"></stop>
					<stop id="sg3" offset="100%" stop-color="#CA7879"></stop>
				</linearGradient>
				<filter id="signalGlow" x="-60%" y="-60%" width="220%" height="220%">
					<feGaussianBlur stdDeviation="4" result="b"></feGaussianBlur>
					<feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
				</filter>
			</defs>
			<path id="sp-base" stroke="url(#signalGrad)" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.85"></path>
			<path id="sp-pkt1" stroke="#FFE3C2" stroke-width="3" fill="none" stroke-linecap="round" filter="url(#signalGlow)"></path>
			<path id="sp-pkt2" stroke="#C561F6" stroke-width="2.5" fill="none" stroke-linecap="round" filter="url(#signalGlow)"></path>
			<line id="sp-filament" stroke="rgba(255,227,194,.5)" stroke-width="1" stroke-dasharray="2 3" opacity="0"></line>
			<circle id="sp-halo" r="22" fill="#C561F6" opacity="0.22" filter="url(#signalGlow)"></circle>
			<circle id="sp-flare" r="7" fill="#FFE3C2" filter="url(#signalGlow)"></circle>
		</svg>

		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="signal-hero">
				<span class="signal-bgword" aria-hidden="true">SIGNAL</span>
				<div class="signal-hero-copy">
					<span class="signal-badge" data-fade><i></i> Available for new projects</span>
					<p class="eyebrow" data-fade>The signal, routed</p>
					<h1 class="signal-h1">
						<span class="ln"><span>Swapnil</span></span>
						<span class="ln"><span>Biswas</span></span>
					</h1>
					<p class="signal-lede" data-fade>I build the marketing engines - <b>AI agents</b>, content systems, and growth loops - that turn raw signal into <b>compounding growth</b>.</p>
					<a class="signal-cta" href="/contact/" data-cursor="say hello" data-magnetic data-fade>
						Let&rsquo;s talk <span class="arw" aria-hidden="true">&#8594;</span>
					</a>
					<div class="signal-roles" data-fade>
						<span>Product Marketing</span><span>Growth</span><span>SEO</span><span>AI</span>
					</div>
				</div>

				<div class="signal-cue" aria-hidden="true"><span>scroll</span><span class="line"></span></div>

				<div class="signal-portrait-wrap" data-cursor="that's me">
					<Picture
						src={portraitImg}
						alt="Swapnil Biswas - AI, Product & Digital Growth Marketer"
						widths={[480, 768, 1024]}
						sizes="(max-width: 50em) 100vw, 480px"
						formats={['avif', 'webp']}
						fallbackFormat="webp"
						loading="eager"
						fetchpriority="high"
						pictureAttributes={{ class: "signal-portrait-pic" }}
						class="signal-portrait"
					/>
				</div>
			</header>

			<div class="signal-marquee signal-marquee--tags" aria-hidden="true">
				<div class="mq-track" id="mq-tags">
					<span class="mq-tag"><span>Product Marketing</span><span class="star">✦</span><span>Growth Strategy</span><span class="star">✦</span><span>AI Agents</span><span class="star">✦</span><span>SEO</span><span class="star">✦</span><span>Content</span><span class="star">✦</span><span>Demand Gen</span><span class="star">✦</span></span>
					<span class="mq-tag"><span>Product Marketing</span><span class="star">✦</span><span>Growth Strategy</span><span class="star">✦</span><span>AI Agents</span><span class="star">✦</span><span>SEO</span><span class="star">✦</span><span>Content</span><span class="star">✦</span><span>Demand Gen</span><span class="star">✦</span></span>
				</div>
			</div>

			<Skills />

			<section class="stats">
				<div class="stat" data-count="657" data-suffix="K">
					<div class="stat-number">
						<span class="stat-value">0</span><span class="stat-suffix">K</span>
					</div>
					<span class="stat-label">Leads Generated</span>
				</div>
				<div class="stat" data-count="18.2" data-suffix="M" data-decimal="1">
					<div class="stat-number">
						<span class="stat-value">0</span><span class="stat-suffix">M</span>
					</div>
					<span class="stat-label">Website Traffic</span>
				</div>
				<div class="stat" data-count="10" data-suffix="x">
					<div class="stat-number">
						<span class="stat-value">0</span><span class="stat-suffix">x</span>
					</div>
					<span class="stat-label">Conversion Results</span>
				</div>
				<div class="stat" data-count="15" data-suffix="+">
					<div class="stat-number">
						<span class="stat-value">0</span><span class="stat-suffix">+</span>
					</div>
					<span class="stat-label">People Mentored</span>
				</div>
				<div class="stat" data-count="20" data-suffix="+">
					<div class="stat-number">
						<span class="stat-value">0</span><span class="stat-suffix">+</span>
					</div>
					<span class="stat-label">AI Agents & Apps Created</span>
				</div>
			</section>
		</div>

		<main class="wrapper stack gap-20 lg:gap-30">
			<!-- Selected Work section hidden - work case studies don't have final data yet
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Selected Work</h3>
					<p>Take a look below at some of my featured marketing and branding projects.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
			-->

			{showSelectedWork && projects.length > 0 && (
				<section class="signal-work">
					<header class="section-header stack gap-2 lg:gap-4">
						<p class="section-eyebrow">Selected Work</p>
						<h2>Campaigns &amp; builds</h2>
					</header>
					<div class="work-list">
						{projects.map((p, i) => (
							<a class="work-item" href={`/work/${p.id}`} data-cursor="view">
								<div class="work-media">
									<img src={p.data.img} alt={p.data.img_alt || p.data.title} loading="lazy" decoding="async" />
									<span class="work-index">{String(i + 1).padStart(2, '0')}</span>
								</div>
								<div class="work-meta">
									<h4 class="work-title">{p.data.title}</h4>
									<p class="work-desc">{p.data.description}</p>
									<div class="work-tags">{p.data.tags.slice(0, 3).map((t) => <span>{t}</span>)}</div>
									<span class="work-arrow">View case study <span aria-hidden="true">&#8594;</span></span>
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			<section class="section with-background">
				<header class="section-header stack gap-2 lg:gap-4">
					<p class="section-eyebrow">The Journal</p>
					<h2>Latest Posts</h2>
					<p>Read my latest thoughts on marketing, AI, SEO, and growth strategy.</p>
				</header>

				<div class="gallery">
					<ul class="signal-posts-grid">
						{
							posts.map((post) => (
								<li>
									<BlogPreview post={post} />
								</li>
							))
						}
					</ul>
				</div>

				<div class="cta signal-posts-cta">
					<CallToAction href="/blog/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background">
				<div class="resume-wrapper">
					<ResumeSection />
				</div>
			</section>

			<section class="signal-brands-sec">
				<header class="signal-brands-head section-header stack gap-2 lg:gap-4">
					<p class="section-eyebrow">Trusted by</p>
					<h2>Brands I've helped grow</h2>
				</header>
				<div class="signal-marquee signal-marquee--brands" aria-hidden="true">
					<div class="mq-track" id="mq-brands">
						{[...brands, ...brands, ...brands, ...brands, ...brands, ...brands].map((brand) => (
							<span class="mq-logo"><img src={brand.logo} alt={brand.name} loading="lazy" decoding="async" /></span>
						))}
					</div>
				</div>
			</section>
		</main>

		<!-- Newsletter / Get Updates -->
		<section class="newsletter-section">
			<div class="wrapper newsletter-wrapper">
				<div class="newsletter-content">
					<h2>Get Updates</h2>
					<p>Subscribe for insights on marketing, AI, SEO, and growth strategy. No spam, just value.</p>
				</div>
				<form id="newsletter-form" class="newsletter-form" action="https://app.kit.com/forms/9145889/subscriptions" method="post" data-sv-form="9145889" data-uid="e4f2ff34aa" data-format="inline" data-version="5">
					<input
						type="email"
						name="email_address"
						placeholder="Your email address"
						required
						autocomplete="email"
						aria-label="Email address for newsletter"
					/>
					<button type="submit">Subscribe</button>
				</form>
				<p class="newsletter-status" id="newsletter-status" role="status" aria-live="polite"></p>
			</div>
		</section>

		<ContactCTA />
	</div>
</BaseLayout>

<script>
	function initHomePage() {
		const stats = document.querySelectorAll('.stat[data-count]');
		if (!stats.length) return;

		// Reset stat values for re-animation
		stats.forEach((stat) => {
			const valueEl = stat.querySelector('.stat-value') as HTMLElement;
			if (valueEl) valueEl.textContent = '0';
		});

		const prefersReduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
		const animateCountUp = () => {
			stats.forEach((stat) => {
				const target = parseFloat(stat.getAttribute('data-count') || '0');
				const hasDecimal = stat.hasAttribute('data-decimal');
				const valueEl = stat.querySelector('.stat-value') as HTMLElement;
				if (!valueEl) return;

				// Respect reduced motion: write the final value, no animation.
				if (prefersReduced) {
					valueEl.textContent = hasDecimal ? target.toFixed(1) : target.toString();
					return;
				}

				const duration = 2000;
				const startTime = performance.now();

				const update = (currentTime: number) => {
					const elapsed = currentTime - startTime;
					const progress = Math.min(elapsed / duration, 1);
					const eased = 1 - Math.pow(1 - progress, 3);
					const current = eased * target;

					valueEl.textContent = hasDecimal
						? current.toFixed(1)
						: Math.floor(current).toString();

					if (progress < 1) {
						requestAnimationFrame(update);
					} else {
						valueEl.textContent = hasDecimal
							? target.toFixed(1)
							: target.toString();
					}
				};

				requestAnimationFrame(update);
			});
		};

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						animateCountUp();
						observer.disconnect();
					}
				});
			},
			{ threshold: 0.3 }
		);

		const section = document.querySelector('.stats');
		if (section) observer.observe(section);

		// Newsletter form (Kit / ConvertKit)
		const nlForm = document.getElementById('newsletter-form') as HTMLFormElement;
		const nlStatus = document.getElementById('newsletter-status') as HTMLElement;
		if (nlForm && !(nlForm as any)._nlInit) {
			(nlForm as any)._nlInit = true;
			nlForm.addEventListener('submit', async (e) => {
				e.preventDefault();
				const btn = nlForm.querySelector('button') as HTMLButtonElement;
				btn.textContent = 'Subscribing...';
				btn.disabled = true;

				try {
					const formData = new FormData(nlForm);
					const res = await fetch(nlForm.action, {
						method: 'POST',
						body: formData,
						headers: { 'Accept': 'application/json' },
					});
					if (!res.ok) throw new Error('Subscription failed');

					nlStatus.textContent = 'Done - subscribed! You\'ll hear from me soon.';
					nlStatus.style.color = 'var(--sg-text)';
					nlForm.reset();

					window.dataLayer?.push({ event: 'newsletter_signup', signup_location: 'homepage' });
				} catch {
					nlStatus.textContent = 'Error - something went wrong. Please try again.';
					nlStatus.style.color = 'var(--sg-text)';
				}
				btn.textContent = 'Subscribe';
				btn.disabled = false;
			});
		}
	}
	document.addEventListener('astro:page-load', initHomePage);
</script>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ====================================================== */

	.stats {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
		text-align: center;
		padding: 2rem 0;
	}

	.stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		padding: 1.5rem 0.75rem;
		position: relative;
	}

	.stat-number {
		display: flex;
		align-items: baseline;
		gap: 0.1em;
	}

	.stat-value {
		font-size: var(--text-3xl);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1;
		color: var(--sg-warm);
		background: linear-gradient(120deg, var(--sg-strand-0), var(--sg-warm));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.stat-suffix {
		font-size: var(--text-xl);
		font-family: var(--font-brand);
		font-weight: 600;
		color: var(--sg-warm);
		background: linear-gradient(120deg, var(--sg-strand-0), var(--sg-warm));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.stat-label {
		font-size: var(--text-sm);
		color: var(--sg-muted);
		letter-spacing: 0.02em;
	}

	@media (min-width: 50em) {
		.stats {
			grid-template-columns: repeat(5, 1fr);
			gap: 0;
			padding: 3rem 0;
		}

		.stat {
			padding: 1.5rem 2rem;
			border-right: 1px solid var(--gray-800);
		}

		.stat:last-child {
			border-right: none;
		}

		.stat-value {
			font-size: var(--text-5xl);
		}

		.stat-suffix {
			font-size: var(--text-2xl);
		}

		.stat-label {
			font-size: var(--text-sm);
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h2 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h2 {
			font-size: clamp(2.5rem, 5vw, 4.5rem);
			letter-spacing: -0.02em;
			line-height: 1;
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.resume-wrapper {
		grid-column: 1 / -1;
		/* frosted glass: the strand passes BEHIND and reads as a soft blur through the panel */
		border: 1px solid var(--sg-hair);
		border-radius: clamp(1rem, 2vw, 1.75rem);
