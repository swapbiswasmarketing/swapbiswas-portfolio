		--sg-strand-w: 3.2;
		--sg-pkt-w: 4.2;
		--sg-pkt2-w: 3.2;
		--sg-aura-op: 0.13;
		--sg-constellation-op: 0.46;
		--sg-eyebrow: #9b30d9;
		--sg-ok: #1aa179;
		--sg-bgword-stroke: rgba(20, 23, 43, 0.09);
		--sg-packet: #7611a6;
		--sg-packet-2: #c561f6;
		--sg-flare: #7611a6;
		--sg-filament: rgba(118, 17, 166, 0.45);
		--sg-ring: rgba(118, 17, 166, 0.55);
		--sg-dot: #7611a6;
		--sg-dot-shadow: rgba(118, 17, 166, 0.45);
	}
	:root.theme-dark {
		--sg-void: #07080d;
		--sg-panel: #0e1018;
		--sg-hair: #1c2030;
		--sg-text: #f2f4fb;
		--sg-lede: #cdd3e6;
		--sg-muted: #8a93b5;
		--sg-v1: #c561f6;
		--sg-warm: #ca7879;
		--sg-bloom: #ffe3c2;
		--sg-strand-0: #c561f6;
		--sg-strand-1: #9b30d9;
		--sg-strand-2: #7611a6;
		--sg-strand-3: #ca7879;
		--sg-strand-opacity: 0.85;
		--sg-strand-w: 2.6;
		--sg-pkt-w: 3.6;
		--sg-pkt2-w: 3;
		--sg-aura-op: 0.32;
		--sg-constellation-op: 0.4;
		--sg-eyebrow: #c561f6;
		--sg-ok: #2ec6a8;
		--sg-bgword-stroke: rgba(255, 255, 255, 0.06);
		--sg-packet: #ffe3c2;
		--sg-packet-2: #c561f6;
		--sg-flare: #ffe3c2;
		--sg-filament: rgba(255, 227, 194, 0.5);
		--sg-ring: rgba(197, 97, 246, 0.6);
		--sg-dot: #ffe3c2;
		--sg-dot-shadow: rgba(202, 120, 121, 0.9);
	}
	body { background: var(--sg-void); }
	.backgrounds { background: var(--sg-void) !important; }
	/* suppress the themed section background washes so the strand reads cleanly */
	.with-background::before { display: none !important; }
	/* strand colors - override the SVG presentation attributes, theme-aware */
	#sg0 { stop-color: var(--sg-strand-0); }
	#sg1 { stop-color: var(--sg-strand-1); }
	#sg2 { stop-color: var(--sg-strand-2); }
	#sg3 { stop-color: var(--sg-strand-3); }
	#sp-base { opacity: var(--sg-strand-opacity); stroke-width: var(--sg-strand-w); }
	#sp-pkt1 { stroke: var(--sg-packet); stroke-width: var(--sg-pkt-w); }
	#sp-pkt2 { stroke: var(--sg-packet-2); stroke-width: var(--sg-pkt2-w); }
	#sp-flare { fill: var(--sg-flare); }
	#sp-filament { stroke: var(--sg-filament); }
	/* skills: the signal "routes" into each capability - staggered rise + a
	   gradient route-line landing on each card (set hidden via JS, so no-JS shows cards) */
	.skills > div { position: relative; }
	.skills > div::before {
		content: ''; position: absolute; top: 0; left: 1.25rem; right: 1.25rem; height: 2px;
		background: linear-gradient(90deg, var(--sg-strand-2), var(--sg-warm));
		transform: scaleX(0); transform-origin: left; border-radius: 2px;
	}
	.skills > div.signal-lit::before { animation: sgRoute 0.7s ease-out forwards; }
	@keyframes sgRoute { to { transform: scaleX(1); } }
	/* contact: the CTA pulses as the strand resolves into the ask */
	a.signal-pulse { animation: sgCtaPulse 1.7s ease-out 0.1s 2; }
	@keyframes sgCtaPulse {
		0%, 100% { box-shadow: 0 0 0 0 rgba(197, 97, 246, 0); }
		35% { box-shadow: 0 0 30px 4px rgba(197, 97, 246, 0.45); }
	}
	@media (prefers-reduced-motion: reduce) {
		.skills > div::before { display: none; }
		a.signal-pulse { animation: none; }
	}
	/* hide the native cursor only while the custom cursor is active */
	body.signal-active,
	body.signal-active a,
	body.signal-active button { cursor: none !important; }
</style>

<script>
	import gsap from 'gsap';
	import ScrollTrigger from 'gsap/ScrollTrigger';
	import Lenis from 'lenis';

	gsap.registerPlugin(ScrollTrigger);

	let S: any = null;
	const onHome = () => location.pathname === '/' || location.pathname === '';

	function smoothPath(pts: number[][]) {
		let d = `M ${pts[0][0]} ${pts[0][1]}`;
		for (let i = 0; i < pts.length - 1; i++) {
			const p0 = pts[i - 1] || pts[i], p1 = pts[i], p2 = pts[i + 1], p3 = pts[i + 2] || p2;
			const c1x = p1[0] + (p2[0] - p0[0]) / 6, c1y = p1[1] + (p2[1] - p0[1]) / 6;
			const c2x = p2[0] - (p3[0] - p1[0]) / 6, c2y = p2[1] - (p3[1] - p1[1]) / 6;
			d += ` C ${c1x} ${c1y}, ${c2x} ${c2y}, ${p2[0]} ${p2[1]}`;
		}
		return d;
	}

	function initSignal() {
		if (!onHome() || S) return;
		const svg = document.getElementById('signal-strand') as unknown as SVGSVGElement | null;
		if (!svg) return;

		const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
		const fine = matchMedia('(pointer: fine)').matches;

		const pBase = document.getElementById('sp-base') as unknown as SVGPathElement;
		const pPkt1 = document.getElementById('sp-pkt1') as unknown as SVGPathElement;
		const pPkt2 = document.getElementById('sp-pkt2') as unknown as SVGPathElement;
		const flare = document.getElementById('sp-flare')!;
		const halo = document.getElementById('sp-halo');
		const filament = document.getElementById('sp-filament');
		const ring = document.querySelector('.sc-ring') as HTMLElement;
		const dot = document.querySelector('.sc-dot') as HTMLElement;
		const clabel = document.querySelector('.signal-cursor-label') as HTMLElement;
		const cursorWrap = document.querySelector('.signal-cursor') as HTMLElement;

		S = { tickers: [] as any[], triggers: [] as any[], lenis: null as any, listeners: [] as any[], marquees: [] as any[], refreshHandlers: [] as any[], delayed: [] as any[], tl: null as any, revealTl: null as any };
		const addL = (t: any, e: string, f: any, o?: any) => { t.addEventListener(e, f, o); S.listeners.push([t, e, f, o]); };

		let len = 0;
		let drawnLen = 0;
		let samplePts: number[][] = [];

		// The strand spans the ENTIRE page (absolute, height = full document) and is
		// drawn progressively as you scroll, so its glowing head travels down the page.
		function buildPath() {
			const W = innerWidth;
			svg!.setAttribute('height', '0'); // don't let the strand inflate the measurement
			const Hpage = Math.max(document.documentElement.scrollHeight, innerHeight);
			svg!.setAttribute('width', String(W));
			svg!.setAttribute('height', String(Hpage));
			svg!.setAttribute('viewBox', `0 0 ${W} ${Hpage}`);
			const cx = W * 0.5;
			// Keep the strand in the side GUTTERS (outside the centered content column,
			// max-width 83rem = 664px half) so it frames the content and never crosses
			// reading text on wide screens. On narrow screens it weaves gently behind.
			const contentHalf = Math.min(W * 0.46, 664);
			const gutter = Math.max(0, W / 2 - contentHalf);
			// Narrow screens have no gutter, so a centered weave would cross the text.
			// Run the strand down the right edge as a quiet side-accent instead.
			const narrow = gutter <= 70;
			const amp = contentHalf + Math.min(gutter * 0.55, 130);
			const edgeX = W - 18;
			const sels = ['.signal-hero', '.signal-marquee--tags', '.stats', '.skills', '.signal-work', 'main > section.with-cta', '.resume-wrapper', '.signal-brands-sec', '.newsletter-section', 'aside'];
			const anchors: number[][] = [];
			let ai = 0;
			for (const s of sels) {
				const el = document.querySelector(s);
				if (!el) continue;
				const r = el.getBoundingClientRect();
				const yc = r.top + window.scrollY + r.height / 2;
				if (narrow) {
					anchors.push([edgeX - 12 - 9 * Math.sin(ai * 1.1), yc]);
				} else {
					const dir = ai % 2 === 0 ? 1 : -1;
					const k = 0.85 + 0.15 * Math.sin(ai * 1.3);
					anchors.push([cx + dir * amp * k, yc]);
				}
				ai++;
			}
			const sx = narrow ? edgeX : cx;
			const pts: number[][] = [[sx, -80], ...(anchors.length ? anchors : [[sx, Hpage * 0.5]]), [sx, Hpage + 80]];
			const d = smoothPath(pts);
			pBase.setAttribute('d', d); pPkt1.setAttribute('d', d); pPkt2.setAttribute('d', d);
			len = pBase.getTotalLength();
			pBase.style.strokeDasharray = String(len);
			pPkt2.style.strokeDasharray = `13 ${len}`;
			// pre-sample points once so the head position is a cheap array lookup
			// (instead of getPointAtLength on a full-document path every scroll frame).
			samplePts = [];
			const SAMPLES = 220;
			for (let i = 0; i <= SAMPLES; i++) { const pt = pBase.getPointAtLength((len * i) / SAMPLES); samplePts.push([pt.x, pt.y]); }
		}
		buildPath();
		if (filament) (filament as HTMLElement).style.display = 'none';

		// custom cursor
		if (fine && !reduce) {
			document.body.classList.add('signal-active');
			if (cursorWrap) cursorWrap.style.opacity = '1';
			const rx = gsap.quickTo(ring, 'x', { duration: 0.5, ease: 'power3' });
			const ry = gsap.quickTo(ring, 'y', { duration: 0.5, ease: 'power3' });
			const dx = gsap.quickTo(dot, 'x', { duration: 0.12, ease: 'power3' });
			const dy = gsap.quickTo(dot, 'y', { duration: 0.12, ease: 'power3' });
			const move = (e: MouseEvent) => {
				rx(e.clientX); ry(e.clientY); dx(e.clientX); dy(e.clientY);
				if (clabel) { clabel.style.left = e.clientX + 'px'; clabel.style.top = e.clientY + 32 + 'px'; }
			};
			addL(window, 'mousemove', move);
			document.querySelectorAll('[data-cursor]').forEach((el) => {
				const en = () => { ring.classList.add('is-hot'); if (clabel) { clabel.textContent = el.getAttribute('data-cursor'); clabel.style.opacity = '1'; } };
				const lv = () => { ring.classList.remove('is-hot'); if (clabel) clabel.style.opacity = '0'; };
				addL(el, 'mouseenter', en); addL(el, 'mouseleave', lv);
			});
			addL(window, 'pointerdown', () => gsap.to(ring, { scale: 0.7, duration: 0.18 }));
			addL(window, 'pointerup', () => gsap.to(ring, { scale: 1, duration: 0.18 }));
		} else if (cursorWrap) {
			cursorWrap.style.display = 'none';
		}

		// Lenis smooth scroll
		if (!reduce) {
			const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
			lenis.on('scroll', ScrollTrigger.update);
			const raf = (t: number) => lenis.raf(t * 1000);
			gsap.ticker.add(raf); gsap.ticker.lagSmoothing(0);
			S.tickers.push(raf); S.lenis = lenis;
			(window as any).__lenis = lenis;
		}

		// Draw the strand to your scroll position; the head + trail ride the tip.
		const trailLen = () => Math.min(180, len * 0.06);
		function paintStrand(p: number) {
			drawnLen = len * (0.045 + p * 0.955);
			pBase.style.strokeDashoffset = String(len - drawnLen);
			const tr = trailLen();
			pPkt1.style.strokeDasharray = `${tr} ${len}`;
			pPkt1.style.strokeDashoffset = String(-(drawnLen - tr));
			const si = samplePts.length ? Math.min(samplePts.length - 1, Math.max(0, Math.round((drawnLen / len) * (samplePts.length - 1)))) : 0;
			const tip = samplePts[si] || [0, 0];
			flare.setAttribute('cx', String(tip[0])); flare.setAttribute('cy', String(tip[1]));
			// fade the head + bright trail in with scroll so they never float disconnected at the top
			const headOp = Math.min(1, p * 5);
			flare.setAttribute('fill-opacity', String(headOp));
			pPkt1.style.opacity = String(headOp);
		}

		if (reduce) {
			pBase.style.strokeDashoffset = '0';
			pPkt1.style.display = 'none';
			pPkt2.style.display = 'none';
			flare.setAttribute('opacity', '0');
			if (halo) halo.setAttribute('opacity', '0');
		} else {
			paintStrand(0);
			const draw = ScrollTrigger.create({
				trigger: document.body, start: 'top top', end: 'bottom bottom', scrub: 0.4,
				onUpdate: (self) => paintStrand(self.progress),
			});
			S.triggers.push(draw);

			// a faint data packet flowing within the drawn portion
			let flow = 0;
			const tick = () => {
				flow = (flow + 6) % Math.max(drawnLen, 1);
				pPkt2.style.strokeDashoffset = String(-flow);
			};
			gsap.ticker.add(tick); S.tickers.push(tick);

			// rebuild the path geometry whenever ScrollTrigger re-measures the page
			const onRefresh = () => buildPath();
			ScrollTrigger.addEventListener('refreshInit', onRefresh);
			S.refreshHandlers.push(onRefresh);
			S.delayed.push(gsap.delayedCall(0.6, () => { if (!S) return; buildPath(); ScrollTrigger.refresh(); }));
		}

		// stats: pulse-on-arrival - the strand delivers each metric as it enters view
		const statsSec = document.querySelector('.stats');
		if (statsSec) {
			const st = ScrollTrigger.create({
				trigger: statsSec, start: 'top 78%', once: true,
				onEnter: () => {
					statsSec.querySelectorAll('.stat').forEach((el, i) => {
						gsap.delayedCall(i * 0.18, () => el.classList.add('signal-hit'));
					});
				},
			});
			S.triggers.push(st);
		}

		// skills: staggered route-in reveal + gradient route line on each card
		const skillCards = gsap.utils.toArray<HTMLElement>('.skills > div');
		if (skillCards.length) {
			if (!reduce) gsap.set(skillCards, { opacity: 0, y: 26 });
			const sk = ScrollTrigger.create({
				trigger: '.skills', start: 'top 82%', once: true,
				onEnter: () => skillCards.forEach((el, i) => {
					if (!reduce) gsap.to(el, { opacity: 1, y: 0, duration: 0.7, delay: i * 0.14, ease: 'power3.out' });
					gsap.delayedCall(i * 0.14 + 0.12, () => el.classList.add('signal-lit'));
				}),
			});
			S.triggers.push(sk);
		}

		// brands: light sweeps across the logo wall, card by card, as the strand passes
		const brandCards = gsap.utils.toArray<HTMLElement>('.mention-card');
		if (brandCards.length) {
			const br = ScrollTrigger.create({
				trigger: brandCards[0], start: 'top 84%', once: true,
				onEnter: () => brandCards.forEach((el, i) => gsap.delayedCall(i * 0.12, () => el.classList.add('signal-lit'))),
			});
			S.triggers.push(br);
		}

		// contact: the CTA pulses as the strand resolves into one taut ask
		const contactBtn = document.querySelector('aside a[href^="mailto:"]');
		if (contactBtn) {
			const ct = ScrollTrigger.create({
				trigger: contactBtn, start: 'top 85%', once: true,
				onEnter: () => contactBtn.classList.add('signal-pulse'),
			});
			S.triggers.push(ct);
		}

		// ---- magnetic buttons ----
		if (fine && !reduce) {
			const magnets = Array.from(document.querySelectorAll('[data-magnetic], .cta a, aside a[href^="mailto:"]')) as HTMLElement[];
			magnets.forEach((el) => {
				const qx = gsap.quickTo(el, 'x', { duration: 0.4, ease: 'power3' });
				const qy = gsap.quickTo(el, 'y', { duration: 0.4, ease: 'power3' });
				const mm = (e: MouseEvent) => {
					const r = el.getBoundingClientRect();
					const dx = e.clientX - (r.left + r.width / 2);
					const dy = e.clientY - (r.top + r.height / 2);
					if (Math.hypot(dx, dy) < Math.max(r.width, r.height) * 1.1) { qx(dx * 0.3); qy(dy * 0.3); }
					else { qx(0); qy(0); }
				};
				addL(window, 'mousemove', mm);
			});
		}

		// ---- 3D tilt on the portrait + skill cards (depth) ----
		if (fine && !reduce) {
			const tilt = (el: HTMLElement, max: number) => {
				gsap.set(el, { transformPerspective: 850, transformOrigin: 'center' });
				const qrx = gsap.quickTo(el, 'rotationX', { duration: 0.5, ease: 'power3' });
				const qry = gsap.quickTo(el, 'rotationY', { duration: 0.5, ease: 'power3' });
				const mv = (e: MouseEvent) => {
					const r = el.getBoundingClientRect();
					qry((((e.clientX - r.left) / r.width) - 0.5) * max);
					qrx(-((((e.clientY - r.top) / r.height) - 0.5) * max));
				};
				const lv = () => { qrx(0); qry(0); };
				addL(el, 'mousemove', mv); addL(el, 'mouseleave', lv);
			};
			const pw = document.querySelector('.signal-portrait-wrap') as HTMLElement | null;
			if (pw) tilt(pw, 10);
			gsap.utils.toArray<HTMLElement>('.skills > div').forEach((c) => tilt(c, 7));
		}

		// ---- canvas constellation: drifting data-nodes that link to the cursor ----
		const cvs = document.querySelector('.signal-constellation') as HTMLCanvasElement | null;
		const cctx = cvs ? cvs.getContext('2d') : null;
		if (cvs && cctx && !reduce && fine) {
			const DPR = Math.min(window.devicePixelRatio || 1, 2);
			let cw = 0, ch = 0, cmx = -9999, cmy = -9999;
			let parts: { x: number; y: number; vx: number; vy: number }[] = [];
			const sizeCvs = () => {
				cw = innerWidth; ch = innerHeight;
				cvs.width = Math.floor(cw * DPR); cvs.height = Math.floor(ch * DPR);
				cvs.style.width = cw + 'px'; cvs.style.height = ch + 'px';
				cctx.setTransform(DPR, 0, 0, DPR, 0, 0);
				const n = Math.min(70, Math.floor((cw * ch) / 26000));
				parts = Array.from({ length: n }, () => ({ x: Math.random() * cw, y: Math.random() * ch, vx: (Math.random() - 0.5) * 0.25, vy: (Math.random() - 0.5) * 0.25 }));
			};
			sizeCvs();
			addL(window, 'resize', sizeCvs);
			addL(window, 'mousemove', (e: MouseEvent) => { cmx = e.clientX; cmy = e.clientY; });
			const drawC = () => {
				const dark = document.documentElement.classList.contains('theme-dark');
				const node = dark ? '197,97,246' : '118,17,166';
				const link = dark ? '140,147,181' : '118,17,166';
				cctx.clearRect(0, 0, cw, ch);
				for (const p of parts) {
					p.x += p.vx; p.y += p.vy;
					if (p.x < 0 || p.x > cw) p.vx *= -1;
					if (p.y < 0 || p.y > ch) p.vy *= -1;
				}
				cctx.lineWidth = 1;
				for (let i = 0; i < parts.length; i++) {
					const a = parts[i];
					const dc = Math.hypot(a.x - cmx, a.y - cmy);
					if (dc < 170) { cctx.strokeStyle = `rgba(${node},${(1 - dc / 170) * 0.45})`; cctx.beginPath(); cctx.moveTo(a.x, a.y); cctx.lineTo(cmx, cmy); cctx.stroke(); }
					for (let j = i + 1; j < parts.length; j++) {
						const b = parts[j], d = Math.hypot(a.x - b.x, a.y - b.y);
						if (d < 120) { cctx.strokeStyle = `rgba(${link},${(1 - d / 120) * 0.18})`; cctx.beginPath(); cctx.moveTo(a.x, a.y); cctx.lineTo(b.x, b.y); cctx.stroke(); }
					}
					cctx.fillStyle = `rgba(${node},0.55)`; cctx.beginPath(); cctx.arc(a.x, a.y, 1.4, 0, Math.PI * 2); cctx.fill();
				}
			};
			gsap.ticker.add(drawC); S.tickers.push(drawC);
		}

		// ---- infinite marquees (seamless -50% over duplicated content) ----
		const mq = (id: string, dur: number) => {
			const el = document.getElementById(id);
			if (el && !reduce) S.marquees.push(gsap.to(el, { xPercent: -50, duration: dur, ease: 'none', repeat: -1 }));
		};
		mq('mq-tags', 28);
		mq('mq-brands', 95);

		// ---- scroll progress bar + section index HUD ----
		const bar = document.getElementById('signal-progress-bar');
		const hudIdx = document.getElementById('signal-hud-idx');
		const TOTAL = 6;
		const sp = ScrollTrigger.create({
			trigger: document.body, start: 'top top', end: 'bottom bottom', scrub: true,
			onUpdate: (self) => {
				if (bar) bar.style.transform = `scaleX(${self.progress})`;
				if (hudIdx) hudIdx.textContent = String(Math.min(TOTAL, Math.floor(self.progress * TOTAL) + 1)).padStart(2, '0');
			},
		});
		S.triggers.push(sp);

		// ---- parallax on the giant background wordmark ----
		const bgword = document.querySelector('.signal-bgword');
		if (bgword && !reduce) {
			const pw = gsap.to(bgword, { yPercent: 24, ease: 'none', scrollTrigger: { trigger: '.signal-hero', start: 'top top', end: 'bottom top', scrub: true } });
			if (pw.scrollTrigger) S.triggers.push(pw.scrollTrigger);
		}

		// ---- reveal-on-scroll across the whole page ----
		if (!reduce) {
			const items = gsap.utils.toArray<HTMLElement>('.section-header, .work-item, .gallery li, .resume-wrapper, .newsletter-content, aside');
			if (items.length) {
				gsap.set(items, { opacity: 0, y: 40 });
				ScrollTrigger.batch(items, {
					start: 'top 86%',
					onEnter: (els) => gsap.to(els, { opacity: 1, y: 0, duration: 0.8, stagger: 0.12, ease: 'power3.out', overwrite: true }),
				}).forEach((t) => S.triggers.push(t));
			}
		}

		// reveal
		const portrait = document.querySelector('.signal-portrait') as HTMLElement | null;
		const fades = gsap.utils.toArray<HTMLElement>('.signal-hero [data-fade]');
		const h1lines = gsap.utils.toArray<HTMLElement>('.signal-h1 .ln > span');

		// split the hero name into letters for a kinetic, cursor-reactive reveal
		const letters: HTMLElement[] = [];
		h1lines.forEach((word) => {
			const text = word.textContent || '';
			word.textContent = '';
			for (const ch of text) {
				const s = document.createElement('span');
				s.className = 'ltr';
				s.textContent = ch;
				word.appendChild(s);
				letters.push(s);
			}
		});
		if (fine && !reduce && letters.length) {
			const qs = letters.map((l) => gsap.quickTo(l, 'y', { duration: 0.5, ease: 'power3' }));
			const hero = document.querySelector('.signal-hero') as HTMLElement | null;
			if (hero) {
				const lm = (e: MouseEvent) => letters.forEach((l, i) => {
					const r = l.getBoundingClientRect();
					const d = Math.hypot(e.clientX - (r.left + r.width / 2), e.clientY - (r.top + r.height / 2));
					qs[i](d < 150 ? -(1 - d / 150) * 18 : 0);
				});
				addL(hero, 'mousemove', lm);
				addL(hero, 'mouseleave', () => qs.forEach((q) => q(0)));
			}
		}

		const reveal = () => {
			if (!S) return;
			const tl = gsap.timeline();
			S.revealTl = tl;
			// ignite only the hero portion of the strand; the rest draws on scroll
			tl.fromTo(pBase, { strokeDashoffset: len }, { strokeDashoffset: len - len * 0.045, duration: 1.0, ease: 'power2.inOut' }, 0)
				.to(letters, { yPercent: 0, duration: 0.85, ease: 'power4.out', stagger: 0.035 }, '-=0.5');
			if (portrait) tl.to(portrait, { clipPath: 'circle(140% at 50% 45%)', duration: 1.1, ease: 'power3.inOut' }, '-=0.8');
			tl.to(fades, { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out', stagger: 0.1 }, '-=0.7');
		};

		if (reduce) {
			document.documentElement.classList.remove('signal-js');
			const ld = document.getElementById('signal-loader'); if (ld) ld.style.display = 'none';
			gsap.set(pBase, { strokeDashoffset: 0 });
		} else {
			// set the hidden start states for the reveal
			gsap.set(pBase, { strokeDashoffset: len });
			if (letters.length) gsap.set(letters, { yPercent: 115 });
			if (fades.length) gsap.set(fades, { opacity: 0, y: 24 });
			if (portrait) gsap.set(portrait, { clipPath: 'circle(0% at 50% 45%)' });

			if ((window as any).__signalLoaderShown) {
				const ld = document.getElementById('signal-loader'); if (ld) ld.style.display = 'none';
				reveal();
			} else {
				(window as any).__signalLoaderShown = true;
				const pctEl = document.getElementById('signal-pct');
				const barEl = document.getElementById('signal-bar');
				const o = { v: 0 };
				S.tl = gsap.timeline()
					.to(o, { v: 100, duration: 1.4, ease: 'power2.inOut', onUpdate: () => {
						if (pctEl) pctEl.textContent = String(Math.round(o.v));
						if (barEl) barEl.style.transform = `scaleX(${o.v / 100})`;
					} })
					.to('.sl-inner', { y: -24, opacity: 0, duration: 0.5, ease: 'power3.in' }, '+=0.12')
					.to('#signal-loader', { yPercent: -100, duration: 0.95, ease: 'expo.inOut', onComplete: () => { const ld = document.getElementById('signal-loader'); if (ld) ld.style.display = 'none'; } }, '-=0.18')
					.add(reveal, '-=0.62');
			}
		}
	}

	function teardownSignal() {
		if (!S) return;
		S.tickers.forEach((fn: any) => gsap.ticker.remove(fn));
		S.triggers.forEach((t: any) => t && t.kill());
		(S.marquees || []).forEach((tw: any) => tw && tw.kill());
		(S.refreshHandlers || []).forEach((h: any) => ScrollTrigger.removeEventListener('refreshInit', h));
		(S.delayed || []).forEach((d: any) => d && d.kill());
		if (S.tl) { try { S.tl.kill(); } catch (e) {} }
		if (S.revealTl) { try { S.revealTl.kill(); } catch (e) {} }
		if (S.lenis) { try { S.lenis.destroy(); } catch (e) {} }
		try { delete (window as any).__lenis; } catch (e) {}
		S.listeners.forEach(([t, e, f, o]: any[]) => t.removeEventListener(e, f, o));
		gsap.ticker.lagSmoothing(500, 33); // restore the global default we disabled for Lenis
		document.body.classList.remove('signal-active');
		S = null;
	}

	document.addEventListener('astro:page-load', initSignal);
	document.addEventListener('astro:before-swap', teardownSignal);
</script>
