---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
	{
		question: "What services do you offer?",
		answer: "I offer AI & Automation, Data Analytics, Digital Marketing, Customer Intelligence, and Strategic Agility services. Contact me for a customized proposal.",
	},
	{
		question: "How much do your services cost?",
		answer: "My rates start at $29.9/hr for part-time engagements, $369.9/week for freelance projects, or $1,299/month for full-time collaboration. Contact me for detailed pricing.",
	},
	{
		question: "What is your experience?",
		answer: "I'm currently pursuing my Postgraduate Degree in Digital Marketing & Growth Strategy at IIM Visakhapatnam. I've worked as a Product Marketing Manager at LambdaTest and have experience with brands like Samsung, Appknox, Sociowash, and Lido Learning.",
	},
	{
		question: "How can I hire you?",
		answer: "Simply send me a message through the contact form or email me directly at swapbiswas.marketing@gmail.com. I typically respond within 24 hours.",
	},
	{
		question: "Do you work remotely?",
		answer: "Yes, I work with clients globally and am comfortable with remote collaboration using modern communication and project management tools.",
	},
];
---

<BaseLayout title="Contact | Swapnil Biswas" description="Get in touch with Swapnil Biswas" breadcrumbs={[{ name: "Contact" }]}>
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": faqs.map((faq) => ({
			"@type": "Question",
			"name": faq.question,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": faq.answer
			}
		}))
	})} />
	<div class="stack gap-20">
		<main class="wrapper contact">
			<Hero
				title="Contact"
				tagline="Let's Talk. Reach out using the form below or email me directly."
				align="start"
			/>

			<div class="contact-grid">
				<section class="form-section">
					<h2>It all starts with hello..</h2>
					<form id="contact-form" action="https://formsubmit.co/swapbiswas.marketing@gmail.com" method="POST" data-send-to="swapbiswas.marketing@gmail.com">
						<input type="hidden" name="_subject" value="Message from swapbiswas.com" />
						<input type="hidden" name="_captcha" value="false" />
						<input type="hidden" name="_template" value="table" />
						<input type="hidden" name="_next" value="https://swapbiswas.com/contact/?success=true" />
						<div class="form-group">
							<label for="full_name">Name</label>
							<input
								type="text"
								id="full_name"
								name="full_name"
								placeholder="Your name"
								required
								autocomplete="name"
							/>
						</div>
						<div class="form-group">
							<label for="email">Contact email</label>
							<input
								type="email"
								id="email"
								name="email"
								placeholder="you@example.com"
								required
								autocomplete="email"
							/>
						</div>
						<div class="form-group">
							<label for="message">Message</label>
							<textarea
								id="message"
								name="message"
								rows="5"
								placeholder="Be as detailed as possible..."
							></textarea>
						</div>
						<div id="form-success" class="form-message success" style="display:none">
							<strong>Message sent!</strong> Thank you for reaching out. I'll get back to you within 24 hours.
						</div>
						<div id="form-error" class="form-message error" style="display:none">
							Something went wrong. Please try emailing me directly at <a href="mailto:swapbiswas.marketing@gmail.com">swapbiswas.marketing@gmail.com</a>.
						</div>
						<button id="send-button" type="submit">Send Message</button>
					</form>
				</section>

				<section class="faq-section">
					<div class="faq-box">
						<h2>Frequently Asked Questions</h2>
						<p class="faq-subtitle">Here are the answers to the most common questions.</p>
						{faqs.map((item, index) => (
							<div class:list={["accordion", { "first": index === 0 }]}>
								<h3 class="accordion-trigger" role="button" tabindex="0" aria-expanded="false">
									<span>{item.question}</span>
									<span class="accordion-icon" aria-hidden="true">+</span>
								</h3>
								<div class="accordion-content" role="region">
									<p>{item.answer}</p>
								</div>
							</div>
						))}
					</div>
				</section>
			</div>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<script>
	function initContactPage() {
		const form = document.querySelector("#contact-form") as HTMLFormElement;
		if (!form || (form as any)._contactInit) return;
		(form as any)._contactInit = true;
		const successEl = document.querySelector("#form-success") as HTMLElement;
		const errorEl = document.querySelector("#form-error") as HTMLElement;
		const sendBtn = document.querySelector("#send-button") as HTMLButtonElement;
		const email = form.getAttribute("data-send-to");

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			sendBtn.disabled = true;
			sendBtn.textContent = "Sending...";
			successEl.style.display = "none";
			errorEl.style.display = "none";

			const formData = new FormData();
			formData.append("_subject", (form.elements.namedItem("_subject") as HTMLInputElement).value);
			formData.append("name", (form.elements.namedItem("full_name") as HTMLInputElement).value);
			formData.append("email", (form.elements.namedItem("email") as HTMLInputElement).value);
			formData.append("message", (form.elements.namedItem("message") as HTMLTextAreaElement).value);
			formData.append("_captcha", "false");
			formData.append("_template", "table");

			try {
				const response = await fetch(`https://formsubmit.co/ajax/${email}`, {
					method: "POST",
					body: formData,
				});

				const result = await response.json();

				if (result.success === "true") {
					form.reset();
					successEl.style.display = "block";
					sendBtn.textContent = "Sent!";
					setTimeout(() => { sendBtn.textContent = "Send Message"; }, 3000);
				} else {
					throw new Error(result.message || "Form submission failed");
				}
			} catch {
				errorEl.style.display = "block";
				sendBtn.textContent = "Send Message";
			} finally {
				sendBtn.disabled = false;
			}
		});

		const accordions = document.querySelectorAll(".accordion");
		accordions.forEach((accordion) => {
			const trigger = accordion.querySelector(".accordion-trigger");
			trigger?.addEventListener("click", () => {
				const isActive = accordion.classList.contains("active");
				accordions.forEach((a) => {
					a.classList.remove("active");
					a.querySelector(".accordion-trigger")?.setAttribute("aria-expanded", "false");
					const content = a.querySelector(".accordion-content") as HTMLElement;
					if (content) content.style.maxHeight = "";
				});
				if (!isActive) {
					accordion.classList.add("active");
					trigger.setAttribute("aria-expanded", "true");
					const content = accordion.querySelector(".accordion-content") as HTMLElement;
					if (content) content.style.maxHeight = content.scrollHeight + "px";
				}
			});
		});
	}
	initContactPage();
	document.addEventListener("astro:page-load", initContactPage);

	// Show success message if redirected back from FormSubmit
	if (window.location.search.includes('success=true')) {
		const successEl = document.querySelector("#form-success") as HTMLElement;
		if (successEl) successEl.style.display = "block";
		// Clean URL
		window.history.replaceState({}, '', window.location.pathname);
	}
</script>

<style>
	.contact {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	.contact-grid {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	h2 {
		font-size: var(--text-2xl);
		color: var(--gray-0);
		margin-bottom: 1rem;
	}

	/* Form Styles */
	.form-section {
		width: 100%;
	}

	.form-group {
		margin-bottom: 1.5rem;
	}

	label {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--gray-200);
		font-size: var(--text-sm);
	}

	input,
	textarea {
		width: 100%;
		padding: 0.75rem 1rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		background: var(--gray-999_40);
		color: var(--gray-200);
		font-family: var(--font-body);
		font-size: var(--text-md);
		transition: border-color var(--theme-transition);
	}

	input:focus,
	textarea:focus {
		outline: none;
		border-color: var(--accent-regular);
	}

	textarea {
		resize: vertical;
	}

	button[type="submit"] {
		display: inline-block;
		padding: 0.75rem 2rem;
		border: none;
		border-radius: 999rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		font-family: var(--font-brand);
		font-size: var(--text-md);
		font-weight: 500;
		cursor: pointer;
		transition: box-shadow var(--theme-transition);
	}

	button[type="submit"]:hover {
		box-shadow: var(--shadow-md);
	}

	button[type="submit"]:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}

	.form-message {
		padding: 0.75rem 1rem;
		border-radius: 0.5rem;
		margin-bottom: 1rem;
		font-size: var(--text-sm);
	}

	.form-message.success {
		background: #065f4620;
		color: #34d399;
		border: 1px solid #34d39940;
	}

	.form-message.error {
		background: #7f1d1d20;
		color: #f87171;
		border: 1px solid #f8717140;
	}

	.form-message.error a {
		color: #f87171;
		text-decoration: underline;
	}

	/* FAQ Styles */
	.faq-box {
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background-color: var(--gray-999_40);
		box-shadow: var(--shadow-sm);
	}

	.faq-subtitle {
		color: var(--gray-300);
		margin-bottom: 1.5rem;
	}

	.accordion {
		border-top: 1px solid var(--gray-800);
	}

	.accordion.first {
		border-top: none;
	}

	.accordion-trigger {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.25rem 0;
		cursor: pointer;
		font-size: var(--text-md);
		font-weight: 500;
		color: var(--gray-200);
		user-select: none;
		margin: 0;
	}

	.accordion-trigger:hover {
		color: var(--gray-0);
	}

	.accordion-icon {
		font-size: var(--text-lg);
		transition: transform 0.2s ease;
	}

	.accordion.active .accordion-icon {
		transform: rotate(45deg);
	}

	.accordion-content {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.25s ease-out, opacity 0.25s ease-out;
		opacity: 0;
	}

	.accordion.active .accordion-content {
		opacity: 1;
	}

	.accordion-content p {
		padding-bottom: 1.25rem;
		color: var(--gray-300);
		line-height: 1.6;
	}

	@media (min-width: 50em) {
		.contact-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
		}

		.faq-box {
			border-radius: 1.5rem;
			padding: 2.5rem;
		}
	}
</style>
