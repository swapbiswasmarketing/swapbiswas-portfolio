<script>
  // Spreadsheet interaction: switch active sheet, select cells, arrow-key navigation.
  // Plain script (no Astro scoping of the JS). Every sheet renders in markup; this only toggles state.
  (function spreadsheet(){
    const nameRef  = document.getElementById('nameref');
    const formula  = document.getElementById('formula');
    const colhead  = document.getElementById('colhead');
    const scroller = document.getElementById('gridscroll');
    const sheets   = Array.from(document.querySelectorAll('.sheet'));
    const tabs     = Array.from(document.querySelectorAll('.tab'));
    const statusMini = document.querySelector('.statusmini');

    const colLetter = c => c; // refs already carry their letter

    function setFormula(ref, val, f){
      nameRef.textContent = ref || 'A1';
      // formula bar shows the formula if present, else the raw value
      const text = (f && f.length) ? f : (val || '');
      formula.textContent = text;
      const cur = document.createElement('span');
      cur.className = 'blink';
      formula.appendChild(cur);
      // light up the matching column header letter
      const letter = ref ? ref.charAt(0) : 'A';
      colhead.querySelectorAll('.cl').forEach(cl => cl.classList.toggle('on', cl.dataset.col === letter));
    }

    function clearSel(){
      document.querySelectorAll('.cell.sel').forEach(c => c.classList.remove('sel'));
      document.querySelectorAll('.r.on').forEach(r => r.classList.remove('on'));
    }

    function selectCell(cell, scroll){
      if(!cell) return;
      clearSel();
      cell.classList.add('sel');
      const row = cell.closest('.r');
      if(row) row.classList.add('on');
      setFormula(cell.dataset.ref, cell.dataset.val, cell.dataset.formula);
      if(scroll){
        cell.scrollIntoView({block:'nearest', inline:'nearest', behavior:'smooth'});
      }
    }

    function activeSheet(){ return sheets.find(s => s.classList.contains('active')); }

    function selectableCells(sheet){
      // cells that have a reference (skip purely structural empties is fine, they have refs too)
      return Array.from(sheet.querySelectorAll('.cell[data-ref]'));
    }

    function showSheet(name){
      const id = 'sheet-' + name;
      sheets.forEach(s => {
        const on = s.id === id;
        s.classList.toggle('active', on);
        if(on){ s.hidden = false; } else { s.hidden = true; }
      });
      tabs.forEach(t => t.setAttribute('aria-selected', String(t.dataset.tab === name)));
      // select the first meaningful cell of the new sheet and reset scroll
      const sheet = document.getElementById(id);
      if(sheet){
        scroller.scrollTop = 0;
        const first = selectableCells(sheet)[0];
        selectCell(first, false);
      }
      if(statusMini){
        const map = {overview:'Sum: 657K+', work:'6 rows', growth:'Trend up', about:'4 facts', contact:'Open'};
        statusMini.innerHTML = '<span style="color:var(--accent)">&#9679;</span> Ready &middot; ' + (map[name] || 'Ready');
      }
    }

    // ---- tab + data-tab click wiring ----
    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('[data-tab]');
      if(trigger){
        e.preventDefault();
        showSheet(trigger.dataset.tab);
        return;
      }
      const cell = e.target.closest('.cell[data-ref]');
      // let real links inside cells work (mailto / linkedin)
      if(cell && !e.target.closest('a')){
        selectCell(cell, false);
      }
    });

    // ---- keyboard navigation (arrow keys move the cursor within the active sheet) ----
    document.addEventListener('keydown', (e) => {
      if(!['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) return;
      const tag = (e.target.tagName || '').toLowerCase();
      if(tag === 'input' || tag === 'textarea') return;
      const sheet = activeSheet();
      if(!sheet) return;
      const cells = selectableCells(sheet);
      if(!cells.length) return;
      const current = sheet.querySelector('.cell.sel');
      let idx = current ? cells.indexOf(current) : -1;
      if(idx === -1){ e.preventDefault(); selectCell(cells[0], true); return; }

      const curRow = current.closest('.r');
      const rowsOrder = Array.from(sheet.querySelectorAll('.r'));
      const rowIndex = rowsOrder.indexOf(curRow);

      if(e.key === 'ArrowLeft'){ idx = Math.max(0, idx - 1); e.preventDefault(); selectCell(cells[idx], true); }
      else if(e.key === 'ArrowRight'){ idx = Math.min(cells.length - 1, idx + 1); e.preventDefault(); selectCell(cells[idx], true); }
      else if(e.key === 'ArrowUp' || e.key === 'ArrowDown'){
        // move to first cell of the prev/next row that has cells
        const dir = e.key === 'ArrowDown' ? 1 : -1;
        let r = rowIndex + dir;
        while(r >= 0 && r < rowsOrder.length){
          const target = rowsOrder[r].querySelector('.cell[data-ref]');
          if(target){ e.preventDefault(); selectCell(target, true); return; }
          r += dir;
        }
      }
    });

    // ---- initial state: Overview, headline cell selected, formula shown ----
    const start = document.querySelector('#sheet-overview .cell[data-ref="A2"]')
              || selectableCells(document.getElementById('sheet-overview'))[0];
    selectCell(start, false);
  })();
</script>
</body>
</html>
