---
// REDESIGN PROTOTYPE - "Spreadsheet" (Concept 38) - the portfolio as a literal spreadsheet app.
// Original concept (NOT a reskin of halftone): own layout + interaction + palette + fonts.
//  - The whole page is a Google-Sheets / Excel style application: toolbar, FORMULA BAR (name box
//    + fx + formula text), column letters A..F, row numbers, a real cell grid, SHEET TABS at the
//    bottom that switch views (Overview / Work / Growth / About / Contact).
//  - Selecting any cell draws the cell cursor (green ring), writes its reference (e.g. B7) into the
//    name box and its value/formula into the formula bar. Arrow keys move the cursor.
//  - Metrics are COMPUTED cells: the cell shows the result (657K) and its formula (=SUM(Leads))
//    appears in the formula bar when selected. Build stats 20+/15+/76 are computed cells too.
//  - A small embedded SVG bar chart lives on the Growth sheet.
// Self-contained: own <html>, own Google Fonts <link>, own tokens, noindex. No BaseLayout/global.css.
// Content reused verbatim from the canonical set. Only LambdaTest has hard numbers.
//
// NO em-dash anywhere. html,body{overflow-x:clip}. The grid scrolls inside its own container so the
// page never scrolls horizontally at 1440px or 414px. AA body contrast >= 4.5:1. JS only toggles the
// active sheet + the selected cell; every sheet renders in the markup and is readable without JS.

const metrics = [
  { ref: 'B4', val: '657K+', label: 'Leads generated',     formula: '=SUM(Leads[LambdaTest])' },
  { ref: 'C4', val: '18.2M+', label: 'Organic traffic',    formula: '=SUM(Sessions[Organic])' },
  { ref: 'D4', val: '10x',    label: 'Pipeline multiple',  formula: '=Pipeline / Spend' },
];
const build = [
  { ref: 'B7', val: '20+', label: 'AI agents & internal tools shipped', formula: '=COUNTA(Agents[Shipped])' },
  { ref: 'C7', val: '15+', label: 'Marketers mentored & levelled up',   formula: '=COUNTA(Mentees)' },
  { ref: 'D7', val: '76',  label: 'Long-form articles published',       formula: '=COUNTA(Articles)' },
];
const pillars = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.' },
];
const work = [
  { c: 'LambdaTest',               y: '2021 - 2025', role: 'Product & digital marketing', o: '657K+ leads, 18.2M+ organic', note: 'Owned product and digital marketing end to end and built the full organic growth engine.' },
  { c: 'TestMu AI',                y: '2026',        role: 'Rebrand lead',                o: 'Full company rebrand',         note: 'Led the complete rebrand from LambdaTest to TestMu AI.' },
  { c: 'Samsung',                  y: '2019',        role: 'via Sociowash',               o: 'Galaxy M-series launch',       note: 'On the Galaxy M-series from inception; ran content distribution, collaborated with Technical Guruji.' },
  { c: 'Medilife Superspeciality', y: '0 to 1',      role: 'Marketing & web',             o: 'Website, GTM, social',         note: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.' },
  { c: 'Lido Learning',            y: '2021',        role: 'Growth / CRM',                o: 'CRM & lead operations',        note: 'Ran CRM management and lead routing and assignment for the EdTech.' },
  { c: 'Appknox',                  y: 'Freelance',   role: 'Content',                     o: 'Security content',             note: 'Freelance content writer for the mobile app security company.' },
];
const recognition = [
  { t: 'Value of Agility Award', m: 'LambdaTest, 2024' },
  { t: 'Wall of Fame',           m: 'LambdaTest' },
  { t: '#1 Product of the Day',  m: 'Product Hunt' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
const facts = [
  { k: 'Based',     v: 'Mumbai, India' },
  { k: 'Tenure',    v: '7+ years marketing, 4+ in B2B SaaS' },
  { k: 'Education', v: 'Postgrad in Digital Marketing & Growth Strategy, IIM Visakhapatnam' },
  { k: 'Practice',  v: 'PMM & growth strategist who codes AI agents, ships websites and runs technical SEO' },
];
// the organic-traffic bars for the embedded chart (illustrative ramp, not invented client metrics)
const chart = [
  { y: '2021', h: 14 }, { y: '2022', h: 33 }, { y: '2023', h: 58 }, { y: '2024', h: 84 }, { y: '2025', h: 100 },
];
---
<!doctype html>
<html lang="en" data-theme="spreadsheet">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --app:#16181c;        /* application backdrop */
    --chrome:#202327;     /* toolbar / header strips */
    --chrome2:#1b1e22;    /* name box / fx field */
    --sheet:#1a1d21;      /* sheet surface (cells) */
    --sheet2:#1d2024;     /* zebra / merged title cell */
    --grid:#2c3138;       /* gridlines */
    --grid2:#373d45;      /* heavier border */
    --hdr:#23272c;        /* column/row header fill */
    --ink:#e8eaed;        /* primary text - ~13:1 on --sheet */
    --ink2:#c2c7cd;       /* secondary - ~8:1 */
    --dim:#9aa0a8;        /* muted labels - ~4.9:1 on --sheet (AA) */
    --faint:#6f757d;      /* chrome-only, never body copy */
    --accent:#37c180;     /* Sheets green */
    --accent-d:#2aa46b;
    --accent-soft:rgba(55,193,128,.16);
    --accent-line:rgba(55,193,128,.55);
    --sel:rgba(55,193,128,.10);
    --sans:"Inter",system-ui,-apple-system,sans-serif;
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --rowh:34px;          /* base data row height */
    --rownum:42px;        /* row-number gutter width */
    --pad:clamp(.7rem,2vw,1.4rem);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{overflow-x:clip}
  html{scroll-behavior:smooth}
  body{
    background:var(--app);color:var(--ink);font-family:var(--sans);min-height:100vh;
    -webkit-font-smoothing:antialiased;line-height:1.55;letter-spacing:.002em;
    display:flex;flex-direction:column;
    background-image:
      linear-gradient(135deg,#15171b,#16181c 40%,#14161a);
  }
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--accent-soft);color:var(--ink)}

  /* ============ APP SHELL ============ */
  .app{
    width:min(1320px,100%);margin:0 auto;flex:1;display:flex;flex-direction:column;
    padding:clamp(.6rem,2vw,1.4rem);gap:0;min-width:0;
  }
  .frame{
    border:1px solid var(--grid2);border-radius:12px;overflow:hidden;
    background:var(--sheet);display:flex;flex-direction:column;min-height:0;min-width:0;
    box-shadow:0 24px 60px -30px rgba(0,0,0,.7),0 2px 0 rgba(255,255,255,.02) inset;
  }

  /* ----- title strip (menu bar) ----- */
  .titlebar{
    display:flex;align-items:center;gap:.75rem;padding:.55rem .9rem;
    background:var(--chrome);border-bottom:1px solid var(--grid);min-width:0;
  }
  .gridicon{width:20px;height:20px;border-radius:4px;flex:none;
    background:
      linear-gradient(var(--accent),var(--accent)) 0 0/100% 100% no-repeat;
    -webkit-mask:
      linear-gradient(#000,#000) content-box,
      repeating-linear-gradient(0deg,#000 0 5px,transparent 5px 6px),
      repeating-linear-gradient(90deg,#000 0 5px,transparent 5px 6px);
    -webkit-mask-composite:xor;mask-composite:exclude;
    position:relative;
  }
  .gridicon::after{content:"";position:absolute;inset:0;border-radius:4px;
    background:repeating-linear-gradient(0deg,transparent 0 5px,var(--app) 5px 6px),
               repeating-linear-gradient(90deg,transparent 0 5px,var(--app) 5px 6px);}
  .filemeta{min-width:0;display:flex;flex-direction:column;line-height:1.15}
  .fname{font-size:.86rem;font-weight:600;color:var(--ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .fname b{color:var(--accent);font-weight:600}
  .menus{display:flex;gap:.95rem;font-size:.72rem;color:var(--dim);margin-top:1px}
  .menus span{white-space:nowrap}
  .titlebar nav{margin-left:auto;display:flex;gap:.2rem}
  .titlebar nav a{
    font-size:.74rem;color:var(--ink2);padding:.32rem .6rem;border-radius:6px;
    border:1px solid transparent;transition:background .2s,border-color .2s,color .2s;white-space:nowrap;
  }
  .titlebar nav a:hover{background:var(--chrome2);border-color:var(--grid);color:var(--ink)}
  .titlebar nav a.cta{background:var(--accent);color:#08120c;font-weight:600;border-color:var(--accent)}
  .titlebar nav a.cta:hover{background:var(--accent-d)}
  @media(max-width:760px){.menus{display:none}.titlebar nav a.nav-extra{display:none}}

  /* ----- toolbar ----- */
  .toolbar{
    display:flex;align-items:center;gap:.35rem;padding:.4rem .7rem;
    background:var(--chrome2);border-bottom:1px solid var(--grid);
    overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;
  }
  .toolbar::-webkit-scrollbar{display:none}
  .tbtn{
    font-size:.74rem;color:var(--ink2);min-width:26px;height:26px;padding:0 .4rem;
    display:inline-flex;align-items:center;justify-content:center;gap:.25rem;
    border-radius:5px;border:1px solid transparent;font-family:var(--mono);flex:none;
  }
  .tbtn:hover{background:var(--chrome);border-color:var(--grid)}
  .tbtn.b{font-weight:700}.tbtn.i{font-style:italic}.tbtn.u{text-decoration:underline}
  .tsep{width:1px;height:18px;background:var(--grid);margin:0 .25rem;flex:none}
  .tbtn.swatch{position:relative}
  .tbtn.swatch::after{content:"";position:absolute;left:5px;right:5px;bottom:4px;height:2px;border-radius:2px;background:var(--accent)}

  /* ----- formula bar ----- */
  .formulabar{
    display:flex;align-items:stretch;background:var(--chrome);border-bottom:1px solid var(--grid2);
    font-family:var(--mono);min-width:0;
  }
  .namebox{
    width:96px;flex:none;display:flex;align-items:center;justify-content:space-between;gap:.3rem;
    padding:0 .55rem;border-right:1px solid var(--grid);font-size:.78rem;color:var(--ink);font-weight:500;
    background:var(--chrome2);
  }
  .namebox .caret{color:var(--faint);font-size:.6rem}
  .fx{
    flex:none;width:38px;display:flex;align-items:center;justify-content:center;
    font-style:italic;color:var(--accent);font-size:.86rem;border-right:1px solid var(--grid);font-weight:500;
  }
  .formula{
    flex:1;min-width:0;display:flex;align-items:center;padding:.5rem .7rem;font-size:.8rem;
    color:var(--ink2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.01em;
  }
  .formula .blink{display:inline-block;width:1px;height:1em;background:var(--accent);margin-left:2px;
    transform:translateY(2px);animation:blink 1.1s steps(1) infinite}
  @keyframes blink{50%{opacity:0}}
  @media(max-width:520px){.namebox{width:70px;font-size:.72rem}.fx{width:30px}}

  /* ----- column header row ----- */
  .colhead{
    display:flex;align-items:stretch;background:var(--hdr);border-bottom:1px solid var(--grid2);
    font-family:var(--mono);font-size:.72rem;color:var(--dim);flex:none;
    position:sticky;top:0;z-index:4;
  }
  .colhead .corner{width:var(--rownum);flex:none;border-right:1px solid var(--grid2);
    display:flex;align-items:center;justify-content:center;position:relative}
  .colhead .corner::after{content:"";position:absolute;right:4px;bottom:4px;width:7px;height:7px;
    border-right:2px solid var(--faint);border-bottom:2px solid var(--faint);border-bottom-right-radius:2px}
  .colhead .cl{
    flex:1;text-align:center;padding:.3rem 0;border-right:1px solid var(--grid);
    min-width:0;display:flex;align-items:center;justify-content:center;
  }
  .colhead .cl:last-child{border-right:0}
  .colhead .cl.on{background:var(--accent-soft);color:var(--accent);font-weight:700}

  /* ----- the scrolling grid body ----- */
  .gridscroll{
    overflow:auto;min-height:0;flex:1;
    scrollbar-width:thin;scrollbar-color:var(--grid2) transparent;
  }
  .gridscroll::-webkit-scrollbar{width:11px;height:11px}
  .gridscroll::-webkit-scrollbar-thumb{background:var(--grid2);border-radius:6px;border:3px solid var(--sheet)}
  .gridscroll::-webkit-scrollbar-track{background:transparent}

  .sheet{display:none}
  .sheet.active{display:block}

  /* a generic spreadsheet row: [row-number gutter] [cells...] */
  .r{display:flex;align-items:stretch;border-bottom:1px solid var(--grid);min-height:var(--rowh)}
  .rn{
    width:var(--rownum);flex:none;background:var(--hdr);border-right:1px solid var(--grid2);
    font-family:var(--mono);font-size:.72rem;color:var(--dim);
    display:flex;align-items:center;justify-content:center;user-select:none;position:sticky;left:0;z-index:2;
  }
  .r.on .rn{background:var(--accent-soft);color:var(--accent);font-weight:700}
  .cells{flex:1;display:flex;align-items:stretch;min-width:0}
  .cell{
    flex:1;min-width:0;border-right:1px solid var(--grid);padding:.5rem .7rem;
    display:flex;flex-direction:column;justify-content:center;gap:.15rem;
    position:relative;cursor:cell;transition:background .12s;
  }
  .cell:last-child{border-right:0}
  .cell:hover{background:var(--sel)}
  .cell.sel{background:var(--accent-soft);box-shadow:inset 0 0 0 2px var(--accent);z-index:3;border-radius:2px}
  .cell.empty{cursor:cell}
  .cell .ov{font-size:.8rem;color:var(--dim);font-family:var(--mono);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

  /* spanned cells (merged) */
  .cell.span2{flex:2}.cell.span3{flex:3}.cell.span4{flex:4}.cell.span5{flex:5}.cell.span6{flex:6}

  /* ---- hero / merged title cell ---- */
  .titlecell{
    background:linear-gradient(180deg,var(--sheet2),var(--sheet));
    padding:clamp(1.4rem,4vw,2.6rem) var(--pad);gap:.4rem;justify-content:center;
  }
  .eyebrow{font-family:var(--mono);font-size:.72rem;letter-spacing:.04em;color:var(--accent);
    display:inline-flex;align-items:center;gap:.5rem;margin-bottom:.5rem}
  .eyebrow::before{content:"";width:8px;height:8px;border-radius:2px;background:var(--accent)}
  h1.title{
    font-size:clamp(2.1rem,6.5vw,4.4rem);line-height:1.02;font-weight:700;letter-spacing:-.02em;color:var(--ink);
  }
  h1.title .ship{color:var(--accent)}
  .subcell{padding:clamp(1rem,2.5vw,1.6rem) var(--pad);justify-content:center}
  .subcell p{max-width:60ch;color:var(--ink2);font-size:clamp(.96rem,1.4vw,1.1rem);line-height:1.6}
  .subcell p b{color:var(--ink);font-weight:600}
  .heroctas{display:flex;gap:.6rem;flex-wrap:wrap;margin-top:.3rem}
  .gbtn{
    font-size:.82rem;font-weight:500;padding:.55rem 1rem;border-radius:7px;border:1px solid var(--grid2);
    color:var(--ink);display:inline-flex;align-items:center;gap:.4rem;transition:background .2s,border-color .2s,transform .2s;
  }
  .gbtn:hover{background:var(--chrome);border-color:var(--accent-line);transform:translateY(-1px)}
  .gbtn.primary{background:var(--accent);color:#08120c;border-color:var(--accent);font-weight:600}
  .gbtn.primary:hover{background:var(--accent-d)}

  /* row label cell (the "A column" of a section): a left header-ish label */
  .lab{font-family:var(--mono);font-size:.74rem;color:var(--dim);letter-spacing:.01em}
  .lab.key{color:var(--ink2);font-weight:500}
  .ttl{font-weight:600;color:var(--ink);font-size:.96rem}
  .val{color:var(--ink);font-size:.92rem}
  .muted{color:var(--ink2);font-size:.86rem;line-height:1.5}

  /* computed metric cells (big numbers) */
  .metricnum{font-weight:700;font-size:clamp(1.5rem,3.6vw,2.5rem);line-height:1;color:var(--accent);
    font-family:var(--mono);letter-spacing:-.01em}
  .metriclabel{font-size:.74rem;color:var(--dim);font-family:var(--mono);letter-spacing:.01em;margin-top:.25rem}
  .badge{display:inline-block;font-family:var(--mono);font-size:.64rem;color:var(--accent);
    border:1px solid var(--accent-line);border-radius:4px;padding:.05rem .35rem;margin-left:.4rem;vertical-align:middle}

  /* section header row inside a sheet (a tinted band) */
  .band{background:var(--sheet2)}
  .band .cell{padding-top:.7rem;padding-bottom:.7rem}
  .sectlabel{font-family:var(--mono);font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;color:var(--accent)}
  .secttitle{font-weight:700;font-size:1.05rem;color:var(--ink)}

  /* work rows: client / year / role / outcome  (clickable like a real row) */
  .featrow .rn{color:var(--accent);font-weight:700}
  .pill{font-family:var(--mono);font-size:.72rem;color:var(--ink2);border:1px solid var(--grid2);
    border-radius:5px;padding:.12rem .45rem;display:inline-block}

  /* embedded chart cell */
  .chartcell{padding:var(--pad);gap:.6rem}
  .chartwrap{display:flex;align-items:flex-end;gap:clamp(.5rem,2.5vw,1.4rem);height:clamp(120px,22vw,190px);
    padding:.4rem .2rem .2rem;border-left:1px solid var(--grid);border-bottom:1px solid var(--grid);position:relative}
  .chartwrap::before{content:"";position:absolute;left:0;right:0;top:25%;border-top:1px dashed var(--grid)}
  .chartwrap::after{content:"";position:absolute;left:0;right:0;top:62%;border-top:1px dashed var(--grid)}
  .bar{flex:1;display:flex;flex-direction:column;align-items:center;gap:.4rem;min-width:0;height:100%;justify-content:flex-end}
  .bar .col{width:100%;max-width:54px;border-radius:5px 5px 0 0;
    background:linear-gradient(180deg,var(--accent),var(--accent-d));
    box-shadow:0 0 0 1px rgba(55,193,128,.3) inset;transform-origin:bottom;
    animation:grow .9s cubic-bezier(.2,.8,.2,1) both}
  .bar:nth-child(2) .col{animation-delay:.08s}
  .bar:nth-child(3) .col{animation-delay:.16s}
  .bar:nth-child(4) .col{animation-delay:.24s}
  .bar:nth-child(5) .col{animation-delay:.32s}
  .bar .yr{font-family:var(--mono);font-size:.7rem;color:var(--dim)}
  @keyframes grow{from{transform:scaleY(0)}to{transform:scaleY(1)}}

  /* about portrait cell */
  .portrait{padding:var(--pad)}
  .portrait img{width:100%;max-width:220px;border-radius:8px;border:1px solid var(--grid2);display:block;
    filter:grayscale(.15) contrast(1.03)}
  .aboutlead{font-size:clamp(1.05rem,2.2vw,1.4rem);font-weight:600;color:var(--ink);line-height:1.35;max-width:36ch}

  /* contact */
  .contactbig{font-size:clamp(1.6rem,4.5vw,3rem);font-weight:700;color:var(--ink);letter-spacing:-.01em}
  .contactbig a{color:var(--accent)}
  .contactbig a:hover{text-decoration:underline}
  .contactmeta{font-family:var(--mono);font-size:.84rem;color:var(--ink2)}
  .contactmeta a{color:var(--accent);border-bottom:1px solid var(--accent-line)}
  .brandchip{font-family:var(--mono);font-size:.76rem;color:var(--ink2);border:1px solid var(--grid2);
    border-radius:6px;padding:.32rem .6rem;background:var(--sheet2)}
  .brandwrap{display:flex;flex-wrap:wrap;gap:.45rem}

  /* ----- sheet tabs (bottom) ----- */
  .tabsbar{
    display:flex;align-items:stretch;background:var(--chrome);border-top:1px solid var(--grid2);
    flex:none;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;
  }
  .tabsbar::-webkit-scrollbar{display:none}
  .tabadd{
    width:40px;flex:none;display:flex;align-items:center;justify-content:center;color:var(--faint);
    font-size:1.1rem;border-right:1px solid var(--grid);
  }
  .tab{
    font-size:.8rem;color:var(--dim);padding:.6rem 1rem;border-right:1px solid var(--grid);
    white-space:nowrap;display:inline-flex;align-items:center;gap:.45rem;cursor:pointer;
    border-top:2px solid transparent;transition:background .18s,color .18s;flex:none;
    font-weight:500;background:transparent;font-family:inherit;line-height:1.2;
  }
  .tab .dot{width:7px;height:7px;border-radius:2px;background:currentColor;opacity:.45}
  .tab:hover{background:var(--chrome2);color:var(--ink2)}
  .tab[aria-selected="true"]{
    background:var(--sheet);color:var(--ink);border-top-color:var(--accent);font-weight:600;
  }
  .tab[aria-selected="true"] .dot{background:var(--accent);opacity:1}
  .tabsbar .spacer{flex:1;min-width:1rem;border-right:0}
  .tabsbar .statusmini{display:flex;align-items:center;gap:.4rem;padding:0 1rem;color:var(--faint);
    font-family:var(--mono);font-size:.7rem;white-space:nowrap}
  @media(max-width:680px){.tabsbar .statusmini{display:none}}

  /* ----- status / footer ----- */
  footer{
    width:min(1320px,100%);margin:0 auto;padding:.75rem clamp(.6rem,2vw,1.4rem) 1.1rem;
    display:flex;justify-content:space-between;flex-wrap:wrap;gap:.6rem;
    font-family:var(--mono);font-size:.72rem;color:var(--faint);
  }
  footer a{color:var(--dim)}footer a:hover{color:var(--accent)}

  /* responsive grid sizing: keep the cell text readable, let the grid scroll inside .gridscroll */
  @media(max-width:560px){
    :root{--rownum:30px;--rowh:auto}
    .cell{padding:.5rem .55rem}
    .cell .ov{font-size:.74rem}
    /* on small screens, work rows stack their 4 columns so nothing clips */
    .worktable .cells{flex-wrap:wrap}
    .worktable .cell{flex:1 1 50%;border-right:0;border-bottom:1px solid var(--grid)}
    .worktable .cell.span6{flex:1 1 100%;border-bottom:0}
    .worktable .r{min-height:auto}
    /* metric rows on the Overview sheet: label spans the full width on its own line,
       then the three computed cells share the row so the big numbers never collide */
    .metricrow .cells{flex-wrap:wrap}
    .metricrow .cells > .cell{flex:1 1 33.333%;border-bottom:1px solid var(--grid)}
    .metricrow .cells > .cell:first-child{flex:1 1 100%;border-right:0}
    .metricrow .cells > .cell.empty{display:none}
    .metricrow .metricnum{font-size:clamp(1.15rem,5.4vw,1.6rem)}
    .metricrow .r{min-height:auto}
  }

  @media(prefers-reduced-motion:reduce){
    *{scroll-behavior:auto}
    .bar .col{animation:none}
    .formula .blink{animation:none}
  }
</style>
