---
// REDESIGN PROTOTYPE - "Foundry" - Concept 31. An industrial ASSEMBLY LINE where the work
// gets SHIPPED. Original concept (NOT a reskin of halftone): own layout + palette + mechanic.
//  - THE MECHANIC: a CONVEYOR BELT carries work PRODUCTS (crates) horizontally past STATIONS
//    (the four disciplines = machines that stamp/assemble a step) and SHIPS them off the end.
//    The belt visibly loops (animated tread texture). Selected work = crates riding the belt,
//    each with client / engagement / outcome and a "SHIPPED / LAUNCHED / LIVE" rubber stamp
//    that thumps down on enter. Hero = a factory sign + the line starting up. Metrics = a
//    digital PRODUCTION COUNTER (odometer) that counts up. Recognition = QC seals.
//  - Palette: industrial steel (gunmetal/graphite) + a single SAFETY-AMBER accent + hazard
//    stripes. Machine-shop display type (Oswald) + a stencil-ish mono (Spline Sans Mono).
//  - Self-contained: own <html>, own fonts, own tokens, noindex. No BaseLayout / global.css.
//  - Guardrails: only LambdaTest has hard numbers. No em-dash. overflow-x:clip. Horizontal
//    belt lives in an INNER scroller (never page-level h-scroll). Reduced-motion = belt static,
//    crates placed, stamps applied, counters final. Every animated bit ends in final state.
const counters = [
  { n: 657, suf: 'K+', l: 'Leads shipped' },
  { n: 18.2, suf: 'M+', l: 'Organic traffic driven' },
  { n: 10, suf: 'x', l: 'Pipeline multiplier' },
];
const buildStats = [
  { n: '20', plus: '+', l: 'AI agents & internal tools shipped' },
  { n: '15', plus: '+', l: 'Marketers mentored & levelled up' },
  { n: '76', plus: '',  l: 'Long-form articles published' },
];
const stations = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.' },
];
const work = [
  { i: '01', t: 'LambdaTest', y: '2021 - 2025', role: 'Product & digital marketing', r: '657K+ leads · 18.2M+ organic', d: 'Owned product and digital marketing end to end and built the full organic growth engine.', stamp: 'SHIPPED', feat: true },
  { i: '02', t: 'TestMu AI', y: '2026', role: 'Rebrand lead', r: 'Full company rebrand', d: 'Led the complete rebrand from LambdaTest to TestMu AI.', stamp: 'LAUNCHED' },
  { i: '03', t: 'Samsung', y: '2019', role: 'via Sociowash', r: 'Galaxy M-series launch', d: 'On the Galaxy M-series from inception; ran content distribution, collaborated with Technical Guruji.', stamp: 'LAUNCHED' },
  { i: '04', t: 'Medilife Superspeciality', y: '0 to 1', role: 'Marketing & web', r: 'Website · GTM · social', d: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.', stamp: 'LIVE' },
  { i: '05', t: 'Lido Learning', y: '2021', role: 'Growth / CRM', r: 'CRM & lead operations', d: 'Ran CRM management and lead routing and assignment for the EdTech.', stamp: 'LIVE' },
  { i: '06', t: 'Appknox', y: 'Freelance', role: 'Content', r: 'Security content', d: 'Freelance content writer for the mobile app security company.', stamp: 'SHIPPED' },
];
const recognition = [
  { t: 'Value of Agility Award', m: 'LambdaTest, 2024' },
  { t: 'Wall of Fame', m: 'LambdaTest' },
  { t: '#1 Product of the Day', m: 'Product Hunt' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
const facts = [
  { k: 'Based', v: 'Mumbai, India' },
  { k: 'Tenure', v: '7+ years marketing · 4+ in B2B SaaS' },
  { k: 'Education', v: 'Postgrad in Digital Marketing & Growth Strategy, IIM Visakhapatnam' },
  { k: 'Practice', v: 'PMM & growth strategist who codes AI agents, ships websites and runs technical SEO' },
];
---
<!doctype html>
<html lang="en" data-theme="foundry">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600&family=Spline+Sans+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#14171b;          /* graphite floor */
    --bg2:#181c21;
    --steel:#1f242b;       /* machine body */
    --steel2:#262c34;
    --plate:#2c333c;       /* raised plate */
    --ink:#eef2f6;         /* near-white text */
    --soft:#d3dae2;        /* body text - AA on steel */
    --dim:#9aa6b2;         /* muted labels (>=4.5:1 on --bg) */
    --faint:#73808d;
    --amber:#ffb020;       /* safety accent */
    --amber-d:#e0941a;
    --hazard:#ffb020;
    --line:rgba(238,242,246,.10);
    --hair:rgba(238,242,246,.20);
    --rivet:rgba(238,242,246,.28);
    --disp:"Oswald",Impact,sans-serif;
    --sans:"Inter",system-ui,sans-serif;
    --mono:"Spline Sans Mono",ui-monospace,monospace;
    --m:clamp(1.1rem,4.2vw,4.5rem);
    --tread: repeating-linear-gradient(90deg,#2a3038 0 26px,#1b2026 26px 30px,#2a3038 30px 56px);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{overflow-x:clip}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:var(--sans);min-height:100vh;
    -webkit-font-smoothing:antialiased;line-height:1.6;letter-spacing:.005em;position:relative}
  /* shop-floor texture: subtle diamond-plate + vignette */
  body::before{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.5;
    background-image:
      radial-gradient(rgba(255,255,255,.018) 1px,transparent 1.4px),
      radial-gradient(ellipse at 50% 0%,rgba(255,176,32,.05),transparent 60%);
    background-size:7px 7px,100% 100%}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--amber);color:#1a1305}
  .wrap{width:min(1300px,100%);margin:0 auto;padding:0 var(--m);position:relative;z-index:2}

  .mono{font-family:var(--mono);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dim)}

  /* ===== hazard tape (reusable) ===== */
  .hazard{height:9px;width:100%;
    background:repeating-linear-gradient(45deg,var(--hazard) 0 14px,#1a1305 14px 28px);
    opacity:.85}

  /* ===== top header / control panel ===== */
  .mast{position:fixed;top:0;left:0;right:0;z-index:50;
    background:linear-gradient(180deg,rgba(20,23,27,.95),rgba(20,23,27,.7) 78%,transparent);
    backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
  .mast-in{width:min(1300px,100%);margin:0 auto;padding:.7rem var(--m);display:flex;align-items:center;
    justify-content:space-between;gap:1rem;border-bottom:1px solid var(--line)}
  .brand{display:flex;align-items:center;gap:.65rem;font-family:var(--mono);font-weight:700;
    letter-spacing:.05em;font-size:.9rem;color:var(--ink)}
  .brand .bolt{width:20px;height:20px;flex:none;display:inline-grid;place-items:center;border-radius:50%;
    background:var(--steel2);border:1px solid var(--hair);position:relative}
  .brand .bolt::before{content:"";position:absolute;width:9px;height:2px;background:var(--amber);
    box-shadow:0 0 0 0 transparent}
  .brand .bolt::after{content:"";position:absolute;width:2px;height:9px;background:var(--amber)}
  .mast nav{display:flex;gap:1.4rem;align-items:center}
  .mast nav a{font-family:var(--mono);font-size:.72rem;letter-spacing:.13em;text-transform:uppercase;
    color:var(--dim);transition:color .3s}
  .mast nav a:hover{color:var(--amber)}
  .runlight{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--mono);font-size:.66rem;
    letter-spacing:.13em;text-transform:uppercase;color:var(--dim)}
  .runlight i{width:8px;height:8px;border-radius:50%;background:var(--amber);
    box-shadow:0 0 8px 1px rgba(255,176,32,.7);animation:pulse 1.8s ease-in-out infinite}
  @keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}
  @media(max-width:720px){.mast nav a:not(.cncpt){display:none}.runlight{display:none}}

  /* ===== hero / factory sign ===== */
  header.hero{padding:7.5rem 0 1.5rem;position:relative;z-index:2}
  .stamp-line{display:flex;justify-content:space-between;align-items:center;gap:1rem;
    border-bottom:1px solid var(--line);padding-bottom:.85rem;margin-bottom:clamp(1.4rem,3.4vw,2.6rem);flex-wrap:wrap}
  .stamp-line .order{font-family:var(--mono);font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--faint)}
  .sign{position:relative;border:1px solid var(--hair);border-radius:14px;overflow:hidden;
    background:
      linear-gradient(180deg,var(--steel2),var(--steel));
    box-shadow:inset 0 1px 0 rgba(255,255,255,.04),0 18px 50px -28px rgba(0,0,0,.8)}
  .sign .rivet{position:absolute;width:9px;height:9px;border-radius:50%;
    background:radial-gradient(circle at 35% 30%,#3a424c,#171b20);box-shadow:inset 0 0 2px rgba(0,0,0,.8)}
  .sign .rivet.tl{top:12px;left:12px}.sign .rivet.tr{top:12px;right:12px}
  .sign .rivet.bl{bottom:12px;left:12px}.sign .rivet.br{bottom:12px;right:12px}
  .sign-in{padding:clamp(1.8rem,4.6vw,3.4rem) clamp(1.5rem,4vw,3rem)}
  .eyebrow{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--mono);font-size:.7rem;
    letter-spacing:.16em;text-transform:uppercase;color:var(--amber);margin-bottom:1.3rem}
  .eyebrow::before{content:"";width:26px;height:2px;background:var(--amber)}
  .hero h1{font-family:var(--disp);font-weight:700;text-transform:uppercase;line-height:.9;
    letter-spacing:.01em;font-size:clamp(3rem,10.5vw,8.4rem);color:var(--ink)}
  .hero h1 .l2{display:block}
  .hero h1 .ships{position:relative;display:inline-block;color:#1a1305;background:var(--amber);
    padding:0 .14em .04em;border-radius:4px;transform:rotate(-1.5deg);
    box-shadow:0 6px 0 -1px var(--amber-d)}
  /* stamp thump on the SHIPS word */
  .hero h1 .ships{transform:rotate(-1.5deg) scale(1.18);opacity:0;
    transition:transform .42s cubic-bezier(.2,1.5,.35,1) .55s,opacity .25s .55s}
  .hero.in h1 .ships{transform:rotate(-1.5deg) scale(1);opacity:1}
  .hero .sub{margin-top:clamp(1.4rem,2.6vw,2rem);max-width:50ch;color:var(--soft);
    font-size:clamp(1rem,1.2vw,1.12rem);line-height:1.65}
  .hero .sub b{color:var(--ink);font-weight:600}
  .hero .cta{margin-top:1.9rem;display:flex;gap:.8rem;flex-wrap:wrap}
  .btn{font-family:var(--mono);font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;
    padding:.85rem 1.35rem;border:1px solid var(--hair);border-radius:7px;display:inline-flex;gap:.55rem;
    align-items:center;transition:background .3s,color .3s,border-color .3s,transform .3s}
  .btn .ar{transition:transform .3s}
  .btn:hover .ar{transform:translate(3px,-3px)}
  .btn.primary{background:var(--amber);color:#1a1305;border-color:var(--amber);font-weight:700}
  .btn.primary:hover{transform:translateY(-2px);box-shadow:0 10px 24px -10px rgba(255,176,32,.6)}
  .btn.ghost:hover{border-color:var(--amber);color:var(--amber);background:rgba(255,176,32,.06)}

  /* ===== production counter board (odometer) ===== */
  .board{margin-top:clamp(1.6rem,3vw,2.4rem);background:#0e1114;border:1px solid var(--hair);
    border-radius:12px;padding:1.3rem clamp(1rem,2.4vw,1.8rem);
    display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
    box-shadow:inset 0 0 40px rgba(0,0,0,.5)}
  .board .cell{padding:.2rem .7rem;display:flex;flex-direction:column;gap:.45rem;position:relative}
  .board .cell + .cell{border-left:1px solid var(--line)}
  .board .odo{font-family:var(--mono);font-weight:700;font-variant-numeric:tabular-nums;
    font-size:clamp(1.8rem,4.6vw,3.1rem);line-height:1;color:var(--amber);letter-spacing:.01em;
    text-shadow:0 0 14px rgba(255,176,32,.25)}
  .board .odo .suf{color:var(--ink);font-size:.5em;margin-left:.06em}
  .board .ol{font-family:var(--mono);font-size:.64rem;letter-spacing:.13em;text-transform:uppercase;color:var(--dim)}
  @media(max-width:560px){.board{grid-template-columns:1fr}.board .cell + .cell{border-left:0;border-top:1px solid var(--line)}}

  .scrollcue{margin-top:2.2rem;display:flex;align-items:center;gap:.7rem;color:var(--faint);
    font-family:var(--mono);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase}
  .scrollcue .bar{width:36px;height:2px;background:var(--hair);position:relative;overflow:hidden;border-radius:2px}
  .scrollcue .bar::after{content:"";position:absolute;inset:0;width:42%;background:var(--amber);animation:slide 2s linear infinite}
  @keyframes slide{0%{transform:translateX(-110%)}100%{transform:translateX(280%)}}

  /* ===== section heads ===== */
  section{padding:clamp(3.2rem,8vh,6rem) 0;position:relative;z-index:2}
  .shead{display:flex;justify-content:space-between;align-items:flex-end;gap:1.5rem;
    border-bottom:1px solid var(--line);padding-bottom:1rem;margin-bottom:2.4rem}
  .shead .idx{font-family:var(--mono);font-size:.66rem;letter-spacing:.18em;text-transform:uppercase;
    color:var(--amber);margin-bottom:.65rem;display:inline-flex;align-items:center;gap:.5rem}
  .shead .idx::before{content:"";width:18px;height:2px;background:var(--amber)}
  .shead h2{font-family:var(--disp);text-transform:uppercase;font-weight:700;
    font-size:clamp(1.8rem,4.2vw,3.2rem);line-height:.95;letter-spacing:.01em}
  .shead .meta{font-family:var(--mono);font-size:.66rem;letter-spacing:.07em;color:var(--dim);
    text-align:right;text-transform:uppercase;line-height:1.7}

  /* ===== stations (disciplines = machines) ===== */
  .stations{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
  .station{position:relative;background:linear-gradient(180deg,var(--steel2),var(--steel));
    border:1px solid var(--hair);border-radius:12px;padding:1.4rem 1.3rem 1.5rem;
    display:flex;flex-direction:column;gap:.8rem;overflow:hidden;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.04)}
  .station::before{content:"";position:absolute;left:0;right:0;top:0;height:9px;
    background:repeating-linear-gradient(45deg,var(--amber) 0 10px,#1a1305 10px 20px);opacity:.85}
  .station .snum{font-family:var(--mono);font-size:.72rem;letter-spacing:.1em;color:var(--faint);margin-top:.4rem}
  .station .sgear{position:absolute;top:1rem;right:1rem;width:30px;height:30px;color:var(--amber);opacity:.55}
  .station .sgear svg{width:100%;height:100%;display:block;animation:spin 9s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}
  .station h3{font-family:var(--disp);text-transform:uppercase;font-weight:600;
    font-size:clamp(1.05rem,1.7vw,1.32rem);line-height:1.05;color:var(--ink)}
  .station p{color:var(--soft);font-size:.9rem;line-height:1.55}
  .station .stag{margin-top:auto;font-family:var(--mono);font-size:.6rem;letter-spacing:.14em;
    text-transform:uppercase;color:var(--amber);display:inline-flex;align-items:center;gap:.4rem}
  .station .stag::before{content:"\25B8"}
  @media(max-width:900px){.stations{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:540px){.stations{grid-template-columns:1fr}}

  /* ===== THE LINE: conveyor of work crates ===== */
  .line-wrap{position:relative}
  .line-hint{font-family:var(--mono);font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;
    color:var(--faint);margin-bottom:.9rem;display:flex;align-items:center;gap:.6rem}
  .line-hint .arr{color:var(--amber)}
  /* inner horizontal scroller - contains overflow, never page-level */
  .belt{position:relative;overflow-x:auto;overflow-y:hidden;padding:1.4rem 0 1.6rem;
    scrollbar-width:thin;scrollbar-color:var(--amber) #0e1114;
    -webkit-overflow-scrolling:touch}
  .belt::-webkit-scrollbar{height:8px}
  .belt::-webkit-scrollbar-track{background:#0e1114;border-radius:8px}
  .belt::-webkit-scrollbar-thumb{background:var(--amber-d);border-radius:8px}
  /* moving belt tread under the crates */
  .belt::before{content:"";position:absolute;left:0;right:0;bottom:.4rem;height:18px;
    background:var(--tread);background-size:56px 18px;opacity:.6;
    animation:tread 1.4s linear infinite;will-change:background-position;
    border-top:1px solid var(--hair);border-bottom:1px solid var(--line)}
  @keyframes tread{from{background-position:0 0}to{background-position:-56px 0}}
  .crates{display:inline-flex;gap:1.1rem;padding:0 var(--m);align-items:stretch}
  /* crate = a work item riding the belt */
  .crate{position:relative;flex:0 0 auto;width:clamp(260px,80vw,340px);
    background:
      linear-gradient(180deg,#2b3138,#1d2228);
    border:1px solid var(--hair);border-radius:10px;padding:1.3rem 1.3rem 1.5rem;
    display:flex;flex-direction:column;gap:.7rem;
    box-shadow:0 16px 36px -22px rgba(0,0,0,.9),inset 0 1px 0 rgba(255,255,255,.05)}
  /* wooden-crate cross-batten detail using borders */
  .crate::before{content:"";position:absolute;inset:8px;border:1px dashed rgba(238,242,246,.12);
    border-radius:6px;pointer-events:none}
  .crate.feat{width:clamp(300px,90vw,460px);border-color:rgba(255,176,32,.4)}
  .crate .chead{display:flex;justify-content:space-between;align-items:baseline;gap:.8rem;
    font-family:var(--mono);font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:var(--faint);
    padding-right:5.2rem}
  /* the stamp sits top-right; keep the year clear of it */
  .crate .chead .cyr{text-align:right}
  .crate .ct{font-family:var(--disp);text-transform:uppercase;font-weight:700;
    font-size:clamp(1.3rem,2.4vw,1.9rem);line-height:1;color:var(--ink);position:relative;z-index:1}
  .crate .crole{font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--amber)}
  .crate .cr{font-family:var(--mono);font-size:.78rem;color:var(--soft);letter-spacing:.01em}
  .crate .cd{color:var(--dim);font-size:.86rem;line-height:1.5;margin-top:.2rem}
  /* feat crate carries the LambdaTest hard numbers as a stat panel */
  .crate.feat .cstats{margin-top:.4rem;display:flex;gap:1.4rem;padding-top:.9rem;border-top:1px solid var(--line)}
  .crate.feat .cstat .v{font-family:var(--disp);font-weight:700;font-size:clamp(1.5rem,3.4vw,2.2rem);
    line-height:.9;color:var(--amber)}
  .crate.feat .cstat .k{font-family:var(--mono);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--dim);margin-top:.3rem}
  /* the SHIPPED rubber stamp */
  .crate .ship-stamp{position:absolute;top:.9rem;right:.8rem;z-index:2;
    font-family:var(--disp);font-weight:700;text-transform:uppercase;letter-spacing:.04em;
    font-size:.82rem;color:var(--amber);border:2px solid var(--amber);border-radius:5px;
    padding:.14em .5em;transform:rotate(-12deg) scale(1.6);opacity:0;
    box-shadow:0 0 0 1px rgba(255,176,32,.25) inset;
    transition:transform .34s cubic-bezier(.2,1.6,.35,1),opacity .18s}
  .crate.stamped .ship-stamp{transform:rotate(-12deg) scale(1);opacity:.92}
  /* outbound dock at end of line */
  .dock{flex:0 0 auto;width:clamp(150px,40vw,210px);border:1px dashed var(--hair);border-radius:10px;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.6rem;
    padding:1.3rem 1rem;text-align:center;background:rgba(255,176,32,.04)}
  .dock .dock-i{font-family:var(--disp);font-weight:700;text-transform:uppercase;color:var(--amber);
    font-size:1.4rem;line-height:.95}
  .dock .dock-l{font-family:var(--mono);font-size:.6rem;letter-spacing:.13em;text-transform:uppercase;color:var(--dim)}
  .dock .truck{font-size:1.6rem;line-height:1;color:var(--amber)}

  /* ===== build stats (counter strip) ===== */
  .builds{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
    background:var(--line);border:1px solid var(--hair);border-radius:12px;overflow:hidden}
  .build{background:linear-gradient(180deg,var(--steel),var(--bg2));padding:clamp(1.5rem,3vw,2.4rem) clamp(1.1rem,2.2vw,1.8rem);
    min-height:170px;display:flex;flex-direction:column;justify-content:space-between;gap:1rem}
  .build .bnum{font-family:var(--disp);font-weight:700;font-size:clamp(3rem,8vw,6rem);line-height:.82;
    color:var(--ink);letter-spacing:.01em}
  .build .bnum sup{color:var(--amber);font-size:.42em;font-weight:700;top:-.5em}
  .build .bl{font-family:var(--mono);font-size:.72rem;letter-spacing:.04em;color:var(--dim);
    text-transform:uppercase;max-width:24ch;line-height:1.55}
  @media(max-width:760px){.builds{grid-template-columns:1fr}.build{min-height:auto;flex-direction:row;align-items:center;gap:1.4rem;justify-content:flex-start}.build .bl{max-width:none}}

  /* ===== QC seals + brands ===== */
  .qc-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:clamp(2rem,5vw,4rem)}
  .seals{display:flex;flex-direction:column;gap:1rem}
  .seal{display:flex;align-items:center;gap:1.1rem;padding:1rem 1.1rem;
    background:linear-gradient(180deg,var(--steel2),var(--steel));border:1px solid var(--hair);border-radius:10px}
  .seal .badge{width:46px;height:46px;flex:none;border-radius:50%;display:grid;place-items:center;
    border:2px solid var(--amber);color:var(--amber);font-family:var(--mono);font-weight:700;font-size:.56rem;
    letter-spacing:.04em;text-align:center;line-height:1;background:rgba(255,176,32,.06);
    box-shadow:0 0 0 4px rgba(255,176,32,.06)}
  .seal b{font-family:var(--disp);text-transform:uppercase;font-weight:600;font-size:1.2rem;
    letter-spacing:.02em;display:block;line-height:1.1;color:var(--ink)}
  .seal span{font-family:var(--mono);font-size:.66rem;letter-spacing:.05em;color:var(--dim);text-transform:uppercase}
  .brands .bl{font-family:var(--mono);font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;
    color:var(--faint);margin-bottom:1.1rem}
  .brands .bgrid{display:flex;flex-wrap:wrap;gap:.55rem}
  .brands .bgrid span{font-family:var(--mono);font-size:.76rem;border:1px solid var(--hair);border-radius:6px;
    padding:.5rem .8rem;color:var(--soft);background:rgba(238,242,246,.02)}
  @media(max-width:720px){.qc-grid{grid-template-columns:1fr}}

  /* ===== about / shipping label ===== */
  .about-grid{display:grid;grid-template-columns:300px 1fr;gap:clamp(2rem,5vw,4rem);align-items:start}
  .about-photo{position:relative;aspect-ratio:5/6;border:1px solid var(--hair);border-radius:12px;overflow:hidden;
    background:var(--steel)}
  .about-photo img{width:100%;height:100%;object-fit:cover;object-position:top center;
    filter:grayscale(.4) contrast(1.05) brightness(1.02)}
  .about-photo .tape{position:absolute;top:1.1rem;left:-1.3rem;transform:rotate(-4deg);
    background:var(--hazard);color:#1a1305;font-family:var(--mono);font-weight:700;font-size:.6rem;
    letter-spacing:.14em;text-transform:uppercase;padding:.35rem 1.6rem;
    box-shadow:0 4px 12px -4px rgba(0,0,0,.6)}
  .about-lead{font-family:var(--disp);text-transform:uppercase;font-weight:600;
    font-size:clamp(1.5rem,3vw,2.4rem);line-height:1.06;letter-spacing:.01em;margin-bottom:1.8rem;color:var(--ink)}
  .facts{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem 2rem}
  .fact{border-left:2px solid var(--amber);padding-left:1rem}
  .fact .k{font-family:var(--mono);font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin-bottom:.4rem}
  .fact .v{color:var(--soft);font-size:.94rem;line-height:1.45}
  @media(max-width:760px){.about-grid{grid-template-columns:1fr}.about-photo{max-width:280px}.facts{grid-template-columns:1fr}}

  /* ===== contact / shipping manifest ===== */
  .contact{border-top:1px solid var(--line)}
  .contact .cl{font-family:var(--mono);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);margin-bottom:1.1rem}
  .contact .big{font-family:var(--disp);text-transform:uppercase;font-weight:700;
    font-size:clamp(2.8rem,10vw,7.5rem);line-height:.88;letter-spacing:.01em;color:var(--ink)}
  .contact .big a{display:inline-flex;align-items:flex-start;gap:.1em;transition:color .3s}
  .contact .big a .ar{font-size:.4em;margin-top:.2em;color:var(--amber)}
  .contact .big a:hover{color:var(--amber)}
  .contact .em{margin-top:1.6rem;font-family:var(--mono);font-size:.82rem;letter-spacing:.04em;color:var(--dim)}
  .contact .em a{color:var(--ink);border-bottom:1px solid var(--amber)}

  /* footer / shipping manifest plate */
  footer{border-top:1px solid var(--line);padding:2.2rem 0 3rem;position:relative;z-index:2}
  .foot-in{width:min(1300px,100%);margin:0 auto;padding:0 var(--m);display:flex;justify-content:space-between;
    flex-wrap:wrap;gap:1rem;font-family:var(--mono);font-size:.7rem;letter-spacing:.06em;color:var(--faint);text-transform:uppercase}
  .foot-in a{color:var(--dim)}.foot-in a:hover{color:var(--amber)}

  /* reveals */
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s cubic-bezier(.2,.8,.2,1),transform .7s cubic-bezier(.2,.8,.2,1)}
  .reveal.show{opacity:1;transform:none}

  @media(prefers-reduced-motion:reduce){
    .reveal{opacity:1!important;transform:none!important;transition:none}
    .belt::before{animation:none}
    .scrollcue .bar::after{animation:none}
    .runlight i{animation:none;opacity:1}
    .station .sgear svg{animation:none}
    .hero h1 .ships{opacity:1!important;transform:rotate(-1.5deg) scale(1)!important;transition:none}
    .crate .ship-stamp{opacity:.92!important;transform:rotate(-12deg) scale(1)!important;transition:none}
    html{scroll-behavior:auto}
  }
</style>
</head>
<body>
  <header class="mast">
    <div class="mast-in">
      <a href="/redesign/" class="brand"><span class="bolt" aria-hidden="true"></span> SWAPNIL BISWAS</a>
      <nav>
        <a href="#line">Work</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <a href="/redesign/" class="cncpt">All concepts</a>
        <span class="runlight"><i></i> Line running</span>
      </nav>
    </div>
  </header>

  <div class="wrap">
    <header class="hero" id="hero">
      <div class="stamp-line">
        <span class="order">Work Order No. 31 &middot; Foundry</span>
        <span class="order">Shift: continuous &middot; Status: shipping</span>
      </div>
      <div class="sign">
        <span class="rivet tl" aria-hidden="true"></span><span class="rivet tr" aria-hidden="true"></span>
        <span class="rivet bl" aria-hidden="true"></span><span class="rivet br" aria-hidden="true"></span>
        <div class="sign-in">
          <span class="eyebrow">Senior Product Marketing Manager - LambdaTest</span>
          <h1>
            <span class="l1">The marketer</span>
            <span class="l2">who <span class="ships">ships.</span></span>
          </h1>
          <p class="sub">I build the agents, sites and SEO systems behind <b>657K+ leads</b> and <b>18M+ in organic traffic</b> - not just the decks that describe them. A product marketer who actually engineers the growth.</p>
          <div class="cta">
            <a class="btn primary" href="#line">Selected work <span class="ar">&#8599;</span></a>
            <a class="btn ghost" href="#contact">Get in touch</a>
          </div>

          <div class="board" role="group" aria-label="Production counter">
            {counters.map(c => (
              <div class="cell">
                <div class="odo" data-target={c.n} data-suf={c.suf} data-dec={String(c.n).includes('.') ? '1' : '0'}>0<span class="suf">{c.suf}</span></div>
                <div class="ol">{c.l}</div>
              </div>
            ))}
          </div>

          <div class="scrollcue"><span class="bar"></span> Scroll to run the line</div>
        </div>
      </div>
    </header>
  </div>

  <div class="wrap">
    <!-- STATIONS = disciplines -->
    <section id="what">
      <div class="shead">
        <div><div class="idx">01 / Stations</div><h2 class="reveal">The machines on the line</h2></div>
        <div class="meta reveal">Four stations<br/>one operator</div>
      </div>
      <div class="stations">
        {stations.map(s => (
          <article class="station reveal">
            <span class="sgear" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 8.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7z"/><path d="M12 2.5v2.6M12 18.9v2.6M21.5 12h-2.6M5.1 12H2.5M18.7 5.3l-1.8 1.8M7.1 16.9l-1.8 1.8M18.7 18.7l-1.8-1.8M7.1 7.1L5.3 5.3"/></svg></span>
            <div class="snum">Station {s.i}</div>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
            <span class="stag">Operational</span>
          </article>
        ))}
      </div>
    </section>

    <!-- THE LINE = selected work riding the conveyor -->
    <section id="line">
      <div class="shead">
        <div><div class="idx">02 / The Line</div><h2 class="reveal">Work coming off the belt</h2></div>
        <div class="meta reveal">Every crate shipped<br/>2019 - 2026</div>
      </div>
    </section>
  </div>

  <div class="wrap">
    <div class="line-wrap reveal">
      <div class="line-hint"><span class="arr">&#9656;&#9656;</span> Drag or scroll the belt &middot; each unit ships at the dock</div>
    </div>
  </div>
  <!-- belt is full-bleed inside its own scroller so it never causes page h-scroll -->
  <div class="belt" id="belt" tabindex="0" aria-label="Conveyor of selected work, horizontally scrollable">
    <div class="crates">
      {work.map(w => (
        <article class={'crate' + (w.feat ? ' feat' : '')} aria-label={w.t + ' - ' + w.r}>
          <span class="ship-stamp" aria-hidden="true">{w.stamp}</span>
          <div class="chead"><span>Unit {w.i}</span><span class="cyr">{w.y}</span></div>
          <div class="ct">{w.t}</div>
          <div class="crole">{w.role}</div>
          <div class="cr">{w.r}</div>
          <div class="cd">{w.d}</div>
          {w.feat && (
            <div class="cstats">
              <div class="cstat"><div class="v">657K+</div><div class="k">Leads generated</div></div>
              <div class="cstat"><div class="v">18.2M+</div><div class="k">Organic traffic</div></div>
            </div>
          )}
        </article>
      ))}
      <div class="dock" aria-label="Outbound shipping dock">
        <span class="truck" aria-hidden="true">&#128666;</span>
        <span class="dock-i">Shipped</span>
        <span class="dock-l">Outbound dock</span>
      </div>
    </div>
  </div>

  <div class="wrap">
    <!-- BUILD STATS -->
    <section id="output">
      <div class="shead">
        <div><div class="idx">03 / Output</div><h2 class="reveal">What got built &amp; shipped</h2></div>
        <div class="meta reveal">The leads sit up top -<br/>this is the body of work</div>
      </div>
      <div class="builds">
        {buildStats.map(b => (
          <div class="build reveal">
            <div class="bnum" data-build={b.n}>0{b.plus && <sup>{b.plus}</sup>}</div>
            <div class="bl">{b.l}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- QC SEALS + BRANDS -->
    <section id="qc">
      <div class="shead">
        <div><div class="idx">04 / Quality Control</div><h2 class="reveal">Recognition &amp; brands</h2></div>
      </div>
      <div class="qc-grid">
        <div class="seals reveal">
          {recognition.map(a => (
            <div class="seal"><span class="badge" aria-hidden="true">QC<br/>PASS</span><div><b>{a.t}</b><span>{a.m}</span></div></div>
          ))}
        </div>
        <div class="brands reveal">
          <div class="bl">Trusted by teams at</div>
          <div class="bgrid">{brands.map(b => <span>{b}</span>)}</div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about">
      <div class="shead">
        <div><div class="idx">05 / The Operator</div><h2 class="reveal">About the maker</h2></div>
        <div class="meta reveal">Mumbai, India</div>
      </div>
      <div class="about-grid">
        <div class="about-photo reveal">
          <span class="tape" aria-hidden="true">Quality checked</span>
          <img src="/assets/portrait-cut.webp" alt="Swapnil Biswas" loading="lazy" decoding="async" />
        </div>
        <div>
          <p class="about-lead reveal">I treat my own career like a product - positioned, measured and shipped. Seven years in marketing, four deep in B2B SaaS.</p>
          <div class="facts">
            {facts.map(f => (
              <div class="fact reveal"><div class="k">{f.k}</div><div class="v">{f.v}</div></div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="contact">
      <div class="cl reveal">Let's build something that compounds</div>
      <div class="big reveal"><a href="mailto:swapbiswas.marketing@gmail.com">Say hello <span class="ar">&#8599;</span></a></div>
      <div class="em reveal">swapbiswas.marketing@gmail.com &nbsp;&middot;&nbsp; <a href="https://www.linkedin.com/in/swapbiswas/">LinkedIn</a></div>
    </section>
  </div>

  <footer>
    <div class="foot-in">
      <span>Foundry &middot; Concept 31</span>
      <span>Swapnil Biswas &copy; 2026</span>
      <span><a href="/redesign/">View all concepts</a></span>
    </div>
  </footer>

<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  setTimeout(() => document.getElementById('hero')?.classList.add('in'), 60);

  /* ---------- production counter (odometer count-up) ---------- */
  function formatVal(val, dec, suf){
    const num = dec ? val.toFixed(1) : Math.round(val).toString();
    return num + '<span class="suf">' + suf + '</span>';
  }
  function runCounter(el){
    const target = parseFloat(el.getAttribute('data-target'));
    const suf = el.getAttribute('data-suf') || '';
    const dec = el.getAttribute('data-dec') === '1';
    if (RM){ el.innerHTML = formatVal(target, dec, suf); return; }
    const dur = 1400; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.innerHTML = formatVal(target * eased, dec, suf);
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const odoIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ runCounter(e.target); odoIO.unobserve(e.target); } });
  }, { threshold: 0.6 });
  document.querySelectorAll('.odo').forEach(el => odoIO.observe(el));

  /* ---------- build stats count-up ---------- */
  function runBuild(el){
    const target = parseInt(el.getAttribute('data-build'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = target + supHTML; return; }
    const dur = 1200; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.innerHTML = Math.round(target * eased) + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const buildIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ runBuild(e.target.querySelector('.bnum')); buildIO.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('.build').forEach(b => buildIO.observe(b));

  /* ---------- SHIPPED stamps thump down as each crate enters view ---------- */
  if (RM){
    document.querySelectorAll('.crate').forEach(c => c.classList.add('stamped'));
  } else {
    const crates = Array.from(document.querySelectorAll('.crate'));
    const stampIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting){
          // stagger by index for a line-feed feel
          const idx = crates.indexOf(e.target);
          setTimeout(() => e.target.classList.add('stamped'), Math.max(0, (idx % 6)) * 90);
          stampIO.unobserve(e.target);
        }
      });
    }, { root: document.getElementById('belt'), threshold: 0.55 });
    crates.forEach(c => stampIO.observe(c));
    // safety net: any crate never observed (e.g. far down the belt) still stamps after load
    setTimeout(() => crates.forEach(c => c.classList.add('stamped')), 2600);
  }

  /* ---------- drag-to-scroll the belt (pointer) ---------- */
  (function dragBelt(){
    const belt = document.getElementById('belt');
    if (!belt) return;
    let down = false, sx = 0, sl = 0, moved = false;
    belt.addEventListener('pointerdown', (e) => {
      down = true; moved = false; sx = e.clientX; sl = belt.scrollLeft;
      belt.style.cursor = 'grabbing';
    });
    belt.addEventListener('pointermove', (e) => {
      if (!down) return;
      const dx = e.clientX - sx;
      if (Math.abs(dx) > 3) moved = true;
      belt.scrollLeft = sl - dx;
    });
    function up(){ down = false; belt.style.cursor = ''; }
    belt.addEventListener('pointerup', up);
    belt.addEventListener('pointerleave', up);
    belt.addEventListener('pointercancel', up);
    // prevent accidental click-through after a drag
    belt.addEventListener('click', (e) => { if (moved){ e.preventDefault(); e.stopPropagation(); } }, true);
  })();
</script>
</body>
</html>
