<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ===================== SPLIT-FLAP ENGINE ===================== */
  // The glyph reel each tile cycles through before landing on its target.
  const GLYPHS = ' ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789+-#./*';
  const idxOf = (c) => { const i = GLYPHS.indexOf(c); return i < 0 ? 0 : i; };

  // Build a tile element for a single character. Returns { el, set(char), flipTo(char, opts) }.
  function makeTile(initial, acc){
    const el = document.createElement('span');
    el.className = 'tile' + (acc ? ' acc' : '') + (initial === ' ' ? ' is-space' : '');
    // the static card face (.ch carries the two-tone background + seam); the glyph lives in .g
    const ch = document.createElement('span');
    ch.className = 'ch';
    const g = document.createElement('span');
    g.className = 'g';
    g.textContent = initial === ' ' ? '' : initial;
    ch.appendChild(g);
    el.appendChild(ch);

    let current = initial;
    let runToken = 0;            // increments on every new flip run; stale runs abort
    let leaves = [];            // live leaf {node, anim} pairs - always tracked so we can purge
    let pendingTimers = [];     // safety timers to clear

    // Remove every leaf node + cancel its animations. After this, ONLY the static face shows.
    function clearLeaves(){
      for (const lf of leaves){
        try { if (lf.a1) lf.a1.cancel(); } catch(e){}
        try { if (lf.a2) lf.a2.cancel(); } catch(e){}
        if (lf.node && lf.node.parentNode) lf.node.parentNode.removeChild(lf.node);
      }
      leaves = [];
      for (const t of pendingTimers) clearTimeout(t);
      pendingTimers = [];
      // belt-and-braces: nuke any orphaned leaf elements that escaped tracking
      el.querySelectorAll(':scope > .flip-top, :scope > .flip-bottom').forEach(n => n.remove());
    }

    function setStatic(c){
      clearLeaves();             // a rest state shows the printed glyph ONLY
      current = c;
      g.textContent = c === ' ' ? '' : c;
      el.classList.toggle('is-space', c === ' ');
    }

    // One visual flap step: top half drops to reveal `to`, bottom half rises.
    // `token` ties this step to its run; if superseded, it self-cleans and stops.
    function flapOnce(from, to, dur, token){
      return new Promise((resolve) => {
        if (token !== runToken){ resolve(); return; }
        // print the destination char on the static face NOW so when leaves clear it is correct
        g.textContent = to === ' ' ? '' : to;
        current = to;
        el.classList.toggle('is-space', to === ' ');

        const top = document.createElement('div'); top.className = 'flip-top';
        const topSpan = document.createElement('span'); topSpan.textContent = from === ' ' ? '' : from;
        top.appendChild(topSpan);
        const bottom = document.createElement('div'); bottom.className = 'flip-bottom';
        const botSpan = document.createElement('span'); botSpan.textContent = to === ' ' ? '' : to;
        bottom.appendChild(botSpan);
        bottom.style.transform = 'rotateX(90deg)';
        el.appendChild(top); el.appendChild(bottom);

        const half = dur / 2;
        const a1 = top.animate(
          [{ transform: 'rotateX(0deg)' }, { transform: 'rotateX(-90deg)' }],
          { duration: half, easing: 'cubic-bezier(.36,0,.66,-0.2)', fill: 'forwards' }
        );
        const a2 = bottom.animate(
          [{ transform: 'rotateX(90deg)' }, { transform: 'rotateX(0deg)' }],
          { duration: half, delay: half, easing: 'cubic-bezier(.34,1.3,.64,1)', fill: 'forwards' }
        );
        const lf = { node: top, a1, a2 };
        const lf2 = { node: bottom, a1: null, a2: null };
        leaves.push(lf, lf2);

        let done = false;
        const finish = () => {
          if (done) return; done = true;
          // remove just these two leaves (others may belong to a newer step - leave them)
          [top, bottom].forEach(n => { if (n.parentNode) n.parentNode.removeChild(n); });
          leaves = leaves.filter(x => x.node !== top && x.node !== bottom);
          resolve();
        };
        a2.onfinish = finish;
        const tm = setTimeout(finish, dur + 60);   // hard safety: leaves never linger
        pendingTimers.push(tm);
      });
    }

    // Flip from current through the reel to `target`, capped at MAX steps.
    async function flipTo(target, opts){
      target = (target || ' ').toUpperCase();
      // a new run supersedes any in-flight run on this tile and purges its leaves
      const token = ++runToken;
      clearLeaves();
      if (target === current){ return; }
      if (RM){ setStatic(target); return; }
      const MAX = (opts && opts.max) || 12;
      const step = (opts && opts.step) || 34; // ms per flap
      let from = idxOf(current);
      const to = idxOf(target);
      let dist = (to - from + GLYPHS.length) % GLYPHS.length;
      if (dist === 0) dist = 1;
      if (dist > MAX){ from = (to - MAX + GLYPHS.length) % GLYPHS.length; dist = MAX; }
      // seed the face at the reel start (without spawning leaves)
      current = GLYPHS[from];
      g.textContent = current === ' ' ? '' : current;
      el.classList.toggle('is-space', current === ' ');
      for (let k = 0; k < dist; k++){
        if (token !== runToken) return;   // superseded - bail, newer run owns the tile
        const a = GLYPHS[(from + k) % GLYPHS.length];
        const b = GLYPHS[(from + k + 1) % GLYPHS.length];
        await flapOnce(a, b, step, token);
      }
      if (token !== runToken) return;
      setStatic(target);                  // guaranteed clean final state: glyph only, no leaves
    }

    if (initial !== ' ') setStatic(initial);
    return { el, setStatic, flipTo, clearLeaves, get current(){ return current; } };
  }

  // Render a string into a .flap container as a row of tiles. Returns an array of tiles.
  function buildFlap(container){
    const target = (container.getAttribute('data-flap') || '').toUpperCase();
    const acc = container.hasAttribute('data-flap-acc');
    container.textContent = '';
    const tiles = [];
    // Group each WORD's tiles in an inline-block nowrap wrapper so a row wraps only BETWEEN
    // words, never inside one (no orphaned single-glyph wraps). Space chars stay standalone
    // dark-slot tiles between word groups, preserving the gaps AND the line-break opportunities.
    let word = null;
    for (const chRaw of target){
      const ch = chRaw;
      // start as a blank BONE card (not a dark slot) so the row already reads as a flap board;
      // real spaces in the target stay dark slots. We flip up to the target char.
      const startBlank = ch === ' ' ? ' ' : '';
      const t = makeTile(startBlank, acc);
      if (RM) t.setStatic(ch);        // reduced motion: print final immediately
      if (ch === ' '){
        word = null;                  // a space ends the current word group and is its own break point
        container.appendChild(t.el);
      } else {
        if (!word){ word = document.createElement('span'); word.className = 'flap-word'; container.appendChild(word); }
        word.appendChild(t.el);
      }
      tiles.push({ t, target: ch });
    }
    container._tiles = tiles;
    container._built = true;
    return tiles;
  }

  // Animate a built container into its target string with a left-to-right stagger ("clatter").
  function flipContainer(container, opts){
    if (!container._built) buildFlap(container);
    const tiles = container._tiles || [];
    if (RM){ tiles.forEach(({ t, target }) => t.setStatic(target)); return; }
    const stag = (opts && opts.stagger) != null ? opts.stagger : 55;
    const step = (opts && opts.step) || 34;
    const max  = (opts && opts.max) || 12;
    tiles.forEach(({ t, target }, i) => {
      setTimeout(() => t.flipTo(target, { step, max }), i * stag);
    });
  }

  // Instantly settle a container to final state (safety + reduced motion).
  function settleContainer(container){
    if (!container._built) buildFlap(container);
    (container._tiles || []).forEach(({ t, target }) => t.setStatic(target));
  }

  /* ---------- wire up all flaps ---------- */
  const allFlaps = Array.from(document.querySelectorAll('.flap[data-flap]'));
  // Build everyone up front (cheap DOM); animation is what we gate by viewport.
  allFlaps.forEach(buildFlap);

  if (RM){
    // reduced motion: everything already printed final by buildFlap. Done.
    allFlaps.forEach(settleContainer);
  } else {
    // Hero headline + non-deferred flaps clatter on load (staggered between rows).
    const heroFlaps = allFlaps.filter(f => !f.hasAttribute('data-flap-defer'));
    heroFlaps.forEach((f, i) => setTimeout(() => flipContainer(f, { stagger: 60, step: 32, max: 14 }), 180 + i * 340));

    // Deferred flaps (metrics, work board, contact) flip when scrolled into view.
    const deferred = allFlaps.filter(f => f.hasAttribute('data-flap-defer'));
    const seen = new WeakSet();
    const flapIO = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && !seen.has(e.target)){
          seen.add(e.target);
          flipContainer(e.target, { stagger: 45, step: 30, max: 12 });
          flapIO.unobserve(e.target);
        }
      });
    }, { threshold: 0.25, rootMargin: '0px 0px -6% 0px' });
    deferred.forEach(f => flapIO.observe(f));

    // Safety net: anything never triggered (e.g. observer edge cases) settles after a grace period.
    setTimeout(() => {
      allFlaps.forEach(f => {
        const tiles = f._tiles || [];
        const incomplete = tiles.some(({ t, target }) => t.current !== (target || ' ').toUpperCase());
        // only force-settle the ones still off-target AND off-screen-ish; harmless if already correct
        if (incomplete && !isNearViewport(f)) settleContainer(f);
      });
    }, 9000);
  }

  function isNearViewport(el){
    const r = el.getBoundingClientRect();
    return r.top < window.innerHeight * 1.3 && r.bottom > -window.innerHeight * 0.3;
  }

  /* ---------- re-flip a work row's STATUS on hover ---------- */
  if (!RM){
    function hoverReflip(scope){
      scope.querySelectorAll('.flap-status').forEach(s => {
        const host = s.closest('tr, .card');
        if (!host || host._hooked) return;
        host._hooked = true;
        host.addEventListener('pointerenter', () => {
          if (!s._built) buildFlap(s);
          flipContainer(s, { stagger: 40, step: 28, max: 12 });
        });
      });
    }
    hoverReflip(document);
  }

  /* ===================== REVEALS ===================== */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ===================== LIVE CLOCK ===================== */
  (function clock(){
    const el = document.getElementById('clock');
    if (!el) return;
    function tick(){
      const d = new Date();
      const p = (n) => String(n).padStart(2, '0');
      el.textContent = p(d.getHours()) + ':' + p(d.getMinutes()) + ':' + p(d.getSeconds());
    }
    tick();
    setInterval(tick, 1000);
  })();
</script>
</body>
