<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- panel reveals (pop / slide / ink-in) ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.14, rootMargin: '0px 0px -7% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* Safety net: if a trigger never fires, force-show every panel after load + on idle. */
  function showAll(){ document.querySelectorAll('.reveal').forEach(el => el.classList.add('show')); }
  if (RM) { showAll(); }
  // Reveal any panel that is currently within (or above) the viewport - covers
  // anchor jumps, fast scrolls and observers that miss a fast-passing element.
  function sweep(){
    document.querySelectorAll('.reveal:not(.show)').forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < window.innerHeight * 1.05) el.classList.add('show');
    });
  }
  window.addEventListener('scroll', sweep, { passive: true });
  window.addEventListener('load', () => { setTimeout(sweep, 1200); });
  // last-resort: nothing should ever stay invisible for long
  setTimeout(showAll, 4000);

  /* ---------- count-up inside the burst numerals ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur = 1000; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(target * eased);
      el.innerHTML = val + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ countUp(e.target); numIO.unobserve(e.target); } });
  }, { threshold: 0.6 });
  document.querySelectorAll('.bigburst').forEach(n => numIO.observe(n));
</script>
