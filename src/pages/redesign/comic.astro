  /* footer */
  footer{border-top:var(--bw) solid var(--ink);padding:1.6rem 0 2.4rem;position:relative;z-index:2;background:var(--paper)}
  .foot-in{width:min(1240px,100%);margin:0 auto;padding:0 var(--pad);display:flex;justify-content:space-between;flex-wrap:wrap;gap:.8rem;
    font-family:var(--mono);font-weight:700;font-size:.68rem;letter-spacing:.06em;color:var(--ink2);text-transform:uppercase}
  .foot-in a{color:var(--red)}.foot-in a:hover{color:var(--ink)}

  /* ===== panel reveal (pop / slide / ink-in) ===== */
  .reveal{opacity:0;transform:translateY(26px) rotate(-.6deg) scale(.97);
    transition:opacity .5s cubic-bezier(.2,.9,.25,1.2),transform .5s cubic-bezier(.2,.9,.25,1.2)}
  .reveal.show{opacity:1;transform:none}
  .reveal.slideL{transform:translateX(-34px) rotate(.5deg)}
  .reveal.slideR{transform:translateX(34px) rotate(-.5deg)}

  @media(prefers-reduced-motion:reduce){
    .reveal{opacity:1!important;transform:none!important;transition:none}
    .scrollcue .arr{animation:none}
    html{scroll-behavior:auto}
  }
</style>
</head>
