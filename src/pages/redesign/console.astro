<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  /* ---------- WebGL gradient backdrop (raw fullscreen-quad shader) ---------- */
  (function(){
    const cv = document.getElementById('gl') as HTMLCanvasElement | null;
    if(!cv) return;
    if(isMobile){ cv.style.display='none'; return; } // CSS gradient fallback stays
    const gl = cv.getContext('webgl', { antialias:true, alpha:true });
    if(!gl){ return; } // CSS fallback on canvas background
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs = `precision highp float;uniform vec2 r;uniform float t;
    float h(vec2 x){return fract(sin(dot(x,vec2(127.1,311.7)))*43758.5453);}
    float n(vec2 x){vec2 i=floor(x),f=fract(x);float a=h(i),b=h(i+vec2(1,0)),c=h(i+vec2(0,1)),d=h(i+vec2(1,1));vec2 u=f*f*(3.-2.*f);return mix(a,b,u.x)+(c-a)*u.y*(1.-u.x)+(d-b)*u.x*u.y;}
    float fbm(vec2 x){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*n(x);x*=2.03;a*=.5;}return v;}
    void main(){
      vec2 uv=gl_FragCoord.xy/r.xy;vec2 p=uv;p.x*=r.x/r.y;
      // soft drifting indigo plume top-right + faint emerald wash bottom-left
      float f=fbm(p*1.6+vec2(t*.025,t*.018));
      float indigo=smoothstep(.2,1.0,fbm(vec2(p.x*1.2-.4,p.y*1.4-t*.02)+f))*smoothstep(1.1,.1,uv.y)*smoothstep(.0,1.0,uv.x);
      float emer=smoothstep(.35,1.0,fbm(vec2(p.x*1.1+2.0,p.y*1.2+t*.016)+f))*smoothstep(.0,.85,1.0-uv.y)*smoothstep(.85,.0,uv.x);
      vec3 bg=mix(vec3(.043,.055,.086),vec3(.04,.051,.078),uv.y);
      vec3 ci=vec3(.39,.40,.95);
      vec3 ce=vec3(.06,.72,.51);
      vec3 col=bg;
      col+=ci*pow(indigo,1.6)*.22;
      col+=ce*pow(emer,1.8)*.10;
      // subtle scanning highlight line that "breathes"
      float beam=smoothstep(.004,.0,abs(uv.y-(.5+.32*sin(t*.25))))*.05;
      col+=ci*beam;
      float vig=smoothstep(1.4,.2,length(uv-vec2(.5,.42)));
      col*=mix(.78,1.0,vig);
      gl_FragColor=vec4(col,1.0);
    }`;
    function sh(type:number,src:string){const o=gl!.createShader(type)!;gl!.shaderSource(o,src);gl!.compileShader(o);return o;}
    const pr=gl.createProgram()!;
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));
    gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));
    gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t');
    function size(){const d=Math.min(window.devicePixelRatio||1,1.6);cv!.width=innerWidth*d;cv!.height=innerHeight*d;gl!.viewport(0,0,cv!.width,cv!.height);gl!.uniform2f(ur,cv!.width,cv!.height);}
    size();addEventListener('resize',size);
    if(reduce){gl.uniform1f(ut,2.0);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    const start=performance.now();
    (function loop(now:number){gl!.uniform1f(ut,(now-start)/1000);gl!.drawArrays(gl!.TRIANGLES,0,3);requestAnimationFrame(loop);})(start);
  })();

  /* ---------- LIVE GROWTH CHART (canvas 2D, draws on + breathes) ---------- */
  (function(){
    const cv = document.getElementById('chart') as HTMLCanvasElement | null;
    if(!cv) return;
    const ctx = cv.getContext('2d');
    if(!ctx) return;
    // synthesized compounding growth series (normalized 0..1)
    const N = 48;
    const base:number[] = [];
    for(let i=0;i<N;i++){
      const x = i/(N-1);
      // ease-in compounding curve + light wobble for a real "data" feel
      const v = Math.pow(x, 1.7)*0.82 + 0.06 + Math.sin(x*9)*0.018 + Math.sin(x*23)*0.01;
      base.push(Math.max(0.02, Math.min(1, v)));
    }
    let dpr = Math.min(window.devicePixelRatio||1, 2);
    let W=0,H=0;
    function resize(){
      const rect = cv!.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio||1, 2);
      cv!.width = Math.max(1, Math.floor(rect.width*dpr));
      cv!.height = Math.max(1, Math.floor(rect.height*dpr));
      W = rect.width; H = rect.height;
      ctx!.setTransform(dpr,0,0,dpr,0,0);
    }
    resize();
    addEventListener('resize', resize);

    let draw = 0;              // 0..1 draw-on progress
    const drawSpeed = reduce ? 1 : 0.012;
    let phase = 0;

    // axis chrome model: endpoint of the series maps to 657K; X spans 2019 -> 2026
    const peakK = 657;                                   // 657K leads at the endpoint
    const yRefs = [ {v:1.0, lbl:'657K'}, {v:0.66, lbl:'430K'}, {v:0.33, lbl:'215K'} ]; // mapped to endpoint
    const xYears = ['2019','2021','2023','2026'];
    const axisFont = '500 9px "JetBrains Mono",ui-monospace,monospace';

    function render(){
      if(W<=0||H<=0){ requestAnimationFrame(render); return; }
      ctx!.clearRect(0,0,W,H);
      const padL = 6, padR = 38, padTop = 26, padBot = 18;  // room for Y labels (right) + X ticks (bottom) + callout (top)
      const plotW = W - padL - padR;
      const plotH = H - padTop - padBot;

      // faint horizontal gridlines + Y reference values (mapped to the 657K endpoint)
      ctx!.lineWidth = 1;
      ctx!.font = axisFont;
      ctx!.textBaseline = 'middle';
      ctx!.textAlign = 'left';
      for(const ref of yRefs){
        const y = padTop + plotH*(1 - ref.v);
        ctx!.strokeStyle = ref.v >= 1 ? 'rgba(255,255,255,0.10)' : 'rgba(255,255,255,0.05)';
        ctx!.beginPath(); ctx!.moveTo(padL, y); ctx!.lineTo(W-padR-4, y); ctx!.stroke();
        ctx!.fillStyle = ref.v >= 1 ? '#b3bccb' : '#a0a8b4';
        ctx!.fillText(ref.lbl, W-padR+2, y);
      }
      // baseline
      ctx!.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx!.beginPath(); ctx!.moveTo(padL, padTop+plotH); ctx!.lineTo(W-padR-4, padTop+plotH); ctx!.stroke();

      // X-axis time ticks 2019 -> 2026
      ctx!.textBaseline = 'top';
      ctx!.fillStyle = '#a0a8b4';
      xYears.forEach((yr,ix)=>{
        const x = padL + plotW*(ix/(xYears.length-1));
        ctx!.textAlign = ix===0 ? 'left' : ix===xYears.length-1 ? 'right' : 'center';
        ctx!.fillText(yr, x, padTop+plotH+6);
        ctx!.strokeStyle = 'rgba(255,255,255,0.07)';
        ctx!.beginPath(); ctx!.moveTo(x, padTop+plotH); ctx!.lineTo(x, padTop+plotH+3); ctx!.stroke();
      });

      const count = Math.max(2, Math.floor(base.length * draw));
      const breathe = reduce ? 0 : Math.sin(phase)*0.012;

      const px = (i:number)=> padL + (plotW)*(i/(base.length-1));
      const py = (v:number)=> padTop + plotH*(1 - Math.min(1, v + breathe));

      // area fill (committed to cyan - single chart color)
      const grad = ctx!.createLinearGradient(0,padTop,0,padTop+plotH);
      grad.addColorStop(0,'rgba(34,211,238,0.30)');
      grad.addColorStop(1,'rgba(34,211,238,0.0)');
      ctx!.beginPath();
      ctx!.moveTo(px(0), padTop+plotH);
      for(let i=0;i<count;i++){ ctx!.lineTo(px(i), py(base[i])); }
      ctx!.lineTo(px(count-1), padTop+plotH);
      ctx!.closePath();
      ctx!.fillStyle = grad;
      ctx!.fill();

      // line stroke (single cyan - no mid-stroke color shift)
      const lg = '#22d3ee';
      ctx!.beginPath();
      for(let i=0;i<count;i++){
        const X=px(i), Y=py(base[i]);
        if(i===0) ctx!.moveTo(X,Y); else ctx!.lineTo(X,Y);
      }
      ctx!.lineWidth = 2;
      ctx!.lineJoin = 'round';
      ctx!.strokeStyle = lg;
      ctx!.stroke();

      // leading dot
      const lx = px(count-1), ly = py(base[count-1]);
      ctx!.beginPath();
      ctx!.arc(lx, ly, 3.4, 0, Math.PI*2);
      ctx!.fillStyle = '#22d3ee';
      ctx!.fill();
      if(!reduce){
        ctx!.beginPath();
        ctx!.arc(lx, ly, 6 + Math.sin(phase*2)*2, 0, Math.PI*2);
        ctx!.strokeStyle = 'rgba(34,211,238,0.4)';
        ctx!.lineWidth = 1.2;
        ctx!.stroke();
      }

      // animated peak callout / tooltip - fades in as the line finishes drawing
      const cAlpha = reduce ? 1 : Math.max(0, Math.min(1, (draw - 0.82) / 0.18));
      if(cAlpha > 0.01){
        const bob = reduce ? 0 : Math.sin(phase*1.4)*1.6;
        const label = `+${peakK}K leads`;
        ctx!.font = '600 10px "JetBrains Mono",ui-monospace,monospace';
        const tw = ctx!.measureText(label).width;
        const bw = tw + 16, bh = 19;
        let bx = lx - bw - 8;                 // prefer left of the dot so it stays in-frame
        if(bx < padL) bx = lx + 8;
        const by = Math.max(padTop + 1, ly - bh - 10) + bob;
        ctx!.globalAlpha = cAlpha;
        // connector
        ctx!.strokeStyle = 'rgba(34,211,238,0.5)';
        ctx!.lineWidth = 1;
        ctx!.beginPath(); ctx!.moveTo(lx, ly); ctx!.lineTo(bx + bw/2, by + bh); ctx!.stroke();
        // bubble
        ctx!.fillStyle = 'rgba(20,26,40,0.96)';
        ctx!.strokeStyle = 'rgba(34,211,238,0.55)';
        ctx!.lineWidth = 1;
        const rr = 6;
        ctx!.beginPath();
        ctx!.moveTo(bx+rr, by);
        ctx!.arcTo(bx+bw, by, bx+bw, by+bh, rr);
        ctx!.arcTo(bx+bw, by+bh, bx, by+bh, rr);
        ctx!.arcTo(bx, by+bh, bx, by, rr);
        ctx!.arcTo(bx, by, bx+bw, by, rr);
        ctx!.closePath();
        ctx!.fill(); ctx!.stroke();
        ctx!.fillStyle = '#7ee9f5';
        ctx!.textAlign = 'left'; ctx!.textBaseline = 'middle';
        ctx!.fillText(label, bx + 8, by + bh/2 + 0.5);
        ctx!.globalAlpha = 1;
      }

      if(draw < 1) draw = Math.min(1, draw + drawSpeed);
      phase += 0.03;
      requestAnimationFrame(render);
    }
    // start drawing when in view (or immediately on reduced motion)
    if(reduce){ draw = 1; }
    requestAnimationFrame(render);
  })();

  /* ---------- ticking metric counters ---------- */
  function tickCounters(){
    document.querySelectorAll<HTMLElement>('.c-metric').forEach(tile=>{
      const target = parseFloat(tile.dataset.metric || '0');
      const scale = parseFloat(tile.dataset.scale || '1');
      const dec = parseInt(tile.dataset.dec || '0', 10);
      const numEl = tile.querySelector('.num') as HTMLElement | null;
      if(!numEl) return;
      const end = target/scale;
      if(reduce){ numEl.textContent = end.toFixed(dec); return; }
      const obj = { v: 0 };
      gsap.to(obj, { v: end, duration: 1.6, ease:'power2.out',
        onUpdate:()=>{ numEl.textContent = obj.v.toFixed(dec); } });
    });
  }

  /* ---------- "What I do" module panels: count metric + draw sparkline when in view ---------- */
  function activatePillar(p:HTMLElement){
    if(p.dataset.lit) return; p.dataset.lit = '1';
    p.classList.add('spark-in');
    const numEl = p.querySelector('.pnum') as HTMLElement | null;
    if(numEl){
      const end = parseFloat(numEl.dataset.pmetric || '0');
      const dec = parseInt(numEl.dataset.pdec || '0', 10);
      if(reduce){ numEl.textContent = end.toFixed(dec); }
      else { const obj={v:0}; gsap.to(obj,{ v:end, duration:1.4, ease:'power2.out',
        onUpdate:()=>{ numEl.textContent = obj.v.toFixed(dec); } }); }
    }
  }

  /* ---------- COMMAND PALETTE ---------- */
  (function(){
    const backdrop = document.getElementById('cmdkBackdrop')!;
    const modal = document.getElementById('cmdk')!;
    const input = document.getElementById('cmdkInput') as HTMLInputElement;
    const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('.cmdk-item'));
    const empty = document.getElementById('cmdkEmpty')!;
    let open = false, sel = 0;

    function setOpen(state:boolean){
      open = state;
      if(state){
        modal.hidden = false;
        requestAnimationFrame(()=>{ backdrop.classList.add('open'); modal.classList.add('open'); });
        input.value=''; filter(''); sel=0; updateSel();
        setTimeout(()=>input.focus(), 30);
      } else {
        backdrop.classList.remove('open'); modal.classList.remove('open');
        setTimeout(()=>{ if(!open) modal.hidden = true; }, 260);
      }
    }
    function visibleItems(){ return items.filter(it=>!it.hidden); }
    function updateSel(){
      const vis = visibleItems();
      items.forEach(it=>it.setAttribute('aria-selected','false'));
      if(vis[sel]){ vis[sel].setAttribute('aria-selected','true'); vis[sel].scrollIntoView({block:'nearest'}); }
    }
    function filter(q:string){
      const ql = q.trim().toLowerCase();
      let any = false;
      items.forEach(it=>{
        const match = !ql || (it.dataset.label||'').includes(ql);
        it.hidden = !match;
        if(match) any = true;
      });
      empty.hidden = any;
      sel = 0; updateSel();
    }
    function activate(){
      const vis = visibleItems();
      const t = vis[sel];
      if(t){ setOpen(false); t.click(); }
    }
    input.addEventListener('input', ()=>filter(input.value));
    document.addEventListener('keydown', (e:KeyboardEvent)=>{
      if((e.key==='k'||e.key==='K') && (e.metaKey||e.ctrlKey)){ e.preventDefault(); setOpen(!open); return; }
      if(e.key==='/' && !open){
        const tag=(document.activeElement?.tagName||'').toLowerCase();
        if(tag!=='input'&&tag!=='textarea'){ e.preventDefault(); setOpen(true); }
        return;
      }
      if(!open) return;
      if(e.key==='Escape'){ e.preventDefault(); setOpen(false); }
      else if(e.key==='ArrowDown'){ e.preventDefault(); sel=Math.min(sel+1, visibleItems().length-1); updateSel(); }
      else if(e.key==='ArrowUp'){ e.preventDefault(); sel=Math.max(sel-1,0); updateSel(); }
      else if(e.key==='Enter'){ e.preventDefault(); activate(); }
    });
    items.forEach((it)=>{
      it.addEventListener('mouseenter',()=>{ sel = visibleItems().indexOf(it); updateSel(); });
      it.addEventListener('click',()=> setOpen(false));
    });
    backdrop.addEventListener('click', ()=>setOpen(false));
    document.getElementById('openCmd')?.addEventListener('click', ()=>setOpen(true));
    document.getElementById('openCmd2')?.addEventListener('click', ()=>setOpen(true));
  })();

  /* ---------- smooth scroll + reveals + counters ---------- */
  if(!reduce){
    const lenis = new Lenis({ lerp:.1, smoothWheel:true });
    function raf(t:number){ lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll', ScrollTrigger.update);
    // keep anchor links + Lenis in sync
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a=>{
      a.addEventListener('click',(e)=>{
        const id = a.getAttribute('href')!;
        if(id.length>1){ const el=document.querySelector(id); if(el){ e.preventDefault(); lenis.scrollTo(el as HTMLElement,{offset:-70}); } }
      });
    });

    // hero headline lines
    gsap.set('.c-headline h1 .ln>span',{ yPercent:115 });
    const tl = gsap.timeline({ delay:.12 });
    tl.to('.c-headline h1 .ln>span',{ yPercent:0, duration:1.05, ease:'expo.out', stagger:.1 });

    // batched reveals - every .reveal ends opacity:1
    ScrollTrigger.batch('.reveal',{
      start:'top 90%',
      onEnter:batch=>gsap.to(batch,{ opacity:1, y:0, duration:.9, ease:'expo.out', stagger:.07, overwrite:true }),
    });

    // counters fire once hero metrics enter
    ScrollTrigger.create({ trigger:'.bento', start:'top 80%', once:true, onEnter:tickCounters });
    // also fire on load in case hero is already fully visible
    setTimeout(()=>{ if(window.scrollY < 80) tickCounters(); }, 400);

    // status bars animate when in view
    ScrollTrigger.create({
      trigger:'.c-status', start:'top 85%', once:true,
      onEnter:()=>{
        document.querySelectorAll<HTMLElement>('.c-status .bar i').forEach(bar=>{
          gsap.to(bar,{ width:(bar.dataset.fill||'0')+'%', duration:1.2, ease:'power2.out' });
        });
      }
    });

    // "What I do" module panels light up as they enter
    document.querySelectorAll<HTMLElement>('.pillar').forEach(p=>{
      ScrollTrigger.create({ trigger:p, start:'top 88%', once:true, onEnter:()=>activatePillar(p) });
    });

    // live feed: stream rows in + start the scan sweep when it enters view
    const feedEl = document.querySelector<HTMLElement>('.feed');
    if(feedEl){
      ScrollTrigger.create({ trigger:feedEl, start:'top 85%', once:true,
        onEnter:()=>feedEl.classList.add('feed-live') });
    }

    // progress bar
    gsap.to('#progress',{ scaleX:1, ease:'none',
      scrollTrigger:{ trigger:document.body, start:'top top', end:'bottom bottom', scrub:.3 } });

    ScrollTrigger.refresh();

    // work table glow follows cursor
    document.querySelectorAll<HTMLElement>('.trow').forEach(row=>{
      row.addEventListener('mousemove',(e:MouseEvent)=>{
        const r = row.getBoundingClientRect();
        row.style.setProperty('--mx', `${((e.clientX-r.left)/r.width)*100}%`);
      });
    });
  } else {
    // reduced motion: paint final states immediately
    tickCounters();
    document.querySelectorAll<HTMLElement>('.c-status .bar i').forEach(bar=>{ bar.style.width=(bar.dataset.fill||'0')+'%'; });
    document.querySelectorAll<HTMLElement>('.pillar').forEach(p=>activatePillar(p));
  }
</script>
</body>
</html>
