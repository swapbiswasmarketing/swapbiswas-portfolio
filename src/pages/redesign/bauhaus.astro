<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  // ---- WebGL constructivist composition ----
  // Hard-edged primary-colour geometric shapes (circles, bars, triangles) slowly
  // rotating / translating / intersecting in a balanced kinetic dance behind the hero.
  // Mobile WebGL is unreliable, so there we fall back to the animated CSS shapes.
  (function(){
    const cv = document.getElementById('gl');
    const css = document.getElementById('cssShapes');
    if(isMobile){
      if(cv) cv.style.display = 'none';
      if(css) css.style.display = 'block';
      return;
    }
    const gl = cv.getContext('webgl', { antialias:true, alpha:false });
    if(!gl){
      if(css) css.style.display = 'block';
      if(cv) cv.style.display = 'none';
      return;
    }
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs = `precision highp float;uniform vec2 r;uniform float t;uniform vec2 mo;
    // primaries
    vec3 BONE=vec3(.957,.945,.910);vec3 RED=vec3(.902,.200,.161);
    vec3 BLUE=vec3(.141,.251,.847);vec3 YEL=vec3(.965,.780,0.0);vec3 INK=vec3(.078,.078,.078);
    mat2 rot(float a){float s=sin(a),c=cos(a);return mat2(c,-s,s,c);}
    // hard-edged anti-aliased fill helpers (1 inside, 0 outside)
    float circle(vec2 uv,vec2 c,float rad){float d=length(uv-c);return smoothstep(rad+.004,rad-.004,d);}
    float ring(vec2 uv,vec2 c,float rad,float w){float d=length(uv-c);return smoothstep(.004,0.,abs(d-rad)-w);}
    float box(vec2 uv,vec2 c,vec2 hs,float a){vec2 q=abs(rot(a)*(uv-c))-hs;float d=max(q.x,q.y);return smoothstep(.004,-.004,d);}
    float tri(vec2 uv,vec2 c,float s,float a){uv=rot(a)*(uv-c);uv.y+=s*.25;
      float d=max(abs(uv.x)*.866+uv.y*.5,-uv.y);return smoothstep(.004,-.004,d-s*.5);}
    void main(){
      vec2 uv=gl_FragCoord.xy/r.xy;uv-=.5;uv.x*=r.x/r.y;
      // slow parallax toward the mouse so the whole composition drifts subtly
      vec2 par=(mo-.5)*.06;
      vec3 col=BONE;
      // BIG static blue circle upper-right (anchor) - pushed further right/up so it
      // clears the left-aligned wordmark glyphs (incl. the 'O' region of MACHINE)
      col=mix(col,BLUE,circle(uv,vec2(.56,.34)+par,.20));
      // rolling red circle - translates left to right and back, low-left
      float rollx=-0.46+0.30*sin(t*.18);
      col=mix(col,RED,circle(uv,vec2(rollx,-.26)+par*.6,.12));
      // sliding yellow bar that travels horizontally across mid-height
      float barx=-0.10+0.18*sin(t*.13+1.0);
      col=mix(col,YEL,box(uv,vec2(barx,.02)+par,vec2(.26,.028),0.0));
      // rotating ink triangle
      col=mix(col,INK,tri(uv,vec2(.20,-.18)+par,.16,t*.10));
      // slowly rotating ink keyline bar (thin) crossing the field
      col=mix(col,INK,box(uv,vec2(0.0,0.0),vec2(.62,.006),0.45+sin(t*.05)*.12));
      // a hollow yellow ring orbiting slowly - lifted up and out to the upper-left
      // margin so its orbit never collides with the wordmark glyphs
      vec2 orb=vec2(cos(t*.16),sin(t*.16))*.30;
      col=mix(col,YEL,ring(uv,vec2(-.42,.36)+orb*.32+par,.085,.018));
      // small blue square pulsing scale, lower-right
      float sc=.05+.012*sin(t*.4);
      col=mix(col,BLUE,box(uv,vec2(.40,-.30)+par,vec2(sc),t*.2));
      // thin red diagonal keyline
      col=mix(col,RED,box(uv,vec2(-.12,-.05),vec2(.7,.0035),-0.55));
      gl_FragColor=vec4(col,1.0);
    }`;
    function sh(ty,s){const o=gl.createShader(ty);gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram();
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));
    gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t'),um=gl.getUniformLocation(pr,'mo');
    let mx=.5,my=.5;
    function size(){const d=Math.min(window.devicePixelRatio||1,1.6);cv.width=innerWidth*d;cv.height=innerHeight*d;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);}
    size();addEventListener('resize',size);
    addEventListener('mousemove',(e)=>{mx=e.clientX/innerWidth;my=1-e.clientY/innerHeight;});
    if(reduce){gl.uniform1f(ut,2.0);gl.uniform2f(um,.5,.5);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    const start=performance.now();let tmx=.5,tmy=.5;
    (function loop(now){
      tmx+=(mx-tmx)*.05;tmy+=(my-tmy)*.05;
      gl.uniform1f(ut,(now-start)/1000);gl.uniform2f(um,tmx,tmy);
      gl.drawArrays(gl.TRIANGLES,0,3);requestAnimationFrame(loop);
    })(start);
  })();

  // ---- smooth scroll + reveals ----
  if(!reduce){
    const lenis=new Lenis({lerp:.1,smoothWheel:true});
    function raf(time){lenis.raf(time);requestAnimationFrame(raf);}requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll',ScrollTrigger.update);

    // hero entrance
    gsap.set('.hero h1 .ln>span',{yPercent:115});
    gsap.set('.hero .tag,.hero .sub,.hero .cta,.hero .herofoot',{opacity:0,y:22});
    const tl=gsap.timeline({delay:.15});
    tl.to('.hero h1 .ln>span',{yPercent:0,duration:1.05,ease:'expo.out',stagger:.1})
      .to('.hero .tag',{opacity:1,y:0,duration:.6},.15)
      .to('.hero .sub',{opacity:1,y:0,duration:.7},.45)
      .to('.hero .cta',{opacity:1,y:0,duration:.7},.6)
      .to('.hero .herofoot',{opacity:1,y:0,duration:.7},.72);

    // batched scroll reveals - every .reveal still ends at opacity:1
    ScrollTrigger.batch('.reveal',{
      start:'top 90%',
      onEnter:batch=>gsap.to(batch,{opacity:1,y:0,duration:.9,ease:'expo.out',stagger:.07,overwrite:true}),
    });
    ScrollTrigger.refresh();

    // scroll progress
    gsap.to('#progress',{scaleX:1,ease:'none',scrollTrigger:{trigger:document.body,start:'top top',end:'bottom bottom',scrub:.3}});

    // marquee - constant drift, nudged by scroll velocity
    const track=document.getElementById('mqtrack');
    if(track){
      const half=track.scrollWidth/2;
      let x=0;
      function mqloop(){x-=0.6;if(-x>=half)x+=half;track.style.transform=`translateX(${x}px)`;requestAnimationFrame(mqloop);}
      mqloop();
    }

    // signature: a circle that rolls (rotates) as you scroll the page
    const roller=document.getElementById('roller');
    if(roller){
      gsap.to(roller,{rotation:1080,ease:'none',scrollTrigger:{trigger:document.body,start:'top top',end:'bottom bottom',scrub:.4}});
    }

    // signature: the sliding-bar parallax - stat decos drift slightly with scroll
    gsap.utils.toArray('.stat .deco').forEach((d,i)=>{
      gsap.to(d,{y:(i%2?-1:1)*18,ease:'none',scrollTrigger:{trigger:d,start:'top bottom',end:'bottom top',scrub:.6}});
    });

    // photo-plate accents drift on scroll (constructivist motion below the fold)
    gsap.to('.about .photoframe .disc',{y:-26,ease:'none',scrollTrigger:{trigger:'.about .photoframe',start:'top bottom',end:'bottom top',scrub:.6}});
    gsap.to('.about .photoframe .bartop',{y:22,x:8,ease:'none',scrollTrigger:{trigger:'.about .photoframe',start:'top bottom',end:'bottom top',scrub:.6}});

    // magnetic primary CTA
    document.querySelectorAll('.btn.primary').forEach(btn=>{
      btn.addEventListener('mousemove',(e)=>{const rc=btn.getBoundingClientRect();gsap.to(btn,{x:(e.clientX-rc.left-rc.width/2)*.3,y:(e.clientY-rc.top-rc.height/2)*.4,duration:.4,ease:'power3.out'});});
      btn.addEventListener('mouseleave',()=>gsap.to(btn,{x:0,y:0,duration:.6,ease:'elastic.out(1,.4)'}));
    });
  }
</script>
</body>
</html>
