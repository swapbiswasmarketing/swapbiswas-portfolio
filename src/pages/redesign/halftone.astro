<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  setTimeout(() => document.getElementById('hero')?.classList.add('in'), 60);

  /* ---------- dot-matrix count-up ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.firstChild ? (el.childNodes[0].nodeValue = String(target)) : (el.textContent = target); if(sup) el.appendChild(sup); return; }
    const dur = 1100; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(target * eased);
      el.innerHTML = val + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ countUp(e.target.querySelector('.dotnum')); numIO.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('.num').forEach(n => numIO.observe(n));

  /* ---------- halftone portrait (loupe) ---------- */
  (function halftone(){
    const cv = document.getElementById('halftone');
    if (!cv) return;
    const ctx = cv.getContext('2d');
    const INK = getComputedStyle(document.documentElement).getPropertyValue('--ink').trim() || '#ece6d8';
    const CELL = 8;            // px between dot centres (CSS px)
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    let cells = [], W = 0, H = 0, ready = false;
    const mouse = { x: -9999, y: -9999, active: false };
    let introStart = 0, introDone = RM;

    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.src = '/assets/portrait-cut.webp';

    function build(){
      const rect = cv.getBoundingClientRect();
      if (rect.width < 4) return;
      W = rect.width; H = rect.height;
      cv.width = Math.round(W * DPR); cv.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      const cols = Math.ceil(W / CELL), rows = Math.ceil(H / CELL);
      const off = document.createElement('canvas'); off.width = cols; off.height = rows;
      const o = off.getContext('2d');
      // cover-fit the portrait, anchored top-centre so the face stays in frame
      const ir = img.width / img.height, cr = cols / rows;
      let dw, dh, dx, dy;
      if (ir > cr){ dh = rows; dw = rows * ir; dx = (cols - dw) / 2; dy = 0; }
      else { dw = cols; dh = cols / ir; dx = 0; dy = 0; }
      o.clearRect(0, 0, cols, rows);
      o.drawImage(img, dx, dy, dw, dh);
      let data;
      try { data = o.getImageData(0, 0, cols, rows).data; }
      catch (err) { return; } // tainted canvas guard
      cells = [];
      for (let j = 0; j < rows; j++){
        for (let i = 0; i < cols; i++){
          const idx = (j * cols + i) * 4;
          const a = data[idx + 3] / 255;
          if (a < 0.12) continue;
          const lum = (0.299 * data[idx] + 0.587 * data[idx+1] + 0.114 * data[idx+2]) / 255;
          const r0 = (0.30 + Math.pow(lum, 0.9) * 1.05) * (CELL * 0.5) * Math.min(1, a + 0.1);
          if (r0 < 0.25) continue;
          const cx = i * CELL + CELL/2, cy = j * CELL + CELL/2;
          cells.push({ x: cx, y: cy, r: r0, d: (cy / H) * 0.55 + Math.random() * 0.45 });
        }
      }
      ready = true;
      if (introDone) drawStatic(); else { introStart = performance.now(); requestAnimationFrame(introFrame); }
    }
    function drawStatic(){
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = INK;
      for (const c of cells){ ctx.beginPath(); ctx.arc(c.x, c.y, c.r, 0, 6.2832); ctx.fill(); }
    }
    function introFrame(now){
      const p = Math.min(1, (now - introStart) / 1300);
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = INK;
      for (const c of cells){
        const local = Math.max(0, Math.min(1, (p * 1.45 - c.d) / 0.55));
        const e = local < 1 ? 1 - Math.pow(1 - local, 2) : 1;
        const r = c.r * e;
        if (r > 0.2){ ctx.beginPath(); ctx.arc(c.x, c.y, r, 0, 6.2832); ctx.fill(); }
      }
      if (p < 1) requestAnimationFrame(introFrame);
      else { introDone = true; drawStatic(); }
    }
    function loupeFrame(){
      if (!mouse.active || !ready || !introDone){ return; }
      const R = Math.max(120, Math.min(W, H) * 0.42);
      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = INK;
      for (const c of cells){
        const dx = c.x - mouse.x, dy = c.y - mouse.y;
        const d = Math.sqrt(dx*dx + dy*dy);
        let r = c.r;
        if (d < R){ const f = 1 - d / R; r = c.r * (1 + f * f * 1.7); }
        ctx.beginPath(); ctx.arc(c.x, c.y, r, 0, 6.2832); ctx.fill();
      }
      requestAnimationFrame(loupeFrame);
    }
    if (!RM){
      cv.addEventListener('pointermove', (ev) => {
        const rect = cv.getBoundingClientRect();
        mouse.x = ev.clientX - rect.left; mouse.y = ev.clientY - rect.top;
        const was = mouse.active; mouse.active = true;
        if (!was) requestAnimationFrame(loupeFrame);
      });
      cv.addEventListener('pointerleave', () => { mouse.active = false; if (ready && introDone) drawStatic(); });
    }
    img.onload = build;
    img.onerror = () => { /* leave the framed plate empty if the asset is missing */ };
    let rt;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => { introDone = true; build(); }, 180); });
  })();
</script>
