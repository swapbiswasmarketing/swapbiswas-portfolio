<script>
  // GSAP not required for this mechanic - a tiny vanilla print sequencer keeps it light + 60fps.
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const root = document.documentElement;
  const receipt = document.getElementById('receipt');
  const head = document.getElementById('printhead');
  const lines = Array.from(document.querySelectorAll('.pl')) as HTMLElement[];

  if (RM || !receipt || !head || !lines.length) {
    // reduced motion (or nothing to do): leave everything fully visible (default CSS), no head.
  } else {
    // Hide lines (CSS: html.js-print .pl -> opacity:0), then spool them back in one by one.
    root.classList.add('js-print');

    const rcpt = receipt as HTMLElement;
    const ph = head as HTMLElement;
    const STEP = Math.max(30, Math.min(70, 1400 / lines.length)); // ms between lines
    let i = 0;
    let safety = 0;

    function showHeadAt(el: HTMLElement) {
      const r = el.getBoundingClientRect();
      const rr = rcpt.getBoundingClientRect();
      ph.style.top = (r.bottom - rr.top - 4) + 'px';
      ph.style.opacity = '1';
    }
    function finish() {
      ph.style.opacity = '0';
      lines.forEach(el => el.classList.add('shown'));
      clearTimeout(safety);
    }
    function tick() {
      if (i >= lines.length) { finish(); return; }
      const el = lines[i];
      el.classList.add('shown');     // CSS transition reveals it
      showHeadAt(el);
      i++;
      setTimeout(() => requestAnimationFrame(tick), STEP);
    }

    // Kick off after two frames so fonts/layout settle (keeps the print-head aligned).
    requestAnimationFrame(() => requestAnimationFrame(() => {
      safety = window.setTimeout(finish, 3500); // hard guarantee: everything visible within 3.5s
      tick();
    }));
  }
</script>
