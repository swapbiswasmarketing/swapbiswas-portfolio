---
// REDESIGN PROTOTYPE - "Kernel" (Concept 21) - the site boots like a developer OS into a riced
// tiling window manager (think i3 / sway + a polybar status bar + neofetch).
// DISTINCT from "Console" (a SaaS dashboard) and "Terminal" (a single phosphor-green CLI):
//  - Mechanic: a short BOOT / POST sequence TYPES out, enumerating his "systems", then the screen
//    "boots" into a TILING DESKTOP of titled windows with subtle gaps (the rice). Each section is a
//    focusable window: a neofetch hero (ASCII SB + a system-info spec block), a work window (an `ls`
//    file listing you arrow/click to expand the outcome), an about window, a contact window.
//  - Status bar (polybar): workspaces 1-5, focused window title, CPU/RAM-style glyphs, a live clock.
//  - Palette: dark #0d0f12, off-white ink, ONE accent = soft coral #f08a7a (+ a cool periwinkle support).
//    NOT green - Terminal owns green. Monospace throughout. Blinking block cursor.
// Self-contained: own <html>, own Google Fonts <link>, own CSS tokens, noindex. GSAP optional in a PLAIN
// <script> (graceful: boot auto-completes / is skippable, JS-off renders the full desktop readable).
const stats = [
  { n: '20', plus: '+', l: 'AI agents & internal tools shipped' },
  { n: '15', plus: '+', l: 'Marketers mentored & levelled up' },
  { n: '76', plus: '',  l: 'Long-form articles published' },
];
const pillars = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.' },
];
const work = [
  { i: '01', file: 'lambdatest', t: 'LambdaTest', y: '2021 - 2025', role: 'Product & digital marketing', r: '657K+ leads · 18.2M+ organic', d: 'Owned product and digital marketing end to end and built the full organic growth engine.', perm: 'drwxr-xr-x', sz: '9.2K', feat: true },
  { i: '02', file: 'testmu-ai', t: 'TestMu AI', y: '2026', role: 'Rebrand lead', r: 'Full company rebrand', d: 'Led the complete rebrand from LambdaTest to TestMu AI.', perm: '-rwxr-xr-x', sz: '5.4K' },
  { i: '03', file: 'samsung', t: 'Samsung', y: '2019', role: 'via Sociowash', r: 'Galaxy M-series launch', d: 'On the Galaxy M-series from inception; ran content distribution, collaborated with Technical Guruji.', perm: '-rwxr-xr-x', sz: '4.8K' },
  { i: '04', file: 'medilife', t: 'Medilife Superspeciality', y: '0 to 1', role: 'Marketing & web', r: 'Website · GTM · social', d: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.', perm: '-rwxr-xr-x', sz: '6.1K' },
  { i: '05', file: 'lido-learning', t: 'Lido Learning', y: '2021', role: 'Growth / CRM', r: 'CRM & lead operations', d: 'Ran CRM management and lead routing and assignment for the EdTech.', perm: '-rwxr-xr-x', sz: '3.6K' },
  { i: '06', file: 'appknox', t: 'Appknox', y: 'Freelance', role: 'Content', r: 'Security content', d: 'Freelance content writer for the mobile app security company.', perm: '-rwxr-xr-x', sz: '2.4K' },
];
const recognition = [
  { t: 'Value of Agility Award', m: 'LambdaTest, 2024' },
  { t: 'Wall of Fame', m: 'LambdaTest' },
  { t: '#1 Product of the Day', m: 'Product Hunt' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
// neofetch-style system spec block - his real role/facts are the "specs"
const specs = [
  { k: 'user', v: 'swapnil@kernel' },
  { k: 'role', v: 'Senior Product Marketing Manager' },
  { k: 'host', v: 'LambdaTest' },
  { k: 'uptime', v: '7+ yrs marketing · 4+ in B2B SaaS' },
  { k: 'kernel', v: 'product-marketing 5.7-ship' },
  { k: 'shell', v: 'GTM · SEO · AEO · AI agents' },
  { k: 'location', v: 'Mumbai, India' },
  { k: 'cache', v: '657K+ leads · 18.2M+ organic · 10x lift' },
];
// the boot / POST lines that type out before the desktop mounts
const bootlines = [
  { pre: '[    0.000000]', t: 'Kernel v5.7-ship booting on swapnil@kernel ...', s: 'ok' },
  { pre: '[    0.142200]', t: 'loading kernel modules: product-marketing.ko gtm.ko', s: 'ok' },
  { pre: '[    0.318400]', t: 'mounting /sites  /seo  /agents  /content', s: 'ok' },
  { pre: '[    0.504100]', t: 'starting seo.daemon  aeo.daemon  growth.engine', s: 'ok' },
  { pre: '[    0.781900]', t: 'cache warm: 657K+ leads · 18.2M+ organic · 10x lift', s: 'ok' },
  { pre: '[    1.020700]', t: 'spawned 20+ agents · mentored 15+ marketers · 76 articles', s: 'ok' },
  { pre: '[    1.244300]', t: 'wm: tiling layout ready  ·  status: shipping', s: 'live' },
];
const workspaces = [
  { n: '1', name: 'home',    href: '#win-home' },
  { n: '2', name: 'work',    href: '#win-work' },
  { n: '3', name: 'stack',   href: '#win-stack' },
  { n: '4', name: 'about',   href: '#win-about' },
  { n: '5', name: 'contact', href: '#win-contact' },
];
---
<!doctype html>
<html lang="en" data-theme="kernel">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#0d0f12; --bg2:#0a0c0f; --win:#13161b; --win2:#10131800; --bar:#0a0c10;
    --ink:#e8ebef; --ink2:#cdd3da; --dim:#9aa3ad; --faint:#7e8893;
    --coral:#f08a7a;         /* the one accent - soft coral */
    --coral2:#f6a99c;
    --peri:#8aa9d6;          /* cool periwinkle support hue */
    --peri2:#a9c0e6;
    --gold:#e7c07b;          /* used sparingly for ok/specs values */
    --line:rgba(232,235,239,.10); --line2:rgba(232,235,239,.06);
    --cline:rgba(240,138,122,.40);
    --titlebar:#181c22;
    --gap:10px;
    --mono:"IBM Plex Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --sans:"IBM Plex Sans",system-ui,sans-serif;
    --bar-h:38px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{overflow-x:clip}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:var(--mono);min-height:100vh;
    -webkit-font-smoothing:antialiased;line-height:1.6;font-size:15px;letter-spacing:.005em;
    background-image:
      radial-gradient(120% 80% at 85% -10%, rgba(240,138,122,.07), transparent 60%),
      radial-gradient(100% 70% at 0% 110%, rgba(138,169,214,.06), transparent 60%);
    background-attachment:fixed;}
  /* faint dotted wallpaper grid - the riced desktop backdrop */
  body::before{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.55;
    background-image:radial-gradient(rgba(232,235,239,.05) 1px, transparent 1.4px);
    background-size:26px 26px;}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--coral);color:#13070a}
  .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap}

  /* blinking block cursor */
  .cur{display:inline-block;width:.58em;height:1.02em;background:var(--coral);vertical-align:-.14em;
    margin-left:.12em;animation:blink 1.05s steps(1) infinite;}
  @keyframes blink{0%,49%{opacity:1}50%,100%{opacity:0}}

  /* ============== POLYBAR STATUS BAR ============== */
  .bar{position:fixed;top:0;left:0;right:0;height:var(--bar-h);z-index:80;display:flex;align-items:stretch;
    background:linear-gradient(180deg,#0b0d11,#090b0e);border-bottom:1px solid var(--line);
    font-size:.78rem;letter-spacing:.02em;}
  .bar-l,.bar-c,.bar-r{display:flex;align-items:center;gap:.1rem;padding:0 .35rem}
  .bar-l{flex:none}
  .bar-c{flex:1;min-width:0;justify-content:flex-start;padding-left:.7rem;color:var(--dim);overflow:hidden}
  .bar-r{flex:none;gap:.55rem;padding-right:.7rem;color:var(--dim)}
  .ws{display:inline-flex;align-items:center;justify-content:center;min-width:30px;height:100%;padding:0 .5rem;
    color:var(--faint);position:relative;transition:color .25s,background .25s;border-right:1px solid var(--line2)}
  .ws:first-child{border-left:1px solid var(--line2)}
  .ws .wsn{font-weight:600}
  .ws .wsname{display:none;margin-left:.4rem;color:inherit}
  .ws:hover{color:var(--ink2);background:rgba(232,235,239,.04)}
  .ws.active{color:#150a08;background:var(--coral);font-weight:600}
  .ws.active::after{content:"";position:absolute;left:0;right:0;bottom:0;height:0}
  .ws.active .wsname{display:inline}
  @media(min-width:920px){ .ws.active{min-width:auto} .ws .wsname{display:inline;color:var(--faint)} .ws.active .wsname{color:#3a140f} }
  .bar-c .layout{color:var(--coral);font-weight:600;margin-right:.7rem;flex:none}
  .bar-c .ftitle{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0}
  .bar-c .ftitle b{color:var(--ink2);font-weight:500}
  .glyph{display:inline-flex;align-items:center;gap:.32rem;white-space:nowrap}
  .glyph i{font-style:normal;color:var(--coral)}
  .glyph .v{color:var(--ink2)}
  .bar-r .clock{color:var(--ink2);font-weight:500;font-variant-numeric:tabular-nums}
  .bar-r .pwr{color:var(--peri2)}
  @media(max-width:680px){
    .bar-c .ftitle{display:none}
    .bar-r .glyph.cpu,.bar-r .glyph.ram{display:none}
    .ws .wsname{display:none!important}
    .ws{min-width:26px;padding:0 .35rem}
  }

  /* ============== BOOT / POST OVERLAY ============== */
  .boot{position:fixed;inset:0;z-index:120;background:var(--bg);display:flex;flex-direction:column;
    padding:clamp(1.1rem,4vw,2.6rem);overflow:hidden}
  .boot::before{content:"";position:absolute;inset:0;pointer-events:none;
    background:radial-gradient(120% 90% at 80% 0%, rgba(240,138,122,.08), transparent 55%);}
  .boot-head{font-size:.74rem;color:var(--faint);letter-spacing:.16em;text-transform:uppercase;
    display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;margin-bottom:1.3rem;position:relative;z-index:2}
  .boot-head .skip{color:var(--dim);border:1px solid var(--line);padding:.28rem .7rem;border-radius:5px;
    cursor:pointer;transition:color .25s,border-color .25s;background:none;font-family:inherit;font-size:inherit;letter-spacing:.12em}
  .boot-head .skip:hover{color:var(--coral);border-color:var(--cline)}
  .boot-body{position:relative;z-index:2;max-width:900px;font-size:clamp(.78rem,1.6vw,.95rem);line-height:1.85}
  .bl{display:flex;gap:.7rem;color:var(--ink2);align-items:baseline;opacity:0;transform:translateY(2px)}
  .bl.shown{opacity:1;transform:none;transition:opacity .12s ease,transform .12s ease}
  .bl .pre{color:var(--faint);flex:none;white-space:nowrap}
  .bl .txt{flex:1;min-width:0}
  .bl .tag{flex:none;font-weight:600}
  .bl .tag.ok{color:var(--peri2)} .bl .tag.ok::before{content:"[ "}.bl .tag.ok::after{content:" ok ]"}
  .bl .tag.live{color:var(--coral)} .bl .tag.live::before{content:"[ "}.bl .tag.live::after{content:" up ]"}
  .boot-foot{margin-top:1.6rem;position:relative;z-index:2;color:var(--dim);font-size:.86rem}
  .boot-foot .login{color:var(--ink)}
  .boot-foot .login .p{color:var(--coral)}
  /* the boot overlay is removed by JS once it finishes; if JS never runs it auto-fades via CSS */
  .boot.gone{opacity:0;visibility:hidden;transition:opacity .5s ease,visibility .5s}
  /* JS-OFF / no-anim fallback: fade the whole overlay out so the desktop underneath is usable */
  @keyframes bootAutoOut{to{opacity:0;visibility:hidden}}
  .boot{animation:bootAutoOut .6s ease forwards 7.6s}

  /* ============== DESKTOP / TILING GRID ============== */
  main{position:relative;z-index:2;padding:calc(var(--bar-h) + var(--gap)) var(--gap) var(--gap);
    max-width:1380px;margin:0 auto}
  .desk{display:grid;grid-template-columns:1.32fr 1fr;gap:var(--gap);align-items:stretch}

  /* window chrome */
  .window{background:var(--win);border:1px solid var(--line);border-radius:9px;overflow:hidden;
    display:flex;flex-direction:column;position:relative;box-shadow:0 1px 0 rgba(232,235,239,.03) inset;
    transition:border-color .35s, box-shadow .35s, transform .35s}
  .window.focused{border-color:var(--cline);box-shadow:0 0 0 1px rgba(240,138,122,.16), 0 16px 50px -28px rgba(0,0,0,.8)}
  .titlebar{display:flex;align-items:center;gap:.6rem;padding:.5rem .75rem;background:var(--titlebar);
    border-bottom:1px solid var(--line);font-size:.76rem;color:var(--dim);flex:none;user-select:none}
  .lights{display:flex;gap:.42rem;flex:none}
  .lights i{width:11px;height:11px;border-radius:50%;display:block;border:1px solid rgba(0,0,0,.25)}
  .lights .c{background:var(--coral)} .lights .m{background:var(--gold)} .lights .x{background:var(--peri)}
  .titlebar .tt{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--ink2)}
  .titlebar .tt b{color:var(--coral);font-weight:600}
  .titlebar .tn{flex:none;color:var(--faint);font-size:.72rem}
  .titlebar .brk{flex:none;color:var(--faint);letter-spacing:.06em}
  .titlebar .brk b{color:var(--dim);font-weight:500;padding:0 .12rem}
  .body{padding:clamp(1rem,2vw,1.5rem);flex:1;display:flex;flex-direction:column}

  /* prompt label inside window bodies */
  .prompt{color:var(--faint);font-size:.78rem;margin-bottom:1rem;display:flex;gap:.55rem;align-items:center;flex-wrap:wrap}
  .prompt .u{color:var(--coral)} .prompt .at{color:var(--dim)} .prompt .h{color:var(--peri2)}
  .prompt .c{color:var(--ink2)}

  /* ---- HERO / NEOFETCH window ---- */
  .neo{display:grid;grid-template-columns:auto 1fr;gap:clamp(1.2rem,3vw,2.4rem);align-items:start}
  .ascii{font-size:clamp(.5rem,1vw,.62rem);line-height:1.05;color:var(--coral);white-space:pre;flex:none;
    text-shadow:0 0 18px rgba(240,138,122,.25)}
  .neo-info{min-width:0}
  .neo-info h1{font-family:var(--sans);font-weight:600;font-size:clamp(1.55rem,3.4vw,2.5rem);line-height:1.04;
    letter-spacing:-.01em;color:var(--ink);margin-bottom:.2rem}
  .neo-info .tag{color:var(--coral);font-size:.84rem;margin-bottom:1.1rem;letter-spacing:.02em}
  .neo-info .hr{height:1px;background:var(--line);margin:.1rem 0 1rem}
  .specs{display:grid;gap:.34rem;font-size:.84rem}
  .specs .row{display:grid;grid-template-columns:5.6rem 1fr;gap:.7rem;align-items:baseline}
  .specs .k{color:var(--coral);font-weight:500}
  .specs .v{color:var(--ink2);min-width:0}
  .specs .v b{color:var(--gold);font-weight:600}
  .palette{display:flex;gap:.32rem;margin-top:1.1rem}
  .palette i{width:1.15rem;height:.62rem;border-radius:2px;display:block}
  .sub{font-family:var(--sans);color:var(--ink2);font-size:.98rem;line-height:1.62;margin-top:1.2rem;max-width:54ch}
  .sub b{color:var(--ink);font-weight:600}
  .cta{margin-top:1.3rem;display:flex;gap:.6rem;flex-wrap:wrap}
  .btn{font-size:.8rem;letter-spacing:.02em;padding:.62rem 1rem;border:1px solid var(--line);border-radius:6px;
    display:inline-flex;gap:.5rem;align-items:center;color:var(--ink2);background:rgba(232,235,239,.02);
    transition:border-color .3s,color .3s,background .3s,transform .3s}
  .btn .k{color:var(--faint)}
  .btn:hover{border-color:var(--cline);color:var(--ink);transform:translateY(-1px)}
  .btn.primary{background:var(--coral);color:#180a07;border-color:var(--coral);font-weight:600}
  .btn.primary .k{color:#5c241a}
  .btn.primary:hover{background:var(--coral2);border-color:var(--coral2)}
  .keyhints{margin-top:1.1rem;font-size:.74rem;color:var(--faint);display:flex;flex-wrap:wrap;gap:.4rem .9rem}
  .keyhints kbd{font-family:inherit;color:var(--ink2);border:1px solid var(--line);border-radius:4px;
    padding:.05rem .34rem;font-size:.72rem;background:rgba(232,235,239,.03)}
  .keyhints span{color:var(--dim)}
  @media(max-width:560px){.neo{grid-template-columns:1fr}.ascii{font-size:.55rem}}

  /* ---- stats strip inside hero ---- */
  .statline{display:flex;flex-wrap:wrap;gap:.9rem 1.6rem;margin-top:1.3rem;padding-top:1.1rem;border-top:1px solid var(--line)}
  .stat{display:flex;align-items:baseline;gap:.5rem}
  .stat .n{font-family:var(--sans);font-weight:600;font-size:1.5rem;color:var(--ink);font-variant-numeric:tabular-nums}
  .stat .n sup{color:var(--coral);font-size:.5em;font-weight:700;vertical-align:super;margin-left:.04em}
  .stat .l{color:var(--dim);font-size:.74rem;max-width:18ch;line-height:1.35}

  /* ---- WORK window: ls listing + expand ---- */
  .ls-head{display:grid;grid-template-columns:8.2rem 1fr 4.2rem;gap:.7rem;color:var(--faint);font-size:.72rem;
    padding-bottom:.55rem;border-bottom:1px solid var(--line);margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.08em}
  .lsfile{border-bottom:1px solid var(--line2)}
  .lsfile:last-child{border-bottom:0}
  .lsrow{display:grid;grid-template-columns:8.2rem 1fr 4.2rem;gap:.7rem;align-items:center;padding:.62rem 0;
    cursor:pointer;font-size:.84rem;transition:background .25s;width:100%;text-align:left;border:0;background:none;
    font-family:inherit;color:inherit}
  .lsrow:hover,.lsrow:focus-visible{background:rgba(240,138,122,.06)}
  .lsrow:focus-visible{outline:1px solid var(--cline);outline-offset:-1px}
  .lsrow .perm{color:var(--faint);font-size:.74rem}
  .lsrow .name{color:var(--ink2);display:flex;align-items:center;gap:.5rem;min-width:0}
  .lsrow .name .arr{color:var(--coral);transition:transform .3s;flex:none}
  .lsrow .name .fn{color:var(--ink);font-weight:500}
  .lsrow .name .fn b{color:var(--coral)}
  .lsrow .name .ext{color:var(--faint)}
  .lsrow .name .yr{color:var(--peri2);font-size:.74rem;margin-left:.2rem}
  .lsrow .sz{color:var(--faint);font-size:.74rem;text-align:right}
  .lsfile.open .lsrow .arr{transform:rotate(90deg)}
  .lsfile.open .lsrow{background:rgba(240,138,122,.05)}
  .detail{max-height:0;overflow:hidden;transition:max-height .4s cubic-bezier(.2,.8,.2,1)}
  .detail-in{padding:.1rem 0 .9rem 1.5rem;border-left:1px solid var(--cline);margin:.1rem 0 .5rem .35rem}
  .detail .role{color:var(--coral);font-size:.74rem;letter-spacing:.04em;text-transform:uppercase}
  .detail .res{color:var(--gold);font-size:.82rem;margin:.35rem 0 .5rem;font-weight:500}
  .detail .d{color:var(--ink2);font-family:var(--sans);font-size:.92rem;line-height:1.55;max-width:60ch}
  .ls-foot{margin-top:.9rem;color:var(--faint);font-size:.74rem;display:flex;gap:.4rem;align-items:center}
  .ls-foot .hint kbd{font-family:inherit;color:var(--ink2);border:1px solid var(--line);border-radius:4px;padding:.02rem .3rem;font-size:.7rem}

  /* ---- STACK / disciplines window ---- */
  .pill{display:grid;grid-template-columns:auto 1fr;gap:.6rem 1rem;padding:.85rem 0;border-bottom:1px solid var(--line2);align-items:baseline}
  .pill:last-child{border-bottom:0}
  .pill .pi{color:var(--coral);font-size:.78rem;font-weight:600}
  .pill .pt{font-family:var(--sans);color:var(--ink);font-weight:600;font-size:1.02rem}
  .pill .pd{grid-column:2;color:var(--dim);font-family:var(--sans);font-size:.9rem;line-height:1.5;max-width:48ch}
  .recog{margin-top:1.1rem;padding-top:1rem;border-top:1px solid var(--line)}
  .recog .rl{color:var(--faint);font-size:.72rem;text-transform:uppercase;letter-spacing:.12em;margin-bottom:.7rem}
  .rrow{display:flex;align-items:baseline;gap:.6rem;padding:.4rem 0;font-size:.86rem}
  .rrow .star{color:var(--gold);flex:none}
  .rrow b{color:var(--ink2);font-weight:500}
  .rrow span{color:var(--faint);font-size:.76rem}
  .brands{margin-top:1rem;display:flex;flex-wrap:wrap;gap:.4rem}
  .brands span{font-size:.74rem;color:var(--ink2);border:1px solid var(--line);border-radius:5px;padding:.32rem .6rem;background:rgba(232,235,239,.02)}

  /* ---- ABOUT window ---- */
  .about-lead{font-family:var(--sans);color:var(--ink);font-size:1.05rem;line-height:1.55;max-width:56ch;margin-bottom:1.2rem}
  .about-lead b{color:var(--coral);font-weight:600}
  .facts{display:grid;grid-template-columns:repeat(2,1fr);gap:.95rem 1.4rem}
  .fact .k{color:var(--coral);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.28rem}
  .fact .v{color:var(--ink2);font-family:var(--sans);font-size:.9rem;line-height:1.45}
  @media(max-width:520px){.facts{grid-template-columns:1fr}}

  /* ---- CONTACT window ---- */
  .contact-big{font-family:var(--sans);font-weight:600;font-size:clamp(1.6rem,4vw,2.6rem);line-height:1.06;
    letter-spacing:-.01em;color:var(--ink);margin:.2rem 0 1rem}
  .contact-big a{display:inline-flex;gap:.4rem;align-items:center;transition:color .3s}
  .contact-big a:hover{color:var(--coral)}
  .contact-big .ar{color:var(--coral);font-size:.7em}
  .clinks{display:flex;flex-direction:column;gap:.5rem;font-size:.88rem;color:var(--dim)}
  .clinks a{color:var(--ink2);border-bottom:1px solid var(--line);padding-bottom:.05rem;transition:color .3s,border-color .3s}
  .clinks a:hover{color:var(--coral);border-color:var(--cline)}
  .clinks .row{display:flex;gap:.6rem;align-items:baseline}
  .clinks .row .k{color:var(--coral);flex:none;min-width:5.2rem}

  /* tiling layout: how the 6 windows sit in the grid */
  .w-home   {grid-column:1 / 2; grid-row:1 / 3}
  .w-work   {grid-column:2 / 3; grid-row:1 / 4}
  .w-stack  {grid-column:1 / 2; grid-row:3 / 5}
  .w-about  {grid-column:2 / 3; grid-row:4 / 5}
  .w-contact{grid-column:1 / 3; grid-row:5 / 6}

  @media(max-width:900px){
    .desk{grid-template-columns:1fr}
    .w-home,.w-work,.w-stack,.w-about,.w-contact{grid-column:1 / -1;grid-row:auto}
  }

  /* footer (in-flow, below the tiles) */
  footer{position:relative;z-index:2;max-width:1380px;margin:var(--gap) auto 0;padding:1.4rem var(--gap) 2.2rem;
    border-top:1px solid var(--line);display:flex;justify-content:space-between;flex-wrap:wrap;gap:.8rem;
    color:var(--faint);font-size:.76rem;letter-spacing:.02em}
  footer a{color:var(--dim);border-bottom:1px solid transparent;transition:color .3s,border-color .3s}
  footer a:hover{color:var(--coral);border-color:var(--cline)}

  /* window mount-in (the boot -> desktop transition). Each ends fully visible. */
  .window{opacity:0;transform:translateY(10px) scale(.992)}
  .desk.mounted .window{opacity:1;transform:none;transition:opacity .55s cubic-bezier(.2,.8,.2,1),transform .55s cubic-bezier(.2,.8,.2,1)}
  /* focus-zoom highlight when a workspace number is clicked */
  .window.zoom{animation:zoomPulse 1.1s ease}
  @keyframes zoomPulse{0%{box-shadow:0 0 0 0 rgba(240,138,122,0)}30%{box-shadow:0 0 0 2px rgba(240,138,122,.5)}100%{box-shadow:0 0 0 1px rgba(240,138,122,.16)}}

  @media(prefers-reduced-motion:reduce){
    html{scroll-behavior:auto}
    .cur{animation:none;opacity:1}
    .window{opacity:1!important;transform:none!important;transition:none}
    .desk .window{opacity:1!important;transform:none!important}
    .boot{animation:none}
    .window.zoom{animation:none}
  }
  /* JS-enabled: keep windows hidden until mounted; JS removes .pre-js after mounting the desktop.
     If JS is OFF, .pre-js never gets added, and this rule does nothing -> windows are visible (the
     base .window opacity:0 is overridden right here for the no-js path). */
  .no-js .window{opacity:1;transform:none}
</style>
</head>
<body class="no-js">
