<script>
  // Plain client script (no Astro imports needed). GSAP not required - everything degrades gracefully.
  document.documentElement; // noop
  (function () {
    const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const body = document.body;
    body.classList.remove('no-js'); // JS is on: take control of mount/boot

    const desk = document.getElementById('desk');
    const boot = document.getElementById('boot');
    const bootBody = document.getElementById('bootBody');
    const bootSkip = document.getElementById('bootSkip');
    const lines = bootBody ? Array.from(bootBody.querySelectorAll('.bl')) : [];

    // ---- mount the desktop (always ends with windows visible) ----
    let mounted = false;
    function mountDesk() {
      if (mounted) return;
      mounted = true;
      if (boot) { boot.classList.add('gone'); }
      if (desk) { desk.classList.add('mounted'); }
      // remove the boot node after its fade so it can't trap focus / clicks
      setTimeout(() => { if (boot && boot.parentNode) boot.parentNode.removeChild(boot); }, 600);
    }

    // ---- BOOT sequence ----
    if (RM || !boot || lines.length === 0) {
      // reduced motion or no boot: skip straight to the readable desktop
      if (boot) boot.classList.add('gone');
      if (desk) desk.classList.add('mounted');
      if (boot && boot.parentNode) setTimeout(() => { if (boot.parentNode) boot.parentNode.removeChild(boot); }, 50);
      mounted = true;
    } else {
      let i = 0;
      let done = false;
      function finishBoot() {
        if (done) return; done = true;
        mountDesk();
      }
      function showLine() {
        if (done) return;
        if (i >= lines.length) { setTimeout(finishBoot, 380); return; }
        lines[i].classList.add('shown');
        i++;
        // staggered, fast - whole sequence well under ~2.2s
        setTimeout(showLine, 230 + Math.random() * 90);
      }
      // kick off
      setTimeout(showLine, 200);
      // HARD SAFETY: never leave the user stuck on boot, even if something stalls
      setTimeout(finishBoot, 3400);
      // manual skip
      if (bootSkip) bootSkip.addEventListener('click', finishBoot);
      // any key / click also skips
      const skipOnce = () => finishBoot();
      window.addEventListener('keydown', skipOnce, { once: true });
      boot.addEventListener('click', (e) => { if (e.target !== bootSkip) finishBoot(); });
    }

    // ---- clock ----
    const clock = document.getElementById('clock');
    function tick() {
      if (!clock) return;
      const d = new Date();
      const hh = String(d.getHours()).padStart(2, '0');
      const mm = String(d.getMinutes()).padStart(2, '0');
      clock.textContent = hh + ':' + mm;
    }
    tick(); setInterval(tick, 15000);

    // ---- subtle CPU/RAM jitter (rice flavour, cheap) ----
    const cpuV = document.getElementById('cpuV');
    const ramV = document.getElementById('ramV');
    if (!RM && cpuV && ramV) {
      setInterval(() => {
        cpuV.textContent = (8 + Math.floor(Math.random() * 22)) + '%';
        ramV.textContent = (2.8 + Math.random() * 1.1).toFixed(1) + 'G';
      }, 2600);
    }

    // ---- workspace focus: clicking a number focuses + zooms its window ----
    const wsMap = {
      '1': 'win-home', '2': 'win-work', '3': 'win-stack', '4': 'win-about', '5': 'win-contact'
    };
    const titleMap = {
      'win-home': '~/home', 'win-work': '~/work', 'win-stack': '~/stack',
      'win-about': '~/about', 'win-contact': '~/contact'
    };
    const focusTitle = document.getElementById('focusTitle');
    const wsEls = Array.from(document.querySelectorAll('.ws'));

    function focusWindow(id, scroll) {
      const el = document.getElementById(id);
      if (!el) return;
      document.querySelectorAll('.window.focused').forEach(w => w.classList.remove('focused'));
      el.classList.add('focused');
      if (!RM) { el.classList.remove('zoom'); void el.offsetWidth; el.classList.add('zoom'); }
      // update status bar
      wsEls.forEach(w => w.classList.toggle('active', wsMap[w.getAttribute('data-ws')] === id));
      if (focusTitle && titleMap[id]) focusTitle.textContent = titleMap[id];
      if (scroll) el.scrollIntoView({ behavior: RM ? 'auto' : 'smooth', block: 'start' });
    }

    wsEls.forEach(w => {
      w.addEventListener('click', (e) => {
        e.preventDefault();
        const id = wsMap[w.getAttribute('data-ws')];
        focusWindow(id, true);
      });
    });

    // keep status bar in sync as the user scrolls through the tiles
    const winSections = ['win-home','win-work','win-stack','win-about','win-contact']
      .map(id => document.getElementById(id)).filter(Boolean);
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        // pick the most-visible window
        let best = null, bestRatio = 0;
        entries.forEach(en => { if (en.intersectionRatio > bestRatio) { bestRatio = en.intersectionRatio; best = en.target; } });
        if (best && bestRatio > 0.35) {
          document.querySelectorAll('.window.focused').forEach(w => { if (w !== best) w.classList.remove('focused'); });
          best.classList.add('focused');
          wsEls.forEach(w => w.classList.toggle('active', wsMap[w.getAttribute('data-ws')] === best.id));
          if (focusTitle && titleMap[best.id]) focusTitle.textContent = titleMap[best.id];
        }
      }, { threshold: [0.36, 0.6] });
      winSections.forEach(s => io.observe(s));
    }

    // ---- MOD+number keybinds (Alt acts as MOD) ----
    window.addEventListener('keydown', (e) => {
      if (!(e.altKey || e.metaKey)) return;
      if (wsMap[e.key]) { e.preventDefault(); focusWindow(wsMap[e.key], true); }
    });

    // ---- WORK window: expandable ls rows + arrow-key navigation ----
    const workWin = document.getElementById('win-work');
    if (workWin) {
      const files = Array.from(workWin.querySelectorAll('.lsfile'));
      const rows = files.map(f => f.querySelector('.lsrow'));
      function toggle(file) {
        const row = file.querySelector('.lsrow');
        const det = file.querySelector('.detail');
        const open = file.classList.toggle('open');
        row.setAttribute('aria-expanded', open ? 'true' : 'false');
        det.style.maxHeight = open ? (det.scrollHeight + 20) + 'px' : '0px';
      }
      files.forEach((file) => {
        const row = file.querySelector('.lsrow');
        row.addEventListener('click', () => toggle(file));
      });
      // arrow-key navigation between rows
      workWin.addEventListener('keydown', (e) => {
        const idx = rows.indexOf(document.activeElement);
        if (idx === -1) return;
        if (e.key === 'ArrowDown') { e.preventDefault(); rows[Math.min(rows.length - 1, idx + 1)].focus(); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); rows[Math.max(0, idx - 1)].focus(); }
      });
      // keep open panels sized correctly on resize
      let rt;
      window.addEventListener('resize', () => {
        clearTimeout(rt);
        rt = setTimeout(() => {
          files.forEach(f => {
            if (f.classList.contains('open')) {
              const det = f.querySelector('.detail');
              det.style.maxHeight = (det.scrollHeight + 20) + 'px';
            }
          });
        }, 150);
      });
    }
  })();
</script>
</body>
</html>
