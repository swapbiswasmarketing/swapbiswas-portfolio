    radial-gradient(120% 140% at 50% 0%,rgba(127,233,255,.06),transparent 65%),var(--panel);
    padding:clamp(2rem,5vw,3.6rem);text-align:center;position:relative;overflow:hidden}
  .tx-panel .cl{font-family:var(--mono);font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--phos-dim);margin-bottom:1.1rem}
