<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('show'); io.unobserve(e.target); } });
  }, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  /* ---------- readout count-up ---------- */
  function countUp(el){
    const target = parseInt(el.getAttribute('data-target'), 10);
    const sup = el.querySelector('sup');
    const supHTML = sup ? sup.outerHTML : '';
    if (RM){ el.innerHTML = String(target) + supHTML; return; }
    const dur = 1100; const t0 = performance.now();
    function step(now){
      const p = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(target * eased);
      el.innerHTML = val + supHTML;
      if (p < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }
  const numIO = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting){ countUp(e.target.querySelector('.val')); numIO.unobserve(e.target); } });
  }, { threshold: 0.5 });
  document.querySelectorAll('.ro').forEach(n => numIO.observe(n));

  /* =========================================================================
     THE MECHANIC - oscilloscope trace: noise -> signal.
     A single phosphor trace drawn across a graticule. Scroll progress drives a
     "lock" parameter: 0 = pure noise, 1 = a clean coherent composite waveform.
     Milestones along the timeline produce annotated spikes. Hovering a stat
     readout injects a labelled measured pulse for that value.
     Performance: fixed sample count, single rAF, paused when offscreen.
     ========================================================================= */
  (function scope(){
    const cv = document.getElementById('scope');
    const screen = document.getElementById('screen');
    const lockState = document.getElementById('lockstate');
    const sampReadout = document.getElementById('sampreadout');
    if (!cv || !screen) return;
    const ctx = cv.getContext('2d');
    const PHOS = '#7fe9ff';
    const GRID = 'rgba(127,233,255,0.10)';
    const GRID2 = 'rgba(127,233,255,0.20)';
    const DPR = Math.min(window.devicePixelRatio || 1, 2);

    const N = 360;                 // capped sample points across the screen
    let W = 0, H = 0, mid = 0, amp = 0;
    let lock = RM ? 1 : 0;         // 0 noise -> 1 signal
    let targetLock = RM ? 1 : 0;
    let visible = true, running = false, raf = 0;

    // milestones along the normalised timeline (x in 0..1) -> annotated spikes
    const marks = [0.12, 0.30, 0.44, 0.58, 0.72, 0.88];
    // per-sample fixed noise phase so noise is stable frame-to-frame structure
    const seed = new Float32Array(N);
    for (let i = 0; i < N; i++) seed[i] = Math.random() * Math.PI * 2;

    // measurement pulse injected on stat hover
    let pulse = null; // {center, width, label, t0, life}

    function size(){
      const rect = screen.getBoundingClientRect();
      if (rect.width < 4) return;
      W = rect.width; H = rect.height;
      cv.width = Math.round(W * DPR); cv.height = Math.round(H * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      mid = H * 0.5;
      amp = Math.min(H * 0.30, 150);
    }

    // graticule grid (10 x 8 divisions, like a real scope)
    function drawGrid(){
      const cols = 10, rows = 8;
      ctx.lineWidth = 1;
      ctx.strokeStyle = GRID;
      ctx.beginPath();
      for (let i = 1; i < cols; i++){ const x = (W / cols) * i; ctx.moveTo(x, 0); ctx.lineTo(x, H); }
      for (let j = 1; j < rows; j++){ const y = (H / rows) * j; ctx.moveTo(0, y); ctx.lineTo(W, y); }
      ctx.stroke();
      // centre cross-hairs stronger, with tick marks
      ctx.strokeStyle = GRID2;
      ctx.beginPath();
      ctx.moveTo(0, mid); ctx.lineTo(W, mid);
      ctx.moveTo(W / 2, 0); ctx.lineTo(W / 2, H);
      ctx.stroke();
      // minor ticks on the centre axes
      ctx.beginPath();
      const tx = W / cols / 5, ty = H / rows / 5;
      for (let x = 0; x <= W; x += tx){ ctx.moveTo(x, mid - 3); ctx.lineTo(x, mid + 3); }
      for (let y = 0; y <= H; y += ty){ ctx.moveTo(W / 2 - 3, y); ctx.lineTo(W / 2 + 3, y); }
      ctx.stroke();
    }

    // pseudo-random but deterministic noise from seed
    function noiseAt(i, t){
      const s = seed[i];
      return (
        Math.sin(s + t * 2.1) * 0.5 +
        Math.sin(s * 1.7 + t * 3.3) * 0.3 +
        Math.sin(s * 3.1 - t * 1.4) * 0.2
      );
    }

    // the clean resolved composite signal (a coherent, legible waveform)
    function signalAt(x, t){
      // gentle carrier + a couple of harmonics + milestone spikes
      let v = Math.sin(x * Math.PI * 6 - t * 1.2) * 0.5;
      v += Math.sin(x * Math.PI * 14 - t * 0.8) * 0.16;
      // milestone spikes: short gaussian bumps at each mark
      for (let m = 0; m < marks.length; m++){
        const d = x - marks[m];
        const g = Math.exp(-(d * d) / 0.00035);
        v += g * 0.7 * (m % 2 === 0 ? 1 : -1);
      }
      return v;
    }

    function frame(now){
      if (!running) return;
      const t = now * 0.001;
      // ease lock toward target
      lock += (targetLock - lock) * 0.08;
      if (Math.abs(targetLock - lock) < 0.001) lock = targetLock;

      ctx.clearRect(0, 0, W, H);
      drawGrid();

      // build the trace
      ctx.lineWidth = 2;
      ctx.strokeStyle = PHOS;
      ctx.shadowColor = 'rgba(127,233,255,0.6)';
      ctx.shadowBlur = 8;
      ctx.lineJoin = 'round';
      ctx.beginPath();
      const noiseGain = (1 - lock);
      const sigGain = lock;
      for (let i = 0; i < N; i++){
        const x = i / (N - 1);
        const px = x * W;
        let v = noiseAt(i, RM ? 0 : t) * noiseGain + signalAt(x, RM ? 0 : t) * sigGain;
        // measurement pulse overlay (square-ish bump) on stat hover
        if (pulse){
          const age = (now - pulse.t0) / pulse.life;
          if (age < 1){
            const env = Math.sin(Math.min(1, age) * Math.PI); // rise + fall
            const within = Math.abs(x - pulse.center) < pulse.width;
            if (within) v += 1.05 * env;
          } else { pulse = null; }
        }
        const py = mid - v * amp;
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.shadowBlur = 0;

      // bright scan dot riding the right edge of the trace (gives "live" feel)
      if (!RM){
        const sx = W - 1;
        const xv = 1;
        let v = signalAt(xv, t) * sigGain + noiseAt(N - 1, t) * noiseGain;
        const sy = mid - v * amp;
        ctx.fillStyle = PHOS;
        ctx.shadowColor = 'rgba(127,233,255,0.9)'; ctx.shadowBlur = 12;
        ctx.beginPath(); ctx.arc(sx, sy, 2.6, 0, 6.2832); ctx.fill();
        ctx.shadowBlur = 0;
      }

      // milestone annotation ticks once locked enough
      if (lock > 0.55){
        ctx.fillStyle = 'rgba(127,233,255,0.55)';
        ctx.font = '10px "Space Mono", monospace';
        for (let m = 0; m < marks.length; m++){
          const px = marks[m] * W;
          const a = Math.min(1, (lock - 0.55) / 0.3);
          ctx.globalAlpha = a;
          ctx.fillRect(px - 0.5, mid - 5, 1, 10);
          ctx.globalAlpha = a * 0.8;
          ctx.fillText('M' + (m + 1), px + 3, mid - 8);
          ctx.globalAlpha = 1;
        }
      }

      // pulse label callout
      if (pulse){
        const px = pulse.center * W;
        const py = mid - amp * 1.05 - 6;
        ctx.fillStyle = PHOS;
        ctx.font = 'bold 13px "Space Mono", monospace';
        ctx.textAlign = 'center';
        ctx.shadowColor = 'rgba(127,233,255,0.7)'; ctx.shadowBlur = 8;
        ctx.fillText(pulse.label, px, Math.max(16, py));
        ctx.shadowBlur = 0;
        ctx.textAlign = 'left';
      }

      // update readouts
      if (sampReadout) sampReadout.textContent = Math.round(lock * 100) + '%';
      if (lockState){
        if (lock > 0.92) lockState.textContent = 'SIGNAL LOCKED';
        else if (lock > 0.4) lockState.textContent = 'RESOLVING…';
        else lockState.textContent = 'ACQUIRING…';
      }

      // keep animating while noise present, a pulse is live, or lock still easing
      const needsMotion = !RM && (lock < 0.999 || pulse || lock < targetLock || targetLock < lock || sigGain < 1);
      if (needsMotion) { raf = requestAnimationFrame(frame); }
      else { running = false; drawStaticLocked(); }
    }

    // static render (reduced motion or settled): clean locked waveform, no noise
    function drawStaticLocked(){
      ctx.clearRect(0, 0, W, H);
      drawGrid();
      ctx.lineWidth = 2;
      ctx.strokeStyle = PHOS;
      ctx.shadowColor = 'rgba(127,233,255,0.55)';
      ctx.shadowBlur = 8;
      ctx.lineJoin = 'round';
      ctx.beginPath();
      for (let i = 0; i < N; i++){
        const x = i / (N - 1);
        const px = x * W;
        const py = mid - signalAt(x, 0) * amp;
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.shadowBlur = 0;
      // milestone ticks
      ctx.fillStyle = 'rgba(127,233,255,0.5)';
      ctx.font = '10px "Space Mono", monospace';
      for (let m = 0; m < marks.length; m++){
        const px = marks[m] * W;
        ctx.fillRect(px - 0.5, mid - 5, 1, 10);
        ctx.fillText('M' + (m + 1), px + 3, mid - 8);
      }
      if (sampReadout) sampReadout.textContent = '100%';
      if (lockState) lockState.textContent = 'SIGNAL LOCKED';
    }

    function kick(){
      if (RM){ drawStaticLocked(); return; }
      if (!running && visible){ running = true; raf = requestAnimationFrame(frame); }
    }

    // scroll drives lock: by the time hero is scrolled through, signal is locked
    function onScroll(){
      if (RM) return;
      const heroH = (document.getElementById('hero')?.offsetHeight || window.innerHeight);
      // lock fully by ~85% of hero height scrolled
      const p = Math.min(1, Math.max(0, window.scrollY / (heroH * 0.85)));
      targetLock = p;
      kick();
    }

    // pause when scope offscreen
    const vis = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        visible = e.isIntersecting;
        if (visible) kick();
        else if (raf) { cancelAnimationFrame(raf); running = false; }
      });
    }, { threshold: 0 });
    vis.observe(screen);

    // stat hover -> measured pulse readout on the scope
    if (!RM){
      document.querySelectorAll('[data-stat]').forEach((el, idx) => {
        const v = el.getAttribute('data-val') + (el.getAttribute('data-plus') || '');
        // place each stat's pulse at a distinct timeline position
        const centers = [0.26, 0.5, 0.74];
        const trigger = () => {
          pulse = { center: centers[idx % centers.length], width: 0.05, label: v, t0: performance.now(), life: 1400 };
          kick();
        };
        el.addEventListener('pointerenter', trigger);
        el.addEventListener('focus', trigger);
      });
    }

    // init
    function init(){
      size();
      if (RM){ drawStaticLocked(); return; }
      onScroll();
      kick();
    }
    if (document.fonts && document.fonts.ready){ document.fonts.ready.then(init); }
    init();

    let rt;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => { size(); if (RM) drawStaticLocked(); else { onScroll(); kick(); } }, 160); });
    window.addEventListener('scroll', onScroll, { passive: true });
  })();

  /* ---------- mini waveform sparklines on capture cards ---------- */
  (function sparklines(){
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    const PHOS = '#7fe9ff';
    function gen(type, x){
      switch(type){
        case 'rise':  return Math.tanh((x - 0.5) * 5) * 0.85;                       // climbing growth curve
        case 'step':  return (x < 0.4 ? -0.55 : (x < 0.55 ? (x - 0.4) / 0.15 * 1.1 - 0.55 : 0.55)); // step up
        case 'burst': return Math.exp(-Math.pow((x - 0.5) * 6, 2)) * 0.9 - 0.1;     // single spike
        case 'ramp':  return (x * 2 - 1) * 0.8;                                      // linear ramp 0->1
        case 'pulse': { const p = (x * 4) % 1; return (p < 0.5 ? 0.55 : -0.55); }   // square pulse train
        case 'sine':  return Math.sin(x * Math.PI * 4) * 0.7;                        // clean sine
        default:      return Math.sin(x * Math.PI * 4) * 0.6;
      }
    }
    function draw(cv){
      const wrap = cv.parentElement;
      const rect = wrap.getBoundingClientRect();
      if (rect.width < 4) return;
      const W = rect.width, H = rect.height;
      cv.width = Math.round(W * DPR); cv.height = Math.round(H * DPR);
      const ctx = cv.getContext('2d');
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      ctx.clearRect(0, 0, W, H);
      const type = cv.getAttribute('data-wave') || 'sine';
      const mid = H * 0.5, amp = H * 0.34;
      ctx.lineWidth = 1.6; ctx.strokeStyle = PHOS; ctx.lineJoin = 'round';
      ctx.shadowColor = 'rgba(127,233,255,0.5)'; ctx.shadowBlur = 5;
      ctx.beginPath();
      const STEPS = 120;
      for (let i = 0; i <= STEPS; i++){
        const x = i / STEPS;
        const px = x * W;
        const py = mid - gen(type, x) * amp;
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.stroke();
      ctx.shadowBlur = 0;
    }
    const all = document.querySelectorAll('.sparkcv');
    const sio = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting){ draw(e.target); sio.unobserve(e.target); } });
    }, { threshold: 0.2 });
    function ready(){ all.forEach(cv => sio.observe(cv)); }
    if (document.fonts && document.fonts.ready){ document.fonts.ready.then(ready); } else { ready(); }
    let rt;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => all.forEach(draw), 200); });
  })();
</script>
</body>
</html>
