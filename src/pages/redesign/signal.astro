---
// REDESIGN PROTOTYPE - "Signal Lab" - the portfolio as a measurement instrument / oscilloscope.
// Original concept (NOT a reskin of halftone): own layout, palette, fonts, mechanic.
//  - A live oscilloscope TRACE on a 2D <canvas> drawn across a fine graticule. On load the trace
//    is NOISE; as you scroll it RESOLVES into a clean coherent waveform (noise -> signal). Scroll
//    scrubs a timeline and the trace annotates spikes at each milestone.
//  - Hovering a stat makes the scope draw that value as a labeled pulse readout (square wave + callout).
//  - Instrument chrome: graticule, channel labels CH1/CH2, V/div + TIME/div readouts, blinking REC dot,
//    seven-seg-ish lit digital readout boxes for the three headline metrics.
// Single PHOSPHOR trace color: cyan-white (#7fe9ff) on near-black panel (#06080a). Distinct from the
// green Terminal, amber Sepia, blue Cobalt concepts.
// prefers-reduced-motion: static clean resolved waveform, no noise animation, all content readable.
// Fully self-contained: own <html>, own fonts, own tokens. No BaseLayout, no global.css.
const stats = [
  { n: '20', plus: '+', l: 'AI agents & internal tools shipped', read: 'CH-A' },
  { n: '15', plus: '+', l: 'Marketers mentored & levelled up', read: 'CH-B' },
  { n: '76', plus: '',  l: 'Long-form articles published', read: 'CH-C' },
];
const channels = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.' },
];
const work = [
  { i: '01', t: 'LambdaTest', y: '2021 - 2025', role: 'Product & digital marketing', r: '657K+ leads · 18.2M+ organic', d: 'Owned product and digital marketing end to end and built the full organic growth engine.', feat: true, wave: 'rise' },
  { i: '02', t: 'TestMu AI', y: '2026', role: 'Rebrand lead', r: 'Full company rebrand', d: 'Led the complete rebrand from LambdaTest to TestMu AI.', wave: 'step' },
  { i: '03', t: 'Samsung', y: '2019', role: 'via Sociowash', r: 'Galaxy M-series launch', d: 'On the Galaxy M-series from inception; ran content distribution, collaborated with Technical Guruji.', wave: 'burst' },
  { i: '04', t: 'Medilife Superspeciality', y: '0 to 1', role: 'Marketing & web', r: 'Website · GTM · social', d: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.', wave: 'ramp' },
  { i: '05', t: 'Lido Learning', y: '2021', role: 'Growth / CRM', r: 'CRM & lead operations', d: 'Ran CRM management and lead routing and assignment for the EdTech.', wave: 'pulse' },
  { i: '06', t: 'Appknox', y: 'Freelance', role: 'Content', r: 'Security content', d: 'Freelance content writer for the mobile app security company.', wave: 'sine' },
];
const recognition = [
  { t: 'Value of Agility Award', m: 'LambdaTest, 2024' },
  { t: 'Wall of Fame', m: 'LambdaTest' },
  { t: '#1 Product of the Day', m: 'Product Hunt' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
---
<!doctype html>
<html lang="en" data-theme="signal">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
<style>
  :root{
    /* near-black instrument panel + single phosphor */
    --bg:#06080a; --panel:#0a0e12; --panel2:#0c1218; --bezel:#11171e;
    --phos:#7fe9ff;            /* the one trace color */
    --phos-dim:#4fb3cc;
    --ink:#e8f6fb;             /* crisp body / headings */
    --body:#bfe0ea;            /* AA body copy on near-black */
    --dim:#86a7b3;             /* secondary labels (still >=4.5:1 on --bg) */
    --faint:#5f7c88;           /* decorative-only mono */
    --grid:rgba(127,233,255,.10);
    --grid-strong:rgba(127,233,255,.20);
    --line:rgba(127,233,255,.16);
    --hair:rgba(127,233,255,.30);
    --rec:#ff5c6c;
    --disp:"Space Grotesk",system-ui,sans-serif;
    --mono:"Space Mono",ui-monospace,monospace;
    --m:clamp(1.15rem,4.5vw,4.5rem);
    --glow:0 0 14px rgba(127,233,255,.35);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{overflow-x:clip}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--body);font-family:var(--disp);min-height:100vh;-webkit-font-smoothing:antialiased;
    line-height:1.6;letter-spacing:.005em;position:relative}
  /* faint phosphor scanlines + vignette over the whole instrument */
  body::before{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.5;
    background-image:repeating-linear-gradient(0deg,rgba(127,233,255,.035) 0 1px,transparent 1px 3px)}
  body::after{content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
    background:radial-gradient(120% 90% at 50% 0%,transparent 55%,rgba(0,0,0,.55) 100%)}
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--phos);color:var(--bg)}
  .wrap{width:min(1280px,100%);margin:0 auto;padding:0 var(--m);position:relative;z-index:2}

  .mono{font-family:var(--mono);font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dim)}

  /* ===== top instrument bar ===== */
  .bar{position:fixed;top:0;left:0;right:0;z-index:40;
    background:linear-gradient(180deg,rgba(6,8,10,.94),rgba(6,8,10,.62) 72%,transparent);
    backdrop-filter:blur(7px);-webkit-backdrop-filter:blur(7px)}
  .bar-in{width:min(1280px,100%);margin:0 auto;padding:.7rem var(--m);display:flex;align-items:center;justify-content:space-between;gap:1rem;
    border-bottom:1px solid var(--line)}
  .brand{display:flex;align-items:center;gap:.6rem;font-family:var(--mono);font-weight:700;letter-spacing:.05em;font-size:.9rem;color:var(--ink)}
  .rec{display:inline-flex;align-items:center;gap:.45rem;font-family:var(--mono);font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--dim)}
  .rec .dot{width:9px;height:9px;border-radius:50%;background:var(--rec);box-shadow:0 0 8px rgba(255,92,108,.8);animation:blink 1.4s steps(1) infinite}
  @keyframes blink{0%,49%{opacity:1}50%,100%{opacity:.2}}
  .bar nav{display:flex;gap:1.5rem}
  .bar nav a{font-family:var(--mono);font-size:.72rem;letter-spacing:.13em;text-transform:uppercase;color:var(--dim);transition:color .3s}
  .bar nav a:hover{color:var(--phos)}
  @media(max-width:760px){.bar nav{display:none}}

  /* ===== hero / the scope ===== */
  header.hero{padding:6.5rem 0 2rem;position:relative;z-index:2}
  .hero-edition{display:flex;justify-content:space-between;align-items:center;gap:1rem;border-bottom:1px solid var(--line);padding-bottom:.8rem;margin-bottom:clamp(1.1rem,2.6vw,1.8rem)}

  /* the oscilloscope instrument */
  .scope{position:relative;border:1px solid var(--line);border-radius:14px;background:
    linear-gradient(180deg,var(--panel2),var(--panel));
    box-shadow:inset 0 0 60px rgba(0,0,0,.6),0 18px 50px rgba(0,0,0,.45);
    overflow:hidden;isolation:isolate}
  /* the CRT screen area (where the canvas lives) */
  .screen{position:relative;aspect-ratio:16/8;width:100%;background:
    radial-gradient(120% 130% at 50% 40%,rgba(127,233,255,.045),transparent 70%),#05080b;
    border-bottom:1px solid var(--line)}
  .screen canvas{position:absolute;inset:0;width:100%;height:100%;display:block}
  /* screen corners */
  .screen .corner{position:absolute;width:13px;height:13px;border:1px solid var(--hair);z-index:3}
  .screen .corner.tl{top:10px;left:10px;border-right:0;border-bottom:0}
  .screen .corner.tr{top:10px;right:10px;border-left:0;border-bottom:0}
  .screen .corner.bl{bottom:10px;left:10px;border-right:0;border-top:0}
  .screen .corner.br{bottom:10px;right:10px;border-left:0;border-top:0}

  /* headline overlay - instrument label etched on the screen */
  .scope-overlay{position:absolute;inset:0;z-index:4;pointer-events:none;display:flex;flex-direction:column;justify-content:space-between;
    padding:clamp(1rem,2.6vw,2rem)}
  .scope-overlay .top-row{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem}
  .chtag{font-family:var(--mono);font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;color:var(--phos-dim)}
  .chtag b{color:var(--phos);font-weight:700}
  .h1-wrap{align-self:flex-start;max-width:18ch;position:relative}
  /* soft dark scrim behind the headline so it holds contrast over the busy noise
     trace. Feathered edges + blur = localized CRT dimming, NOT a hard box, and it
     does not dim the rest of the trace. Sits above the canvas, below the text. */
  .h1-wrap::before{content:"";position:absolute;z-index:-1;
    left:-.7em;right:-1.5em;top:-.45em;bottom:-.55em;
    background:radial-gradient(125% 135% at 36% 50%,rgba(4,7,10,.93) 0%,rgba(4,7,10,.9) 52%,rgba(4,7,10,.74) 74%,rgba(4,7,10,.38) 88%,transparent 100%);
    filter:blur(8px);border-radius:18px}
  .hero h1{font-family:var(--disp);font-weight:700;text-transform:uppercase;line-height:.92;letter-spacing:.01em;
    font-size:clamp(2rem,6.4vw,5rem);color:var(--ink);position:relative;
    text-shadow:0 0 22px rgba(127,233,255,.28)}
  .hero h1 .accent{color:var(--phos)}
  .scope-overlay .status{align-self:flex-end;font-family:var(--mono);font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--dim);text-align:right;line-height:1.7}
  .scope-overlay .status .live{color:var(--phos)}

  /* readout strip beneath the screen (V/div, TIME/div, lock state) */
  .scope-foot{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;
    padding:.7rem clamp(1rem,2.4vw,1.6rem);font-family:var(--mono);font-size:.64rem;letter-spacing:.12em;text-transform:uppercase;color:var(--faint)}
  .scope-foot .grp{display:flex;gap:1.4rem;flex-wrap:wrap}
  .scope-foot .grp span b{color:var(--phos-dim)}
  .scope-foot .knobs{display:flex;gap:.7rem}
  .scope-foot .knob{width:18px;height:18px;border-radius:50%;border:1px solid var(--hair);position:relative;background:
    radial-gradient(circle at 50% 40%,rgba(127,233,255,.12),transparent 70%)}
  .scope-foot .knob::after{content:"";position:absolute;left:50%;top:3px;width:1px;height:6px;background:var(--phos-dim);transform:translateX(-.5px)}
  .scope-foot .knob:nth-child(2)::after{transform:translateX(-.5px) rotate(40deg);transform-origin:bottom}
  .scope-foot .knob:nth-child(3)::after{transform:translateX(-.5px) rotate(-65deg);transform-origin:bottom}

  /* side panel - instrument controls */
  .hero-grid{display:grid;grid-template-columns:1fr;gap:clamp(1.3rem,3vw,2rem);margin-top:clamp(1.3rem,3vw,2rem)}
  .controls{display:grid;grid-template-columns:1.4fr 1fr;gap:clamp(1.3rem,3vw,2.4rem);align-items:start}
  .controls .sub{color:var(--body);font-size:clamp(1rem,1.2vw,1.1rem);line-height:1.66;max-width:48ch}
  .controls .sub b{color:var(--ink);font-weight:600}
  .controls .cta{margin-top:1.6rem;display:flex;gap:.8rem;flex-wrap:wrap}
  .btn{font-family:var(--mono);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;padding:.8rem 1.3rem;border:1px solid var(--hair);border-radius:7px;display:inline-flex;gap:.55rem;align-items:center;transition:background .35s,color .35s,border-color .35s,transform .35s,box-shadow .35s;color:var(--ink)}
  .btn .ar{transition:transform .35s}
  .btn:hover .ar{transform:translate(3px,-3px)}
  .btn.primary{background:var(--phos);color:#04181d;border-color:var(--phos)}
  .btn.primary:hover{transform:translateY(-2px);box-shadow:0 0 22px rgba(127,233,255,.4)}
  .btn.ghost:hover{border-color:var(--phos);color:var(--phos);background:rgba(127,233,255,.06)}
  .scrollcue{margin-top:1.7rem;display:flex;align-items:center;gap:.7rem;color:var(--faint);font-family:var(--mono);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase}
  .scrollcue .track{width:36px;height:1px;background:var(--hair);position:relative;overflow:hidden}
  .scrollcue .track::after{content:"";position:absolute;inset:0;width:40%;background:var(--phos);animation:sweep 2.2s linear infinite}
  @keyframes sweep{0%{transform:translateX(-110%)}100%{transform:translateX(280%)}}

  /* readout displays - the three headline metrics as lit segment boxes */
  .readouts{display:grid;grid-template-rows:repeat(3,1fr);gap:.75rem}
  .ro{border:1px solid var(--line);border-radius:9px;background:
    linear-gradient(180deg,rgba(127,233,255,.04),transparent),#05080b;
    padding:.8rem .95rem;display:flex;align-items:center;justify-content:space-between;gap:.8rem;
    position:relative;overflow:hidden;transition:border-color .35s,box-shadow .35s,transform .35s;cursor:default}
  .ro::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--phos-dim);opacity:.5;transition:opacity .35s,box-shadow .35s}
  .ro:hover{border-color:var(--hair);box-shadow:inset 0 0 24px rgba(127,233,255,.08);transform:translateY(-1px)}
  .ro:hover::before{opacity:1;box-shadow:0 0 12px var(--phos)}
  .ro .val{font-family:var(--mono);font-weight:700;font-size:clamp(1.7rem,4vw,2.5rem);line-height:1;color:var(--phos);letter-spacing:.01em;
    text-shadow:var(--glow);font-variant-numeric:tabular-nums}
  .ro .val sup{font-size:.5em;top:-.05em;margin-left:.04em}
  .ro .meta{text-align:right;max-width:16ch}
  .ro .meta .lbl{font-family:var(--mono);font-size:.62rem;letter-spacing:.06em;text-transform:uppercase;color:var(--dim);line-height:1.5}
  .ro .meta .ch{font-family:var(--mono);font-size:.56rem;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);margin-top:.25rem}

  @media(max-width:900px){
    .controls{grid-template-columns:1fr;gap:1.6rem}
    .readouts{grid-template-rows:none;grid-template-columns:repeat(3,1fr)}
    .ro{flex-direction:column;align-items:flex-start;gap:.55rem}
    .ro .meta{text-align:left}
  }
  @media(max-width:560px){
    .screen{aspect-ratio:4/3}
    /* taller screen = noise fills the whole panel, so the headline needs a wider,
       denser scrim to stay legible over the trace - including the cyan accent word
       on the right of the last line, where a centred scrim would feather out */
    .h1-wrap::before{left:-.6em;right:-.6em;top:-.4em;bottom:-.35em;
      background:linear-gradient(90deg,rgba(4,7,10,.96) 0%,rgba(4,7,10,.94) 70%,rgba(4,7,10,.82) 90%,rgba(4,7,10,.55) 100%);
      filter:blur(10px);border-radius:14px}
    .readouts{grid-template-columns:1fr}
    .ro{flex-direction:row;align-items:center}
    .ro .meta{text-align:right}
  }

  /* ===== section heads ===== */
  section{padding:clamp(3.4rem,8vh,6rem) 0;position:relative;z-index:2}
  .shead{display:flex;justify-content:space-between;align-items:flex-end;gap:1.5rem;border-bottom:1px solid var(--line);padding-bottom:1.1rem;margin-bottom:2.4rem}
  .shead .idx{font-family:var(--mono);font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--phos-dim);margin-bottom:.7rem}
  .shead h2{font-family:var(--disp);text-transform:uppercase;font-weight:700;font-size:clamp(1.7rem,4.2vw,3rem);line-height:.98;letter-spacing:.01em;color:var(--ink)}
  .shead .meta{font-family:var(--mono);font-size:.66rem;letter-spacing:.08em;color:var(--dim);text-align:right;text-transform:uppercase;line-height:1.7}

  /* ===== channels / disciplines ===== */
  .channels{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:12px;overflow:hidden}
  .ch{background:var(--panel);padding:1.6rem 1.5rem;display:flex;flex-direction:column;gap:.7rem;position:relative;transition:background .4s}
  .ch::before{content:"";position:absolute;left:0;top:1.6rem;bottom:1.6rem;width:2px;background:var(--phos-dim);opacity:.35;transition:opacity .4s,box-shadow .4s}
  .ch:hover{background:var(--panel2)}
  .ch:hover::before{opacity:1;box-shadow:0 0 10px var(--phos)}
  .ch .chid{font-family:var(--mono);font-size:.64rem;letter-spacing:.16em;text-transform:uppercase;color:var(--faint)}
  .ch .cht{font-family:var(--disp);font-weight:600;font-size:clamp(1.15rem,2.2vw,1.5rem);line-height:1.1;color:var(--ink)}
  .ch .chd{color:var(--body);font-size:.95rem;line-height:1.55;max-width:40ch}
  @media(max-width:680px){.channels{grid-template-columns:1fr}}

  /* ===== signal captures (work) ===== */
  .captures{display:grid;grid-template-columns:repeat(12,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:12px;overflow:hidden}
  .cap{background:var(--panel);grid-column:span 4;padding:1.4rem 1.4rem 1.5rem;display:flex;flex-direction:column;gap:.7rem;position:relative;min-height:250px;transition:background .4s}
  .cap.feat{grid-column:span 12;flex-direction:row;align-items:stretch;gap:2.2rem;min-height:240px}
  .cap:hover{background:var(--panel2)}
  .cap .chead{display:flex;justify-content:space-between;align-items:baseline;gap:1rem;font-family:var(--mono);font-size:.62rem;letter-spacing:.13em;text-transform:uppercase;color:var(--faint)}
  /* mini waveform sparkline */
  .spark{height:46px;width:100%;border:1px solid var(--line);border-radius:6px;background:
    linear-gradient(0deg,transparent 0 49%,var(--grid) 49% 51%,transparent 51%),
    radial-gradient(100% 120% at 50% 50%,rgba(127,233,255,.04),transparent 70%),#05080b;
    position:relative;overflow:hidden}
  .spark canvas{position:absolute;inset:0;width:100%;height:100%;display:block}
  .cap .ct{font-family:var(--disp);font-weight:600;font-size:clamp(1.2rem,2.2vw,1.55rem);line-height:1.05;color:var(--ink)}
  .cap .crole{font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--faint)}
  .cap .cr{font-family:var(--mono);font-size:.76rem;color:var(--phos-dim);letter-spacing:.01em}
  .cap .cd{color:var(--body);font-size:.9rem;line-height:1.55;margin-top:auto}
  /* featured layout */
  .cap.feat .cleft{flex:1.15;display:flex;flex-direction:column;gap:.8rem}
  .cap.feat .cright{flex:1;border-left:1px solid var(--line);padding-left:2.2rem;display:flex;flex-direction:column;justify-content:center;gap:.3rem}
  .cap.feat .bignum{font-family:var(--mono);font-weight:700;font-size:clamp(2.2rem,5vw,3.6rem);line-height:1;color:var(--phos);text-shadow:var(--glow);font-variant-numeric:tabular-nums}
  .cap.feat .bigl{font-family:var(--mono);font-size:.66rem;letter-spacing:.06em;text-transform:uppercase;color:var(--dim);margin-bottom:1rem}
  @media(max-width:920px){.cap{grid-column:span 6}.cap.feat{flex-direction:column;gap:1.3rem}.cap.feat .cright{border-left:0;border-top:1px solid var(--line);padding-left:0;padding-top:1.3rem}}
  @media(max-width:560px){.cap{grid-column:span 12}}

  /* ===== calibration (recognition) + brands ===== */
  .cal-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:clamp(2rem,5vw,4rem)}
  .stamps{display:flex;flex-direction:column;gap:0}
  .stamp{display:flex;align-items:center;gap:1.1rem;padding:1.1rem 0;border-top:1px solid var(--line)}
  .stamp:last-child{border-bottom:1px solid var(--line)}
  .stamp .seal{width:30px;height:30px;border:1px solid var(--hair);border-radius:50%;position:relative;flex:none;display:grid;place-items:center}
  .stamp .seal::before{content:"";width:9px;height:9px;border-radius:50%;background:var(--phos-dim);box-shadow:0 0 8px rgba(127,233,255,.5)}
  .stamp b{font-family:var(--disp);font-weight:600;font-size:1.1rem;letter-spacing:.01em;display:block;line-height:1.2;color:var(--ink)}
  .stamp span{font-family:var(--mono);font-size:.66rem;letter-spacing:.06em;color:var(--dim);text-transform:uppercase}
  .brands .bl{font-family:var(--mono);font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);margin-bottom:1.1rem}
  .brands .bgrid{display:flex;flex-wrap:wrap;gap:.6rem}
  .brands .bgrid span{font-family:var(--mono);font-size:.76rem;border:1px solid var(--line);border-radius:6px;padding:.5rem .8rem;color:var(--body)}
  @media(max-width:720px){.cal-grid{grid-template-columns:1fr}}

  /* ===== about / spec sheet ===== */
  .about-grid{display:grid;grid-template-columns:280px 1fr;gap:clamp(2rem,5vw,4rem);align-items:start}
  .about-photo{position:relative;aspect-ratio:5/6;border:1px solid var(--line);border-radius:12px;overflow:hidden;background:var(--panel)}
  .about-photo img{width:100%;height:100%;object-fit:cover;object-position:top center;filter:grayscale(.7) brightness(1.02) contrast(1.05)}
  .about-photo::after{content:"";position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,rgba(127,233,255,.06) 0 1px,transparent 1px 3px);pointer-events:none;mix-blend-mode:screen;opacity:.5}
  .about-lead{font-family:var(--disp);font-weight:500;font-size:clamp(1.3rem,2.6vw,1.9rem);line-height:1.18;letter-spacing:.005em;margin-bottom:1.8rem;color:var(--ink)}
  /* spec sheet table */
  .specs{display:grid;grid-template-columns:1fr;gap:0;border:1px solid var(--line);border-radius:10px;overflow:hidden}
