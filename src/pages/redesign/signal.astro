  .tx-panel .em{margin-top:1.5rem;font-family:var(--mono);font-size:.8rem;letter-spacing:.03em;color:var(--dim)}
  .tx-panel .em a{color:var(--ink);border-bottom:1px solid var(--hair)}
  .tx-panel .em a:hover{color:var(--phos);border-color:var(--phos)}

  /* footer */
  footer{border-top:1px solid var(--line);padding:2rem 0 3rem;position:relative;z-index:2}
  .foot-in{width:min(1280px,100%);margin:0 auto;padding:0 var(--m);display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;font-family:var(--mono);font-size:.68rem;letter-spacing:.06em;color:var(--faint);text-transform:uppercase}
  .foot-in a{color:var(--dim)}.foot-in a:hover{color:var(--phos)}

  /* reveals */
  .reveal{opacity:0;transform:translateY(20px);transition:opacity .8s cubic-bezier(.2,.8,.2,1),transform .8s cubic-bezier(.2,.8,.2,1)}
  .reveal.show{opacity:1;transform:none}

  @media(prefers-reduced-motion:reduce){
