<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- halftone WebGL: treat a soft portrait gradient as classic newsprint dots ----
  // Raw GLSL fullscreen quad. The dot phase animates subtly so the plate "breathes".
  // CSS gradient already painted on the canvas as a fallback if context is null.
  function halftone(id, seed, opts){
    const cv = document.getElementById(id);
    if(!cv) return;
    const gl = cv.getContext('webgl', { antialias:true, alpha:true });
    if(!gl) return; // CSS fallback stays visible
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs = `precision highp float;uniform vec2 r;uniform float t;uniform float seed;uniform float build;
    // DELIBERATE DATA PLATE: a bold typographic 'S' monogram inside a ruled press
    // frame, rendered as honest newsprint halftone. No portrait pretense - this is
    // confidently a masthead plate, so structure (the letterform) survives the dots.
    // distance to a thick stroke segment a->b
    float seg(vec2 p, vec2 a, vec2 b){
      vec2 pa = p - a, ba = b - a;
      float h = clamp(dot(pa,ba)/dot(ba,ba), 0.0, 1.0);
      return length(pa - ba*h);
    }
    // signed-ish field for a stylized 'S' built from an arc skeleton, centered ~origin
    float glyphS(vec2 p){
      // sample a 'S' as two C-curves: top bowl opening right, bottom bowl opening left
      float d = 1e3;
      const int N = 22;
      for(int i=0;i<N;i++){
        float u = float(i)/float(N-1);           // 0..1 along the stroke
        float ang;
        vec2 c;
        if(u < 0.5){
          // top bowl: arc from upper-right, sweeping left and down (open to the right)
          float a = mix(-0.55, 3.3, u*2.0);       // radians
          c = vec2(0.0, 0.21) + vec2(cos(a), sin(a))*vec2(0.20,0.20);
        } else {
          // bottom bowl: arc continuing, open to the left (mirror)
          float a = mix(0.16, 4.0, (u-0.5)*2.0);
          c = vec2(0.0, -0.21) + vec2(-cos(a), sin(a))*vec2(0.20,0.20);
        }
        if(i>0){
          // accumulate min distance to polyline by comparing consecutive samples
        }
        d = min(d, length(p - c));
      }
      return d;
    }
    float tone(vec2 uv){
      vec2 c = (uv - 0.5);
      c.x *= r.x / r.y;                  // square the working space
      // the monogram letterform: thick ink stroke -> big dots
      float dG = glyphS(c * 1.55);
      float letter = smoothstep(0.105, 0.055, dG);   // stroke thickness
      // a ruled rectangular plate border, like a registered press frame
      vec2 q = abs(c) - vec2(0.40, 0.42);
      float frameOuter = max(q.x, q.y);
      float frame = smoothstep(0.012, 0.0, abs(frameOuter + 0.02)) * 0.85;
      // a faint corner-tick + center cross-hair register marks for "data plate" honesty
      float ch = smoothstep(0.004,0.0,abs(c.x))*step(abs(c.y),0.06)
               + smoothstep(0.004,0.0,abs(c.y))*step(abs(c.x),0.06);
      float v = max(letter, max(frame, ch*0.35*(1.0-letter)));
      v *= smoothstep(1.10, 0.40, length(uv - vec2(0.5)));   // gentle vignette
      v = clamp(v, 0.0, 1.0);
      return v;
    }
    void main(){
      vec2 uv = gl_FragCoord.xy / r.xy;
      // keep dot cells square regardless of plate aspect
      float aspect = r.x / r.y;
      vec2 grid = vec2(uv.x * aspect, uv.y);
      float cell = 0.030;                 // halftone frequency (coarser = legible dots)
      // classic 45deg newsprint screen, barely animated so it stays a portrait not a shimmer
      float ang = 0.785 + sin(t*0.12 + seed)*0.015;
      mat2 rot = mat2(cos(ang),-sin(ang),sin(ang),cos(ang));
      vec2 g = rot * grid / cell;
      vec2 f = fract(g) - 0.5;
      float d = length(f);
      // dot-by-dot RECONSTRUCTION on load: 'build' (0->1) is a wavefront sweeping
      // top->bottom; each cell only "develops" once the wavefront passes its row,
      // with a little per-cell jitter so dots pop in organically like a developing print.
      vec2 cellId = floor(g);
      float jit = fract(sin(dot(cellId, vec2(12.99,78.23))) * 43758.55);
      float appear = smoothstep(uv.y - 0.06, uv.y + 0.02, build) * step(jit*0.18, build + 0.02);
      // tone -> dot radius (darker tone = bigger dot)
      float ton = tone(uv);
      float radius = sqrt(ton) * 0.66 * appear;
      float dot = smoothstep(radius, radius - 0.08, d);
      vec3 paper = vec3(0.953, 0.937, 0.894);
      vec3 ink   = vec3(0.082, 0.071, 0.047);
      // faint press-red mis-registration ghost, offset slightly, for authenticity
      vec2 gr = rot * (vec2((uv.x+0.004)*aspect, uv.y+0.003)) / cell;
      float dr = length(fract(gr)-0.5);
      float dotR = smoothstep(radius, radius-0.08, dr);
      vec3 col = mix(paper, ink, dot);
      col = mix(col, mix(col, vec3(0.753,0.188,0.114), 0.20), clamp(dotR-dot,0.0,1.0)*0.5);
      // wavefront edge: a faint developing line that travels down as it builds
      float edge = smoothstep(0.05, 0.0, abs(uv.y - build)) * (1.0 - step(0.999, build));
      col = mix(col, vec3(0.753,0.188,0.114), edge*0.12);
      gl_FragColor = vec4(col, 1.0);
    }`;
    function sh(ty,s){const o=gl.createShader(ty);gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram();
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));
    gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));
    gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);
    gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t'),us=gl.getUniformLocation(pr,'seed'),ub=gl.getUniformLocation(pr,'build');
    gl.uniform1f(us, seed);
    function size(){
      const d=Math.min(window.devicePixelRatio||1,1.6);
      const w=cv.clientWidth||cv.offsetWidth||320, h=cv.clientHeight||cv.offsetHeight||320;
      cv.width=Math.max(2,Math.round(w*d));cv.height=Math.max(2,Math.round(h*d));
      gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);
    }
    size();addEventListener('resize',size);
    // reduced motion: render the finished plate, fully built, no animation
    if(reduce){gl.uniform1f(ut,2.0);gl.uniform1f(ub,1.0);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    // dot-by-dot reconstruction: 'build' ramps 0->1 over ~1.8s, eased, the one
    // on-concept motion beat. After it lands the plate holds (build=1) and only
    // the screen angle breathes almost imperceptibly.
    const start=performance.now();
    const dur=1800, delay=(opts&&opts.delay)||0;
    (function loop(now){
      const elapsed=now-start;
      let b=Math.max(0,(elapsed-delay)/dur);
      b=b>=1?1:1-Math.pow(1-b,3);          // easeOutCubic to a clean stop at 1
      gl.uniform1f(ut,elapsed/1000);
      gl.uniform1f(ub,b);
      gl.drawArrays(gl.TRIANGLES,0,3);
      requestAnimationFrame(loop);
    })(start);
  }
  halftone('halftone', 0.0, { delay: 350 });
  halftone('halftone2', 2.3, { delay: 0 });

  // ---- smooth scroll + reveals + microinteractions ----
  if(!reduce){
    const lenis = new Lenis({ lerp:.1, smoothWheel:true });
    function raf(t){ lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll', ScrollTrigger.update);

    // lead headline lines slide up like a press impression
    gsap.set('.lead h2 .ln>span',{ yPercent:115 });
    gsap.set('.kicker,.deck,.byline,.cols,.aside',{ opacity:0, y:18 });
    const tl = gsap.timeline({ delay:.12 });
    tl.to('.lead h2 .ln>span',{ yPercent:0, duration:1.05, ease:'expo.out', stagger:.1 })
      .to('.kicker',{ opacity:1, y:0, duration:.6 }, .15)
      .to('.deck',{ opacity:1, y:0, duration:.7 }, .35)
      .to('.byline',{ opacity:1, y:0, duration:.6 }, .5)
      .to('.cols',{ opacity:1, y:0, duration:.8 }, .55)
      .to('.aside',{ opacity:1, y:0, duration:.8 }, .45);

    // batched scroll reveals - every .reveal still ends at opacity:1
    ScrollTrigger.batch('.reveal',{
      start:'top 90%',
      onEnter:batch=>gsap.to(batch,{ opacity:1, y:0, duration:.9, ease:'expo.out', stagger:.08, overwrite:true }),
    });
    ScrollTrigger.refresh();

    // press-red progress rule
    const prog = document.getElementById('progress');
    gsap.to(prog,{ scaleX:1, ease:'none', scrollTrigger:{ trigger:document.body, start:'top top', end:'bottom bottom', scrub:.3 } });

    // pause ticker on hover for readability
    const tk = document.getElementById('ticker');
    const tkParent = tk?.parentElement;
    if(tkParent){
      tkParent.addEventListener('mouseenter',()=>{ tk.style.animationPlayState='paused'; });
      tkParent.addEventListener('mouseleave',()=>{ tk.style.animationPlayState='running'; });
    }
  }
</script>
</body>
</html>
