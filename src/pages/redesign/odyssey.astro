      linear-gradient(0deg,transparent 48%,rgba(94,234,212,.5) 49%,rgba(94,234,212,.55) 51%,transparent 52%),
      linear-gradient(90deg,transparent 70%,rgba(255,207,107,.5) 70%,rgba(255,207,107,.5) 72%,transparent 72%),
      linear-gradient(0deg,transparent 33%,rgba(255,207,107,.5) 33%,rgba(255,207,107,.5) 35%,transparent 35%) 72% 0/16% 100% no-repeat,
      radial-gradient(60% 80% at 78% 30%,rgba(255,207,107,.16),transparent 60%),
      linear-gradient(135deg,#0c1a2e,#06070f)}
