      radial-gradient(closest-side at 24% 78%,transparent 26%,rgba(125,150,255,.4) 28%,transparent 32%),
      radial-gradient(closest-side at 24% 78%,transparent 46%,rgba(94,234,212,.32) 48%,transparent 53%),
      radial-gradient(closest-side at 24% 78%,transparent 66%,rgba(255,207,107,.34) 68%,transparent 74%),
      radial-gradient(50% 60% at 24% 78%,rgba(75,108,255,.3),transparent 64%),
      linear-gradient(135deg,#0a1838,#05070f)}
  /* Medilife - medical pulse / cross: a heartbeat line + a soft warm cross */
