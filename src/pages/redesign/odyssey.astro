  .contact .big a{position:relative;color:var(--ink)}
  .contact .big a::after{content:"";position:absolute;left:0;bottom:.04em;width:100%;height:3px;background:var(--warm);transform:scaleX(0);transform-origin:left;transition:transform .5s cubic-bezier(.2,.8,.2,1)}
