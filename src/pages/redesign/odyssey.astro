<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  // ---------------------------------------------------------------
  // THREE.js particle field: chaotic NOISE -> ordered SIGNAL ring,
  // morph driven by scroll progress, colour cold(blue)->warm(gold).
  // Falls back to the CSS field on mobile or if Three fails to load.
  // ---------------------------------------------------------------
  let scrollProgress = 0;       // 0..1 across the whole page
  let mx = 0, my = 0;           // -1..1 mouse parallax

  // ---------------------------------------------------------------
  // Hero IDLE DEMO: before any scroll, run a short autonomous "breathing" of the
  // morph (noise -> partial constellation -> noise) so the signature reads on load.
  // Hands off the instant the user scrolls; reduced-motion holds a static partial frame.
  // `effProgress()` = max(real scroll, idle demo) so scrolling always wins immediately.
  // ---------------------------------------------------------------
  let idleProgress = 0;         // 0..1 autonomous demo value, decays to 0 once scrolling
  let hasScrolled = false;
  const idleStart = (typeof performance !== 'undefined' ? performance.now() : Date.now());
  function effProgress(){
    if (reduce) return 0.55;
    if (hasScrolled || scrollProgress > 0.002) { hasScrolled = true; idleProgress = 0; return scrollProgress; }
    // gentle, looping breath: ~6s period, peaks ~0.42 (a partial constellation, never full).
    const el = ((typeof performance !== 'undefined' ? performance.now() : Date.now()) - idleStart) / 1000;
    const breath = (1 - Math.cos((el / 3) * Math.PI)) / 2;      // 0->1->0 every 6s
    idleProgress = breath * 0.42;
    return Math.max(scrollProgress, idleProgress);
  }

  const cv = document.getElementById('scene');
  const cssField = document.getElementById('cssField');

  function showCssFallback(){
    if (cv) cv.style.display = 'none';
    if (cssField) cssField.style.display = 'block';
  }

  if (isMobile) {
    // Mobile: skip Three/WebGL but keep a LIGHTWEIGHT 2D particle canvas pinned behind
    // the hero + act dividers, still driven by scroll cold(blue)->warm(gold).
    startMobileField();
  } else {
    // probe WebGL on a THROWAWAY canvas - probing on `cv` itself would lock it to a
    // webgl1 context and make Three's webgl2 request fail ("existing context of a different type").
    const tmp = document.createElement('canvas');
    const probe = tmp.getContext('webgl2') || tmp.getContext('webgl') || tmp.getContext('experimental-webgl');
    if (!probe) {
      showCssFallback();
    } else {
      import('https://esm.sh/three@0.160.0').then((THREE) => {
        try { initThree(THREE); }
        catch (e) { showCssFallback(); }
      }).catch(() => showCssFallback());
    }
  }

  function initThree(THREE){
    const renderer = new THREE.WebGLRenderer({ canvas: cv, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 1.6));
    renderer.setSize(window.innerWidth, window.innerHeight);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.z = 16;

    const COUNT = 4200;
    const noisePos = new Float32Array(COUNT * 3);   // chaotic source
    const signalPos = new Float32Array(COUNT * 3);  // ordered target (constellation ring + wave)
    const seeds = new Float32Array(COUNT);

    for (let i = 0; i < COUNT; i++) {
      // NOISE: random cloud in a box
      noisePos[i*3+0] = (Math.random() - 0.5) * 30;
      noisePos[i*3+1] = (Math.random() - 0.5) * 22;
      noisePos[i*3+2] = (Math.random() - 0.5) * 20;

      // SIGNAL: layered ordered structure - a constellation ring with a sine wave running through it
      const a = (i / COUNT) * Math.PI * 2 * 5;           // wraps several times
      const ringR = 8 + Math.sin(i * 0.21) * 0.6;
      const onRing = i % 3 !== 0;                         // ~2/3 form the ring, rest form the wave line
      if (onRing) {
        signalPos[i*3+0] = Math.cos(a) * ringR;
        signalPos[i*3+1] = Math.sin(a) * ringR * 0.62 + Math.sin(a * 3) * 0.5;
        signalPos[i*3+2] = Math.sin(a * 2) * 1.6;
      } else {
        const x = ((i / COUNT) - 0.5) * 26;
        signalPos[i*3+0] = x;
        signalPos[i*3+1] = Math.sin(x * 0.7) * 2.4;       // the clean signal wave
        signalPos[i*3+2] = Math.cos(x * 0.5) * 1.2;
      }
      seeds[i] = Math.random();
    }

    const geo = new THREE.BufferGeometry();
    // start at noise positions; we lerp manually each frame
    const cur = new Float32Array(noisePos);
    geo.setAttribute('position', new THREE.BufferAttribute(cur, 3));

    // round soft sprite for points
    const c = document.createElement('canvas'); c.width = c.height = 64;
    const ctx = c.getContext('2d');
    const g = ctx.createRadialGradient(32,32,0,32,32,32);
    g.addColorStop(0,'rgba(255,255,255,1)');
    g.addColorStop(.4,'rgba(255,255,255,.6)');
    g.addColorStop(1,'rgba(255,255,255,0)');
    ctx.fillStyle = g; ctx.fillRect(0,0,64,64);
    const sprite = new THREE.CanvasTexture(c);

    const mat = new THREE.PointsMaterial({
      size: 0.16,
      map: sprite,
      transparent: true,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      color: new THREE.Color(0x4b6cff),
    });
    const points = new THREE.Points(geo, mat);
    scene.add(points);

    const cold = new THREE.Color(0x4b6cff);
    const warm = new THREE.Color(0xffcf6b);
    const tmpCol = new THREE.Color();

    function resize(){
      renderer.setSize(window.innerWidth, window.innerHeight);
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', resize);

    window.addEventListener('mousemove', (e) => {
      mx = (e.clientX / window.innerWidth) * 2 - 1;
      my = (e.clientY / window.innerHeight) * 2 - 1;
    });

    const posAttr = geo.getAttribute('position');
    let t = 0;

    function frame(){
      t += 0.004;
      // morph factor: real scroll, or the autonomous idle demo before first scroll
      const p = effProgress();
      const ease = p < 0.5 ? 2*p*p : 1 - Math.pow(-2*p+2,2)/2; // easeInOutQuad

      const arr = posAttr.array;
      for (let i = 0; i < COUNT; i++) {
        const ix = i*3;
        // gentle drift on the noise so the chaos breathes
        const sx = noisePos[ix]   + Math.sin(t + seeds[i]*6.28) * 0.6;
        const sy = noisePos[ix+1] + Math.cos(t*0.8 + seeds[i]*6.28) * 0.6;
        const sz = noisePos[ix+2];
        arr[ix]   = sx + (signalPos[ix]   - sx) * ease;
        arr[ix+1] = sy + (signalPos[ix+1] - sy) * ease;
        arr[ix+2] = sz + (signalPos[ix+2] - sz) * ease;
      }
      posAttr.needsUpdate = true;

      // colour cold -> warm with progress
      tmpCol.copy(cold).lerp(warm, ease);
      mat.color.copy(tmpCol);
      mat.size = 0.13 + ease * 0.07;

      // slow auto-rotation + mouse parallax
      points.rotation.y = (reduce ? 0 : t * 0.05) + mx * 0.35;
      points.rotation.x = my * 0.2;
      // pull camera in slightly as the signal forms
      camera.position.z = 16 - ease * 2.4;

      renderer.render(scene, camera);
      requestAnimationFrame(frame);
    }

    if (reduce) {
      // single static composed frame (signal mostly formed, warm)
      frame();
    } else {
      frame();
    }
  }

  // ---------------------------------------------------------------
  // Mobile lightweight 2D particle field (Canvas2D, reduced count).
  // Scattered cold drift (noise) -> converges toward a calm warm wave (signal),
  // interpolated by scrollProgress. Legible: low density, soft additive dots.
  // ---------------------------------------------------------------
  function startMobileField(){
    if (!cv) { showCssFallback(); return; }
    const ctx = cv.getContext('2d');
    if (!ctx) { showCssFallback(); return; }   // last-resort CSS haze
    cv.style.display = 'block';
    let W = 0, H = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
    const N = 90;                               // reduced count for mobile
    const P = [];

    function layout(){
      W = window.innerWidth; H = window.innerHeight;
      cv.width = Math.floor(W * dpr); cv.height = Math.floor(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    function seed(){
      P.length = 0;
      for (let i = 0; i < N; i++) {
        const ph = i / N;
        P.push({
          nx: Math.random() * W, ny: Math.random() * H,   // noise home
          tx: ph * W,                                       // signal target x (across)
          amp: H * 0.10 + Math.random() * H * 0.05,
          spd: 0.5 + Math.random() * 0.8,
          off: Math.random() * Math.PI * 2,
          r: 0.8 + Math.random() * 1.6,
        });
      }
    }
    layout(); seed();
    window.addEventListener('resize', () => { layout(); seed(); }, { passive: true });

    const COLD = [125,150,255], WARM = [255,207,107];
    let t = 0;
    function lerp(a,b,k){ return a + (b-a)*k; }

    function frame(){
      t += reduce ? 0 : 0.012;
      const p = effProgress();
      const ease = p < 0.5 ? 2*p*p : 1 - Math.pow(-2*p+2,2)/2;
      ctx.clearRect(0,0,W,H);
      ctx.globalCompositeOperation = 'lighter';
      const midY = H * 0.5;
      const cr = Math.round(lerp(COLD[0],WARM[0],ease));
      const cg = Math.round(lerp(COLD[1],WARM[1],ease));
      const cb = Math.round(lerp(COLD[2],WARM[2],ease));
      for (let i = 0; i < N; i++) {
        const d = P[i];
        // noise position (gentle drift)
        const dx = d.nx + Math.sin(t * d.spd + d.off) * 14;
        const dy = d.ny + Math.cos(t * d.spd * 0.8 + d.off) * 14;
        // signal position (ordered wave across the screen)
        const sx = d.tx;
        const sy = midY + Math.sin(d.tx / W * Math.PI * 3 + t * 0.4) * d.amp;
        const x = lerp(dx, sx, ease);
        const y = lerp(dy, sy, ease);
        const a = 0.18 + ease * 0.34;
        const rr = d.r * (1 + ease * 0.5);
        const grd = ctx.createRadialGradient(x, y, 0, x, y, rr * 4);
        grd.addColorStop(0, `rgba(${cr},${cg},${cb},${a})`);
        grd.addColorStop(1, `rgba(${cr},${cg},${cb},0)`);
        ctx.fillStyle = grd;
        ctx.beginPath(); ctx.arc(x, y, rr * 4, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalCompositeOperation = 'source-over';
      requestAnimationFrame(frame);
    }
    frame();
  }

  // ---------------------------------------------------------------
  // Feature work tile: live converging particle/data motif on the lead case.
  // Idle = scattered cold dots; on hover the field converges to a rising warm
  // signal line. Canvas2D, tiny count, reduced-motion safe.
  // ---------------------------------------------------------------
  function startFeatureMotif(){
    if (reduce) return;
    const canvas = document.querySelector('.work .row.feat .fcanvas');
    const card = document.querySelector('.work .row.feat');
    if (!canvas || !card) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0, H = 0, hover = 0, target = 0;
    const N = 64, P = [];
    function layout(){
      const r = card.getBoundingClientRect();
      W = r.width; H = r.height;
      canvas.width = Math.floor(W * dpr); canvas.height = Math.floor(H * dpr);
      ctx.setTransform(dpr,0,0,dpr,0,0);
      P.length = 0;
      for (let i = 0; i < N; i++) {
        const ph = i / N;
        P.push({ nx: Math.random()*W, ny: Math.random()*H, tx: ph*W,
          amp: H*0.16, off: Math.random()*Math.PI*2, r: 0.8 + Math.random()*1.3 });
      }
    }
    layout();
    const ro = new ResizeObserver(layout); ro.observe(card);
    card.addEventListener('mouseenter', () => target = 1);
    card.addEventListener('mouseleave', () => target = 0);
    const COLD=[125,150,255], WARM=[255,207,107];
    const L=(a,b,k)=>a+(b-a)*k;
    let t = 0;
    function frame(){
      t += 0.02; hover += (target - hover) * 0.07;
      const e = hover < 0.5 ? 2*hover*hover : 1 - Math.pow(-2*hover+2,2)/2;
      ctx.clearRect(0,0,W,H);
      ctx.globalCompositeOperation='lighter';
      const cr=Math.round(L(COLD[0],WARM[0],e)),cg=Math.round(L(COLD[1],WARM[1],e)),cb=Math.round(L(COLD[2],WARM[2],e));
      const midY=H*0.5;
      // signal line connecting converged dots
      if (e > 0.15){
        ctx.globalCompositeOperation='source-over';
        ctx.beginPath();
        for (let i=0;i<N;i++){ const d=P[i]; const sy=midY+Math.sin(d.tx/W*Math.PI*2.4+t*0.5)*d.amp;
          const x=L(d.nx,d.tx,e), y=L(d.ny,sy,e); i?ctx.lineTo(x,y):ctx.moveTo(x,y); }
        ctx.strokeStyle=`rgba(${cr},${cg},${cb},${0.18*e})`; ctx.lineWidth=1.2; ctx.stroke();
        ctx.globalCompositeOperation='lighter';
      }
      for (let i=0;i<N;i++){ const d=P[i];
        const dx=d.nx+Math.sin(t+d.off)*10, dy=d.ny+Math.cos(t*0.8+d.off)*10;
        const sy=midY+Math.sin(d.tx/W*Math.PI*2.4+t*0.5)*d.amp;
        const x=L(dx,d.tx,e), y=L(dy,sy,e);
        const a=0.22+e*0.4, rr=d.r*(1+e*0.6);
        const g=ctx.createRadialGradient(x,y,0,x,y,rr*4);
        g.addColorStop(0,`rgba(${cr},${cg},${cb},${a})`); g.addColorStop(1,`rgba(${cr},${cg},${cb},0)`);
        ctx.fillStyle=g; ctx.beginPath(); ctx.arc(x,y,rr*4,0,Math.PI*2); ctx.fill();
      }
      ctx.globalCompositeOperation='source-over';
      requestAnimationFrame(frame);
    }
    frame();
  }
  startFeatureMotif();

  // ---------------------------------------------------------------
  // Lenis smooth scroll + GSAP reveals + progress + nav state
  // (drives scrollProgress for the particle morph)
  // ---------------------------------------------------------------
  const nav = document.getElementById('nav');
  const prog = document.getElementById('progress');

  function updateProgress(){
    const max = document.documentElement.scrollHeight - window.innerHeight;
    scrollProgress = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
    if (window.scrollY > 0) hasScrolled = true;   // end the idle demo, scroll owns the morph
    if (prog) prog.style.transform = `scaleX(${scrollProgress})`;
    if (nav) nav.classList.toggle('solid', window.scrollY > 40);
  }

  if (!reduce) {
    const lenis = new Lenis({ lerp: .1, smoothWheel: true });
    function raf(time){ lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll', () => { ScrollTrigger.update(); updateProgress(); });

    // hero kinetic reveal
    gsap.set('.hero h1 .ln>span', { yPercent: 120 });
    gsap.set('.hero .credential,.hero .sub,.hero .cta', { opacity: 0, y: 22 });
    const tl = gsap.timeline({ delay: .15 });
    tl.to('.hero h1 .ln>span', { yPercent: 0, duration: 1.15, ease: 'expo.out', stagger: .1 })
      .to('.hero .credential', { opacity: 1, y: 0, duration: .7 }, .2)
      .to('.hero .sub', { opacity: 1, y: 0, duration: .8 }, .55)
      .to('.hero .cta', { opacity: 1, y: 0, duration: .8 }, .7);

    // batched scroll reveals - every .reveal ends opacity:1
    ScrollTrigger.batch('.reveal', {
      start: 'top 88%',
      onEnter: batch => gsap.to(batch, { opacity: 1, y: 0, duration: 1, ease: 'expo.out', stagger: .08, overwrite: true }),
    });

    // act names get a subtle kinetic slide as they enter
    gsap.utils.toArray('.actmark .aname').forEach((el) => {
      gsap.from(el, {
        xPercent: -4, opacity: .35, ease: 'none',
        scrollTrigger: { trigger: el, start: 'top 90%', end: 'top 45%', scrub: .6 },
      });
    });

    ScrollTrigger.refresh();
    updateProgress();
  } else {
    // reduced motion: no Lenis, no scrub - just keep progress + nav state live
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // custom trailing cursor (desktop only) + work-card signal beam
  if (!reduce && window.matchMedia('(hover:hover)').matches) {
    const cur = document.getElementById('cur');
    let cx = -100, cy = -100, tx = cx, ty = cy;
    window.addEventListener('mousemove', (e) => { tx = e.clientX; ty = e.clientY; });
    (function cloop(){ cx += (tx-cx)*.18; cy += (ty-cy)*.18; cur.style.transform = `translate(${cx}px,${cy}px) translate(-50%,-50%)`; requestAnimationFrame(cloop); })();
    document.querySelectorAll('a,button').forEach(el => {
      el.addEventListener('mouseenter', () => cur.classList.add('big'));
      el.addEventListener('mouseleave', () => cur.classList.remove('big'));
    });
    document.querySelectorAll('.work .row').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${((e.clientX-r.left)/r.width)*100}%`);
        card.style.setProperty('--my', `${((e.clientY-r.top)/r.height)*100}%`);
      });
    });
  }
</script>
</body>
</html>
