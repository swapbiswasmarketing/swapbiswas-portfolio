      radial-gradient(closest-side at 70% 46%,transparent 34%,rgba(94,234,212,.5) 36%,transparent 41%),
      radial-gradient(closest-side at 70% 46%,transparent 54%,rgba(125,150,255,.34) 56%,transparent 62%),
      radial-gradient(60% 80% at 70% 46%,rgba(255,207,107,.18),transparent 60%),
