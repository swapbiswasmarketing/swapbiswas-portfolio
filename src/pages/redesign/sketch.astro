  /* ---- recognition + brands ---- */
  .recog{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(2rem,5vw,4rem);align-items:start}
  .recol .clabel{font-family:var(--hand);font-size:1.5rem;color:var(--blue);font-weight:700;margin-bottom:1rem}
  .award{display:grid;grid-template-columns:1fr auto;align-items:baseline;gap:1rem;padding:.9rem 0;
    border-bottom:1.5px dashed var(--line)}
  .award b{font-family:var(--head);font-weight:700;font-size:clamp(1.1rem,2.2vw,1.5rem);letter-spacing:-.01em;line-height:1.15;color:var(--ink)}
  .award b .num{color:var(--red);font-family:var(--hand)}
  .award span{color:var(--ink2);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;white-space:nowrap;justify-self:end;font-weight:600}
  /* brands as little hand-circled chips */
  .brands{display:flex;flex-wrap:wrap;gap:.8rem .9rem}
  .brands span{font-family:var(--head);font-weight:600;font-size:.92rem;color:var(--ink);
    padding:.5rem .9rem;border:2px solid var(--ink);border-radius:40% 60% 55% 45% / 55% 45% 60% 40%;
    background:rgba(255,255,255,.5);transition:transform .3s,background .3s}
  .brands span:nth-child(2n){border-radius:55% 45% 50% 50% / 45% 55% 50% 60%;transform:rotate(-1.4deg)}
  .brands span:nth-child(3n){transform:rotate(1.6deg)}
  .brands span:hover{transform:rotate(0) scale(1.05);background:var(--yel)}
  @media(max-width:720px){.recog{grid-template-columns:1fr;gap:2.2rem}}
  /* ---- about ---- */
  .about .abody{display:grid;grid-template-columns:210px 1fr 320px;gap:clamp(1.6rem,3vw,3rem);align-items:stretch}
  /* CUT-OUT STICKER: the transparent portrait figure dropped straight onto the cream page,
     with a hand-drawn scribble/marker halo around it + one strip of washi tape. The suit is
     near-black and reads fine on the light paper, so no background panel/mask is needed. */
  .polaroid{position:relative;align-self:end;justify-self:center;width:min(300px,80vw);
    padding-top:1.2rem;transform:rotate(-2.5deg);
    transition:transform .45s cubic-bezier(.2,.8,.2,1)}
  .polaroid:hover{transform:rotate(-.6deg) translateY(-5px) scale(1.02)}
  /* the rough hand-drawn marker halo / scribble outline behind the figure */
  .polaroid .halo{position:absolute;top:.2rem;left:50%;transform:translateX(-50%);
    width:104%;height:99%;z-index:0;overflow:visible;pointer-events:none}
  .polaroid .halo path{fill:none;stroke:var(--blue);stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round;opacity:.55}
  .polaroid .halo path.h2{stroke:var(--red);opacity:.4}
  /* the cut-out figure itself: contain (it is a cut figure, not a fill), fixed box, no mask */
  .polaroid .ph{position:relative;z-index:1;display:block;width:100%;aspect-ratio:1023/1536;
    object-fit:contain;object-position:bottom center;
    filter:drop-shadow(5px 10px 14px rgba(26,26,26,.28))}
  /* one piece of washi tape pinning the sticker at the top */
  .polaroid .tape{position:absolute;width:78px;height:24px;z-index:2;
    background:repeating-linear-gradient(45deg,rgba(255,225,77,.62) 0 7px,rgba(255,225,77,.4) 7px 14px);
