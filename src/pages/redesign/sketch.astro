<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  // ---- WebGL paper/grain background ----
  // Raw GLSL fullscreen-quad (Aurora boilerplate), fragment shader swapped for an animated
  // warm paper texture with a faint hand-drawn 'wobble'/displacement of the grain. On small
  // screens (unreliable mobile WebGL) or a null context, fall back to the CSS paper plate.
  (function(){
    const cv = document.getElementById('paper');
    const css = document.getElementById('cssPaper');
    if(isMobile){
      if(cv) cv.style.display='none';
      if(css) css.style.display='block';
      return;
    }
    const gl = cv.getContext('webgl',{antialias:true,alpha:true});
    if(!gl){ if(css) css.style.display='block'; return; }
    const vs=`attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs=`precision highp float;uniform vec2 r;uniform float t;
    float h(vec2 x){return fract(sin(dot(x,vec2(127.1,311.7)))*43758.5453);}
    float n(vec2 x){vec2 i=floor(x),f=fract(x);float a=h(i),b=h(i+vec2(1,0)),c=h(i+vec2(0,1)),d=h(i+vec2(1,1));vec2 u=f*f*(3.-2.*f);return mix(a,b,u.x)+(c-a)*u.y*(1.-u.x)+(d-b)*u.x*u.y;}
    float fbm(vec2 x){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*n(x);x*=2.03;a*=.5;}return v;}
    void main(){
      vec2 uv=gl_FragCoord.xy/r.xy;
      vec2 p=uv;p.x*=r.x/r.y;
      // hand-drawn 'wobble': low-freq displacement that breathes over time, like ink on a
      // slightly buckled page. This warps the fibre/grain sampling so the paper feels analog.
      vec2 wob=vec2(fbm(p*2.2+t*.03),fbm(p*2.2+7.3-t*.025))-0.5;
      vec2 sp=p+wob*0.06;
      // paper fibre: two octaves of fine grain, multiplied so it reads as woven stock
      float fib=fbm(sp*42.0)*0.6+fbm(sp*120.0)*0.4;
      float fibre=mix(0.985,1.0,smoothstep(0.3,0.75,fib));
      // warm paper base #fbfaf4 -> #f4f2e8, biased warmer top-right (the hero highlight)
      vec3 paperA=vec3(0.984,0.980,0.957);
      vec3 paperB=vec3(0.956,0.949,0.910);
      vec3 col=mix(paperB,paperA,smoothstep(0.0,1.0,uv.y*0.6+uv.x*0.4));
      col*=fibre;
      // faint highlighter-yellow bloom top-right + cool blue wash low-left (brand inks)
      float yel=smoothstep(0.55,1.0,uv.x)*smoothstep(0.45,1.0,uv.y);
      col+=vec3(1.0,0.88,0.30)*yel*0.07*(0.85+0.15*sin(t*0.4));
      float blu=smoothstep(0.5,0.0,uv.x)*smoothstep(0.5,0.0,uv.y);
      col+=vec3(0.17,0.36,1.0)*blu*0.025;
      // very subtle moving 'coffee-ring' soft spots so the page feels lived-in
      float spot=smoothstep(0.16,0.0,length((uv-vec2(0.78,0.2))*vec2(1.0,1.3)));
      col-=vec3(0.02,0.02,0.0)*spot;
      // soft page vignette toward edges
      float vig=smoothstep(1.4,0.35,length(uv-vec2(0.5,0.5)));
      col=mix(col*0.965,col,vig);
      gl_FragColor=vec4(col,1.0);
    }`;
    function sh(ty,s){const o=gl.createShader(ty);gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram();gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t');
    function size(){const d=Math.min(window.devicePixelRatio||1,1.6);cv.width=innerWidth*d;cv.height=innerHeight*d;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);}
    size();addEventListener('resize',size);
    if(reduce){gl.uniform1f(ut,2.0);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    let start=performance.now();
    (function loop(now){gl.uniform1f(ut,(now-start)/1000);gl.drawArrays(gl.TRIANGLES,0,3);requestAnimationFrame(loop);})(start);
  })();

  // ---- prep SVG draw-on paths: set dash to the full length so they start "undrawn" ----
  function primeDraw(el){
    if(!el) return 0;
    const len = el.getTotalLength();
    el.style.strokeDasharray = len;
    el.style.strokeDashoffset = reduce ? 0 : len;
    return len;
  }
  const heroUL = document.getElementById('heroUnderline');
  const contactUL = document.getElementById('contactUnderline');
  primeDraw(heroUL); primeDraw(contactUL);
  document.querySelectorAll('.stat .ringpath').forEach(primeDraw);
  document.querySelectorAll('.note .doodle path, .note .doodle polyline, .note .doodle circle')
    .forEach(p=>primeDraw(p));

  // ---- smooth scroll + reveals + signature animations ----
  if(!reduce){
    const lenis=new Lenis({lerp:.1,smoothWheel:true});
    function raf(t){lenis.raf(t);requestAnimationFrame(raf);}requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll',ScrollTrigger.update);

    // hero lines rise, then the marker underline "draws on"
    gsap.set('.hero h1 .ln>span',{yPercent:115});
    gsap.set('.hero .credential,.hero .sub,.hero .cta,.hero .heroanchor,.hero .aside',{opacity:0,y:18});
    const tl=gsap.timeline({delay:.15});
    tl.to('.hero h1 .ln>span',{yPercent:0,duration:1.0,ease:'expo.out',stagger:.1})
      .to('.hero .credential',{opacity:1,y:0,duration:.6},.15)
      .to(heroUL,{strokeDashoffset:0,duration:.9,ease:'power2.inOut'},'-=.2')
      .to('.hero .sub',{opacity:1,y:0,duration:.7},'-=.5')
      .to('.hero .cta',{opacity:1,y:0,duration:.7},'-=.45')
      .to('.hero .heroanchor',{opacity:1,y:0,duration:.6},'-=.4')
      .to('.hero .aside',{opacity:1,y:0,duration:.7,ease:'back.out(1.6)'},'-=.5')
      .add(()=>document.querySelectorAll('.hero .sub .hl').forEach((h,i)=>setTimeout(()=>h.classList.add('lit'),i*180)),'-=.2');

    // batched scroll reveals - every .reveal ends opacity:1
    ScrollTrigger.batch('.reveal',{
      start:'top 88%',
      onEnter:batch=>gsap.to(batch,{opacity:1,y:0,duration:.9,ease:'expo.out',stagger:.08,overwrite:true}),
    });

    // signature: stat circles draw on, then the highlighter under their label swipes
    document.querySelectorAll('.stat').forEach(stat=>{
      const ring=stat.querySelector('.ringpath');
      ScrollTrigger.create({trigger:stat,start:'top 80%',once:true,onEnter:()=>{
        if(ring) gsap.to(ring,{strokeDashoffset:0,duration:.8,ease:'power2.inOut'});
      }});
    });

    // signature: sticky-note doodles draw on as each note enters
    document.querySelectorAll('.note').forEach(note=>{
      const strokes=note.querySelectorAll('.doodle path, .doodle polyline, .doodle circle');
      ScrollTrigger.create({trigger:note,start:'top 82%',once:true,onEnter:()=>{
        gsap.to(strokes,{strokeDashoffset:0,duration:.7,ease:'power2.out',stagger:.06});
      }});
    });

    // signature: highlighter strokes swipe across key words on scroll
    document.querySelectorAll('.hl').forEach(h=>{
      ScrollTrigger.create({trigger:h,start:'top 86%',once:true,
        onEnter:()=>h.classList.add('lit')});
    });

    // contact underline draws on
    ScrollTrigger.create({trigger:'#contact',start:'top 70%',once:true,
      onEnter:()=>{ if(contactUL) gsap.to(contactUL,{strokeDashoffset:0,duration:.9,ease:'power2.inOut'}); }});

    // statement marquee - gentle continuous drift, half-width loop
    const marq=document.getElementById('marq');
    if(marq){
      gsap.to(marq,{xPercent:-50,duration:26,ease:'none',repeat:-1});
    }

    // scroll progress
    gsap.to('#progress',{scaleX:1,ease:'none',scrollTrigger:{trigger:document.body,start:'top top',end:'bottom bottom',scrub:.3}});

    ScrollTrigger.refresh();
  } else {
    // reduced motion: still loop the marquee statically (no transform) and ensure reveals show
    document.querySelectorAll('.hl').forEach(h=>h.classList.add('lit'));
  }
</script>
</body>
</html>
