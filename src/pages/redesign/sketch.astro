  /* hand-drawn caption tucked under the cut-out */
  .polaroid .cap{position:relative;z-index:2;font-family:var(--hand);font-size:1.75rem;color:var(--ink);font-weight:700;
    text-align:center;line-height:1;padding:.5rem 0 0;transform:rotate(-1.5deg)}
  /* doodle arrow pointing at the cut-out figure */
  .polaroid .arrowdoodle{position:absolute;bottom:24%;left:-50px;width:60px;height:64px;overflow:visible;z-index:3}
  .polaroid .arrowdoodle path{fill:none;stroke:var(--red);stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round}
