<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- WebGL fine-line topographic contour texture (barely-there) ----
  (function(){
    const cv = document.getElementById('contour');
    const gl = cv.getContext('webgl', { antialias:true, alpha:true });
    if(!gl){ cv.style.background='radial-gradient(120% 90% at 80% 0%,rgba(180,69,31,.10),transparent 55%)'; return; }
    const vs=`attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs=`precision highp float;uniform vec2 r;uniform float t;uniform float prog;uniform float scr;uniform vec2 ptr;
    float h(vec2 x){return fract(sin(dot(x,vec2(127.1,311.7)))*43758.5453);}
    float n(vec2 x){vec2 i=floor(x),f=fract(x);float a=h(i),b=h(i+vec2(1,0)),c=h(i+vec2(0,1)),d=h(i+vec2(1,1));vec2 u=f*f*(3.-2.*f);return mix(a,b,u.x)+(c-a)*u.y*(1.-u.x)+(d-b)*u.x*u.y;}
    float fbm(vec2 x){float v=0.,a=.5;for(int i=0;i<6;i++){v+=a*n(x);x*=2.03;a*=.5;}return v;}
    void main(){
      vec2 uv=gl_FragCoord.xy/r.xy;vec2 p=uv;p.x*=r.x/r.y;
      // continuous idle drift (always alive) + pointer parallax + scroll drift -> the map shifts under the type
      vec2 wander=vec2(sin(t*0.06)*0.05, cos(t*0.045)*0.045);
      vec2 par=ptr*0.10+vec2(0.0,scr*0.14)+wander;
      p+=par;
      // slowly morphing height field -> topographic contour lines (faster evolution so it reads as living)
      float field=fbm(p*2.7+vec2(t*.020,t*.028));
      field+=0.20*fbm(p*5.4-vec2(t*.024,0.0));
      // index contour bands (every 5th line drawn heavier, like a real map)
      float lines=field*16.0;
      float edge=abs(fract(lines)-0.5);
      float w=fwidth(lines);
      // thin 1px hairline + a touch of softness so it reads as ink, not aliasing
      float contour=1.0-smoothstep(w*0.5,w*1.6,edge);
      // index lines: every 5th contour rendered as a heavier stroke
      float idx=field*16.0/5.0;
      float iedge=abs(fract(idx)-0.5);
      float iw=fwidth(idx);
      float index=(1.0-smoothstep(iw*0.5,iw*2.0,iedge))*0.7;
      float strokes=max(contour,index);
      // burnt sienna ink hairlines, warming toward ridge-tops (higher sienna contrast)
      vec3 sienna=vec3(.760,.250,.090);
      vec3 ink=vec3(.105,.090,.075);
      vec3 lineCol=mix(ink,sienna,smoothstep(.18,.72,field));
      // map sheet feathers off toward the empty lower-right quadrant so type stays clean
      float falloff=smoothstep(1.30,.18,length(uv-vec2(.86,.02)));
      // gentle left-margin fade so headline column keeps clear paper
      falloff*=smoothstep(0.04,0.34,uv.x)*0.55+0.45;
      // draw-on as the page settles
      float draw=smoothstep(0.0,0.8,prog);
      // legible target: clearer sienna linework, still calm on paper
      float a=strokes*falloff*0.84*draw;
      gl_FragColor=vec4(lineCol,a);
    }`;
    // contour shader needs derivatives
    gl.getExtension('OES_standard_derivatives');
    function sh(ty,s){const o=gl.createShader(ty);gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram();
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));
    // prepend derivative extension to fragment source
    gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,'#extension GL_OES_standard_derivatives : enable\n'+fs));
    gl.linkProgram(pr);gl.useProgram(pr);
    if(!gl.getProgramParameter(pr,gl.LINK_STATUS)){
      cv.style.background='radial-gradient(120% 90% at 80% 0%,rgba(180,69,31,.10),transparent 55%)';return;
    }
    gl.enable(gl.BLEND);gl.blendFunc(gl.SRC_ALPHA,gl.ONE_MINUS_SRC_ALPHA);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t'),
          uprog=gl.getUniformLocation(pr,'prog'),uscr=gl.getUniformLocation(pr,'scr'),
          uptr=gl.getUniformLocation(pr,'ptr');
    // pointer parallax target (smoothed each frame)
    let ptx=0,pty=0,ptxT=0,ptyT=0;
    addEventListener('pointermove',e=>{
      ptxT=(e.clientX/(window.innerWidth||1))*2-1;
      ptyT=(e.clientY/(window.innerHeight||1))*2-1;
    },{passive:true});
    function size(){
      const host=cv.parentElement;
      const d=Math.min(window.devicePixelRatio||1,1.6);
      const w=host.clientWidth, hh=host.clientHeight;
      cv.width=w*d;cv.height=hh*d;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);
    }
    size();addEventListener('resize',size);
    if(reduce){gl.uniform1f(ut,8.0);gl.uniform1f(uprog,1.0);gl.uniform1f(uscr,0.0);gl.uniform2f(uptr,0,0);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    const start=performance.now();
    let prog=0;
    (function loop(now){
      const tt=(now-start)/1000;
      prog+=(1-prog)*0.018;                 // draw-on the linework
      const sc=window.scrollY||0;
      const scr=Math.min(sc/(window.innerHeight||1),1.0);  // hero-bounded parallax factor
      ptx+=(ptxT-ptx)*0.08;pty+=(ptyT-pty)*0.08;            // smoothed pointer parallax
      gl.uniform1f(ut,tt);gl.uniform1f(uprog,prog);gl.uniform1f(uscr,scr);gl.uniform2f(uptr,ptx,pty);
      gl.drawArrays(gl.TRIANGLES,0,3);requestAnimationFrame(loop);
    })(start);
  })();

  // ---- nav solidify on scroll ----
  const nav=document.getElementById('nav');
  const onScroll=()=>{ if(window.scrollY>40) nav.classList.add('solid'); else nav.classList.remove('solid'); };
  onScroll();addEventListener('scroll',onScroll,{passive:true});

  // ---- smooth scroll + reveals ----
  if(!reduce){
    const lenis=new Lenis({lerp:.1,smoothWheel:true});
    function raf(t){lenis.raf(t);requestAnimationFrame(raf);}requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll',ScrollTrigger.update);

    // hero serif line-reveal (clip-mask)
    gsap.set('.hero h1 .ln>span',{yPercent:118});
    gsap.set('.hero .topline,.hero .sub,.hero .cta,.hero .metric',{opacity:0,y:18});
    gsap.set('.hero .toprule',{scaleX:0});
    const tl=gsap.timeline({delay:.12});
    tl.to('.hero h1 .ln>span',{yPercent:0,duration:1.15,ease:'expo.out',stagger:.12})
      .to('.hero .topline',{opacity:1,y:0,duration:.7},.2)
      .to('.hero .toprule',{scaleX:1,duration:1,ease:'expo.out'},.3)
      .to('.hero .sub',{opacity:1,y:0,duration:.85},.55)
      .to('.hero .cta',{opacity:1,y:0,duration:.85},.68)
      .to('.hero .metric',{opacity:1,y:0,duration:.8,stagger:.1},.62);

    // generic reveals
    gsap.utils.toArray('.reveal').forEach(el=>{
      gsap.to(el,{opacity:1,y:0,duration:1,ease:'expo.out',scrollTrigger:{trigger:el,start:'top 90%'}});
    });

    // animated hairline rules draw-in (drives ::after scaleX via custom prop)
    gsap.utils.toArray('.rule').forEach(el=>{
      const scaler={v:0};
      ScrollTrigger.create({trigger:el,start:'top 92%',once:true,onEnter(){
        gsap.to(scaler,{v:1,duration:1.2,ease:'expo.out',onUpdate(){
          el.style.setProperty('--rscale',scaler.v);
        }});
      }});
    });

    // magnetic primary button
    const mag=document.querySelector('.btn.primary');
    if(mag){
      const strength=18;
      mag.addEventListener('mousemove',e=>{
        const b=mag.getBoundingClientRect();
        const x=(e.clientX-b.left-b.width/2)/b.width*strength;
        const y=(e.clientY-b.top-b.height/2)/b.height*strength;
        gsap.to(mag,{x,y,duration:.4,ease:'power3.out'});
      });
      mag.addEventListener('mouseleave',()=>gsap.to(mag,{x:0,y:0,duration:.5,ease:'elastic.out(1,.4)'}));
    }
  } else {
    // reduced-motion: ensure hairline rules are drawn
    document.querySelectorAll('.rule').forEach(el=>el.style.setProperty('--rscale',1));
  }
</script>
</body>
