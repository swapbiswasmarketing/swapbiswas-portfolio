      ))}
    </div>
  </section>

  <section id="recognition">
    <div class="shead"><h2>Recognition &amp; <span class="oil-txt">brands</span></h2><div class="eyebrow">Selected honors</div></div>
    <div class="recog">
      <div class="recol reveal">
        <div class="clabel">Honors &amp; awards</div>
        <div class="awards">
          <div class="award"><b>Value of Agility Award</b> <span>LambdaTest &middot; 2024</span></div>
          <div class="award"><b>Wall of Fame</b> <span>LambdaTest</span></div>
          <div class="award"><b><span class="num">#1</span> Product of the Day</b> <span>Product Hunt</span></div>
        </div>
      </div>
      <div class="recol reveal">
        <div class="clabel">Trusted by teams at</div>
        <div class="brands">
          {brands.map(b => <span>{b}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="about">
    <div class="shead"><h2><span class="oil-txt">About</span></h2><div class="eyebrow">The operator behind the work</div></div>
    <div class="abody">
      <div class="rail reveal">
        <div class="k lead">About</div>
        <div class="k">Based in</div>
        <div class="v">Mumbai, India</div>
        <div class="div"></div>
        <div class="sig">Swapnil B.</div>
      </div>
      <div class="plate reveal">
        <p>Seven years in marketing, four in B2B SaaS. A postgrad in growth strategy at <em>IIM Visakhapatnam</em>. I treat my own career like a product - positioned, measured and shipped.</p>
      </div>
      <figure class="portrait reveal">
        <div class="pframe">
          <span class="refl" aria-hidden="true"></span>
          <img src="/assets/portrait-cut.webp" alt="Swapnil Biswas, product marketer" width="1023" height="1536" loading="lazy" decoding="async" />
          <span class="gloss" aria-hidden="true"></span>
          <figcaption class="cap"><span class="nm">Swapnil Biswas</span><span class="rl">Mumbai, IN</span></figcaption>
        </div>
      </figure>
    </div>
  </section>

  <section id="contact" class="contact">
    <div class="eyebrow reveal" style="margin-bottom:2rem">Let's build something that compounds</div>
    <div class="big reveal"><a href="mailto:swapbiswas.marketing@gmail.com" class="chrome-txt">Say hello &#8599;</a></div>
    <div class="em reveal">swapbiswas.marketing@gmail.com &nbsp;&middot;&nbsp; <a href="https://www.linkedin.com/in/swapbiswas/">LinkedIn</a></div>
  </section>
</div>

<footer>
  <span>&copy; 2026 Swapnil Biswas</span>
  <span>Concept 15 - Chrome &middot; <a href="/redesign/">View all concepts</a></span>
</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  // ---- raw-WebGL oil-slick backdrop ----
  // On small screens, fall back to the animated CSS oil-slick (mobile WebGL unreliable).
  (function(){
    const cv = document.getElementById('bg');
    const css = document.getElementById('cssOil');
    if(isMobile){ if(cv) cv.style.display='none'; if(css) css.style.display='block'; return; }
    const gl = cv.getContext('webgl', { antialias:true, alpha:true });
    if(!gl){ if(css) css.style.display='block'; return; }
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs = `precision highp float;uniform vec2 r;uniform float t;
      float h(vec2 x){return fract(sin(dot(x,vec2(127.1,311.7)))*43758.5453);}
      float n(vec2 x){vec2 i=floor(x),f=fract(x);float a=h(i),b=h(i+vec2(1,0)),c=h(i+vec2(0,1)),d=h(i+vec2(1,1));vec2 u=f*f*(3.-2.*f);return mix(a,b,u.x)+(c-a)*u.y*(1.-u.x)+(d-b)*u.x*u.y;}
      float fbm(vec2 x){float v=0.,a=.5;for(int i=0;i<6;i++){v+=a*n(x);x*=2.02;a*=.5;}return v;}
      void main(){
        vec2 uv=gl_FragCoord.xy/r.xy;vec2 p=uv;p.x*=r.x/r.y;
        // slow flowing field
        float f=fbm(p*2.4+vec2(t*.025,t*.04));
        float g=fbm(p*1.6-vec2(t*.03,-t*.02)+f*1.4);
        // iridescent oil-slick palette (violet/cyan/green/magenta sheen)
        vec3 violet=vec3(.69,.55,1.0);
        vec3 cyan=vec3(.40,.91,.98);
        vec3 green=vec3(.49,.94,.77);
        vec3 magenta=vec3(.94,.65,.91);
        vec3 col=mix(violet,cyan,smoothstep(.2,.8,f));
        col=mix(col,green,smoothstep(.45,.95,g)*.6);
        col=mix(col,magenta,smoothstep(.55,1.0,f*g)*.4);
        // keep it dark + reflective: low overall luminance, brighter where the slick swirls
        float swirl=pow(smoothstep(.25,.85,g),1.6);
        col*=swirl*.34;
        // bias glow to upper-right where the chrome blob mirrors the scene
        float halo=smoothstep(1.1,.0,length((uv-vec2(.72,.30))*vec2(1.0,1.3)));
        col+=mix(violet,cyan,.5)*halo*.10;
        float vig=smoothstep(1.35,.2,length(uv-vec2(.5,.42)));
        col*=vig;
        gl_FragColor=vec4(col,1.0);
      }`;
    function sh(ty,s){const o=gl.createShader(ty);gl.shaderSource(o,s);gl.compileShader(o);return o;}
    const pr=gl.createProgram();gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t');
    function size(){const d=Math.min(window.devicePixelRatio||1,1.6);cv.width=innerWidth*d;cv.height=innerHeight*d;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);}
    size();addEventListener('resize',size);
    if(reduce){gl.uniform1f(ut,4.0);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    const start=performance.now();
    (function loop(now){gl.uniform1f(ut,(now-start)/1000);gl.drawArrays(gl.TRIANGLES,0,3);requestAnimationFrame(loop);})(start);
  })();

  // ---- Three.js liquid-metal chrome blob ----
  // A single reflective icosahedron with metalness:1, low roughness, mirroring a colourful
  // oil-slick environment built from a CanvasTexture -> PMREMGenerator. Slow auto-rotate +
  // mouse-reactive vertex displacement so the metal liquifies. DPR capped, gradient fallback.
  (async function(){
    const cv = document.getElementById('chrome');
    const fb = document.getElementById('chromeFallback');
    // mobile: skip WebGL chrome, show the CSS chrome fallback orb
    if(isMobile){ if(cv) cv.style.display='none'; if(fb) fb.style.display='block'; return; }
    let THREE;
    try { THREE = await import('https://esm.sh/three@0.160.0'); }
    catch(e){ if(cv) cv.style.display='none'; if(fb) fb.style.display='block'; return; }
    const gl = cv.getContext('webgl2') || cv.getContext('webgl');
    if(!gl){ cv.style.display='none'; if(fb) fb.style.display='block'; return; }

    const renderer = new THREE.WebGLRenderer({ canvas:cv, antialias:true, alpha:true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio||1,1.6));
    renderer.setSize(innerWidth, innerHeight);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.15;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, innerWidth/innerHeight, 0.1, 100);
    camera.position.set(0, 0, 6.4);

    // ---- iridescent oil-slick equirectangular environment (NOT neutral studio) ----
    const envCv = document.createElement('canvas');
    envCv.width = 1024; envCv.height = 512;
    const ec = envCv.getContext('2d');
    // base vertical dark gradient
    let bg = ec.createLinearGradient(0,0,0,512);
    bg.addColorStop(0,'#161427'); bg.addColorStop(.5,'#0c0c16'); bg.addColorStop(1,'#05050a');
    ec.fillStyle = bg; ec.fillRect(0,0,1024,512);
    // colourful oil-slick blobs the chrome will mirror
    const blobs = [
      ['#b08cff', 240, 150, 320],
      ['#67e8f9', 700, 180, 300],
      ['#7df0c4', 500, 360, 260],
      ['#f0a6e8', 880, 340, 240],
      ['#8b6cff', 120, 380, 220],
      ['#5fd6ff', 420, 90,  200],
      ['#ff7a59', 980, 120, 150],
    ];
    blobs.forEach(([c,x,y,rad])=>{
      const g = ec.createRadialGradient(x,y,0,x,y,rad);
      g.addColorStop(0, c); g.addColorStop(1, 'rgba(0,0,0,0)');
      ec.globalCompositeOperation = 'lighter';
      ec.fillStyle = g; ec.beginPath(); ec.arc(x,y,rad,0,Math.PI*2); ec.fill();
    });
    // a bright top band = key highlight so the metal gets a clean specular streak
    ec.globalCompositeOperation = 'lighter';
    let hl = ec.createLinearGradient(0,0,0,120);
    hl.addColorStop(0,'rgba(255,255,255,.6)'); hl.addColorStop(1,'rgba(255,255,255,0)');
    ec.fillStyle = hl; ec.fillRect(0,0,1024,120);
    ec.globalCompositeOperation = 'source-over';

    const envTex = new THREE.CanvasTexture(envCv);
    envTex.mapping = THREE.EquirectangularReflectionMapping;
    envTex.colorSpace = THREE.SRGBColorSpace;
    const pmrem = new THREE.PMREMGenerator(renderer);
    const envRT = pmrem.fromEquirectangular(envTex);
    scene.environment = envRT.texture;

    // a couple of lights to give the metal form beyond pure reflection
    const key = new THREE.DirectionalLight(0xffffff, 1.2); key.position.set(3,4,5); scene.add(key);
    const rim = new THREE.DirectionalLight(0xb08cff, 1.0); rim.position.set(-4,-2,-3); scene.add(rim);
    scene.add(new THREE.AmbientLight(0x404060, 0.6));

    // ---- the chrome blob: high-detail icosahedron, displaced for "liquid" surface ----
    const geo = new THREE.IcosahedronGeometry(1.85, 24);
    const basePos = geo.attributes.position.array.slice();
    const nVerts = geo.attributes.position.count;
    const mat = new THREE.MeshStandardMaterial({
      color: 0xeef1f8, metalness: 1.0, roughness: 0.08, envMapIntensity: 1.35,
    });
    const blob = new THREE.Mesh(geo, mat);
    scene.add(blob);

    // simple 3D value noise for vertex displacement
    function hash(x,y,z){const s=Math.sin(x*127.1+y*311.7+z*74.7)*43758.5453;return s-Math.floor(s);}
    function vnoise(x,y,z){
      const xi=Math.floor(x),yi=Math.floor(y),zi=Math.floor(z);
      const xf=x-xi,yf=y-yi,zf=z-zi;
      const u=xf*xf*(3-2*xf),v=yf*yf*(3-2*yf),w=zf*zf*(3-2*zf);
      function l(a,b,t){return a+(b-a)*t;}
      const c000=hash(xi,yi,zi),c100=hash(xi+1,yi,zi),c010=hash(xi,yi+1,zi),c110=hash(xi+1,yi+1,zi);
      const c001=hash(xi,yi,zi+1),c101=hash(xi+1,yi,zi+1),c011=hash(xi,yi+1,zi+1),c111=hash(xi+1,yi+1,zi+1);
      return l(l(l(c000,c100,u),l(c010,c110,u),v),l(l(c001,c101,u),l(c011,c111,u),v),w);
    }

    const pos = geo.attributes.position;
    let mx=0,my=0,tmx=0,tmy=0;
    addEventListener('mousemove',e=>{ tmx=(e.clientX/innerWidth)*2-1; tmy=(e.clientY/innerHeight)*2-1; });

    function displace(time){
      const amp = 0.30 + (Math.abs(mx)+Math.abs(my))*0.22; // mouse 'liquifies' the metal more
      const freq = 1.15;
      for(let i=0;i<nVerts;i++){
        const ix=i*3;
        const bx=basePos[ix], by=basePos[ix+1], bz=basePos[ix+2];
        // direction = normalized base vertex (sphere normal)
        const len=Math.sqrt(bx*bx+by*by+bz*bz)||1;
        const nx=bx/len, ny=by/len, nz=bz/len;
        const nz1 = vnoise(bx*freq + time*0.5, by*freq + mx*1.5, bz*freq + time*0.35);
        const nz2 = vnoise(bx*2.3 - time*0.3, by*2.3 + my*1.5, bz*2.3 + time*0.4)*0.5;
        const d = (nz1 + nz2 - 0.75) * amp;
        pos.array[ix]   = bx + nx*d;
        pos.array[ix+1] = by + ny*d;
        pos.array[ix+2] = bz + nz*d;
      }
      pos.needsUpdate = true;
      geo.computeVertexNormals();
    }

    function resize(){
      camera.aspect = innerWidth/innerHeight; camera.updateProjectionMatrix();
      renderer.setSize(innerWidth, innerHeight);
    }
    addEventListener('resize', resize);

    let rafId;
    if(reduce){
      displace(0.6);
      blob.rotation.y = 0.5;
      renderer.render(scene, camera);
    } else {
      const t0 = performance.now();
      (function animate(now){
        const t = (now - t0)/1000;
        mx += (tmx-mx)*0.05; my += (tmy-my)*0.05;
        displace(t);
        blob.rotation.y = t*0.18 + mx*0.4;
        blob.rotation.x = Math.sin(t*0.12)*0.15 - my*0.3;
        renderer.render(scene, camera);
        rafId = requestAnimationFrame(animate);
      })(t0);
    }

    // dispose on unload to avoid leaks
    addEventListener('beforeunload', ()=>{
      if(rafId) cancelAnimationFrame(rafId);
      geo.dispose(); mat.dispose(); envTex.dispose(); envRT.dispose(); pmrem.dispose(); renderer.dispose();
    });
  })();

  // ---- smooth scroll + reveals + microinteractions ----
  if(!reduce){
    const lenis = new Lenis({ lerp:.1, smoothWheel:true });
    function raf(t){ lenis.raf(t); requestAnimationFrame(raf); } requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll', ScrollTrigger.update);

    // hero entrance
    gsap.set('.hero h1 .ln>span',{ yPercent:115 });
    gsap.set('.hero .credential,.hero .sub,.hero .cta,.hero .heroanchor',{ opacity:0, y:20 });
    const tl = gsap.timeline({ delay:.15 });
    tl.to('.hero h1 .ln>span',{ yPercent:0, duration:1.1, ease:'expo.out', stagger:.09 })
      .to('.hero .credential',{ opacity:1, y:0, duration:.7 }, .2)
      .to('.hero .sub',{ opacity:1, y:0, duration:.8 }, .5)
      .to('.hero .cta',{ opacity:1, y:0, duration:.8 }, .65)
      .to('.hero .heroanchor',{ opacity:1, y:0, duration:.7 }, .8);

    // batched scroll reveals
    ScrollTrigger.batch('.reveal',{
      start:'top 88%',
      onEnter:batch=>gsap.to(batch,{ opacity:1, y:0, duration:1, ease:'expo.out', stagger:.09, overwrite:true }),
    });
    ScrollTrigger.refresh();

    // Fade the bright fixed canvases (reflective chrome blob + oil-slick) out as the
    // user leaves the hero, so their bright flares can never wash out the light text in
    // the scrolled-over sections (stats / pillars / recognition / about / contact).
    const chromeCv = document.getElementById('chrome');
    const bgCv = document.getElementById('bg');
    gsap.to([chromeCv, bgCv].filter(Boolean),{
      opacity:0, ease:'none',
      scrollTrigger:{ trigger:'#manifesto', start:'top 70%', end:'top top', scrub:.4 }
    });

    // scroll progress bar
    const prog = document.getElementById('progress');
    gsap.to(prog,{ scaleX:1, ease:'none', scrollTrigger:{ trigger:document.body, start:'top top', end:'bottom bottom', scrub:.3 }});

    // trailing chrome cursor
    const cur = document.getElementById('cur');
    let cx=-100,cy=-100,tx=cx,ty=cy;
    addEventListener('mousemove',e=>{ tx=e.clientX; ty=e.clientY; });
    (function cloop(){ cx+=(tx-cx)*.18; cy+=(ty-cy)*.18; cur.style.transform=`translate(${cx}px,${cy}px) translate(-50%,-50%)`; requestAnimationFrame(cloop); })();
    document.querySelectorAll('a,button').forEach(el=>{
      el.addEventListener('mouseenter',()=>cur.classList.add('big'));
      el.addEventListener('mouseleave',()=>cur.classList.remove('big'));
    });

    // magnetic primary CTA
    document.querySelectorAll('.btn.primary').forEach(btn=>{
      btn.addEventListener('mousemove',e=>{ const r=btn.getBoundingClientRect();
        gsap.to(btn,{ x:(e.clientX-r.left-r.width/2)*.35, y:(e.clientY-r.top-r.height/2)*.45, duration:.4, ease:'power3.out' }); });
      btn.addEventListener('mouseleave',()=>gsap.to(btn,{ x:0, y:0, duration:.6, ease:'elastic.out(1,.4)' }));
    });

    // signature: chrome sheen tracks cursor across each work card
    document.querySelectorAll('.work .row').forEach(card=>{
      card.addEventListener('mousemove',e=>{ const r=card.getBoundingClientRect();
        card.style.setProperty('--mx',`${((e.clientX-r.left)/r.width)*100}%`);
        card.style.setProperty('--my',`${((e.clientY-r.top)/r.height)*100}%`);
      });
    });
  }
</script>
</body>
</html>
