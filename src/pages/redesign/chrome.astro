  <section id="stats">
    <div class="stats">
      {stats.map(s => (
        <div class="stat reveal"><div class="n">{s.n}</div><div class="l">{s.l}</div></div>
      ))}
    </div>
  </section>

  <section id="services">
    <div class="shead"><h2>What I <span class="oil-txt">do</span></h2><div class="eyebrow">Four disciplines, one operator</div></div>
    <div class="pillars">
      {pillars.map(p => (
        <div class="pillar reveal"><div class="pi">{p.i}</div><div><h3>{p.t}</h3><p>{p.d}</p></div></div>
      ))}
    </div>
  </section>

  <section id="work">
    <div class="shead"><h2>Selected <span class="oil-txt">work</span></h2><div class="eyebrow">2019 - 2026</div></div>
    <div class="work">
      {work.map((w, idx) => (
        <a class={`row reveal${idx === 0 ? ' feat' : ''}`} href="#">
          <span class={`art ${w.sw}`} aria-hidden="true"></span>
          <span class="sheen" aria-hidden="true"></span>
          {w.sw === 'shield' && (
            <span class="hint up" aria-hidden="true"><svg viewBox="0 0 24 26" fill="none">
              <path d="M12 2 L21 6 V13 C21 19 17 23 12 25 C7 23 3 19 3 13 V6 Z" stroke="var(--hint)" stroke-width="2" stroke-linejoin="round"/>
              <path d="M8 13 L11 16 L16 9" stroke="var(--cyan)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" opacity=".9"/>
            </svg></span>
          )}
          {w.sw === 'pulse' && (
            <span class="hint up" aria-hidden="true"><svg viewBox="0 0 26 24" fill="none">
              <path d="M1 12 H7 L10 4 L15 20 L18 12 H25" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity=".9"/>
            </svg></span>
          )}
          <span class={`swatch ${w.sw}`} aria-hidden="true"></span>
          <span class="copy">
            <span class="widx">{w.i}</span>
            <span class="wt">{w.r}<span class="arrow">&#8599;</span></span>
            <span class="wm"><span class="nm">{w.t}</span><span class="role">{w.role}{w.y ? ` · ${w.y}` : ''}</span></span>
            {idx === 0 && <span class="wnote">{w.note}</span>}
