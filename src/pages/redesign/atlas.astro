<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  // ---- palette pulled from CSS tokens ----
  const RED = '#e5341c', SLATE = '#3b5bdb', INK = '#111111', FAINT = '#9a9a94';

  // ---- WebGL plotter-grid background ----
  // A faint engineering plot-paper plane that drifts; on mobile use the CSS fallback.
  (function(){
    const cv = document.getElementById('plot');
    const css = document.getElementById('cssGrid');
    if(isMobile){
      if(cv) cv.style.display = 'none';
      if(css) css.style.display = 'block';
      return;
    }
    const gl = cv.getContext('webgl', { antialias:true, alpha:true });
    if(!gl){ if(css) css.style.display = 'block'; return; }
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    const fs = `precision highp float;uniform vec2 r;uniform float t;
      // faint moving plot grid on warm paper, with a soft slate/red plotted line drift
      float gridline(vec2 uv,float div){
        vec2 g=abs(fract(uv*div-.5)-.5)/fwidth(uv*div);
        float l=min(g.x,g.y);
        return 1.-min(l,1.);
      }
      void main(){
        vec2 uv=gl_FragCoord.xy/r.xy;
        vec2 p=uv; p.x*=r.x/r.y;
        p.y+=t*0.012;            // gentle vertical drift like paper feeding through a plotter
        vec3 paper=mix(vec3(.980,.976,.964),vec3(.941,.937,.913),uv.y);
        float fine=gridline(p,46.0)*0.05;
        float major=gridline(p,9.2)*0.07;
        vec3 col=paper - fine - major;
        // a faint plotted curve - sinusoid that breathes, warm ink, very subtle
        float curve=p.y - (0.5 + 0.10*sin(p.x*6.0 + t*0.25) + 0.05*sin(p.x*13.0 - t*0.15));
        float line=smoothstep(0.012,0.0,abs(curve));
        col=mix(col,vec3(.067,.067,.067),line*0.09);
        // a second red plotted curve, offset - the brand accent line
        float curve2=p.y - (0.62 + 0.07*sin(p.x*4.0 - t*0.2));
        float line2=smoothstep(0.011,0.0,abs(curve2));
        col=mix(col,vec3(.898,.204,.110),line2*0.10);
        // vignette to keep edges calm
        float vig=smoothstep(1.25,.2,length(uv-vec2(.5,.45)));
        col=mix(paper*0.985,col,vig*0.9+0.1);
        gl_FragColor=vec4(col,1.0);
      }`;
    // enable derivatives for crisp grid lines
    gl.getExtension('OES_standard_derivatives');
    const fsHeader = '#extension GL_OES_standard_derivatives : enable\n';
    function sh(type,src){const o=gl.createShader(type);gl.shaderSource(o,src);gl.compileShader(o);return o;}
    const pr=gl.createProgram();
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));
    gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fsHeader+fs));
    gl.linkProgram(pr);gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t');
    function size(){const d=Math.min(window.devicePixelRatio||1,1.6);cv.width=innerWidth*d;cv.height=innerHeight*d;gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);}
    size();addEventListener('resize',size);
    if(reduce){gl.uniform1f(ut,2.0);gl.drawArrays(gl.TRIANGLES,0,3);return;}
    const start=performance.now();
    (function loop(now){gl.uniform1f(ut,(now-start)/1000);gl.drawArrays(gl.TRIANGLES,0,3);requestAnimationFrame(loop);})(start);
  })();

  // ---- canvas chart helpers ----
  // Each chart accepts a 0..1 progress and redraws. ScrollTrigger scrubs progress.
  function setupCanvas(canvas, cssH){
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    const w = rect.width || canvas.clientWidth || 300;
    const h = cssH || rect.height || 200;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    const ctx = canvas.getContext('2d');
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    return { ctx, w, h };
  }

  // shared chart frame: gridlines + baseline + Y ticks + peak callout.
  // Returns plot rect {x0,x1,y0,y1}. Reserves left gutter for Y ticks, bottom for baseline.
  function frame(c, yticks){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const gutterL = 38, padR = 14, padT = 18, baseB = 8;
    const x0 = gutterL, x1 = w - padR, y0 = h - baseB, y1 = padT;
    const rows = yticks.length;
    ctx.textBaseline = 'middle'; ctx.textAlign = 'right';
    ctx.font = (w < 520 ? 12 : 11) + 'px "Space Mono", monospace';
    for(let k=0;k<rows;k++){
      const yy = y1 + (y0 - y1) * k / (rows - 1);
      ctx.strokeStyle = k === rows-1 ? 'rgba(17,17,17,.32)' : 'rgba(17,17,17,.09)';
      ctx.lineWidth = k === rows-1 ? 1.4 : 1;
      ctx.beginPath(); ctx.moveTo(x0, yy + .5); ctx.lineTo(x1, yy + .5); ctx.stroke();
      if(yticks[k]){ ctx.fillStyle = '#6b6b66'; ctx.fillText(yticks[k], x0 - 8, yy); }
    }
    return { x0, x1, y0, y1 };
  }

  function peakLabel(ctx, x, y, text, align){
    ctx.font = '700 13px "Space Mono", monospace';
    ctx.textAlign = align || 'right'; ctx.textBaseline = 'alphabetic';
    const tw = ctx.measureText(text).width;
    const bx = align === 'left' ? x : x - tw;
    ctx.fillStyle = 'rgba(250,249,246,.92)';
    ctx.fillRect(bx - 5, y - 14, tw + 10, 19);
    ctx.fillStyle = RED; ctx.fillText(text, x, y);
  }

  // area chart - cumulative leads (657K). Fills ~75% of plot height, peak callout at line end.
  function drawArea(c, prog, peak){
    const { ctx } = c;
    const { x0, x1, y0, y1 } = frame(c, ['700K','525K','350K','175K','0']);
    const pts = [0.05,0.11,0.10,0.22,0.31,0.36,0.50,0.58,0.71,0.80,0.90,0.94];
    const n = pts.length, maxI = Math.max(1, prog*(n-1));
    const px=i=>x0+(i/(n-1))*(x1-x0), py=v=>y0-v*(y0-y1);
    ctx.beginPath(); ctx.moveTo(x0,y0);
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); ctx.lineTo(px(ii),py(pts[ii])); }
    const lx=px(Math.min(maxI,n-1)), lv=pts[Math.min(Math.round(maxI),n-1)];
    ctx.lineTo(lx,y0); ctx.closePath();
    const g=ctx.createLinearGradient(0,y1,0,y0);
    g.addColorStop(0,'rgba(229,52,28,.34)'); g.addColorStop(1,'rgba(229,52,28,.03)');
    ctx.fillStyle=g; ctx.fill();
    ctx.beginPath();
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); i===0?ctx.moveTo(px(ii),py(pts[ii])):ctx.lineTo(px(ii),py(pts[ii])); }
    ctx.strokeStyle=RED; ctx.lineWidth=2.6; ctx.lineJoin='round'; ctx.lineCap='round'; ctx.stroke();
    ctx.beginPath(); ctx.arc(lx,py(lv),3.6,0,Math.PI*2); ctx.fillStyle=RED; ctx.fill();
    if(prog>0.9 && peak) peakLabel(ctx, lx, py(lv)-10, peak, 'right');
  }

  // line chart - traffic (18.2M).
  function drawLine(c, prog, peak){
    const { ctx } = c;
    const { x0, x1, y0, y1 } = frame(c, ['20M','15M','10M','5M','0']);
    const pts=[0.10,0.16,0.14,0.27,0.25,0.40,0.47,0.43,0.60,0.72,0.85,0.91];
    const n=pts.length, maxI=Math.max(1, prog*(n-1));
    const px=i=>x0+(i/(n-1))*(x1-x0), py=v=>y0-v*(y0-y1);
    // subtle fill under the line in slate
    ctx.beginPath(); ctx.moveTo(x0,y0);
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); ctx.lineTo(px(ii),py(pts[ii])); }
    ctx.lineTo(px(Math.min(maxI,n-1)),y0); ctx.closePath();
    const g=ctx.createLinearGradient(0,y1,0,y0);
    g.addColorStop(0,'rgba(59,91,219,.20)'); g.addColorStop(1,'rgba(59,91,219,.02)');
    ctx.fillStyle=g; ctx.fill();
    ctx.beginPath();
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); i===0?ctx.moveTo(px(ii),py(pts[ii])):ctx.lineTo(px(ii),py(pts[ii])); }
    ctx.strokeStyle=SLATE; ctx.lineWidth=2.8; ctx.lineJoin='round'; ctx.lineCap='round'; ctx.stroke();
    const lx=px(Math.min(maxI,n-1)), lv=pts[Math.min(Math.round(maxI),n-1)];
    ctx.beginPath(); ctx.arc(lx,py(lv),3.6,0,Math.PI*2); ctx.fillStyle=SLATE; ctx.fill();
    ctx.beginPath(); ctx.arc(lx,py(lv),6.5,0,Math.PI*2); ctx.strokeStyle='rgba(59,91,219,.35)'; ctx.lineWidth=1.4; ctx.stroke();
    if(prog>0.9 && peak){ ctx.fillStyle=RED; peakLabel(ctx, lx, py(lv)-12, peak, 'right'); }
  }

  // bar chart - 10x conversion. Baseline bar (1x) vs optimized (10x), tall.
  function drawBar(c, prog, peak){
    const { ctx } = c;
    const { x0, x1, y0, y1 } = frame(c, ['10x','','5x','','1x']);
    const vals=[0.10,0.94];
    const slot=(x1-x0)/vals.length, bw=Math.min(slot*0.46, 78);
    vals.forEach((v,i)=>{
      const cx=x0+slot*(i+0.5);
      const bh=v*(y0-y1)*prog;
      ctx.fillStyle = i===vals.length-1 ? RED : 'rgba(17,17,17,.26)';
      ctx.fillRect(cx-bw/2, y0-bh, bw, bh);
      if(i===vals.length-1 && prog>0.9 && peak){
        ctx.fillStyle=RED; ctx.font='700 14px "Space Mono", monospace';
        ctx.textAlign='center'; ctx.textBaseline='alphabetic';
        ctx.fillText(peak, cx, y0-bh-8);
      }
    });
  }

  // arc/donut - 20+ agents composition.
  function drawArc(c, prog){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const cx=w/2, cy=h/2+2, R=Math.min(w,h)/2 - 14, r=R*0.60;
    ctx.beginPath(); ctx.arc(cx,cy,(R+r)/2,0,Math.PI*2);
    ctx.lineWidth=R-r; ctx.strokeStyle='rgba(17,17,17,.07)'; ctx.stroke();
    const segs=[{f:0.55,col:RED},{f:0.30,col:SLATE},{f:0.15,col:'rgba(17,17,17,.45)'}];
    let a=-Math.PI/2; const total=prog*Math.PI*2; let drawn=0;
    for(const s of segs){
      const span=s.f*Math.PI*2;
      const end=Math.min(span, Math.max(0,total-drawn));
      if(end>0){
        ctx.beginPath(); ctx.arc(cx,cy,(R+r)/2, a, a+end);
        ctx.lineWidth=R-r-4; ctx.lineCap='butt'; ctx.strokeStyle=s.col; ctx.stroke();
      }
      a+=span; drawn+=span;
    }
    ctx.fillStyle=INK; ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.font='800 '+Math.round(R*0.52)+'px "Archivo", sans-serif';
    ctx.fillText(Math.round(prog*20)+'+', cx, cy-2);
    ctx.fillStyle=FAINT; ctx.font='9px "Space Mono", monospace';
    ctx.fillText('SHIPPED', cx, cy+R*0.46);
  }

  const drawers = { area:drawArea, line:drawLine, bar:drawBar, arc:drawArc };

  // ---- work-tile motif drawers (compact, scroll-draw-on) ----
  function motifArea(c, data, prog){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const x0=2,x1=w-2,y0=h-12,y1=6, max=Math.max(...data),min=Math.min(...data),n=data.length;
    const px=i=>x0+(i/(n-1))*(x1-x0), py=v=>y0-((v-min)/(max-min||1))*(y0-y1);
    ctx.strokeStyle='rgba(17,17,17,.10)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x0,y0+.5); ctx.lineTo(x1,y0+.5); ctx.stroke();
    const maxI=Math.max(0,prog*(n-1));
    ctx.beginPath(); ctx.moveTo(x0,y0);
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); ctx.lineTo(px(ii),py(data[ii])); }
    ctx.lineTo(px(Math.min(maxI,n-1)),y0); ctx.closePath();
    const g=ctx.createLinearGradient(0,y1,0,y0);
    g.addColorStop(0,'rgba(229,52,28,.28)'); g.addColorStop(1,'rgba(229,52,28,.02)');
    ctx.fillStyle=g; ctx.fill();
    ctx.beginPath();
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); i===0?ctx.moveTo(px(ii),py(data[ii])):ctx.lineTo(px(ii),py(data[ii])); }
    ctx.strokeStyle=RED; ctx.lineWidth=2.2; ctx.lineJoin='round'; ctx.lineCap='round'; ctx.stroke();
    const lx=px(Math.min(maxI,n-1)), lv=data[Math.min(Math.round(maxI),n-1)];
    ctx.beginPath(); ctx.arc(lx,py(lv),3,0,Math.PI*2); ctx.fillStyle=RED; ctx.fill();
  }
  function motifBars(c, data, prog){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const x0=2,x1=w-2,y0=h-12,y1=6, max=Math.max(...data),n=data.length;
    ctx.strokeStyle='rgba(17,17,17,.10)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x0,y0+.5); ctx.lineTo(x1,y0+.5); ctx.stroke();
    const slot=(x1-x0)/n, bw=Math.min(slot*0.62, 16);
    data.forEach((v,i)=>{
      const cx=x0+slot*(i+0.5), bh=(v/max)*(y0-y1)*prog;
      ctx.fillStyle = i===n-1 ? RED : 'rgba(229,52,28,'+(0.30+0.5*i/n)+')';
      ctx.fillRect(cx-bw/2, y0-bh, bw, bh);
    });
  }
  function motifDonut(c, data, prog){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const cx=w/2, cy=h/2, R=Math.min(w,h)/2-6, r=R*0.58;
    ctx.beginPath(); ctx.arc(cx,cy,(R+r)/2,0,Math.PI*2);
    ctx.lineWidth=R-r; ctx.strokeStyle='rgba(17,17,17,.08)'; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,(R+r)/2,-Math.PI/2,-Math.PI/2+prog*Math.PI*2*0.92);
    ctx.lineWidth=R-r; ctx.lineCap='round'; ctx.strokeStyle=RED; ctx.stroke();
    ctx.fillStyle=RED; ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.font='800 '+Math.round(R*0.7)+'px "Archivo", sans-serif';
    ctx.fillText('1', cx, cy);
  }
  function motifGauge(c, data, prog){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const cx=w/2, cy=h-6, R=Math.min(w/2-4, h-12);
    ctx.lineWidth=9; ctx.lineCap='round';
    ctx.beginPath(); ctx.arc(cx,cy,R,Math.PI,Math.PI*2); ctx.strokeStyle='rgba(17,17,17,.08)'; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx,cy,R,Math.PI,Math.PI+prog*Math.PI*0.97); ctx.strokeStyle=RED; ctx.stroke();
    ctx.fillStyle=RED; ctx.textAlign='center'; ctx.textBaseline='alphabetic';
    ctx.font='800 '+Math.round(R*0.42)+'px "Archivo", sans-serif';
    ctx.fillText(Math.round(prog*100), cx, cy-6);
  }
  const motifs = { area:motifArea, bars:motifBars, donut:motifDonut, gauge:motifGauge };

  // ---- counter helper: animate a figure string like "657K+", "18.2M+", "10x", "20+" ----
  function animateFigure(el, raw, prog){
    const m = raw.match(/^([\d.]+)(.*)$/);
    if(!m){ el.textContent = raw; return; }
    const target = parseFloat(m[1]);
    const suffix = m[2];
    let val = target * prog;
    let out = (target % 1 === 0) ? Math.round(val).toString() : val.toFixed(1);
    el.textContent = out + suffix;
  }

  // ---- hero cover chart: clean area sparkline, no axis clutter ----
  function drawHero(c, prog){
    const { ctx, w, h } = c;
    ctx.clearRect(0,0,w,h);
    const x0=1,x1=w-1,y0=h-12,y1=6;
    const pts=[0.05,0.11,0.10,0.22,0.31,0.36,0.50,0.58,0.71,0.80,0.90,0.94];
    const n=pts.length, maxI=Math.max(1,prog*(n-1));
    const px=i=>x0+(i/(n-1))*(x1-x0), py=v=>y0-v*(y0-y1);
    ctx.strokeStyle='rgba(17,17,17,.14)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x0,y0+.5); ctx.lineTo(x1,y0+.5); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x0,y0);
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); ctx.lineTo(px(ii),py(pts[ii])); }
    ctx.lineTo(px(Math.min(maxI,n-1)),y0); ctx.closePath();
    const g=ctx.createLinearGradient(0,y1,0,y0);
    g.addColorStop(0,'rgba(229,52,28,.30)'); g.addColorStop(1,'rgba(229,52,28,.02)');
    ctx.fillStyle=g; ctx.fill();
    ctx.beginPath();
    for(let i=0;i<=maxI;i++){ const ii=Math.min(i,n-1); i===0?ctx.moveTo(px(ii),py(pts[ii])):ctx.lineTo(px(ii),py(pts[ii])); }
    ctx.strokeStyle=RED; ctx.lineWidth=2.4; ctx.lineJoin='round'; ctx.lineCap='round'; ctx.stroke();
    const lx=px(Math.min(maxI,n-1)), lv=pts[Math.min(Math.round(maxI),n-1)];
    ctx.beginPath(); ctx.arc(lx,py(lv),3.2,0,Math.PI*2); ctx.fillStyle=RED; ctx.fill();
  }
  (function(){
    const canvas = document.getElementById('heroChart');
    if(!canvas) return;
    let c = setupCanvas(canvas, 88);
    let p = reduce ? 1 : 0.7; // never start blank
    function step(){
      p = Math.min(1, p + 0.012);
      drawHero(c, p);
      const cnt = document.getElementById('coverCount');
      if(cnt) cnt.textContent = Math.round(657 * p).toString();
      if(p < 1) requestAnimationFrame(step);
    }
    if(reduce){ drawHero(c,1); const cnt=document.getElementById('coverCount'); if(cnt) cnt.textContent='657'; }
    else { drawHero(c,p); setTimeout(step, 300); }
    addEventListener('resize', ()=>{ c=setupCanvas(canvas,88); drawHero(c, reduce?1:p); });
  })();

  // ---- marquee ----
  if(!reduce){
    const marq = document.getElementById('marq');
    if(marq){
      gsap.to(marq, { xPercent:-50, duration:24, ease:'none', repeat:-1 });
    }
  }

  // ---- smooth scroll + reveals + chart draw-on ----
  if(!reduce){
    const lenis = new Lenis({ lerp:.1, smoothWheel:true });
    function raf(t){ lenis.raf(t); requestAnimationFrame(raf); } requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll', ScrollTrigger.update);

    // hero lines
    gsap.set('.hero h1 .ln>span', { yPercent:118 });
    gsap.set('.hero .sub,.hero .cta,.coverhead,.coverfig', { opacity:0, y:18 });
    const tl = gsap.timeline({ delay:.1 });
    tl.to('.coverhead', { opacity:1, y:0, duration:.7 }, 0)
      .to('.hero h1 .ln>span', { yPercent:0, duration:1.05, ease:'expo.out', stagger:.1 }, .1)
      .to('.hero .sub', { opacity:1, y:0, duration:.7 }, .55)
      .to('.hero .cta', { opacity:1, y:0, duration:.7 }, .68)
      .to('.coverfig', { opacity:1, y:0, duration:.8 }, .5);

    // reveals
    ScrollTrigger.batch('.reveal', {
      start:'top 90%',
      onEnter:batch=>gsap.to(batch, { opacity:1, y:0, duration:.95, ease:'expo.out', stagger:.08, overwrite:true }),
    });

    // --- the signature: scroll-triggered chart draw-on for each metric ---
    document.querySelectorAll('.metricCanvas').forEach(canvas=>{
      const kind = canvas.getAttribute('data-kind');
      const peak = canvas.getAttribute('data-peak') || '';
      const draw = drawers[kind] || drawArea;
      let c = setupCanvas(canvas);
      const card = canvas.closest('.metric');
      const figEl = card ? card.querySelector('.mnum') : null;
      const tickEl = card ? card.querySelector('.ticker') : null;
      const raw = figEl ? figEl.getAttribute('data-count') : '';
      const state = { p:0 };
      // Figure shows the REAL final value at rest (657K+, never a partial like 539K).
      // On first enter the chart draws on AND the figure counts up once, then both LOCK
      // at the final value (no scrub) so resting / scrolled-past always reads full.
      if(figEl) figEl.textContent = raw;
      if(tickEl) tickEl.textContent = raw;
      draw(c, 0, peak);
      let played = false;
      function playIn(){
        if(played) return; played = true;
        gsap.to(state, { p:1, duration:1.3, ease:'power2.out', onUpdate:()=>{
          draw(c, state.p, peak);
          if(figEl) animateFigure(figEl, raw, state.p);
          if(tickEl) animateFigure(tickEl, raw, state.p);
        }, onComplete:()=>{ draw(c,1,peak); if(figEl) figEl.textContent=raw; if(tickEl) tickEl.textContent=raw; } });
      }
      ScrollTrigger.create({ trigger: card, start: 'top 85%', onEnter: playIn, onEnterBack: playIn });
      // above-fold safety: if already in view on load, draw fully
      if(card.getBoundingClientRect().top < window.innerHeight * 0.92){ playIn(); }
      addEventListener('resize', ()=>{ c = setupCanvas(canvas); draw(c, state.p, peak); });
    });

    // --- work-tile motifs draw on as the tile reveals ---
    document.querySelectorAll('.wtile').forEach(tile=>{
      const canvas = tile.querySelector('.motifCanvas');
      const motif = canvas.getAttribute('data-motif');
      const draw = motifs[motif] || motifArea;
      const data = (tile.getAttribute('data-spark')||'').split(',').map(Number);
      let c = setupCanvas(canvas, 96);
      draw(c, data, 0);
      ScrollTrigger.create({
        trigger: tile, start:'top 90%', once:true,
        onEnter:()=>{ gsap.to({v:0},{v:1,duration:1.1,ease:'power2.out',onUpdate:function(){ draw(c, data, this.targets()[0].v); }}); },
      });
      addEventListener('resize', ()=>{ c = setupCanvas(canvas, 96); draw(c, data, 1); });
    });

    // scroll progress bar
    gsap.to('#progress', { scaleX:1, ease:'none', scrollTrigger:{ trigger:document.body, start:'top top', end:'bottom bottom', scrub:.3 } });

    ScrollTrigger.refresh();
  } else {
    // reduced motion: render every chart fully, set counters to final
    document.querySelectorAll('.metricCanvas').forEach(canvas=>{
      const kind = canvas.getAttribute('data-kind');
      const peak = canvas.getAttribute('data-peak') || '';
      const draw = drawers[kind] || drawArea;
      const c = setupCanvas(canvas); draw(c, 1, peak);
      const card = canvas.closest('.metric');
      if(card){
        const figEl = card.querySelector('.mnum'), tickEl = card.querySelector('.ticker');
        if(figEl) figEl.textContent = figEl.getAttribute('data-count');
        if(tickEl) tickEl.textContent = tickEl.getAttribute('data-count');
      }
    });
    document.querySelectorAll('.wtile').forEach(tile=>{
      const canvas = tile.querySelector('.motifCanvas');
      const motif = canvas.getAttribute('data-motif');
      const draw = motifs[motif] || motifArea;
      const data = (tile.getAttribute('data-spark')||'').split(',').map(Number);
      const c = setupCanvas(canvas, 96); draw(c, data, 1);
    });
  }
</script>
</body>
</html>
