  @media(max-width:700px){.recog{grid-template-columns:1fr;gap:2.4rem}}
  /* ---- about: methodology column ---- */
  .about .abody{display:grid;grid-template-columns:230px 1fr;gap:clamp(2rem,5vw,4rem);align-items:start}
  .about .rail{display:flex;flex-direction:column;gap:1.05rem;border-right:1px solid var(--rule);padding-right:1.6rem}
  .about .rail .item{display:flex;flex-direction:column;gap:.2rem}
  .about .rail .k{font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--faint)}
  .about .rail .v{font-family:var(--grotesk);font-weight:600;font-size:1rem;letter-spacing:-.01em;color:var(--ink)}
  .about p{font-family:var(--grotesk);font-weight:500;font-size:clamp(1.35rem,3vw,2.2rem);line-height:1.3;letter-spacing:-.025em;max-width:24ch}
  .about p em{font-style:normal;color:var(--red)}
  .about p+.meth{margin-top:1.4rem}
  .about .meth{font-family:var(--sans);font-size:.96rem;color:var(--ink2);line-height:1.66;max-width:48ch;font-weight:400}
  @media(max-width:700px){.about .abody{grid-template-columns:1fr;gap:1.6rem}
    .about .rail{flex-direction:row;flex-wrap:wrap;gap:1rem 1.8rem;border-right:0;padding-right:0;border-bottom:1px solid var(--rule);padding-bottom:1.4rem}}
  /* ---- contact ---- */
  .contact{padding-bottom:7rem;border-top:1.5px solid var(--ink);padding-top:clamp(3.5rem,8vh,6rem)}
  .contact .lead{font-family:var(--mono);font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;color:var(--red);margin-bottom:1.8rem;font-weight:700}
  .contact .big{font-family:var(--grotesk);font-weight:800;font-size:clamp(3.7rem,13vw,10.5rem);line-height:.9;letter-spacing:-.05em}
  .contact .big a{position:relative;display:inline-block}
  .contact .big a::after{content:"";position:absolute;left:0;bottom:.04em;width:100%;height:.09em;background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform .5s cubic-bezier(.2,.8,.2,1)}
  .contact .big a:hover::after{transform:scaleX(1)}
  .contact .em{margin-top:2.2rem;display:flex;flex-wrap:wrap;gap:.5rem 1.4rem;font-family:var(--mono);font-size:.78rem;color:var(--mut);letter-spacing:.02em}
  .contact .em a{color:var(--ink);border-bottom:1px solid var(--rule);padding-bottom:2px;transition:color .25s,border-color .25s}
  .contact .em a:hover{color:var(--red);border-color:var(--red)}
  /* ---- footer colophon ---- */
  footer{border-top:1.5px solid var(--ink);padding:2.4rem var(--m);position:relative;z-index:2}
  .colophon{max-width:var(--maxw);margin:0 auto;display:grid;grid-template-columns:repeat(12,1fr);gap:1rem;
    font-family:var(--mono);font-size:.7rem;color:var(--mut);letter-spacing:.02em}
  .colophon .c1{grid-column:1 / span 4}
  .colophon .c2{grid-column:5 / span 4}
