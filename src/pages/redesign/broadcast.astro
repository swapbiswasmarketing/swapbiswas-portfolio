---
// REDESIGN PROTOTYPE - "Broadcast" - a vintage CRT television you channel-surf.
// Original concept (NOT a reskin of halftone): own layout, palette, fonts, mechanic.
//  - The whole page is one CRT TV screen inside a soft bezel. Each SECTION is a CHANNEL.
//  - Changing channels (remote up/down, on-screen +/-, arrow keys, scroll, channel pad,
//    nav links) plays a SIGNAL STATIC burst + a brief horizontal-hold tracking ROLL,
//    then the new channel "tunes in" and the channel number flashes in the corner bug.
//  - Scanlines, screen curvature/vignette, RGB chromatic-aberration fringing on the title,
//    a live "CH 0x" bug, a station ident "SBTV", and a tracking / timecode strip.
//  - The static transition is the signature; content is ALWAYS crisp once tuned in and is
//    NEVER trapped behind the static (reduced-motion = instant switch, all channels reachable,
//    and the page also scrolls normally so every channel is a real anchored section).
// Palette: broadcast night - deep blue-black tube (#06080d) lit by warm CRT phosphor white
//  (#f4f6ff) with a broadcast-amber accent (#ffb44b) and a cyan signal tint (#5fe6ff).
// Fully self-contained: own <html>, own fonts, own tokens. No BaseLayout, no global.css.
const channels = [
  { n: '01', id: 'tune',    label: 'Title Card' },
  { n: '02', id: 'what',    label: 'What I Do' },
  { n: '03', id: 'work',    label: 'Program Guide' },
  { n: '04', id: 'honours', label: 'Recognition' },
  { n: '05', id: 'about',   label: 'Station ID' },
  { n: '06', id: 'contact', label: 'Sign Off' },
];
const pillars = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.' },
];
const buildStats = [
  { n: '20', plus: '+', l: 'AI agents & internal tools shipped' },
  { n: '15', plus: '+', l: 'Marketers mentored & levelled up' },
  { n: '76', plus: '',  l: 'Long-form articles published' },
];
const work = [
  { i: '01', t: 'LambdaTest', y: '2021 - 2025', role: 'Product & digital marketing', r: '657K+ leads · 18.2M+ organic', d: 'Owned product and digital marketing end to end and built the full organic growth engine.', feat: true },
  { i: '02', t: 'TestMu AI', y: '2026', role: 'Rebrand lead', r: 'Full company rebrand', d: 'Led the complete rebrand from LambdaTest to TestMu AI.' },
  { i: '03', t: 'Samsung', y: '2019', role: 'via Sociowash', r: 'Galaxy M-series launch', d: 'On the Galaxy M-series from inception; ran content distribution, collaborated with Technical Guruji.' },
  { i: '04', t: 'Medilife Superspeciality', y: '0 to 1', role: 'Marketing & web', r: 'Website · GTM · social', d: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.' },
  { i: '05', t: 'Lido Learning', y: '2021', role: 'Growth / CRM', r: 'CRM & lead operations', d: 'Ran CRM management and lead routing and assignment for the EdTech.' },
  { i: '06', t: 'Appknox', y: 'Freelance', role: 'Content', r: 'Security content', d: 'Freelance content writer for the mobile app security company.' },
];
const recognition = [
  { t: 'Value of Agility Award', m: 'LambdaTest, 2024' },
  { t: 'Wall of Fame', m: 'LambdaTest' },
  { t: '#1 Product of the Day', m: 'Product Hunt' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
const facts = [
  { k: 'Based', v: 'Mumbai, India' },
  { k: 'Tenure', v: '7+ years marketing · 4+ in B2B SaaS' },
  { k: 'Education', v: 'Postgrad in Digital Marketing & Growth Strategy, IIM Visakhapatnam' },
  { k: 'Practice', v: 'PMM & growth strategist who codes AI agents, ships websites and runs technical SEO' },
];
---
<!doctype html>
<html lang="en" data-theme="broadcast">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=VT323&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --tube:#06080d;          /* deepest tube black */
    --tube2:#0a0e18;         /* lit tube */
    --phos:#f4f6ff;          /* warm phosphor white (body ink) */
    --phos-dim:#c4ccdf;      /* dimmed phosphor */
    --phos-faint:#7e88a0;    /* faint label */
    --amber:#ffb44b;         /* broadcast amber accent */
    --cyan:#5fe6ff;          /* signal cyan */
    --green:#7dffb0;         /* on-air green */
    --line:rgba(244,246,255,.14);
    --hair:rgba(244,246,255,.28);
    --disp:"Bebas Neue",Impact,sans-serif;
    --osd:"VT323",ui-monospace,monospace;       /* on-screen-display / TV mono */
    --sans:"Inter",system-ui,sans-serif;
    --pad:clamp(1.1rem,4vw,3rem);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html,body{overflow-x:clip}
  html{scroll-behavior:smooth}
  body{
    background:#020308;color:var(--phos);font-family:var(--sans);min-height:100vh;
    -webkit-font-smoothing:antialiased;line-height:1.6;
    background-image:
      radial-gradient(120% 90% at 50% 0%, #0c1322 0%, #04060c 55%, #010206 100%);
  }
  a{color:inherit;text-decoration:none}
  ::selection{background:var(--amber);color:#1a1206}
  .mono{font-family:var(--osd);letter-spacing:.06em}
  .vh{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap}

  /* ============ TV SET / BEZEL ============ */
  .tv{
    width:min(1180px,100%);margin:0 auto;
    padding:clamp(1rem,3vw,2.4rem) clamp(1rem,3vw,2.4rem) 1.4rem;
  }
  .topbar{
    display:flex;justify-content:space-between;align-items:center;gap:1rem;
    padding:.2rem .2rem 1rem;font-family:var(--osd);font-size:1.05rem;letter-spacing:.08em;color:var(--phos-faint);
    text-transform:uppercase;
  }
  .topbar .set-name{display:flex;align-items:center;gap:.6rem;color:var(--phos-dim)}
  .topbar .set-name .dot{width:9px;height:9px;border-radius:50%;background:var(--amber);box-shadow:0 0 10px var(--amber);flex:none;animation:pwrpulse 3.4s ease-in-out infinite}
  @keyframes pwrpulse{0%,100%{opacity:.55}50%{opacity:1}}
  .topbar nav{display:flex;gap:1.2rem}
  .topbar nav a{color:var(--phos-faint);transition:color .25s}
  .topbar nav a:hover{color:var(--cyan)}
  @media(max-width:680px){.topbar nav{display:none}}

  .bezel{
    position:relative;border-radius:26px;
    padding:clamp(.7rem,2.2vw,1.5rem);
    background:
      linear-gradient(150deg,#23262e,#101216 40%,#191c22 70%,#0c0d11);
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,.08),
      inset 0 -2px 6px rgba(0,0,0,.7),
      0 30px 70px -30px rgba(0,0,0,.9),
      0 0 0 1px rgba(0,0,0,.5);
  }
  /* the glass screen */
  .screen{
    position:relative;
    aspect-ratio:16/10;
    border-radius:18px / 30px;
    overflow:hidden;
    background:radial-gradient(120% 130% at 50% 45%, var(--tube2) 0%, var(--tube) 62%, #02030a 100%);
    box-shadow:inset 0 0 60px 20px rgba(0,0,0,.85), inset 0 0 0 2px rgba(0,0,0,.6);
    /* subtle CRT bulge */
    transform:perspective(1400px);
  }
  @media(max-width:760px){
    .screen{aspect-ratio:auto;min-height:78vh}
  }

  /* the viewport that holds & clips channel content */
  .stage{position:absolute;inset:0;overflow:hidden;border-radius:inherit;z-index:1}
  /* gentle curvature mask on the content layer */
  .stage::before{
    content:"";position:absolute;inset:-2%;z-index:6;pointer-events:none;border-radius:inherit;
    box-shadow:inset 0 0 120px 30px rgba(2,3,8,.85);
  }
  /* vignette corners */
  .stage::after{
    content:"";position:absolute;inset:0;z-index:6;pointer-events:none;border-radius:inherit;
    background:radial-gradient(130% 130% at 50% 50%, transparent 58%, rgba(2,3,8,.55) 100%);
  }

  /* ============ SCANLINES + GLASS OVERLAYS (decorative, above content but text stays legible) ============ */
  .scanlines{
    position:absolute;inset:0;z-index:7;pointer-events:none;border-radius:inherit;
    background:repeating-linear-gradient(to bottom, rgba(0,0,0,.16) 0 1px, transparent 1px 3px);
    mix-blend-mode:multiply;opacity:.55;
  }
  .scanlines.roll::after{
    content:"";position:absolute;left:0;right:0;height:34%;top:-34%;
    background:linear-gradient(to bottom, transparent, rgba(255,255,255,.05) 45%, rgba(255,255,255,.09) 50%, rgba(255,255,255,.05) 55%, transparent);
    animation:hroll 5.5s linear infinite;
  }
  @keyframes hroll{from{transform:translateY(0)}to{transform:translateY(360%)}}
  .glassglow{
    position:absolute;inset:0;z-index:7;pointer-events:none;border-radius:inherit;
    background:radial-gradient(80% 60% at 50% 18%, rgba(120,150,220,.10), transparent 60%);
  }

  /* static canvas (signal noise) - hidden until a channel change.
     width/height:100% force the small intrinsic 160x100 noise buffer to upscale and fill
     the whole screen (with inset:0 alone the canvas keeps its intrinsic size, pinned top-left). */
  #static{
    position:absolute;inset:0;width:100%;height:100%;z-index:9;pointer-events:none;border-radius:inherit;
    image-rendering:pixelated;
    opacity:0;transition:opacity .12s linear;mix-blend-mode:screen;
  }
  #static.on{opacity:.9}

  /* ============ ON-SCREEN OVERLAYS (bug, ident, timecode) ============ */
  .osd-layer{position:absolute;inset:0;z-index:8;pointer-events:none;border-radius:inherit;font-family:var(--osd)}
  .bug{
    position:absolute;top:clamp(.7rem,2.4vw,1.4rem);right:clamp(.8rem,2.6vw,1.6rem);
    text-align:right;line-height:1;
  }
  .bug .ch{font-size:clamp(1.6rem,4.6vw,2.7rem);color:var(--amber);letter-spacing:.06em;
    text-shadow:0 0 14px rgba(255,180,75,.55)}
  .bug .ch.flash{animation:chflash .7s steps(2,end) 2}
  @keyframes chflash{0%,100%{opacity:1}50%{opacity:.15}}
  .bug .chlabel{font-size:clamp(.9rem,2vw,1.15rem);color:var(--phos-dim);letter-spacing:.12em;text-transform:uppercase;margin-top:.2rem}
  .ident{
    position:absolute;top:clamp(.7rem,2.4vw,1.4rem);left:clamp(.8rem,2.6vw,1.6rem);
    display:flex;align-items:center;gap:.5rem;font-size:clamp(1rem,2.4vw,1.4rem);letter-spacing:.16em;color:var(--phos-dim);
  }
  .ident .live{display:inline-flex;align-items:center;gap:.4rem;color:var(--green);font-size:.78em;letter-spacing:.18em}
  .ident .live i{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pwrpulse 1.6s ease-in-out infinite}
  .timecode{
    position:absolute;left:0;right:0;bottom:0;
    display:flex;justify-content:space-between;align-items:center;gap:1rem;
    padding:.45rem clamp(.8rem,2.6vw,1.6rem);
    font-size:clamp(.85rem,2vw,1.12rem);letter-spacing:.1em;color:var(--phos-faint);text-transform:uppercase;
    background:linear-gradient(to top, rgba(2,3,8,.78), transparent);
  }
  .timecode .tracking{display:flex;align-items:center;gap:.5rem}
  .timecode .tracking .bars{display:inline-flex;gap:2px}
  .timecode .tracking .bars i{width:3px;height:10px;background:var(--cyan);opacity:.4;display:block;animation:trk 1.1s steps(1,end) infinite}
  .timecode .tracking .bars i:nth-child(2){animation-delay:.12s}
  .timecode .tracking .bars i:nth-child(3){animation-delay:.24s}
  .timecode .tracking .bars i:nth-child(4){animation-delay:.36s}
  .timecode .tracking .bars i:nth-child(5){animation-delay:.48s}
  @keyframes trk{0%{opacity:.25}40%{opacity:1}100%{opacity:.25}}

  /* ============ CHANNEL PANELS ============ */
  .channels{position:absolute;inset:0;z-index:2;border-radius:inherit}
  .panel{
    position:absolute;inset:0;
    display:flex;flex-direction:column;
    /* top padding clears the OSD ident/bug overlay so the channel header never tucks under it */
    padding:clamp(3.4rem,7vw,4.4rem) clamp(1.4rem,5vw,4rem) clamp(2.4rem,5vw,3.4rem);
    overflow-y:auto;overflow-x:hidden;
    opacity:0;visibility:hidden;
    transition:opacity .42s ease;
    /* scrollbar tidy */
    scrollbar-width:thin;scrollbar-color:rgba(244,246,255,.2) transparent;
  }
  .panel::-webkit-scrollbar{width:8px}
  .panel::-webkit-scrollbar-thumb{background:rgba(244,246,255,.18);border-radius:8px}
  .panel.active{opacity:1;visibility:visible}
  /* the brief horizontal-hold skew while tuning */
  .channels.tuning .panel.active{animation:tunein .5s cubic-bezier(.2,.8,.2,1)}
  @keyframes tunein{
    0%{transform:translateY(-7px) skewX(-4deg);filter:brightness(1.5)}
    35%{transform:translateY(4px) skewX(2deg)}
    100%{transform:none;filter:none}
  }
  /* margin:auto centres when there's spare height but anchors to the top and stays fully
     scrollable when the channel content is taller than the screen (avoids the flex
     justify-content:center + overflow trap that clips the first row out of reach). */
  .panel-pad{width:min(900px,100%);margin:auto}

  /* shared block headers inside channels */
  .ch-head{display:flex;align-items:baseline;gap:.9rem;margin-bottom:clamp(1.1rem,2.6vw,1.8rem);
    font-family:var(--osd);text-transform:uppercase;letter-spacing:.12em;color:var(--cyan);font-size:clamp(1rem,2.4vw,1.35rem)}
  .ch-head .num{color:var(--amber)}
  .ch-head .line{flex:1;height:1px;background:var(--line)}

  /* ---- CH 01 title card ---- */
  .title-card{text-align:center}
  .title-card .eyebrow{font-family:var(--osd);font-size:clamp(1rem,2.6vw,1.4rem);letter-spacing:.2em;text-transform:uppercase;color:var(--amber);margin-bottom:clamp(1rem,3vw,1.8rem)}
  .title-card h1{
    font-family:var(--disp);font-weight:400;text-transform:uppercase;line-height:.92;letter-spacing:.01em;
    font-size:clamp(3rem,12vw,8rem);color:var(--phos);position:relative;
  }
  .title-card h1 .l2{display:block}
  /* RGB chromatic aberration on the title (decorative pseudo copies, real text stays crisp on top) */
  .title-card h1 .aberr{position:relative;display:inline-block}
  .title-card h1 .aberr::before,.title-card h1 .aberr::after{
    content:attr(data-t);position:absolute;left:0;top:0;width:100%;pointer-events:none;opacity:.55;
  }
  .title-card h1 .aberr::before{color:#ff3b5c;transform:translate(-2.5px,0);mix-blend-mode:screen}
  .title-card h1 .aberr::after{color:#3bd6ff;transform:translate(2.5px,0);mix-blend-mode:screen}
  .title-card .sub{margin:clamp(1.4rem,3vw,2.1rem) auto 0;max-width:54ch;color:var(--phos-dim);
    font-size:clamp(1rem,1.5vw,1.18rem);line-height:1.65}
  .title-card .sub b{color:var(--phos);font-weight:600}
  .title-card .metrics{display:flex;justify-content:center;flex-wrap:wrap;gap:clamp(1rem,4vw,3rem);margin-top:clamp(1.6rem,3.5vw,2.4rem)}
  .title-card .metric .mv{font-family:var(--disp);font-size:clamp(2rem,5vw,3.2rem);line-height:1;color:var(--amber);letter-spacing:.02em}
  .title-card .metric .ml{font-family:var(--osd);font-size:.95rem;letter-spacing:.1em;text-transform:uppercase;color:var(--phos-faint);margin-top:.25rem}
  .title-card .cta{margin-top:clamp(1.8rem,4vw,2.6rem);display:flex;gap:.8rem;flex-wrap:wrap;justify-content:center}
  .btn{font-family:var(--osd);font-size:1.05rem;letter-spacing:.1em;text-transform:uppercase;
    padding:.7rem 1.3rem;border:1px solid var(--hair);display:inline-flex;gap:.5rem;align-items:center;
    transition:background .3s,color .3s,border-color .3s,transform .3s;cursor:pointer;background:transparent;color:var(--phos)}
  .btn .ar{transition:transform .3s}
  .btn:hover .ar{transform:translate(3px,-3px)}
  .btn.primary{background:var(--amber);color:#1a1206;border-color:var(--amber)}
  .btn.primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px -8px rgba(255,180,75,.6)}
  .btn.ghost:hover{border-color:var(--cyan);color:var(--cyan)}

  /* ---- CH 02 what I do ---- */
  .pillars{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(.8rem,2vw,1.2rem)}
  .pillar{border:1px solid var(--line);border-radius:12px;padding:clamp(1.1rem,2.4vw,1.6rem);background:rgba(95,230,255,.03);
    transition:border-color .3s,background .3s,transform .4s}
  .pillar:hover{border-color:var(--hair);background:rgba(95,230,255,.06);transform:translateY(-3px)}
  .pillar .pi{font-family:var(--osd);font-size:1.1rem;color:var(--amber);letter-spacing:.1em}
  .pillar .pt{font-family:var(--disp);font-size:clamp(1.3rem,2.6vw,1.8rem);line-height:1.04;letter-spacing:.02em;color:var(--phos);margin:.3rem 0 .5rem;text-transform:uppercase}
  .pillar .pd{color:var(--phos-dim);font-size:.96rem;line-height:1.55}
  .what-stats{display:flex;flex-wrap:wrap;gap:clamp(1rem,4vw,2.6rem);margin-top:clamp(1.4rem,3vw,2rem);
    padding-top:clamp(1.2rem,2.6vw,1.6rem);border-top:1px solid var(--line)}
  .what-stats .ws .wv{font-family:var(--disp);font-size:clamp(1.7rem,4vw,2.6rem);line-height:1;color:var(--cyan);letter-spacing:.02em}
  .what-stats .ws .wl{font-family:var(--osd);font-size:.9rem;letter-spacing:.06em;text-transform:uppercase;color:var(--phos-faint);margin-top:.2rem;max-width:22ch}
  @media(max-width:620px){.pillars{grid-template-columns:1fr}}

  /* ---- CH 03 program guide (work) ---- */
  .guide{display:flex;flex-direction:column;border:1px solid var(--line);border-radius:12px;overflow:hidden}
  .row{display:grid;grid-template-columns:4.5rem 1fr auto;gap:1rem;align-items:center;
    padding:clamp(.85rem,2vw,1.15rem) clamp(1rem,2.4vw,1.4rem);border-top:1px solid var(--line);
    transition:background .3s}
  .row:first-child{border-top:0}
  .row:hover{background:rgba(255,180,75,.06)}
  .row.feat{background:rgba(255,180,75,.07);align-items:start}
  .row .slot{font-family:var(--osd);font-size:1.05rem;color:var(--amber);letter-spacing:.06em;line-height:1.3}
  .row .prog .pn{font-family:var(--disp);font-size:clamp(1.2rem,2.6vw,1.75rem);line-height:1.04;letter-spacing:.02em;text-transform:uppercase;color:var(--phos)}
  .row .prog .pr{font-family:var(--osd);font-size:1rem;color:var(--cyan);letter-spacing:.04em;margin-top:.1rem}
  .row .prog .pd{color:var(--phos-dim);font-size:.92rem;line-height:1.5;margin-top:.4rem;max-width:62ch}
  .row .prog .prole{font-family:var(--osd);font-size:.92rem;letter-spacing:.08em;text-transform:uppercase;color:var(--phos-faint);margin-top:.15rem}
  .row .yr{font-family:var(--osd);font-size:1rem;color:var(--phos-faint);letter-spacing:.06em;text-align:right;white-space:nowrap}
  @media(max-width:600px){
    .row{grid-template-columns:3.4rem 1fr;gap:.5rem .9rem}
    .row .yr{grid-column:2;text-align:left;margin-top:.2rem}
  }

  /* ---- CH 04 recognition ---- */
  .honours{display:grid;grid-template-columns:1.3fr 1fr;gap:clamp(1.5rem,4vw,3rem);align-items:start}
  .awards{display:flex;flex-direction:column;gap:0}
  .award{display:flex;align-items:center;gap:1rem;padding:clamp(.9rem,2vw,1.15rem) 0;border-top:1px solid var(--line)}
  .award:first-child{border-top:0}
  .award .star{font-family:var(--disp);font-size:1.6rem;color:var(--amber);line-height:1;flex:none}
  .award b{font-family:var(--disp);font-weight:400;font-size:clamp(1.2rem,2.6vw,1.7rem);letter-spacing:.02em;display:block;line-height:1.05;text-transform:uppercase;color:var(--phos)}
  .award span{font-family:var(--osd);font-size:.95rem;letter-spacing:.05em;color:var(--phos-faint);text-transform:uppercase}
  .brands .bl{font-family:var(--osd);font-size:1rem;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);margin-bottom:.9rem}
  .brands .bgrid{display:flex;flex-wrap:wrap;gap:.55rem}
  .brands .bgrid span{font-family:var(--osd);font-size:1rem;border:1px solid var(--line);border-radius:8px;padding:.4rem .7rem;color:var(--phos-dim)}
  @media(max-width:680px){.honours{grid-template-columns:1fr}}

  /* ---- CH 05 about ---- */
  .about{display:grid;grid-template-columns:230px 1fr;gap:clamp(1.5rem,4vw,3rem);align-items:start}
  .about-photo{position:relative;aspect-ratio:5/6;border:1px solid var(--line);border-radius:12px;overflow:hidden;background:var(--tube2);flex:none}
  .about-photo img{width:100%;height:100%;object-fit:cover;object-position:top center;filter:saturate(.85) contrast(1.05) brightness(1.02)}
  .about-photo::after{content:"";position:absolute;inset:0;background:repeating-linear-gradient(to bottom, rgba(0,0,0,.18) 0 1px, transparent 1px 3px);pointer-events:none;mix-blend-mode:multiply;opacity:.5}
  .about-lead{font-family:var(--disp);font-weight:400;text-transform:uppercase;font-size:clamp(1.4rem,3.2vw,2.3rem);line-height:1.04;letter-spacing:.02em;margin-bottom:clamp(1.2rem,2.6vw,1.7rem);color:var(--phos)}
  .facts{display:grid;grid-template-columns:repeat(2,1fr);gap:clamp(1rem,2.4vw,1.5rem)}
  .fact .k{font-family:var(--osd);font-size:.92rem;letter-spacing:.1em;text-transform:uppercase;color:var(--cyan);margin-bottom:.3rem}
  .fact .v{color:var(--phos-dim);font-size:.98rem;line-height:1.45}
  @media(max-width:640px){.about{grid-template-columns:1fr}.about-photo{max-width:200px}.facts{grid-template-columns:1fr}}

  /* ---- CH 06 contact / sign off ---- */
  .signoff{text-align:center}
  .signoff .cl{font-family:var(--osd);font-size:clamp(1rem,2.6vw,1.4rem);letter-spacing:.16em;text-transform:uppercase;color:var(--cyan);margin-bottom:clamp(1rem,2.6vw,1.6rem)}
  .signoff .big{font-family:var(--disp);text-transform:uppercase;font-weight:400;font-size:clamp(2.6rem,10vw,7rem);line-height:.9;letter-spacing:.02em;color:var(--phos)}
  .signoff .big a{display:inline-flex;align-items:flex-start;gap:.1em;transition:color .3s}
  .signoff .big a .ar{font-size:.4em;margin-top:.18em}
  .signoff .big a:hover{color:var(--amber)}
  .signoff .em{margin-top:clamp(1.2rem,3vw,1.8rem);font-family:var(--osd);font-size:1.1rem;letter-spacing:.04em;color:var(--phos-faint)}
  .signoff .em a{color:var(--cyan);border-bottom:1px solid var(--hair)}
  .signoff .em a:hover{color:var(--phos)}
  .signoff .colorbars{display:flex;height:14px;width:min(360px,80%);margin:clamp(1.6rem,3.5vw,2.4rem) auto 0;border-radius:4px;overflow:hidden;opacity:.85}
  .signoff .colorbars i{flex:1}

  /* ============ REMOTE / CHANNEL CONTROLS (below the set) ============ */
  .deck{
    display:flex;align-items:stretch;gap:clamp(.8rem,2vw,1.4rem);margin-top:clamp(1rem,2.4vw,1.6rem);flex-wrap:wrap;
  }
  .channel-strip{
    flex:1 1 320px;display:flex;gap:.5rem;flex-wrap:wrap;align-content:center;
    padding:.7rem .8rem;border:1px solid var(--line);border-radius:14px;background:rgba(10,14,24,.6);
  }
  .chip{
    font-family:var(--osd);font-size:1rem;letter-spacing:.04em;text-transform:uppercase;
    display:flex;align-items:center;gap:.5rem;padding:.5rem .8rem;border:1px solid var(--line);border-radius:9px;
    color:var(--phos-dim);background:transparent;cursor:pointer;transition:border-color .25s,color .25s,background .25s;
  }
  .chip .cn{color:var(--amber);font-size:.95em}
  .chip:hover{border-color:var(--hair);color:var(--phos)}
  .chip[aria-current="true"]{border-color:var(--amber);color:var(--phos);background:rgba(255,180,75,.1)}
  .chip[aria-current="true"] .cn{color:var(--amber)}

  .remote{
    flex:0 0 auto;display:flex;align-items:center;gap:.8rem;
    padding:.65rem .9rem;border:1px solid var(--line);border-radius:14px;background:rgba(10,14,24,.6);
  }
  .remote .rlabel{font-family:var(--osd);font-size:.9rem;letter-spacing:.14em;text-transform:uppercase;color:var(--phos-faint)}
  .remote .dpad{display:flex;flex-direction:column;gap:.4rem}
  .navbtn{
    font-family:var(--osd);font-size:1.3rem;line-height:1;width:46px;height:34px;display:grid;place-items:center;
    border:1px solid var(--hair);border-radius:8px;background:rgba(244,246,255,.04);color:var(--phos);cursor:pointer;
    transition:background .2s,border-color .2s,transform .12s;
  }
  .navbtn:hover{background:rgba(255,180,75,.14);border-color:var(--amber)}
  .navbtn:active{transform:scale(.92)}
  .navbtn:focus-visible{outline:2px solid var(--cyan);outline-offset:2px}
  .chip:focus-visible,.btn:focus-visible,.topbar nav a:focus-visible{outline:2px solid var(--cyan);outline-offset:2px}

  footer.tvfoot{
    width:min(1180px,100%);margin:0 auto;padding:1.6rem clamp(1rem,3vw,2.4rem) 3rem;
    display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;
    font-family:var(--osd);font-size:1rem;letter-spacing:.06em;color:var(--phos-faint);text-transform:uppercase;
  }
  footer.tvfoot a{color:var(--phos-dim)}
  footer.tvfoot a:hover{color:var(--cyan)}

  /* ============ REDUCED MOTION ============ */
  @media(prefers-reduced-motion:reduce){
    html{scroll-behavior:auto}
    .scanlines.roll::after{animation:none;display:none}
    .topbar .set-name .dot,.ident .live i,.timecode .tracking .bars i{animation:none;opacity:1}
    .channels.tuning .panel.active{animation:none}
    .bug .ch.flash{animation:none}
    #static{display:none}
    .panel{transition:none}
  }
</style>
</head>
<body>
  <div class="tv">
    <div class="topbar">
      <span class="set-name"><span class="dot" aria-hidden="true"></span> SBTV &middot; Broadcast</span>
      <nav aria-label="Channels">
        <a href="#" data-goch="2">02 What I Do</a>
        <a href="#" data-goch="3">03 Work</a>
        <a href="#" data-goch="5">05 About</a>
        <a href="#" data-goch="6">06 Contact</a>
        <a href="/redesign/">All concepts</a>
      </nav>
    </div>

    <div class="bezel">
      <div class="screen">
        <div class="stage">
          <!-- channel content panels -->
          <div class="channels" id="channels">

            <!-- CH 01 - TITLE CARD -->
            <section class="panel" id="ch-tune" data-ch="1" aria-label="Channel 01, Title Card">
              <div class="panel-pad title-card">
                <div class="eyebrow">Senior Product Marketing Manager - LambdaTest</div>
                <h1>
                  <span class="l1">The marketer</span>
                  <span class="l2">who <span class="aberr" data-t="ships.">ships.</span></span>
                </h1>
                <p class="sub">I build the agents, sites and SEO systems behind <b>657K+ leads</b> and <b>18M+ in organic traffic</b> - not just the decks that describe them. A product marketer who actually engineers the growth.</p>
                <div class="metrics">
                  <div class="metric"><div class="mv">657K+</div><div class="ml">Leads generated</div></div>
                  <div class="metric"><div class="mv">18.2M+</div><div class="ml">Organic traffic</div></div>
                  <div class="metric"><div class="mv">10x</div><div class="ml">Organic growth</div></div>
                </div>
                <div class="cta">
                  <button class="btn primary" type="button" data-goch="3">Tune in to work <span class="ar">&#8599;</span></button>
                  <button class="btn ghost" type="button" data-goch="6">Get in touch</button>
                </div>
              </div>
            </section>

            <!-- CH 02 - WHAT I DO -->
            <section class="panel" id="ch-what" data-ch="2" aria-label="Channel 02, What I Do">
              <div class="panel-pad">
                <div class="ch-head"><span class="num">CH 02</span> What I do <span class="line" aria-hidden="true"></span></div>
                <div class="pillars">
                  {pillars.map(p => (
                    <div class="pillar">
                      <div class="pi">{p.i}</div>
                      <div class="pt">{p.t}</div>
                      <div class="pd">{p.d}</div>
                    </div>
                  ))}
                </div>
                <div class="what-stats">
                  {buildStats.map(s => (
                    <div class="ws">
                      <div class="wv">{s.n}{s.plus}</div>
                      <div class="wl">{s.l}</div>
                    </div>
                  ))}
                </div>
              </div>
            </section>

            <!-- CH 03 - PROGRAM GUIDE / SELECTED WORK -->
            <section class="panel" id="ch-work" data-ch="3" aria-label="Channel 03, Program Guide">
              <div class="panel-pad">
                <div class="ch-head"><span class="num">CH 03</span> Program guide &middot; Selected work <span class="line" aria-hidden="true"></span></div>
                <div class="guide">
                  {work.map(w => (
                    <div class={'row' + (w.feat ? ' feat' : '')}>
                      <div class="slot">{w.feat ? 'PRIME' : w.i}</div>
                      <div class="prog">
                        <div class="pn">{w.t}</div>
                        <div class="pr">{w.r}</div>
                        <div class="prole">{w.role}</div>
                        <div class="pd">{w.d}</div>
                      </div>
                      <div class="yr">{w.y}</div>
                    </div>
                  ))}
                </div>
              </div>
            </section>

            <!-- CH 04 - RECOGNITION -->
            <section class="panel" id="ch-honours" data-ch="4" aria-label="Channel 04, Recognition">
              <div class="panel-pad">
                <div class="ch-head"><span class="num">CH 04</span> Recognition &amp; brands <span class="line" aria-hidden="true"></span></div>
                <div class="honours">
                  <div class="awards">
                    {recognition.map(a => (
                      <div class="award">
                        <span class="star" aria-hidden="true">&#9733;</span>
                        <div><b>{a.t}</b><span>{a.m}</span></div>
                      </div>
                    ))}
                  </div>
                  <div class="brands">
                    <div class="bl">Trusted by teams at</div>
                    <div class="bgrid">{brands.map(b => <span>{b}</span>)}</div>
                  </div>
                </div>
              </div>
            </section>

            <!-- CH 05 - STATION ID / ABOUT -->
            <section class="panel" id="ch-about" data-ch="5" aria-label="Channel 05, Station ID">
              <div class="panel-pad">
                <div class="ch-head"><span class="num">CH 05</span> Station ID &middot; About <span class="line" aria-hidden="true"></span></div>
                <div class="about">
                  <div class="about-photo"><img src="/assets/portrait-cut.webp" alt="Swapnil Biswas" loading="lazy" decoding="async" /></div>
                  <div>
                    <p class="about-lead">I treat my own career like a product - positioned, measured and shipped. Seven years in marketing, four deep in B2B SaaS.</p>
                    <div class="facts">
                      {facts.map(f => (
                        <div class="fact"><div class="k">{f.k}</div><div class="v">{f.v}</div></div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <!-- CH 06 - SIGN OFF / CONTACT -->
            <section class="panel" id="ch-contact" data-ch="6" aria-label="Channel 06, Sign Off">
              <div class="panel-pad signoff">
                <div class="cl">Let's build something that compounds</div>
                <div class="big"><a href="mailto:swapbiswas.marketing@gmail.com">Say hello <span class="ar">&#8599;</span></a></div>
                <div class="em">swapbiswas.marketing@gmail.com &nbsp;&middot;&nbsp; <a href="https://www.linkedin.com/in/swapbiswas/">LinkedIn</a></div>
                <div class="colorbars" aria-hidden="true">
                  <i style="background:#c7c7c7"></i><i style="background:#d6d62e"></i><i style="background:#2ed6d6"></i>
                  <i style="background:#2ed62e"></i><i style="background:#d62ed6"></i><i style="background:#d62e2e"></i><i style="background:#2e2ed6"></i>
                </div>
              </div>
            </section>

          </div><!-- /channels -->
        </div><!-- /stage -->

        <!-- decorative CRT overlays -->
        <div class="glassglow" aria-hidden="true"></div>
        <canvas id="static" aria-hidden="true"></canvas>
        <div class="scanlines roll" aria-hidden="true"></div>

        <!-- on-screen-display overlays -->
        <div class="osd-layer" aria-hidden="true">
          <div class="ident">SBTV <span class="live"><i></i>LIVE</span></div>
          <div class="bug">
            <div class="ch" id="bug-ch">CH 01</div>
            <div class="chlabel" id="bug-label">Title Card</div>
          </div>
          <div class="timecode">
            <span class="tc-time" id="tc-time">00:00:01:00</span>
            <span class="tracking">TRACKING
              <span class="bars"><i></i><i></i><i></i><i></i><i></i></span>
            </span>
          </div>
        </div>
      </div><!-- /screen -->
    </div><!-- /bezel -->

    <!-- ===== REMOTE / CHANNEL DECK ===== -->
    <div class="deck">
      <div class="channel-strip" role="tablist" aria-label="Channel selector">
        {channels.map(c => (
          <button class="chip" type="button" role="tab" data-goch={parseInt(c.n, 10)} aria-current={c.n === '01' ? 'true' : 'false'}>
            <span class="cn">CH {c.n}</span> {c.label}
          </button>
        ))}
      </div>
      <div class="remote">
        <span class="rlabel">Channel</span>
        <div class="dpad">
          <button class="navbtn" type="button" id="ch-up" aria-label="Channel up">&#9650;</button>
          <button class="navbtn" type="button" id="ch-down" aria-label="Channel down">&#9660;</button>
        </div>
      </div>
    </div>
  </div>

  <footer class="tvfoot">
    <span>Broadcast &middot; Concept 30</span>
    <span>Swapnil Biswas &copy; 2026</span>
    <span><a href="/redesign/">View all concepts</a></span>
  </footer>

<script>
  const RM = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const channelsEl = document.getElementById('channels');
  const panels = Array.from(document.querySelectorAll('.panel'));
  const chips = Array.from(document.querySelectorAll('.chip'));
  const bugCh = document.getElementById('bug-ch');
  const bugLabel = document.getElementById('bug-label');
  const scanRoll = document.querySelector('.scanlines');
  const staticCv = document.getElementById('static');

  const labels = { 1:'Title Card', 2:'What I Do', 3:'Program Guide', 4:'Recognition', 5:'Station ID', 6:'Sign Off' };
  const TOTAL = panels.length;
  let current = 1;
  let tuning = false;

  function pad(n){ return String(n).padStart(2,'0'); }

  /* ---------- static noise (cheap, capped) ---------- */
  const ctx = staticCv.getContext('2d', { alpha: true });
  let noiseRAF = 0, noiseStop = 0, noiseImg = null, noiseW = 0, noiseH = 0;
  function sizeNoise(){
    // render noise at a small fixed buffer then upscale via CSS - keeps it 60fps
    noiseW = 160; noiseH = 100;
    staticCv.width = noiseW; staticCv.height = noiseH;
    noiseImg = ctx.createImageData(noiseW, noiseH);
  }
  function paintNoise(){
    const d = noiseImg.data;
    for (let i = 0; i < d.length; i += 4){
      const v = (Math.random() * 255) | 0;
      d[i] = d[i+1] = d[i+2] = v;
      d[i+3] = 235;
    }
    ctx.putImageData(noiseImg, 0, 0);
  }
  function startNoise(ms){
    if (RM) return;
    if (!noiseImg) sizeNoise();
    staticCv.classList.add('on');
    noiseStop = performance.now() + ms;
    cancelAnimationFrame(noiseRAF);
    let last = 0;
    const loop = (now) => {
      // throttle noise repaint to ~30fps so the burst is cheap
      if (now - last > 33){ paintNoise(); last = now; }
      if (now < noiseStop){ noiseRAF = requestAnimationFrame(loop); }
      else { staticCv.classList.remove('on'); }
    };
    noiseRAF = requestAnimationFrame(loop);
  }

  /* ---------- channel switching ---------- */
  function setBug(n, flash){
    bugCh.textContent = 'CH ' + pad(n);
    bugLabel.textContent = labels[n] || '';
    if (flash && !RM){
      bugCh.classList.remove('flash'); void bugCh.offsetWidth; bugCh.classList.add('flash');
    }
  }

  function showPanel(n){
    panels.forEach(p => {
      const isOn = Number(p.dataset.ch) === n;
      p.classList.toggle('active', isOn);
      if (isOn) p.scrollTop = 0;
    });
    chips.forEach(c => c.setAttribute('aria-current', Number(c.dataset.goch) === n ? 'true' : 'false'));
  }

  function goTo(n, opts = {}){
    n = ((n - 1 + TOTAL) % TOTAL) + 1;   // wrap 1..TOTAL
    if (n === current && !opts.force) return;
    current = n;

    if (RM){
      showPanel(n);
      setBug(n, false);
      return;
    }

    // static burst + horizontal-hold roll, then tune in
    if (tuning) return; // ignore rapid double-fire mid-transition; final state always settles
    tuning = true;
    startNoise(230);
    setBug(n, false);

    // mid-burst: swap the panel under the static
    setTimeout(() => {
      showPanel(n);
      channelsEl.classList.add('tuning');
      setBug(n, true);
    }, 150);

    // settle: guarantee the channel ends fully tuned-in even if interrupted
    setTimeout(() => {
      channelsEl.classList.remove('tuning');
      tuning = false;
    }, 560);
  }

  // safety net: if anything wedges, force-settle the active panel visible
  function ensureSettled(){
    channelsEl.classList.remove('tuning');
    staticCv.classList.remove('on');
    tuning = false;
    showPanel(current);
  }

  /* ---------- controls ---------- */
  document.getElementById('ch-up').addEventListener('click', () => goTo(current + 1));
  document.getElementById('ch-down').addEventListener('click', () => goTo(current - 1));

  chips.forEach(c => c.addEventListener('click', () => goTo(Number(c.dataset.goch))));

  document.querySelectorAll('[data-goch]').forEach(el => {
    if (el.classList.contains('chip')) return; // already wired
    el.addEventListener('click', (e) => {
      if (el.tagName === 'A') e.preventDefault();
      goTo(Number(el.dataset.goch));
      // keep the set in view when a nav/cta jumps channels
      document.querySelector('.screen')?.scrollIntoView({ behavior: RM ? 'auto' : 'smooth', block: 'center' });
    });
  });

  // arrow keys (ignore when typing in a field, though there are none here)
  window.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowUp' || e.key === 'ArrowRight'){ e.preventDefault(); goTo(current + 1); }
    else if (e.key === 'ArrowDown' || e.key === 'ArrowLeft'){ e.preventDefault(); goTo(current - 1); }
  });

  /* ---------- scroll / wheel to surf (debounced) ---------- */
  let wheelLock = false;
  const screenEl = document.querySelector('.screen');
  screenEl.addEventListener('wheel', (e) => {
    // let the active panel scroll its own overflow first if it can
    const active = panels.find(p => p.classList.contains('active'));
    if (active){
      const canScrollDown = active.scrollTop + active.clientHeight < active.scrollHeight - 2;
      const canScrollUp = active.scrollTop > 2;
      if ((e.deltaY > 0 && canScrollDown) || (e.deltaY < 0 && canScrollUp)) return; // internal scroll
    }
    e.preventDefault();
    if (wheelLock || tuning) return;
    wheelLock = true;
    if (e.deltaY > 0) goTo(current + 1); else goTo(current - 1);
    setTimeout(() => { wheelLock = false; }, RM ? 120 : 620);
  }, { passive: false });

  // touch swipe (vertical) to change channel
  let touchY = null;
  screenEl.addEventListener('touchstart', (e) => { touchY = e.touches[0].clientY; }, { passive: true });
  screenEl.addEventListener('touchend', (e) => {
    if (touchY == null) return;
    const dy = e.changedTouches[0].clientY - touchY;
    const active = panels.find(p => p.classList.contains('active'));
    // only surf if the panel isn't mid-scroll-needed; small guard
    if (Math.abs(dy) > 60 && !tuning){
      if (active){
        const canScrollDown = active.scrollTop + active.clientHeight < active.scrollHeight - 2;
        const canScrollUp = active.scrollTop > 2;
        if (dy < 0 && canScrollDown) { touchY = null; return; }
        if (dy > 0 && canScrollUp) { touchY = null; return; }
      }
      if (dy < 0) goTo(current + 1); else goTo(current - 1);
    }
    touchY = null;
  }, { passive: true });

  /* ---------- live timecode ---------- */
  const tcEl = document.getElementById('tc-time');
  let frame = 0, secs = 1;
  function tickTC(){
    frame = (frame + 1) % 30;
    if (frame === 0) secs++;
    const hh = pad(Math.floor(secs / 3600) % 24);
    const mm = pad(Math.floor(secs / 60) % 60);
    const ss = pad(secs % 60);
    tcEl.textContent = `${hh}:${mm}:${ss}:${pad(frame)}`;
  }
  if (!RM) setInterval(tickTC, 1000 / 12); // light cadence, not a render hog

  /* ---------- init ---------- */
  goTo(1, { force: true });
  // hard guarantee on load: nothing trapped behind static
  ensureSettled();
  showPanel(current);
  setBug(current, false);

  // if the tab is hidden/restored, make sure we're settled and visible
  document.addEventListener('visibilitychange', () => { if (!document.hidden) ensureSettled(); });
</script>
</body>
</html>
