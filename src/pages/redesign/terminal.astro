  .about .abtext em{font-style:normal;color:var(--green);text-shadow:0 0 26px rgba(55,245,181,.3)}
  .about .meta{margin-top:2rem;display:flex;flex-wrap:wrap;gap:1.5rem;font-size:.78rem;color:var(--mut2);letter-spacing:.04em}
  .about .meta b{color:var(--amber);font-weight:500}
  /* contact */
  .contact{text-align:left;padding-bottom:6rem}
