    @keyframes livetick{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.7)}}
  }
  .wright .wy{font-size:.74rem;color:var(--mut);display:flex;align-items:center;gap:.5rem;margin-top:.1rem}
