     border:1.5px solid rgba(150,245,228,.7);border-radius:6px 6px 50% 50%/6px 6px 70% 70%;box-shadow:0 0 12px rgba(94,234,212,.5),inset 0 0 8px rgba(94,234,212,.25)}
