---
// REDESIGN PROTOTYPE - "Terminal" - retro-futuristic techno terminal / signal lab.
// Concept 03. Fully self-contained: own <html>, own fonts, own tokens. No BaseLayout, no global.css.
// Tech: raw-WebGL oscilloscope / FFT signal waveform shader bleeding across the hero in phosphor green +
// amber peaks, CRT scanline + bloom overlay, GSAP boot-sequence typing + scroll reveals, Lenis smooth scroll.
const boot = [
  { p: '> initializing swapnil.biswas', t: 'ok' },
  { p: '> role: senior product marketing manager @ lambdatest', t: 'ok' },
  { p: '> loading modules: gtm · seo · ai-agents · sites', t: 'ok' },
  { p: '> status: shipping', t: 'live' },
];
const stats = [
  { n: 657, suf: 'K+', l: 'leads_generated' },
  { n: 18.2, suf: 'M+', l: 'organic_traffic' },
  { n: 10, suf: 'x', l: 'conversion_lift' },
  { n: 20, suf: '+', l: 'agents_apps_built' },
  { n: 15, suf: '+', l: 'marketers_mentored' },
  { n: 76, suf: '', l: 'articles_published' },
];
const pillars = [
  { i: '01', t: 'Product Marketing & GTM', d: 'Positioning, launches, battlecards and sales enablement for B2B SaaS.' },
  { i: '02', t: 'Growth, SEO & AEO', d: 'Technical audits, AI-search optimization and demand gen that compounds.' },
  { i: '03', t: 'AI & Automation', d: 'I build the agents and internal tools that do the work - 20+ shipped.' },
  { i: '04', t: 'Building in public', d: 'This site, 8 free tools and 76 articles. Shipped systems, not slide-ware.' },
];
const work = [
  { id: '01', f: 'lambdatest.md', perm: '-rwxr-xr-x', sz: '9.2k', t: 'LambdaTest', m: 'product · digital marketing', y: '2021-2025', d: 'Owned product and digital marketing end to end and built the full organic growth engine.', res: '657K+ leads · 18.2M+ organic traffic', tile: 'lambdatest' },
  { id: '02', f: 'testmu-ai.rebrand', perm: '-rwxr-xr-x', sz: '5.4k', t: 'TestMu AI', m: 'rebrand lead', y: '2026', d: 'Led the complete rebrand from LambdaTest to TestMu AI.', res: 'Full company rebrand', tile: 'testmu' },
  { id: '03', f: 'samsung-galaxy-m.launch', perm: '-rwxr-xr-x', sz: '4.8k', t: 'Samsung', m: 'launch content · distribution', y: '2019', d: 'On the Galaxy M-series from inception; ran content distribution (collaborated with Technical Guruji).', res: 'Galaxy M-series launch', tile: 'samsung' },
  { id: '04', f: 'medilife.md', perm: '-rwxr-xr-x', sz: '6.1k', t: 'Medilife Superspeciality', m: 'marketing · web · 0→1', y: '', d: 'Built the full digital presence and go-to-market for a NABH-accredited superspeciality hospital in Dehradun.', res: 'Website, GTM, social & launch', tile: 'medilife' },
  { id: '05', f: 'lido-learning.md', perm: '-rwxr-xr-x', sz: '3.6k', t: 'Lido Learning', m: 'growth · crm', y: '2021', d: 'Ran CRM management and lead routing/assignment for the EdTech.', res: 'CRM & lead operations', tile: 'lido' },
  { id: '06', f: 'appknox.md', perm: '-rwxr-xr-x', sz: '2.4k', t: 'Appknox', m: 'freelance content', y: '', d: 'Freelance content writer for the mobile app security company.', res: 'Security content', tile: 'appknox' },
];
const awards = [
  { b: 'Value of Agility Award', s: 'LambdaTest, 2024' },
  { b: 'Wall of Fame', s: 'LambdaTest' },
  { b: '#1 Product of the Day', s: 'Product Hunt' },
];
const brands = ['LambdaTest', 'TestMu AI', 'Samsung', 'Medilife', 'Lido Learning', 'Appknox'];
---
<!doctype html>
<html lang="en" data-theme="terminal">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Swapnil Biswas - The marketer who ships</title>
<meta name="robots" content="noindex" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;0,800;1,400&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
<style>
  :root{
    --bg:#07090f; --bg2:#060a12; --panel:#0a0e18; --ink:#eaf5f0; --mut:#b8c6cd;
    --mut2:#c4d2db;
    --green:#37f5b5; --green2:#7CFFB0; --amber:#ffb86b; --amber2:#ffb000;
    --line:rgba(55,245,181,.20); --line2:rgba(55,245,181,.10);
    --aline:rgba(255,184,107,.22);
    --glow:0 0 18px rgba(55,245,181,.35);
    --aglow:0 0 16px rgba(255,184,107,.42);
    --mono:"JetBrains Mono",ui-monospace,SFMono-Regular,Menlo,monospace;
    --disp:"Space Grotesk","JetBrains Mono",sans-serif;
    --m:clamp(1.1rem,4.5vw,5rem);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  /* Solid dark base on html so the page is ALWAYS dark below the fold
     (body uses a fixed-attachment glow that only paints the first viewport). */
  html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;background:#05070c;overflow-x:clip}
  body{background:
      radial-gradient(120% 80% at 50% -10%,rgba(55,245,181,.05),transparent 55%),
      radial-gradient(90% 60% at 85% 100%,rgba(255,176,0,.035),transparent 60%),
      linear-gradient(180deg,var(--bg2),var(--bg) 40%,#05070c);
    background-attachment:fixed;color:var(--ink);font-family:var(--mono);line-height:1.62;overflow-x:clip;font-weight:400;font-size:17px}
  /* every content section sits on the dark base, never transparent-to-white */
  .wrap, main, section{position:relative;z-index:2}
  @media(max-width:600px){body{font-size:15px}}
  ::selection{background:var(--green);color:#05080f}
  a{color:inherit;text-decoration:none}
  /* WebGL canvas - the signal waveform, bleeding across hero */
  canvas#sig{position:fixed;inset:0;width:100vw;height:100vh;z-index:0;pointer-events:none;opacity:1}
  .nowebgl{position:fixed;inset:0;z-index:0;pointer-events:none;
    background:radial-gradient(90% 70% at 50% 12%,rgba(55,245,181,.10),transparent 60%),
    radial-gradient(70% 60% at 80% 90%,rgba(255,176,0,.05),transparent 60%),var(--bg)}
  /* phosphor bloom over the signal */
  .bloom{position:fixed;inset:0;z-index:1;pointer-events:none;
    background:radial-gradient(75% 50% at 50% 38%,rgba(55,245,181,.06),transparent 70%);
    mix-blend-mode:screen}
  /* CRT scanlines + flicker */
  .scan{position:fixed;inset:0;z-index:3;pointer-events:none;
    background:repeating-linear-gradient(180deg,rgba(0,0,0,0) 0,rgba(0,0,0,0) 2px,rgba(0,0,0,.05) 2px,rgba(0,0,0,.05) 4px);
    mix-blend-mode:multiply}
  .crt{position:fixed;inset:0;z-index:3;pointer-events:none;opacity:.5;will-change:opacity;
    background:radial-gradient(120% 100% at 50% 50%,transparent 58%,rgba(5,7,12,.7) 100%)}
  @keyframes flick{0%,100%{opacity:.5}48%{opacity:.42}50%{opacity:.58}52%{opacity:.46}}
  @media(prefers-reduced-motion:no-preference){.crt{animation:flick 7s steps(1) infinite}}
  .wrap{position:relative;z-index:2;max-width:1240px;margin:0 auto;padding:0 var(--m)}
  /* nav */
  nav{position:fixed;top:0;left:0;right:0;z-index:10;display:flex;justify-content:space-between;align-items:center;
    padding:1rem var(--m);background:linear-gradient(180deg,rgba(6,9,14,.92),rgba(6,9,14,0));backdrop-filter:blur(5px)}
  .logo{font-family:var(--mono);font-size:.86rem;font-weight:700;letter-spacing:.02em;color:var(--green);text-shadow:var(--glow)}
  .logo b{color:var(--amber);text-shadow:var(--aglow)}
  .navlinks{display:flex;gap:1.6rem;font-size:.8rem;letter-spacing:.04em;color:var(--mut2);align-items:center}
  .navlinks a{position:relative;transition:color .25s}
  .navlinks a:hover{color:var(--green)}
  .navlinks a::after{content:"";position:absolute;left:0;bottom:-4px;width:0;height:1px;background:var(--green);box-shadow:var(--glow);transition:width .3s ease}
  .navlinks a:hover::after{width:100%}
  .navlinks a.muted{color:var(--mut2)}
  .navlinks a.muted:hover{color:var(--ink)}
  .navlinks a.muted::after{background:var(--mut);box-shadow:none}
  @media(max-width:760px){.navlinks{display:none}}
  /* terminal prompt headers */
  .prompt{font-size:.84rem;letter-spacing:.04em;color:var(--ink);display:flex;align-items:center;gap:.55rem;margin-bottom:.6rem}
  .prompt .pp{color:var(--green2)}
  .prompt .cmd{color:var(--ink)}
  .ascii{font-size:.7rem;letter-spacing:0;white-space:nowrap;overflow:hidden;display:block;
    color:rgba(55,245,181,.28);user-select:none}
  /* hero */
  header.hero{min-height:100svh;display:flex;flex-direction:column;justify-content:center;padding-top:6rem;padding-bottom:3rem}
  .boot{font-size:clamp(.78rem,1.6vw,.9rem);color:var(--green2);margin-bottom:2rem;min-height:7.5em;line-height:1.7}
  .boot .row{display:block;white-space:pre-wrap;color:rgba(124,255,176,.92)}
  .boot .row:last-of-type{color:var(--green2)}
  .boot .row .tag{color:var(--amber);font-weight:600}
  .boot .row .tag.live{color:#05080f;background:var(--green);padding:0 .4em;border-radius:2px;box-shadow:var(--glow)}
  .boot .cur{display:inline-block;width:.6em;height:1.05em;background:var(--green);box-shadow:var(--glow);transform:translateY(.18em);margin-left:.1em}
  @keyframes blink{0%,49%{opacity:1}50%,100%{opacity:0}}
  .cur{animation:blink 1s steps(1) infinite}
  /* HEADLINE: Space Grotesk heavy, committed system, tight tracking */
  .hero h1{font-family:var(--disp);font-weight:700;font-size:clamp(3.2rem,8.5vw,7rem);line-height:.92;letter-spacing:-.035em;max-width:14ch;color:var(--ink);position:relative}
  /* dark halo behind the headline so the waveform glow never softens the type edges */
  .hero h1::before{content:"";position:absolute;left:-6%;right:-6%;top:-14%;bottom:-16%;z-index:-1;pointer-events:none;
    background:radial-gradient(60% 70% at 35% 50%,rgba(5,7,12,.92),rgba(5,7,12,.7) 55%,transparent 80%);filter:blur(8px)}
  .hero h1 em{font-style:normal;color:var(--green);text-shadow:0 0 34px rgba(55,245,181,.45)}
  .hero h1 .ln{display:block;overflow:hidden}
  .hero h1 .ln>span{display:block;will-change:transform}
  /* body: bright near-white-green for crisp AA, single restrained highlight family */
  .hero .sub{margin-top:1.9rem;max-width:54ch;font-size:clamp(.98rem,1.35vw,1.1rem);color:#dfeee7;line-height:1.75}
  .hero .sub b{color:var(--green2);font-weight:600}
  .hero .sub .ship{display:block;margin-top:.55rem;color:#eef7f2;font-weight:500}
  .hero .sub .ship em{font-style:normal;color:var(--amber);text-shadow:var(--aglow);font-weight:600}
  .cta{margin-top:2.3rem;display:flex;gap:.9rem;flex-wrap:wrap;align-items:center}
  .btn{display:inline-flex;align-items:center;gap:.55rem;padding:.8rem 1.3rem;font-size:.78rem;font-weight:500;letter-spacing:.04em;
    border:1px solid var(--line);transition:transform .3s cubic-bezier(.2,.8,.2,1),background .25s,color .25s,box-shadow .25s;text-transform:lowercase}
  .btn.primary{background:var(--green);color:#05080f;border-color:var(--green);font-weight:700}
  .btn.primary:hover{transform:translateY(-2px);box-shadow:var(--glow)}
  .btn.ghost{color:var(--green)}
  .btn.ghost:hover{background:rgba(55,245,181,.08);border-color:var(--green);box-shadow:var(--glow);transform:translateY(-2px)}
  .btn .ar{transition:transform .3s}
  .btn:hover .ar{transform:translate(3px,-3px)}
  /* signal-status HUD aligned to grid - replaces floating pill */
  .hud{margin-top:2.6rem;display:flex;flex-wrap:wrap;align-items:center;gap:1.5rem;
    border-top:1px solid var(--line);padding-top:1.1rem;font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mut2)}
  .hud .h{display:flex;align-items:center;gap:.5rem}
  .hud .h .dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:var(--glow)}
  .hud .h .dot.amber{background:var(--amber);box-shadow:var(--aglow)}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
  @media(prefers-reduced-motion:no-preference){.hud .h .dot{animation:pulse 1.8s ease-in-out infinite}}
  .hud .h b{color:var(--green);font-weight:500}
  .hud .h.amber b{color:var(--amber)}
  .hud .spacer{flex:1}
  .hud .scrollp{color:var(--mut2)}
  .hud .scrollp .gp{color:var(--green)}
  .hud .scrollp .c{display:inline-block;width:.55em;height:.95em;background:var(--green);transform:translateY(.13em);margin-left:.12em;box-shadow:var(--glow)}
  @media(max-width:560px){.hud{gap:.9rem 1.2rem}.hud .spacer{display:none}}
  /* mobile hero: trim boot to 2 lines, headline OWNS viewport 1, signal bleeds TALL behind it */
  @media(max-width:600px){
    header.hero{padding-top:5.4rem;justify-content:center;min-height:100svh}
    .boot{min-height:3.4em;margin-bottom:1.5rem}
    .boot .row:nth-child(2),.boot .row:nth-child(3){display:none}
    /* commanding headline: bigger floor, tighter leading */
    .hero h1{font-size:clamp(3.7rem,16.5vw,5rem);line-height:.86;letter-spacing:-.04em}
    .hero .sub{margin-top:1.5rem;font-size:1rem;line-height:1.68}
    .cta{margin-top:1.9rem}
    /* let the WebGL signal bleed TALLER behind the headline instead of a thin band:
       scale the fixed canvas vertically from the top so the trace/grid fill the upper viewport */
    canvas#sig{opacity:.62;height:140vh;transform-origin:top center;transform:scaleY(1.18)}
    .bloom{background:radial-gradient(85% 62% at 50% 30%,rgba(55,245,181,.10),transparent 72%)}
  }
  @media(max-width:600px) and (prefers-reduced-motion:reduce){
    canvas#sig{transform:none;height:100vh}
  }
  /* sections */
  section{padding:clamp(4rem,10vh,7.5rem) 0;position:relative}
  /* tighten the hero->stats->services run so energy holds; trim the airy gutters */
  #stats{padding-top:clamp(2.6rem,5vh,3.6rem);padding-bottom:clamp(2.6rem,5vh,3.6rem)}
  #services{padding-top:clamp(2.6rem,5vh,3.6rem)}
  #services .shead{margin-bottom:1.7rem}
  .shead{margin-bottom:2.6rem}
  .shead h2{font-family:var(--disp);font-weight:700;font-size:clamp(1.5rem,3.4vw,2.6rem);letter-spacing:-.025em;color:var(--ink)}
  .shead h2 em{font-style:normal;color:var(--green);text-shadow:0 0 26px rgba(55,245,181,.3)}
  .eyebrow{font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:var(--amber);margin-bottom:.55rem;text-shadow:var(--aglow);display:flex;align-items:center;gap:.5rem}
  .eyebrow::before{content:"//";color:var(--amber2);opacity:.7}
  /* marquee */
  .marquee{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:1rem 0;overflow:hidden;white-space:nowrap;position:relative;z-index:2;background:rgba(10,14,24,.5)}
  .marquee .track{display:inline-flex;gap:2.6rem;will-change:transform;font-size:.82rem;letter-spacing:.06em;color:var(--mut)}
  .marquee .track b{color:var(--green)}
  .marquee .track span{color:var(--amber)}
  /* stats - mono readout grid, green-glow numbers + amber uppercase labels */
  .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid var(--line);border-left:1px solid var(--line)}
  .stat{padding:2.2rem 1.6rem 2rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);position:relative;transition:background .3s;overflow:hidden}
  .stat::before{content:"";position:absolute;left:0;top:0;width:0;height:2px;background:var(--green);box-shadow:var(--glow);transition:width .5s cubic-bezier(.2,.8,.2,1)}
  .stat:hover::before{width:100%}
  .stat:hover{background:rgba(55,245,181,.04)}
  .stat .n{font-family:var(--mono);font-weight:800;font-size:clamp(2.6rem,6vw,4.4rem);letter-spacing:-.03em;line-height:.92;color:var(--green2);text-shadow:0 0 30px rgba(55,245,181,.5),0 0 6px rgba(55,245,181,.4)}
  .stat:first-child .n{color:var(--amber);text-shadow:0 0 32px rgba(255,184,107,.55),0 0 6px rgba(255,184,107,.4);font-size:clamp(3rem,7vw,5.2rem)}
  .stat .l{margin-top:.7rem;font-size:.7rem;letter-spacing:.14em;color:var(--amber);text-transform:uppercase;font-weight:600}
  .stat .l::before{content:"› ";color:var(--green);opacity:.7}
  @media(max-width:760px){.stats{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:430px){.stats{grid-template-columns:1fr}}
  /* pillars */
  .pillars{display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid var(--line);border-left:1px solid var(--line)}
  .pillar{padding:2.1rem 1.8rem;border-right:1px solid var(--line);border-bottom:1px solid var(--line);transition:background .3s;position:relative}
  .pillar:hover{background:rgba(55,245,181,.04)}
  .pillar .pi{font-size:.74rem;color:var(--amber);letter-spacing:.1em;margin-bottom:.9rem;text-shadow:var(--aglow)}
  .pillar h3{font-family:var(--disp);font-size:clamp(1.05rem,1.6vw,1.3rem);font-weight:600;letter-spacing:-.015em;margin-bottom:.6rem;color:var(--ink)}
  .pillar:hover h3{color:var(--green)}
  .pillar p{color:var(--mut2);font-size:.88rem;line-height:1.65;max-width:42ch}
  @media(max-width:760px){.pillars{grid-template-columns:1fr}}
  /* work as `ls -la ./selected-work` directory listing - the centerpiece */
  .lsbar{font-size:.78rem;color:var(--mut2);letter-spacing:.02em;margin-bottom:.5rem}
  .lsbar .pp{color:var(--green)}
  .lstotal{font-size:.74rem;color:var(--mut);letter-spacing:.04em;margin-bottom:.9rem}
  .worktbl{border:1px solid var(--line);background:rgba(10,14,24,.5)}
  .worktbl .wrow{display:grid;grid-template-columns:104px 1fr minmax(15rem,20rem);gap:1.6rem;align-items:center;padding:1.6rem 1.5rem 1.6rem 2.4rem;border-top:1px solid var(--line2);transition:background .35s,box-shadow .35s,padding-left .4s cubic-bezier(.2,.8,.2,1);position:relative}
  .worktbl{overflow:hidden}
  .worktbl .wrow:first-child{border-top:0}
  /* "> " caret slides in on hover, full-row */
  .worktbl .wrow:not(.whead)::before{content:"> ";position:absolute;left:1rem;top:50%;transform:translateY(-50%) translateX(-4px);color:rgb(var(--acc));opacity:0;transition:opacity .3s,transform .3s;text-shadow:0 0 14px rgba(var(--acc),.7);font-weight:800;font-size:1.05rem}
  .worktbl .wrow:not(.whead):hover::before{opacity:1;transform:translateY(-50%) translateX(0)}
  .worktbl .whead{padding:.7rem 1.5rem .7rem 2.4rem;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--amber);border-top:0;background:rgba(55,245,181,.06)}
  /* per-project accent: each row carries its own hue so the four read distinct, not repeated */
  .worktbl .wrow{--acc:55,245,181;--accs:124,255,176}
  .worktbl .wrow.r-lambdatest{--acc:124,255,176;--accs:124,255,176}
  .worktbl .wrow.r-testmu{--acc:192,132,252;--accs:210,165,255}
  .worktbl .wrow.r-samsung{--acc:96,165,250;--accs:130,190,255}
  .worktbl .wrow.r-medilife{--acc:245,160,161;--accs:255,190,190}
  .worktbl .wrow.r-lido{--acc:255,184,107;--accs:255,200,140}
  .worktbl .wrow.r-appknox{--acc:94,234,212;--accs:150,245,228}
  /* resting state: a quiet left phosphor rail (per-project hue) so rows read premium even before hover */
  .worktbl .wrow:not(.whead){box-shadow:inset 3px 0 0 rgba(var(--acc),.34)}
  /* full-row phosphor underglow on hover AND keyboard focus, tinted to the project accent */
  .worktbl .wrow:not(.whead):hover,
  .worktbl .wrow:not(.whead):focus-visible{background:rgba(var(--acc),.10);box-shadow:inset 0 0 0 1px rgba(var(--acc),.40),inset 0 -24px 40px -18px rgba(var(--acc),.60),inset 5px 0 0 rgb(var(--acc));padding-left:3rem;outline:none}
  .worktbl .wrow:not(.whead):focus-visible::before{opacity:1;transform:translateY(-50%) translateX(0)}
  /* MICRO-INTERACTION: a phosphor scanline beam sweeps the row on hover */
  .worktbl .wrow:not(.whead)::after{content:"";position:absolute;left:0;top:0;bottom:0;width:120px;pointer-events:none;
    background:linear-gradient(90deg,transparent,rgba(var(--accs),.18) 45%,rgba(var(--accs),.30) 50%,rgba(var(--accs),.18) 55%,transparent);
    opacity:0;transform:translateX(-130px);mix-blend-mode:screen}
  @media(prefers-reduced-motion:no-preference){
    .worktbl .wrow:not(.whead):hover::after,
    .worktbl .wrow:not(.whead):focus-visible::after{opacity:1;animation:rowsweep 1.15s cubic-bezier(.4,0,.2,1) infinite}
    @keyframes rowsweep{0%{transform:translateX(-130px)}100%{transform:translateX(calc(100% + 130px))}}
  }
  /* index + project tile: deliberate typographic/duotone composition with LARGE index number */
  .wtile{width:104px;height:78px;border:1px solid var(--line);border-radius:5px;position:relative;overflow:hidden;flex:0 0 auto;display:flex;align-items:center;justify-content:center;transition:transform .4s cubic-bezier(.2,.8,.2,1),box-shadow .4s,border-color .4s}
  .worktbl .wrow:hover .wtile,
  .worktbl .wrow:focus-visible .wtile{transform:translateY(-3px) scale(1.02);box-shadow:0 10px 26px rgba(var(--acc),.30);border-color:rgb(var(--acc))}
  /* HERO-FEATURE the first project for grid rhythm: taller tile, larger result, breathing room */
  .worktbl .wrow.feat{grid-template-columns:148px 1fr minmax(15rem,20rem);padding-top:2.1rem;padding-bottom:2.1rem}
  .worktbl .wrow.feat .wtile{width:148px;height:104px}
  .worktbl .wrow.feat .wtile .widx{font-size:2.6rem}
