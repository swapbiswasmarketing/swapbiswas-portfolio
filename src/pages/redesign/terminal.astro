  .wmid .wd{font-size:.82rem;color:var(--mut2);line-height:1.55}
  /* RIGHT column: RESULT METRIC typeset LARGE, leads the row's value */
  .wright{text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:.5rem}
  .wright .wreslbl{font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--mut);font-weight:600}
