  .contact .big em{font-style:normal;color:var(--green);text-shadow:0 0 30px rgba(55,245,181,.4)}
  .contact .big a{position:relative;color:var(--green)}
  .contact .big a::after{content:"";position:absolute;left:0;bottom:.02em;width:100%;height:2px;background:var(--green);box-shadow:var(--glow);transform:scaleX(0);transform-origin:left;transition:transform .45s cubic-bezier(.2,.8,.2,1)}
  .contact .big a:hover::after{transform:scaleX(1)}
  .contact .em{margin-top:2rem;font-size:.86rem;color:var(--mut2);letter-spacing:.02em;display:flex;flex-wrap:wrap;gap:.5rem 1.2rem;align-items:center}
  .contact .em .gp{color:var(--green);opacity:.8;margin-right:.35rem;font-weight:700}
  .contact .em a{color:var(--ink);border-bottom:1px solid var(--line);padding-bottom:2px;transition:color .25s,border-color .25s}
  .contact .em a:hover{color:var(--green);border-color:var(--green)}
  .ctacur{display:inline-block;width:.5em;height:.85em;background:var(--green);box-shadow:var(--glow);transform:translateY(.02em);margin-left:.18em;vertical-align:baseline}
  /* status-bar footer - bookends the boot bar up top */
  .statusbar{border-top:1px solid var(--line);background:rgba(55,245,181,.05);display:flex;flex-wrap:wrap;gap:0;align-items:stretch;font-size:.76rem;letter-spacing:.06em;color:var(--ink);position:relative;z-index:2;font-weight:500}
  .statusbar .seg{padding:.7rem 1.1rem;display:flex;align-items:center;gap:.5rem;border-right:1px solid var(--line)}
  .statusbar .seg.on{background:var(--green);color:#05080f;font-weight:700;border-right:1px solid rgba(5,8,15,.2)}
  .statusbar .seg.amber{color:var(--amber)}
  .statusbar .seg.green{color:var(--green2);font-weight:600}
  .statusbar .seg .dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:var(--glow)}
  .statusbar .seg.on .dot{background:#05080f;box-shadow:none}
  .statusbar .grow{flex:1;border-right:0}
  @media(max-width:600px){.statusbar{font-size:.64rem}.statusbar .seg{padding:.6rem .8rem}.statusbar .hidesm{display:none}}
  footer{border-top:1px solid var(--line);padding:2rem var(--m);display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;font-size:.8rem;color:var(--ink);position:relative;z-index:2;letter-spacing:.04em}
  footer .fa{color:var(--green2);border-bottom:1px solid var(--line);transition:color .25s,border-color .25s}
  footer .fa:hover{color:var(--green2);border-color:var(--green)}
  .reveal{opacity:0;transform:translateY(20px)}
  @media(prefers-reduced-motion:reduce){.reveal{opacity:1!important;transform:none!important}}
</style>
