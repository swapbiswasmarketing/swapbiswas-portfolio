  .wtile.lido .gl{position:absolute;left:42%;top:24%;width:16%;height:52%;
     background:linear-gradient(180deg,rgba(255,200,140,.32),rgba(255,184,107,.6));clip-path:polygon(0 0,100% 0,62% 100%,38% 100%);box-shadow:0 0 12px rgba(255,184,107,.4)}
