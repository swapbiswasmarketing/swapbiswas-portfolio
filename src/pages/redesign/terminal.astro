  .worktbl .wrow:hover .wright .wy .yar,
  .worktbl .wrow:focus-visible .wright .wy .yar{opacity:1;transform:translateX(0)}
  @media(max-width:860px){
    .worktbl .whead{display:none}
    .worktbl .wrow{grid-template-columns:80px 1fr;gap:1rem 1.1rem;padding:1.4rem 1.2rem 1.4rem 1.2rem;align-items:start}
