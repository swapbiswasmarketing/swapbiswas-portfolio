  /* live-value tick: a phosphor block beside the metric that wakes up + pulses on row hover */
  .wright .wreslbl .tick{display:inline-block;width:.52em;height:.52em;margin-left:.45em;border-radius:1px;
    background:rgb(var(--acc));box-shadow:0 0 12px rgba(var(--acc),.7);vertical-align:baseline;opacity:.5;transition:opacity .3s,transform .3s}
