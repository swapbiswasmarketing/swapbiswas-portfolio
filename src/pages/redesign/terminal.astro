  .wtile.medilife .gl{position:absolute;left:6%;top:50%;width:88%;height:2px;
     background:linear-gradient(90deg,rgba(245,160,161,.5) 0 30%,transparent 30% 38%,rgba(255,190,190,.9) 38% 42%,transparent 42% 50%,rgba(245,160,161,.5) 50%);box-shadow:0 0 8px rgba(245,160,161,.6)}
  .wtile.medilife .widx{color:#ffc7c7;text-shadow:0 0 16px rgba(245,160,161,.6)}
