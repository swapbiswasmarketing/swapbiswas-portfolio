     radial-gradient(circle at 72% 50%,rgba(192,132,252,.4) 0 7px,transparent 8px);opacity:.9}
  .wtile.testmu .gl{position:absolute;left:50%;top:14%;bottom:14%;width:1px;background:linear-gradient(180deg,transparent,rgba(210,165,255,.8),transparent);box-shadow:0 0 10px rgba(192,132,252,.7)}
  .wtile.testmu .widx{color:#dcc4ff;text-shadow:0 0 16px rgba(192,132,252,.6)}
  /* SAMSUNG: blue, broadcast / signal-out concentric arcs (device launch) */
  .wtile.samsung{background:linear-gradient(120deg,#0a1626,#10233b)}
  .wtile.samsung .gx{position:absolute;inset:0;background:
     radial-gradient(circle at 18% 50%,transparent 14px,rgba(96,165,250,.42) 15px,transparent 16px),
     radial-gradient(circle at 18% 50%,transparent 24px,rgba(130,190,255,.3) 25px,transparent 26px),
     radial-gradient(circle at 18% 50%,transparent 34px,rgba(96,165,250,.18) 35px,transparent 36px);opacity:.95}
  .wtile.samsung .gl{position:absolute;left:14%;top:46%;width:6px;height:8%;background:rgba(130,190,255,.9);box-shadow:0 0 12px rgba(96,165,250,.8)}
  .wtile.samsung .widx{color:#bcd8ff;text-shadow:0 0 16px rgba(96,165,250,.6)}
