  .wright .wres{font-family:var(--mono);font-weight:800;font-size:clamp(.96rem,1.5vw,1.22rem);line-height:1.2;letter-spacing:-.01em;color:rgb(var(--accs));max-width:18ch;text-shadow:0 0 18px rgba(var(--acc),.45);transition:transform .35s cubic-bezier(.2,.8,.2,1),text-shadow .3s}
