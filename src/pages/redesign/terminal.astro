  import Lenis from 'lenis';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ---- WebGL signal waveform: oscilloscope + FFT bars + scrolling data-grid horizon ----
  // Renders a live, clearly visible green/amber signal that bleeds across the hero,
  // luminance kept low (10-20%) so the headline stays legible.
  (function(){
    const cv = document.getElementById('sig');
    const gl = cv && (cv.getContext('webgl', { antialias:true, alpha:true }) || cv.getContext('experimental-webgl'));
    if(!gl){
      if(cv) cv.style.display='none';
      const fb = document.getElementById('fallbg'); if(fb) fb.hidden=false;
      return;
    }
    const vs = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
    // Oscilloscope trace (sum of sines) + FFT-style bars + drifting grid horizon, in phosphor green w/ amber peaks.
    const fs = `precision highp float;
    uniform vec2 r;uniform float t;
    float hash(float x){return fract(sin(x*127.1)*43758.5453);}
    // a moving multi-harmonic wave value at horizontal position x (0..1)
    float wave(float x){
      float w=0.0;
      w+=0.55*sin(x*9.0  + t*1.7);
      w+=0.28*sin(x*21.0 - t*2.3 + 1.3);
      w+=0.16*sin(x*38.0 + t*3.1);
      w+=0.10*sin(x*61.0 - t*4.0);
      return w;
    }
    void main(){
      vec2 frag=gl_FragCoord.xy;
      vec2 uv=frag/r.xy;          // 0..1
      vec2 c=uv*2.0-1.0;          // -1..1
      c.x*=r.x/r.y;               // aspect correct

      vec3 green=vec3(0.216,0.961,0.710);
      vec3 amber=vec3(1.0,0.690,0.0);
      vec3 col=vec3(0.0);

      // ---- scrolling data-grid horizon ----
      vec2 g=uv*vec2(46.0,26.0);
      g.x+=t*0.9;                 // horizontal drift
      vec2 gf=abs(fract(g)-0.5);
      float grid=smoothstep(0.48,0.5,max(gf.x,gf.y));
      col+=green*grid*0.022;

      // ---- bottom data band: quantized discrete bars (a distinct readout,
      //      NOT a second analog trace) - quieter, stepped, no bright amber caps
      //      so it never competes with the oscilloscope waveform above ----
      float bx=floor(uv.x*40.0);
      float barRaw=0.05+0.16*abs(wave(bx/40.0));
      barRaw*=0.6+0.4*hash(bx+floor(t*1.5));   // flicker each bar
      float barH=floor(barRaw*9.0)/9.0;        // quantize into discrete cells -> data-readout feel
      float cells=step(fract(uv.y*9.0),0.62);  // horizontal cell gaps between stacked blocks
      float inBar=step(uv.y,barH)*step(fract(uv.x*40.0),0.70)*cells;
      col+=green*inBar*0.035;     // dim discrete blocks, no amber peak caps

      // ---- main oscilloscope trace across the hero ----
      float yw=0.30*wave(uv.x) ;        // wave amplitude (screen space, centered)
      float traceY=0.52 + yw*0.5;       // ride a bit above center
      float dist=abs(uv.y-traceY);
      float line=smoothstep(0.014,0.0,dist);
      float glowL=smoothstep(0.10,0.0,dist)*0.18;
      // amber where the wave peaks hard
      float hot=smoothstep(0.22,0.30,abs(yw));
      vec3 traceCol=mix(green,amber,hot);
      col+=traceCol*line*0.9;
      col+=traceCol*glowL;

      // ---- a faster secondary trace (subtler, blue-green) ----
      float yw2=0.16*wave(uv.x*1.7+0.6);
      float d2=abs(uv.y-(0.40+yw2*0.5));
      col+=green*smoothstep(0.008,0.0,d2)*0.35;
      col+=green*smoothstep(0.07,0.0,d2)*0.05;

      // moving scan beam highlight
      float beam=fract(uv.x - t*0.06);
      col+=green*smoothstep(0.0,0.04,beam)*smoothstep(0.10,0.04,beam)*0.04;

      // gentle vertical falloff so it sits behind the text, brighter mid/bottom
      float fall=mix(0.45,1.0,smoothstep(0.95,0.15,uv.y));
      col*=fall;

      // keep overall luminance low; subtle phosphor lift
      col=pow(col,vec3(0.95));
      gl_FragColor=vec4(col,1.0);
    }`;
    function sh(type,src){const o=gl.createShader(type);gl.shaderSource(o,src);gl.compileShader(o);
      if(!gl.getShaderParameter(o,gl.COMPILE_STATUS)){console.warn('shader',gl.getShaderInfoLog(o));}return o;}
    const pr=gl.createProgram();
    gl.attachShader(pr,sh(gl.VERTEX_SHADER,vs));
    gl.attachShader(pr,sh(gl.FRAGMENT_SHADER,fs));
    gl.linkProgram(pr);
    if(!gl.getProgramParameter(pr,gl.LINK_STATUS)){
      console.warn('link',gl.getProgramInfoLog(pr));
      cv.style.display='none'; const fb=document.getElementById('fallbg'); if(fb) fb.hidden=false; return;
    }
    gl.useProgram(pr);
    const buf=gl.createBuffer();gl.bindBuffer(gl.ARRAY_BUFFER,buf);
    gl.bufferData(gl.ARRAY_BUFFER,new Float32Array([-1,-1,3,-1,-1,3]),gl.STATIC_DRAW);
    const lp=gl.getAttribLocation(pr,'p');gl.enableVertexAttribArray(lp);
    gl.vertexAttribPointer(lp,2,gl.FLOAT,false,0,0);
    const ur=gl.getUniformLocation(pr,'r'),ut=gl.getUniformLocation(pr,'t');
    function size(){const d=Math.min(window.devicePixelRatio||1,1.6);cv.width=Math.max(2,innerWidth*d);cv.height=Math.max(2,innerHeight*d);gl.viewport(0,0,cv.width,cv.height);gl.uniform2f(ur,cv.width,cv.height);}
    size();addEventListener('resize',size);
    // paint one static frame always (verifies the canvas truly renders)
    gl.uniform1f(ut,2.0);gl.drawArrays(gl.TRIANGLES,0,3);
    if(reduce){return;} // reduced-motion: keep the single static frame, no rAF loop
    const start=performance.now();
    (function loop(now){gl.uniform1f(ut,(now-start)/1000);gl.drawArrays(gl.TRIANGLES,0,3);requestAnimationFrame(loop);})(performance.now());
  })();

  // ---- boot-sequence typing (gated behind first visit) ----
  const BOOT_KEY='term_booted_v1';
  let firstVisit=true;
  try{ firstVisit=!sessionStorage.getItem(BOOT_KEY); sessionStorage.setItem(BOOT_KEY,'1'); }catch(e){}

  function runBoot(instant){
    const rows = Array.from(document.querySelectorAll('#boot .row'));
    const cur = document.getElementById('bootcur');
    const lines = [
      'initializing swapnil.biswas',
      'role: senior product marketing manager @ lambdatest',
      'loading modules: gtm · seo · ai-agents · sites',
      'status: shipping',
    ];
    const tags = { ok:'[ ok ]', live:'[ live ]' };
    if(instant){
      rows.forEach(row=>{
        const t=row.getAttribute('data-tag');
        row.querySelector('.txt').innerHTML='&gt; '+lines[rows.indexOf(row)]+'  <span class="tag '+(t==='live'?'live':'')+'">'+tags[t]+'</span>';
      });
      if(cur) cur.style.display='none';
      return;
    }
    let ri=0;
    function typeRow(){
      if(ri>=rows.length){ if(cur) cur.style.display='none'; return; }
      const row=rows[ri];
      const el=row.querySelector('.txt');
      const tagType=row.getAttribute('data-tag');
      const full='> '+lines[ri];
      let ci=0;
      (function type(){
        el.textContent=full.slice(0,ci);
        ci++;
        if(ci<=full.length){ setTimeout(type, 16+Math.random()*22); }
        else {
          const tag=document.createElement('span');
          tag.className='tag '+(tagType==='live'?'live':'');
          tag.textContent='  '+tags[tagType];
          el.appendChild(tag);
          ri++;
          setTimeout(typeRow, 180);
        }
      })();
    }
    typeRow();
  }

  if(reduce){
    runBoot(true);
    const c=document.getElementById('bootcur'); if(c) c.style.display='none';
    document.querySelectorAll('.reveal').forEach(el=>{el.style.opacity='1';el.style.transform='none';});
    // settle counters to final value
    document.querySelectorAll('.stat .n').forEach(el=>{
      el.textContent=(el.getAttribute('data-target'))+ (el.getAttribute('data-suf')||'');
    });
  } else {
    const lenis=new Lenis({lerp:.1,smoothWheel:true});
    function raf(t){lenis.raf(t);requestAnimationFrame(raf);}requestAnimationFrame(raf);
    gsap.registerPlugin(ScrollTrigger);
    lenis.on('scroll',ScrollTrigger.update);

    // hero headline lines
    gsap.set('.hero h1 .ln>span',{yPercent:115});
    gsap.set('.hero .sub,.hero .cta,.hero .hud',{opacity:0,y:16});

    // boot animation only on first visit; otherwise resolve instantly
    if(firstVisit){ runBoot(false); } else { runBoot(true); }
    const headlineDelay = firstVisit ? 1.4 : 0.15;
    const tl=gsap.timeline({delay:headlineDelay});
    tl.to('.hero h1 .ln>span',{yPercent:0,duration:1.0,ease:'expo.out',stagger:.1})
      .to('.hero .sub',{opacity:1,y:0,duration:.7},'-=.4')
      .to('.hero .cta',{opacity:1,y:0,duration:.7},'-=.5')
      .to('.hero .hud',{opacity:1,y:0,duration:.7},'-=.5');

    // reveals: stagger siblings that share a parent grid so each band resolves as a wave,
    // while standalone reveals animate on their own. Every .reveal still ends opacity:1.
    const grouped=new Set();
    document.querySelectorAll('.stats,.pillars,.worktbl,.recog').forEach(group=>{
      const items=gsap.utils.toArray(group.querySelectorAll('.reveal'));
      if(!items.length) return;
      items.forEach(el=>grouped.add(el));
      gsap.to(items,{opacity:1,y:0,duration:.85,ease:'expo.out',stagger:.09,
        scrollTrigger:{trigger:group,start:'top 88%'}});
    });
    gsap.utils.toArray('.reveal').forEach(el=>{
      if(grouped.has(el)) return;
      gsap.to(el,{opacity:1,y:0,duration:.9,ease:'expo.out',scrollTrigger:{trigger:el,start:'top 90%'}});
    });

    // marquee scroll-velocity drift
    const mq=document.getElementById('mq');
    if(mq){
      let mx=0;
      gsap.ticker.add(()=>{ mx-=0.55; if(mx<=-mq.scrollWidth/2) mx=0; mq.style.transform='translateX('+mx+'px)'; });
    }

    // count-up stat counters
    document.querySelectorAll('.stat .n').forEach(el=>{
      const target=parseFloat(el.getAttribute('data-target'));
      const suf=el.getAttribute('data-suf')||'';
      const isFloat=String(target).indexOf('.')>-1;
      const obj={v:0};
      ScrollTrigger.create({
        trigger:el, start:'top 88%', once:true,
        onEnter:()=>{
          gsap.to(obj,{v:target,duration:1.6,ease:'power2.out',
            onUpdate:()=>{ el.textContent=(isFloat?obj.v.toFixed(1):Math.round(obj.v))+suf; },
            onComplete:()=>{ el.textContent=(isFloat?target.toFixed(1):target)+suf; }
          });
        }
      });
    });
  }
</script>
</body>
</html>
