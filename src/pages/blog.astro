---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BlogPreview from '../components/BlogPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

// Extract unique categories sorted by frequency
const categoryCount = new Map<string, number>();
posts.forEach((post) => {
	post.data.category.forEach((cat) => {
		categoryCount.set(cat, (categoryCount.get(cat) || 0) + 1);
	});
});
const categories = [...categoryCount.entries()]
	.sort((a, b) => b[1] - a[1])
	.map(([cat]) => cat);

function categorySlug(cat: string): string {
	return cat
		.toLowerCase()
		.replace(/&/g, 'and')
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '');
}

const POSTS_PER_PAGE = 9;
---

<BaseLayout
	title="Blog | Swapnil Biswas"
	description="Articles on marketing, SEO, AI, and growth strategy by Swapnil Biswas"
	breadcrumbs={[{ name: "Blog" }]}
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Blog"
				tagline="Thoughts on marketing, AI, SEO, and growth strategy."
				align="start"
			/>

			<a href="/rss.xml" class="rss-link" target="_blank" rel="noopener noreferrer" aria-label="RSS Feed">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
			</a>

			<!-- Search + Filter Toolbar -->
			<div class="toolbar">
				<div class="search-bar">
					<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
					<input
						type="search"
						class="search-input"
						placeholder="Search articles..."
						aria-label="Search blog posts"
					/>
					<button class="search-clear" aria-label="Clear search" style="display:none">&times;</button>
				</div>
				<nav class="filter-bar" aria-label="Browse by category">
					<a class="filter-btn active" href="/blog/">All</a>
					{categories.map((cat) => (
						<a class="filter-btn" href={`/blog/category/${categorySlug(cat)}/`}>
							{cat} <span class="filter-count">{categoryCount.get(cat)}</span>
						</a>
					))}
				</nav>
			</div>

			<!-- Blog Grid -->
			<ul class="blog-grid">
				{posts.map((post) => (
					<li class="blog-item">
						<BlogPreview post={post} />
					</li>
				))}
			</ul>

			<!-- Pagination -->
			<nav class="pagination" aria-label="Blog pagination">
				<button class="page-btn prev" disabled>&larr; Previous</button>
				<div class="page-numbers"></div>
				<button class="page-btn next">Next &rarr;</button>
			</nav>

			<!-- Empty state -->
			<div class="empty-state" style="display:none">
				<p>No articles found in this category yet.</p>
			</div>

			<!-- Browse by topic (SEO-discoverable category hub links) -->
			<section class="topic-hub" aria-labelledby="topic-hub-heading">
				<h2 id="topic-hub-heading">Browse by Topic</h2>
				<p class="topic-hub-sub">Jump straight to everything in a category.</p>
				<ul class="topic-hub-list">
					{categories.map((cat) => (
						<li>
							<a href={`/blog/category/${categorySlug(cat)}/`} class="topic-hub-link">
								<span class="topic-hub-name">{cat}</span>
								<span class="topic-hub-count">{categoryCount.get(cat)}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>

<script define:vars={{ POSTS_PER_PAGE }}>
	const items = Array.from(document.querySelectorAll('.blog-item'));
	const pagination = document.querySelector('.pagination');
	const pageNumbers = document.querySelector('.page-numbers');
	const prevBtn = document.querySelector('.page-btn.prev');
	const nextBtn = document.querySelector('.page-btn.next');
	const emptyState = document.querySelector('.empty-state');
	const searchInput = document.querySelector('.search-input');

	let currentPage = 1;
	let searchMatchSlugs = null; // null = no search active, array = matched slugs from Pagefind

	// Load Pagefind lazily
	let pagefind = null;
	async function loadPagefind() {
		if (pagefind) return pagefind;
		try {
			pagefind = await import('/pagefind/pagefind.js');
			await pagefind.init();
		} catch {
			pagefind = null;
		}
		return pagefind;
	}

	let searchTimer = null;
	async function handleSearch(query) {
		if (!query) {
			searchMatchSlugs = null;
			currentPage = 1;
			render();
			return;
		}

		const pf = await loadPagefind();
		if (!pf) {
			// Fallback to simple title text matching if Pagefind unavailable (dev mode)
			const q = query.toLowerCase();
			searchMatchSlugs = items.filter((item) => {
				const title = item.querySelector('.title')?.textContent?.toLowerCase() || '';
				return title.includes(q);
			});
			currentPage = 1;
			render();
			return;
		}

		const search = await pf.search(query);
		// Load result data to get URLs
		const resultData = await Promise.all(search.results.map((r) => r.data()));
		const matchedUrls = resultData.map((d) => d.url.replace(/\/$/, ''));
		// Match items by checking if their link href matches a result URL
		searchMatchSlugs = [];
		for (const item of items) {
			const link = item.querySelector('a[href]');
			if (!link) continue;
			const href = link.getAttribute('href').replace(/\/$/, '');
			if (matchedUrls.some((url) => url === href || url.endsWith(href))) {
				searchMatchSlugs.push(item);
			}
		}
		currentPage = 1;
		render();
	}

	function getFilteredItems() {
		return searchMatchSlugs !== null ? searchMatchSlugs : items;
	}

	function render() {
		const filtered = getFilteredItems();
		const totalPages = Math.max(1, Math.ceil(filtered.length / POSTS_PER_PAGE));
		if (currentPage > totalPages) currentPage = totalPages;

		const start = (currentPage - 1) * POSTS_PER_PAGE;
		const end = start + POSTS_PER_PAGE;

		items.forEach((item) => item.style.display = 'none');
		filtered.slice(start, end).forEach((item) => item.style.display = '');

		emptyState.style.display = filtered.length === 0 ? 'block' : 'none';
		pagination.style.display = totalPages <= 1 ? 'none' : 'flex';

		pageNumbers.innerHTML = '';
		for (let i = 1; i <= totalPages; i++) {
			const btn = document.createElement('button');
			btn.className = 'page-num' + (i === currentPage ? ' active' : '');
			btn.textContent = String(i);
			btn.addEventListener('click', () => {
				currentPage = i;
				render();
				document.querySelector('.filter-bar')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			});
			pageNumbers.appendChild(btn);
		}

		prevBtn.disabled = currentPage <= 1;
		nextBtn.disabled = currentPage >= totalPages;
	}

	// Search handler with debounce
	const searchClear = document.querySelector('.search-clear');
	searchInput?.addEventListener('input', (e) => {
		const query = e.target.value.trim();
		if (searchClear) searchClear.style.display = query ? 'flex' : 'none';
		clearTimeout(searchTimer);
		searchTimer = setTimeout(() => handleSearch(query), 200);
	});
	searchClear?.addEventListener('click', () => {
		if (searchInput) searchInput.value = '';
		searchMatchSlugs = null;
		searchClear.style.display = 'none';
		currentPage = 1;
		render();
		searchInput?.focus();
	});

	// Prev/Next handlers
	prevBtn?.addEventListener('click', () => { if (currentPage > 1) { currentPage--; render(); } });
	nextBtn?.addEventListener('click', () => { currentPage++; render(); });

	// Initial render
	render();
</script>

<style>
	/* Topic hub (browse by topic section) */
	.topic-hub {
		margin-top: 2rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--gray-800);
	}

	.topic-hub h2 {
		font-size: var(--text-xl);
		margin: 0 0 0.25rem;
	}

	.topic-hub-sub {
		color: var(--gray-400);
		font-size: var(--text-sm);
		margin: 0 0 1.25rem;
	}

	.topic-hub-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.topic-hub-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.9rem;
		border-radius: 999rem;
		border: 1px solid var(--gray-800);
		background: var(--gray-999_40);
		color: var(--gray-200);
		text-decoration: none;
		font-size: var(--text-sm);
		transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
	}

	.topic-hub-link:hover {
		border-color: var(--accent-regular);
		color: var(--accent-light);
		background: var(--accent-overlay);
	}

	.topic-hub-count {
		font-size: 0.75rem;
		padding: 0.1rem 0.45rem;
		border-radius: 999rem;
		background: var(--gray-800);
		color: var(--gray-300);
	}

	.topic-hub-link:hover .topic-hub-count {
		background: var(--accent-dark);
		color: var(--gray-0);
	}

	/* Toolbar */
	.toolbar {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	/* Search Bar */
	.search-bar {
		position: relative;
		display: flex;
		align-items: center;
	}

	.search-icon {
		position: absolute;
		left: 1rem;
		color: var(--gray-400);
		pointer-events: none;
		transition: color 0.2s ease;
	}

	.search-bar:focus-within .search-icon {
		color: var(--accent-dark);
	}

	.search-input {
		width: 100%;
		padding: 0.75rem 2.75rem 0.75rem 2.75rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: var(--gray-999_40);
		color: var(--gray-0);
		font-family: var(--font-body);
		font-size: var(--text-md);
		outline: none;
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.search-input::placeholder {
		color: var(--gray-400);
	}

	.search-input:focus {
		border-color: var(--accent-dark);
		box-shadow: 0 0 0 3px var(--accent-overlay);
	}

	.search-clear {
		position: absolute;
		right: 0.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border: none;
		border-radius: 50%;
		background: var(--gray-800);
		color: var(--gray-300);
		font-size: 1.1rem;
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.search-clear:hover {
		background: var(--gray-700);
		color: var(--gray-0);
	}

	/* Filter Bar */
	.filter-bar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.5rem 1rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: var(--gray-999_40);
		color: var(--gray-300);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
		text-decoration: none;
	}

	.filter-btn:link,
	.filter-btn:visited {
		color: var(--gray-300);
	}

	.filter-btn:hover {
		border-color: var(--gray-700);
		color: var(--gray-0);
	}

	.filter-btn.active {
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		border-color: transparent;
	}

	.filter-btn.active:link,
	.filter-btn.active:visited {
		color: var(--accent-text-over);
	}

	.filter-count {
		font-size: 0.7rem;
		padding: 0.1rem 0.4rem;
		border-radius: 999rem;
		background: rgba(255, 255, 255, 0.15);
	}

	.filter-btn.active .filter-count {
		background: rgba(255, 255, 255, 0.25);
	}

	/* Blog Grid */
	.blog-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		list-style: none;
		padding: 0;
	}

	@media (min-width: 50em) {
		.blog-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}
	}

	@media (min-width: 72em) {
		.blog-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Pagination */
	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	.page-btn {
		padding: 0.5rem 1rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		background: var(--gray-999_40);
		color: var(--gray-300);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.page-btn:hover:not(:disabled) {
		border-color: var(--gray-700);
		color: var(--gray-0);
	}

	.page-btn:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}

	:global(.page-numbers) {
		display: flex;
		gap: 0.25rem;
	}

	:global(.page-num) {
		width: 2.25rem;
		height: 2.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--gray-800);
		border-radius: 0.5rem;
		background: var(--gray-999_40);
		color: var(--gray-300);
		font-family: var(--font-brand);
		font-size: var(--text-sm);
		cursor: pointer;
		transition: all 0.2s ease;
	}

	:global(.page-num:hover) {
		border-color: var(--gray-700);
		color: var(--gray-0);
	}

	:global(.page-num.active) {
		background: var(--accent-regular);
		color: var(--accent-text-over);
		border-color: transparent;
	}

	/* Empty State */
	.empty-state {
		text-align: center;
		padding: 3rem 1rem;
		color: var(--gray-400);
		font-size: var(--text-lg);
	}

	/* RSS Link */
	.rss-link {
		display: inline-flex;
		color: var(--gray-400);
		transition: color 0.2s ease;
		margin-top: -1rem;
	}

	.rss-link:hover {
		color: #f97316;
	}
</style>
