---
import { getCollection } from 'astro:content';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPreview from '../components/BlogPreview.astro';

const allPosts = await getCollection('blog');

// Handpicked popular posts (fall back to most recent if any are missing)
const popularSlugs = [
	'ai-seo-strategy',
	'aeo-vs-seo',
	'competitive-battlecard-template',
	'marketers-ai-maturity-curve',
	'go-to-market-strategy-for-startups',
];
const popular = popularSlugs
	.map((slug) => allPosts.find((p) => p.id === slug))
	.filter((p): p is NonNullable<typeof p> => Boolean(p))
	.slice(0, 3);

const fallback = allPosts
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 3);

const posts = popular.length >= 3 ? popular : fallback;
---

<BaseLayout title="Page Not Found | Swapnil Biswas" description="404 Error - this page was not found" noindex={true}>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero title="404 - Page Not Found" tagline="The page you're looking for doesn't exist, moved, or was never written. Try a search or one of the links below." align="start" />

			<!-- Pagefind-powered search -->
			<form class="notfound-search" role="search" id="notfound-search-form">
				<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
				<input
					type="search"
					id="notfound-search-input"
					class="notfound-search-input"
					placeholder="Search articles..."
					aria-label="Search the site"
					autocomplete="off"
				/>
				<button type="submit" class="notfound-search-btn">Search</button>
			</form>
			<div class="notfound-results" id="notfound-search-results" aria-live="polite"></div>

			<div class="actions">
				<a href="/" class="action-link">
					<span class="action-icon">&#8592;</span>
					Go to Homepage
				</a>
				<a href="/blog/" class="action-link">
					<span class="action-icon">&#9998;</span>
					Browse Blog
				</a>
				<a href="/contact/" class="action-link">
					<span class="action-icon">&#9993;</span>
					Contact Me
				</a>
			</div>

			<section class="recent-posts">
				<h2>Popular Articles</h2>
				<div class="post-grid">
					{posts.map((post) => (
						<BlogPreview post={post} />
					))}
				</div>
			</section>

			<!-- Newsletter CTA -->
			<section class="nf-newsletter">
				<div class="nf-newsletter-inner">
					<div>
						<h2>Don't leave empty-handed</h2>
						<p>Get the weekly newsletter - marketing &amp; AI, without the fluff. Every Sunday, 3-minute read.</p>
					</div>
					<form
						id="nf-newsletter-form"
						class="nf-newsletter-form"
						action="https://app.kit.com/forms/9145889/subscriptions"
						method="post"
					>
						<label for="nf-email" class="sr-only">Email address</label>
						<input id="nf-email" type="email" name="email_address" placeholder="you@example.com" required autocomplete="email" />
						<button type="submit">Subscribe</button>
					</form>
					<p class="nf-newsletter-status" id="nf-newsletter-status" aria-live="polite"></p>
				</div>
			</section>
		</main>
	</div>
</BaseLayout>

<script is:inline>
	(function () {
		if (window._notFoundInit) return;
		window._notFoundInit = true;

		let pagefind = null;
		async function loadPagefind() {
			if (pagefind) return pagefind;
			try {
				pagefind = await import('/pagefind/pagefind.js');
				await pagefind.init();
			} catch {
				pagefind = null;
			}
			return pagefind;
		}

		function escapeHtml(s) {
			return String(s).replace(/[&<>"']/g, function (c) {
				return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
			});
		}

		function initNotFoundSearch() {
			const form = document.getElementById('notfound-search-form');
			const input = document.getElementById('notfound-search-input');
			const results = document.getElementById('notfound-search-results');
			if (!form || !input || !results) return;
			if (form._nfInit) return;
			form._nfInit = true;

			async function runSearch(query) {
				if (!query) { results.innerHTML = ''; return; }
				const pf = await loadPagefind();
				if (!pf) {
					results.innerHTML = '<p class="nf-search-empty">Search is unavailable right now. Try the links below.</p>';
					return;
				}
				const search = await pf.search(query);
				if (!search.results.length) {
					results.innerHTML = '<p class="nf-search-empty">No results for <strong>' + escapeHtml(query) + '</strong>. Try different keywords.</p>';
					return;
				}
				const top = await Promise.all(search.results.slice(0, 5).map(function (r) { return r.data(); }));
				results.innerHTML =
					'<p class="nf-search-count">' + search.results.length + ' match' + (search.results.length === 1 ? '' : 'es') + ' for "' + escapeHtml(query) + '"</p>' +
					'<ul class="nf-search-list">' +
						top.map(function (r) {
							return '<li><a href="' + escapeHtml(r.url) + '">' +
								'<span class="nf-result-title">' + escapeHtml((r.meta && r.meta.title) || r.url) + '</span>' +
								'<span class="nf-result-excerpt">' + (r.excerpt || '') + '</span>' +
							'</a></li>';
						}).join('') +
					'</ul>';
			}

			let timer = null;
			input.addEventListener('input', function () {
				if (timer) window.clearTimeout(timer);
				timer = window.setTimeout(function () { runSearch(input.value.trim()); }, 180);
			});
			form.addEventListener('submit', function (e) {
				e.preventDefault();
				runSearch(input.value.trim());
			});
		}

		function initNotFoundNewsletter() {
			const form = document.getElementById('nf-newsletter-form');
			const statusEl = document.getElementById('nf-newsletter-status');
			if (!form || form._nfNlInit) return;
			form._nfNlInit = true;

			form.addEventListener('submit', function (e) {
				e.preventDefault();
				const btn = form.querySelector('button[type="submit"]');
				if (btn) { btn.textContent = 'Subscribing...'; btn.disabled = true; }
				fetch(form.action, {
					method: 'POST',
					body: new FormData(form),
					headers: { Accept: 'application/json' }
				}).then(function (res) {
					if (!res.ok) throw new Error('failed');
					if (statusEl) { statusEl.textContent = 'Subscribed! Check your inbox.'; statusEl.style.color = 'var(--accent-regular)'; }
					form.reset();
					window.dataLayer = window.dataLayer || [];
					window.dataLayer.push({ event: 'newsletter_signup', signup_location: '404' });
				}).catch(function () {
					if (statusEl) { statusEl.textContent = 'Something went wrong. Please try again.'; statusEl.style.color = '#ca7879'; }
				}).finally(function () {
					if (btn) { btn.textContent = 'Subscribe'; btn.disabled = false; }
				});
			});
		}

		function init() { initNotFoundSearch(); initNotFoundNewsletter(); }
		init();
		document.addEventListener('astro:page-load', init);
	})();
</script>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	/* Search */
	.notfound-search {
		position: relative;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		max-width: 40rem;
		padding: 0.35rem 0.5rem 0.35rem 2.75rem;
		border: 1px solid var(--gray-800);
		border-radius: 999px;
		background: var(--gray-999_40);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.notfound-search:focus-within {
		border-color: var(--accent-dark);
		box-shadow: 0 0 0 3px rgba(118, 17, 166, 0.15);
	}

	.search-icon {
		position: absolute;
		left: 0.95rem;
		color: var(--gray-400);
		pointer-events: none;
	}

	.notfound-search-input {
		flex: 1;
		min-width: 0;
		padding: 0.65rem 0;
		border: none;
		background: transparent;
		color: var(--gray-0);
		font-size: var(--text-base);
		font-family: var(--font-body);
		outline: none;
	}

	.notfound-search-input::placeholder {
		color: var(--gray-400);
	}

	.notfound-search-btn {
		padding: 0.55rem 1.1rem;
		border: none;
		border-radius: 999px;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		font-family: var(--font-brand);
		font-weight: 600;
		font-size: var(--text-sm);
		cursor: pointer;
		transition: filter 0.2s ease, transform 0.2s ease;
	}

	.notfound-search-btn:hover {
		filter: brightness(1.05);
		transform: translateY(-1px);
	}

	.notfound-results {
		max-width: 40rem;
	}

	.notfound-results:empty {
		display: none;
	}

	.nf-search-count {
		font-size: var(--text-sm);
		color: var(--gray-400);
		margin: 0 0 0.65rem;
	}

	.nf-search-empty {
		font-size: var(--text-sm);
		color: var(--gray-300);
		padding: 0.75rem 0;
		margin: 0;
	}

	.nf-search-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.nf-search-list a {
		display: block;
		padding: 0.85rem 1rem;
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		background: var(--gray-999_40);
		text-decoration: none;
		color: var(--gray-200);
		transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
	}

	.nf-search-list a:hover,
	.nf-search-list a:focus-visible {
		border-color: var(--accent-dark);
		background: var(--gray-999);
		transform: translateX(2px);
	}

	.nf-result-title {
		display: block;
		color: var(--gray-0);
		font-weight: 600;
		font-family: var(--font-brand);
		font-size: var(--text-base);
		margin-bottom: 0.2rem;
	}

	.nf-result-excerpt {
		display: block;
		color: var(--gray-400);
		font-size: 0.85rem;
		line-height: 1.4;
	}

	.nf-result-excerpt :global(mark) {
		background: rgba(118, 17, 166, 0.2);
		color: var(--gray-0);
		padding: 0 0.15rem;
		border-radius: 0.2rem;
	}

	/* Actions */
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.action-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 999rem;
		background: var(--gradient-subtle);
		color: var(--gray-200);
		font-family: var(--font-brand);
		font-weight: 500;
		text-decoration: none;
		transition: box-shadow var(--theme-transition), color var(--theme-transition);
	}

	.action-link:hover {
		box-shadow: var(--shadow-md);
		color: var(--gray-0);
	}

	.action-icon {
		font-size: 1.2em;
	}

	.recent-posts {
		margin-top: 1rem;
	}

	.recent-posts h2 {
		font-size: var(--text-xl);
		margin-bottom: 1.5rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		list-style: none;
		padding: 0;
	}

	@media (min-width: 50em) {
		.post-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* Newsletter card */
	.nf-newsletter {
		padding: 0.5rem 0;
	}

	.nf-newsletter-inner {
		padding: 1.75rem;
		border-radius: 1rem;
		border: 1px solid var(--gray-800);
		background:
			radial-gradient(120% 120% at 100% 0%, rgba(202, 120, 121, 0.10), transparent 55%),
			radial-gradient(120% 120% at 0% 100%, rgba(118, 17, 166, 0.10), transparent 55%),
			var(--gray-999_40);
	}

	.nf-newsletter h2 {
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		color: var(--gray-0);
		margin: 0 0 0.35rem;
	}

	.nf-newsletter p {
		margin: 0 0 1rem;
		color: var(--gray-200);
	}

	.nf-newsletter-form {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.nf-newsletter-form input {
		flex: 1;
		min-width: 16rem;
		padding: 0.7rem 0.9rem;
		border-radius: 0.55rem;
		border: 1px solid var(--gray-800);
		background: var(--gray-999);
		color: var(--gray-0);
		font-family: var(--font-body);
		font-size: var(--text-sm);
		outline: none;
	}

	.nf-newsletter-form input:focus {
		border-color: var(--accent-dark);
		box-shadow: 0 0 0 3px rgba(118, 17, 166, 0.15);
	}

	.nf-newsletter-form button {
		padding: 0.7rem 1.25rem;
		border: none;
		border-radius: 0.55rem;
		background: var(--gradient-accent-orange);
		color: var(--accent-text-over);
		font-family: var(--font-brand);
		font-weight: 600;
		cursor: pointer;
		transition: filter 0.2s ease, transform 0.2s ease;
	}

	.nf-newsletter-form button:hover {
		filter: brightness(1.05);
		transform: translateY(-1px);
	}

	.nf-newsletter-status {
		margin: 0.5rem 0 0 !important;
		font-size: 0.8125rem;
		min-height: 1rem;
	}
</style>
